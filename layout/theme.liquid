<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}" dir="{{ request.locale.iso_code | handle | slice: 0, 2 | replace: 'ar', 'rtl' | replace: 'he', 'rtl' | default: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

    {%- comment %}theme-check-disable AssetSizeJavaScript{% endcomment -%}
    {%- if settings.animations_reveal_on_scroll -%}
      <script src="{{ 'vendor-gsap.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'vendor-scrolltrigger.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'vendor-lenis.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'smooth-scroll.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- comment %}theme-check-enable AssetSizeJavaScript{% endcomment -%}

    {{ content_for_header }}

    {%- render 'kt-css-variables' -%}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- unless settings.type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_accent_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_accent_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      {{ 'component-localization-form.css' | asset_url | stylesheet_tag: preload: true }}
      <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    <script>
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
  </head>

  <body class="gradient" data-kt-scheme="{{ settings.color_schemes.first.id }}" data-cart-type="{{ settings.cart_type | default: 'drawer' }}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {%- comment -%}
      Drawer/overlay CSS — only needed when the user opens them via a click.
      Load them async with the media="print"→media="all" swap pattern so they
      never block first render. noscript fallback ensures styling still works
      when JavaScript is disabled.
    {%- endcomment -%}

    {%- comment -%} Cart Drawer (loaded conditionally) {%- endcomment -%}
    {%- if settings.cart_type == 'drawer' -%}
      <link rel="stylesheet" href="{{ 'component-cart-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="{{ 'component-cart-drawer.css' | asset_url }}"></noscript>
      {%- render 'cart-drawer' -%}
    {%- endif -%}

    {%- comment -%} Search Overlay {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'component-search-overlay.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ 'component-search-overlay.css' | asset_url }}"></noscript>
    {%- render 'search-overlay' -%}
    <script src="{{ 'search-overlay.js' | asset_url }}" defer="defer"></script>

    {%- comment -%} Appointment Drawer {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'component-appointment-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ 'component-appointment-drawer.css' | asset_url }}"></noscript>
    {%- render 'appointment-drawer' -%}
    <script src="{{ 'appointment-drawer.js' | asset_url }}" defer="defer"></script>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout focus-none" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Structured Data (JSON-LD) {%- endcomment -%}
    {%- render 'structured-data' -%}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };

      {%- liquid
        assign search_types = ''
        if settings.search_include_products
          assign search_types = search_types | append: 'product,'
        endif
        if settings.search_include_pages
          assign search_types = search_types | append: 'page,'
        endif
        if settings.search_include_articles
          assign search_types = search_types | append: 'article,'
        endif
        if settings.search_include_collections
          assign search_types = search_types | append: 'collection,'
        endif
        assign search_types = search_types | split: ',' | join: ','
      -%}
      window.searchSettings = {
        types: '{{ search_types }}'
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      };

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.success_message' | t }}`,
      };
    </script>

    {%- if settings.cart_type == 'drawer' -%}
      <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
