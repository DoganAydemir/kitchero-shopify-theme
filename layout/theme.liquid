<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    {%- comment -%}
      theme-color — pulls the default color-scheme's surface colour so
      Chrome/Safari paint the address-bar and PWA chrome in the brand
      background instead of defaulting to browser chrome. Falls back
      to the Kitchero brand ivory when the scheme is not yet saved.
    {%- endcomment -%}
    {%- liquid
      assign default_scheme = settings.kt_schemes | default: settings.color_schemes
      assign theme_color = '#FAFAF9'
      if default_scheme and default_scheme['scheme-1'] and default_scheme['scheme-1'].settings.surface
        assign theme_color = default_scheme['scheme-1'].settings.surface
      endif
    -%}
    <meta name="theme-color" content="{{ theme_color }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- comment -%}
      cdn.shopify.com hosts product and section images — the critical
      LCP resource on every storefront page. Pre-connecting here saves
      the DNS + TLS round-trip (~150–300 ms on mobile) before the HTML
      parser discovers the <img>. crossorigin is required because
      Shopify serves image assets as CORS-enabled responses.
    {%- endcomment -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- comment -%}
      hreflang alternates — one <link> per published locale so Google
      serves the right translation per user locale. Emitted only when
      the shop has more than one published locale; x-default falls back
      to the primary locale.
    {%- endcomment -%}
    {%- if shop.published_locales.size > 1 -%}
      {%- for locale in shop.published_locales -%}
        {%- if locale.primary -%}
          <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ request.origin }}{{ request.path }}">
        {%- else -%}
          <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ request.origin }}/{{ locale.iso_code }}{{ request.path }}">
        {%- endif -%}
      {%- endfor -%}
      <link rel="alternate" hreflang="x-default" href="{{ request.origin }}{{ request.path }}">
    {%- endif -%}

    {%- if settings.kt_favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.kt_favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.kt_heading_font.system? and settings.kt_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'kt.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'kt.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

    {%- comment %}theme-check-disable AssetSizeJavaScript{% endcomment -%}
    {%- if settings.kt_motion_reveal -%}
      <script src="{{ 'vendor-gsap.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'vendor-scrolltrigger.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'vendor-lenis.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'smooth-scroll.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- comment %}theme-check-enable AssetSizeJavaScript{% endcomment -%}

    {{ content_for_header }}

    {%- render 'kt-css-variables' -%}

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'kt-loader.css' | asset_url | stylesheet_tag }}

    {%- unless settings.kt_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.kt_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.kt_heading_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.kt_heading_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.kt_accent_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.kt_accent_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      {{ 'kt-localization-form.css' | asset_url | stylesheet_tag: preload: true }}
      <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    <script>
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    {%- comment -%}
      Loader bootstrap: decides — before first paint — whether to skip
      the intro loader. Added here (not in kt-loader.js) because the JS
      file is deferred and by the time it runs the loader would already
      have flashed visible. Adds a class to <html> so CSS can hide the
      loader with `display: none` from the very first paint.
    {%- endcomment -%}
    <script>
      (function () {
        try {
          var loaderEnabled = {{ settings.kt_loader_enable | json }};
          if (!loaderEnabled ||
              sessionStorage.getItem('kitchero:loader-shown') ||
              (window.Shopify && Shopify.designMode)) {
            document.documentElement.classList.add('kt-loader-skip');
          }
        } catch (e) {
          /* Private mode / storage blocked — show the loader anyway. */
        }
      })();
    </script>
    <script src="{{ 'kt-loader.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="gradient" data-kt-scheme="{{ settings.kt_schemes.first.id }}" data-cart-type="{{ settings.kt_cart_type | default: 'drawer' }}">
    {%- render 'kt-loader' -%}

    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'kt.a11y.skip_to_text' | t }}
    </a>

    {%- comment -%}
      Drawer/overlay CSS — only needed when the user opens them via a click.
      Load them async with the media="print"→media="all" swap pattern so they
      never block first render. noscript fallback ensures styling still works
      when JavaScript is disabled.
    {%- endcomment -%}

    {%- comment -%} Cart Drawer (loaded conditionally, registered as a
        section so JS can refresh it via the Section Rendering API) {%- endcomment -%}
    {%- if settings.kt_cart_type == 'drawer' -%}
      <link rel="stylesheet" href="{{ 'kt-cart-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="{{ 'kt-cart-drawer.css' | asset_url }}"></noscript>
      {% section 'cart-drawer' %}
    {%- endif -%}

    {%- comment -%} Search Overlay {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'kt-search-overlay.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ 'kt-search-overlay.css' | asset_url }}"></noscript>
    {%- render 'search-overlay' -%}
    <script src="{{ 'search-overlay.js' | asset_url }}" defer="defer"></script>

    {%- comment -%} Appointment Drawer {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'kt-appointment-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ 'kt-appointment-drawer.css' | asset_url }}"></noscript>
    {%- render 'appointment-drawer' -%}
    <script src="{{ 'appointment-drawer.js' | asset_url }}" defer="defer"></script>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout focus-none" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Structured Data (JSON-LD) {%- endcomment -%}
    {%- render 'structured-data' -%}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'kt.a11y.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'kt.a11y.link.new_window' | t }}</li>
    </ul>

    <script>
      // Bootstrap the Kitchero runtime namespace. `global.js` (loaded with
      // defer) adds focusTrap / bus / escapeCloseDetails to the same object,
      // so the `|| {}` guard lets either script run first.
      window.Kitchero = window.Kitchero || {};

      {%- liquid
        assign search_types = ''
        if settings.kt_search_inc_products
          assign search_types = search_types | append: 'product,'
        endif
        if settings.kt_search_inc_pages
          assign search_types = search_types | append: 'page,'
        endif
        if settings.kt_search_inc_articles
          assign search_types = search_types | append: 'article,'
        endif
        if settings.kt_search_inc_collections
          assign search_types = search_types | append: 'collection,'
        endif
        assign search_types = search_types | split: ',' | join: ','
      -%}
      Object.assign(window.Kitchero, {
        shopUrl: '{{ request.origin }}',
        routes: {
          cartAdd:          '{{ routes.cart_add_url }}',
          cartChange:       '{{ routes.cart_change_url }}',
          cartUpdate:       '{{ routes.cart_update_url }}',
          cart:             '{{ routes.cart_url }}',
          predictiveSearch: '{{ routes.predictive_search_url }}',
        },
        searchSettings: {
          types: '{{ search_types }}'
        },
        cartStrings: {
          error:         `{{ 'kt.cart.cart_error' | t }}`,
          quantityError: `{{ 'kt.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
        },
        variantStrings: {
          addToCart:      `{{ 'kt.product.add_to_cart' | t }}`,
          addedToCart:    `{{ 'kt.product.added_to_cart' | t }}`,
          addToCartError: `{{ 'kt.product.add_to_cart_error' | t }}`,
          soldOut:        `{{ 'kt.product.sold_out' | t }}`,
          unavailable:    `{{ 'kt.product.unavailable' | t }}`,
        },
        a11yStrings: {
          imageAvailable: `{{ 'kt.product.media.image_available' | t: index: '[index]' }}`,
          shareSuccess:   `{{ 'kt.share.success_message' | t }}`,
        }
      });
    </script>

    {%- if settings.kt_cart_type == 'drawer' -%}
      <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.kt_search_predictive -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
