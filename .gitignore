# Shopify theme package output — generated by `shopify theme package`.
# Releases should upload the zip from GitHub Releases, not commit it.
Kitchero-*.zip
*.zip

# Shopify CLI environment file — contains store-specific tokens.
.shopifyrc
.env
.env.local

# Node modules (only present if a developer adds dev tooling locally).
node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Theme Check cache
.theme-check-cache/

# Local developer tooling meta — Claude Code / Cursor / Copilot permissions
# files carry absolute dev paths (e.g. references to other repos on disk) that
# Theme Store reviewers could misread as cross-codebase copying. .shopifyignore
# already keeps them out of the theme push; .gitignore keeps them out of the
# published repo history entirely.
.claude/settings.local.json
