<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{{ request.locale.iso_code | handle | slice: 0, 2 | replace: 'ar', 'rtl' | replace: 'he', 'rtl' | default: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ 'gift_cards.issued.title' | t }} - {{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>
  <body>
    <main class="gift-card page-width" role="main">
      <header class="gift-card__header">
        <h1 class="gift-card__heading">{{ 'gift_cards.issued.title' | t }}</h1>
        <p class="gift-card__subtext">{{ 'gift_cards.issued.subtext' | t }}</p>
      </header>

      <div class="gift-card__image-wrapper">
        {%- if gift_card.image -%}
          <img
            src="{{ gift_card.image | image_url: width: 570 }}"
            alt=""
            width="570"
            height="{{ 570 | divided_by: gift_card.image.aspect_ratio | ceil }}"
            loading="lazy"
          >
        {%- else -%}
          <img
            src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
            alt=""
            width="570"
            height="360"
          >
        {%- endif -%}
      </div>

      <div class="gift-card__info">
        {%- assign formatted_initial_value = gift_card.initial_value | money_without_trailing_zeros -%}
        {%- assign formatted_current_balance = gift_card.balance | money_without_trailing_zeros -%}

        {%- if gift_card.balance != gift_card.initial_value -%}
          <p class="gift-card__balance">{{ formatted_current_balance }} / {{ formatted_initial_value }}</p>
        {%- endif -%}

        <div class="gift-card__code-wrapper">
          <input
            type="text"
            class="gift-card__code"
            value="{{ gift_card.code | format_code }}"
            aria-label="{{ 'gift_cards.issued.copy_code' | t }}"
            readonly
          >
        </div>

        {%- if gift_card.expired -%}
          <p class="gift-card__expired badge badge--sold-out">{{ 'gift_cards.issued.expired' | t }}</p>
        {%- elsif gift_card.enabled -%}
          <p class="gift-card__active badge">{{ 'gift_cards.issued.active' | t: expiry: gift_card.expires_on | date: '%d/%m/%Y' }}</p>
        {%- endif -%}

        <a href="{{ shop.url }}" class="button" target="_blank" rel="noopener">
          {{ 'gift_cards.issued.shop_link' | t | default: 'Continue shopping' }}
        </a>
      </div>
    </main>
  </body>
</html>
