{%- comment -%}
  Gift Card — standalone template.
  Shopify does NOT allow JSON templates for gift_card. This is a full
  HTML document styled in the Kitchero design language: serif title,
  dotted background band, big editorial gift-card card, code field
  with copy button, balance + expiry pills, and a black "Continue
  shopping" CTA.
{%- endcomment -%}
<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{{ request.locale.direction | default: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#fafaf9">
    <title>{{ 'kt.giftcard.issued.title' | t }} · {{ shop.name }}</title>
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'template-gift-card.css' | asset_url | stylesheet_tag }}
    {%- comment -%}
      Shopify-hosted QR generator. This is NOT an external CDN —
      `shopify_asset_url` serves from Shopify's own CDN and the
      vendor QR bundle ships with every theme (Shopify-approved
      third-party library). Required so we can render the
      `gift_card.qr_identifier` as a scannable QR code for in-store
      redemption.
    {%- endcomment -%}
    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer="defer"></script>
  </head>
  <body class="kt-gift-card-page">
    <main class="kt-gift-card" role="main">
      <a href="{{ shop.url | default: routes.root_url }}" class="kt-gift-card__logo" aria-label="{{ shop.name }}">
        {%- if settings.kt_logo != blank -%}
          {{
            settings.kt_logo
            | image_url: width: 400
            | image_tag:
              class: 'kt-gift-card__logo-image',
              loading: 'eager',
              widths: '160, 240, 320, 400',
              height: 28,
              width: 160,
              alt: shop.name
          }}
        {%- else -%}
          <span class="kt-gift-card__wordmark">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <header class="kt-gift-card__header">
        <span class="kt-gift-card__eyebrow">{{ 'kt.giftcard.issued.subtext' | t }}</span>
        <h1 class="kt-gift-card__title">{{ 'kt.giftcard.issued.title' | t }}</h1>
      </header>

      <section class="kt-gift-card__visual" aria-label="{{ 'kt.giftcard.issued.title' | t }}">
        {%- assign formatted_initial_value = gift_card.initial_value | money_without_trailing_zeros -%}
        {%- assign formatted_current_balance = gift_card.balance | money_without_trailing_zeros -%}

        <div class="kt-gift-card__card">
          <div class="kt-gift-card__card-media">
            {%- if gift_card.image -%}
              <img
                src="{{ gift_card.image | image_url: width: 720 }}"
                srcset="
                  {{ gift_card.image | image_url: width: 400 }} 400w,
                  {{ gift_card.image | image_url: width: 600 }} 600w,
                  {{ gift_card.image | image_url: width: 900 }} 900w,
                  {{ gift_card.image | image_url: width: 1200 }} 1200w
                "
                sizes="(min-width: 750px) 540px, 90vw"
                width="720"
                height="{{ 720 | divided_by: gift_card.image.aspect_ratio | ceil }}"
                loading="eager"
                alt=""
                class="kt-gift-card__card-image"
              >
            {%- else -%}
              {%- comment -%} Editorial placeholder — a luxe gradient with a serif monogram {%- endcomment -%}
              <div class="kt-gift-card__card-placeholder">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 120 120" class="kt-gift-card__card-icon">
                  <path d="M20 40h80v60a4 4 0 0 1-4 4H24a4 4 0 0 1-4-4V40z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                  <path d="M20 40h80" fill="none" stroke="currentColor" stroke-width="2"/>
                  <path d="M60 40v64" fill="none" stroke="currentColor" stroke-width="2"/>
                  <path d="M60 40s-14-20-24-12 4 12 24 12zm0 0s14-20 24-12-4 12-24 12z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                </svg>
                <span class="kt-gift-card__card-monogram">{{ shop.name | slice: 0 | upcase }}</span>
              </div>
            {%- endif -%}

            <div class="kt-gift-card__card-overlay">
              <span class="kt-gift-card__card-label">{{ 'kt.giftcard.issued.title' | t }}</span>
              <span class="kt-gift-card__card-value">
                {%- if gift_card.balance != gift_card.initial_value -%}
                  {{ formatted_current_balance }}
                  <span class="kt-gift-card__card-total">/ {{ formatted_initial_value }}</span>
                {%- else -%}
                  {{ formatted_initial_value }}
                {%- endif -%}
              </span>
            </div>
          </div>
        </div>
      </section>

      <section class="kt-gift-card__meta">
        <div class="kt-gift-card__code-row">
          <label for="GiftCardCode" class="kt-gift-card__code-label">
            {{ 'kt.giftcard.issued.copy_code' | t | default: 'Gift card code' }}
          </label>
          <div class="kt-gift-card__code-wrap">
            <input
              id="GiftCardCode"
              type="text"
              class="kt-gift-card__code"
              value="{{ gift_card.code | format_code }}"
              readonly
              aria-label="{{ 'kt.giftcard.issued.copy_code' | t }}"
            >
            <button
              type="button"
              class="kt-gift-card__copy"
              data-gift-card-copy="GiftCardCode"
              data-success-label="{{ 'kt.share.success_message' | t | escape }}"
              aria-label="{{ 'kt.giftcard.issued.copy_code' | t }}"
            >
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span class="kt-gift-card__copy-text">{{ 'kt.giftcard.issued.copy_code' | t }}</span>
            </button>
          </div>
        </div>

        <div class="kt-gift-card__pills">
          {%- if gift_card.expired -%}
            <span class="kt-gift-card__pill kt-gift-card__pill--expired">
              {{ 'kt.giftcard.issued.expired' | t }}
            </span>
          {%- elsif gift_card.enabled -%}
            <span class="kt-gift-card__pill kt-gift-card__pill--active">
              {{ 'kt.giftcard.issued.active' | t: expiry: gift_card.expires_on | date: '%B %-d, %Y' }}
            </span>
          {%- endif -%}
        </div>
      </section>

      <section class="kt-gift-card__qr-section" aria-label="{{ 'kt.giftcard.issued.qr_heading' | t }}">
        <span class="kt-gift-card__qr-caption">{{ 'kt.giftcard.issued.qr_heading' | t }}</span>
        <div
          class="kt-gift-card__qr"
          data-gift-card-qr
          data-identifier="{{ gift_card.qr_identifier }}"
          data-alt-text="{{ 'kt.giftcard.issued.qr_image_alt' | t | escape }}"
          role="img"
          aria-label="{{ 'kt.giftcard.issued.qr_image_alt' | t }}"
        ></div>
        <p class="kt-gift-card__qr-hint">{{ 'kt.giftcard.issued.qr_hint' | t }}</p>
      </section>

      <div class="kt-gift-card__actions">
        <a href="{{ shop.url | default: routes.root_url }}" class="kt-gift-card__cta">
          {{ 'kt.giftcard.issued.shop_link' | t | default: 'Continue shopping' }}
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>

        <div class="kt-gift-card__secondary-actions">
          <button
            type="button"
            class="kt-gift-card__secondary-btn"
            data-gift-card-print
            aria-label="{{ 'kt.giftcard.issued.print_aria' | t }}"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            <span>{{ 'kt.giftcard.issued.print' | t }}</span>
          </button>

          {%- if gift_card.pass_url != blank -%}
            <a
              href="{{ gift_card.pass_url }}"
              class="kt-gift-card__wallet"
              aria-label="{{ 'kt.giftcard.issued.add_to_apple_wallet' | t }}"
            >
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                width="120"
                height="40"
                loading="lazy"
                alt="{{ 'kt.giftcard.issued.add_to_apple_wallet' | t }}"
              >
            </a>
          {%- endif -%}
        </div>
      </div>
    </main>

    <script src="{{ 'gift-card.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
