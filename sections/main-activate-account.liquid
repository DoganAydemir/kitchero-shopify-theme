{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}
<script src="{{ 'password-match.js' | asset_url }}" defer="defer"></script>

<section class="kt-customer" data-section-id="{{ section.id }}">
  <div class="kt-customer__container">
    <h1 class="kt-customer__title">{{ 'kt.customer.activate_account.title' | t }}</h1>
    <p class="kt-customer__subtitle">{{ 'kt.customer.activate_account.subtext' | t }}</p>

    {%- form 'activate_customer_password', id: 'ActivateAccountForm' -%}
      {%- if form.errors -%}
        {%- comment -%}
          role="alert" scoped to UL (dynamic) not outer div (static
          heading) — see main-login.liquid for full rationale.
        {%- endcomment -%}
        <div class="kt-customer__errors" data-form-error-summary tabindex="-1">
          <h2 class="kt-customer__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h2>
          <ul class="kt-customer__errors-list" role="alert">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {%- comment -%}
                    Underscore → hyphen: Shopify field name is
                    `password_confirmation`, input id is
                    `activate-password-confirm`. See main-register for
                    the full rationale.
                  {%- endcomment -%}
                  <a href="#activate-{{ field | replace: '_confirmation', '-confirm' | replace: '_', '-' }}">
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="kt-customer__form">
        <div class="kt-customer__field">
          <label for="activate-password" class="kt-customer__label">
            {{ 'kt.customer.activate_account.password' | t }}
          </label>
          <input
            type="password"
            id="activate-password"
            name="customer[password]"
            class="kt-customer__input"
            required
            autocomplete="new-password"
            aria-required="true"
            {% if form.errors contains 'password' %}aria-invalid="true" aria-describedby="activate-password-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'password', describedby_id: 'activate-password-error' -%}
        </div>

        <div class="kt-customer__field">
          <label for="activate-password-confirm" class="kt-customer__label">
            {{ 'kt.customer.activate_account.password_confirm' | t }}
          </label>
          <input
            type="password"
            id="activate-password-confirm"
            name="customer[password_confirmation]"
            class="kt-customer__input"
            required
            autocomplete="new-password"
            aria-required="true"
            data-password-match="activate-password"
            data-mismatch-message="{{ 'kt.customer.reset_password.password_mismatch' | t | escape }}"
            {% if form.errors contains 'password_confirmation' %}aria-invalid="true" aria-describedby="activate-password-confirm-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'password_confirmation', describedby_id: 'activate-password-confirm-error' -%}
        </div>

        <button type="submit" class="kt-customer__submit">
          {{ 'kt.customer.activate_account.submit' | t }}
        </button>

        <button type="submit" name="decline" value="1" class="kt-customer__cancel" formnovalidate>
          {{- 'kt.customer.activate_account.cancel' | t -}}
          {%- comment -%}
            formnovalidate is required because the password + confirm
            inputs above carry HTML5 `required` attrs. Without it,
            clicking Decline triggers browser validation on the
            required password fields (which are still empty because
            the customer is declining activation entirely) and the
            form never POSTs. With formnovalidate, Decline submits
            the `decline` parameter bare — Shopify interprets that
            as "refuse account activation" and the customer is
            released back to the login flow.
          {%- endcomment -%}
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-activate-account.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/activate_account"]
  },
  "settings": []
}
{% endschema %}
