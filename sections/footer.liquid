{{ 'kt-section-footer.css' | asset_url | stylesheet_tag }}

<footer class="kt-footer{% if section.settings.color_scheme != blank %} color-{{ section.settings.color_scheme }}{% endif %}" data-section-id="{{ section.id }}">
  <div class="kt-footer__inner page-width">
    <div class="kt-footer__grid">

      {%- comment -%} Brand Column (always first) {%- endcomment -%}
      <div class="kt-footer__brand">
        {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
        <{{ heading_tag }} class="kt-footer__brand-heading">
          {{ section.settings.heading_line1 | default: 'Let&rsquo;s build your' }}<br>{{ section.settings.heading_line2 | default: 'dream space.' }}
        </{{ heading_tag }}>
        <p class="kt-footer__brand-text">
          {{ section.settings.description | default: 'Experience the perfect orchestration of engineering and tactile luxury in your own home.' }}
        </p>

        <div class="kt-footer__social">
          {% render 'social-icons' %}
        </div>

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="kt-footer__cta">
            <span>{{ section.settings.cta_text }}</span>
            <span class="kt-footer__cta-arrow" aria-hidden="true">
              <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Dynamic Link Columns via Blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              <h2 class="kt-footer__column-title">
                {{ block.settings.heading | default: block.settings.menu.title }}
              </h2>
              {%- if block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
                <ul class="kt-footer__link-list list-unstyled" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="kt-footer__link">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- elsif request.design_mode -%}
                {%- comment -%}
                  Merchant hasn't picked a menu yet. Surface an onboarding
                  hint only inside the theme editor so shoppers on the
                  live storefront never see a broken/empty column. We
                  intentionally do NOT emit placeholder `href="#"` links:
                  those fail Theme Store review (deceptive navigation)
                  and they give shoppers non-functional click targets.
                {%- endcomment -%}
                <p class="kt-footer__empty-notice">
                  {{ 'kt.general.footer.empty_menu_notice' | t }}
                </p>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="kt-footer__column-title">{{ block.settings.heading }}</h2>
              {%- endif -%}
              <div class="kt-footer__text rte">{{ block.settings.text }}</div>
            </div>

          {%- when 'newsletter' -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="kt-footer__column-title">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- form 'customer', id: 'FooterNewsletter' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="hidden" name="contact[accepts_marketing]" value="true">
                {%- if form.posted_successfully? -%}
                  <p class="kt-footer__newsletter-success" role="status">
                    {{ 'kt.section.newsletter-popup.success' | t | default: 'Thanks for subscribing.' }}
                  </p>
                {%- else -%}
                  <div class="kt-footer__newsletter">
                    <label for="footer-newsletter-email" class="visually-hidden">{{ 'kt.newsletter.label' | t }}</label>
                    <input
                      type="email"
                      id="footer-newsletter-email"
                      name="contact[email]"
                      class="field__input kt-footer__newsletter-input"
                      placeholder="{{ 'kt.newsletter.label' | t }}"
                      required
                      aria-required="true"
                      inputmode="email"
                      autocomplete="email"
                      aria-invalid="{% if form.errors %}true{% else %}false{% endif %}"
                      aria-describedby="FooterNewsletter-error"
                    >
                    <button type="submit" class="button kt-footer__newsletter-btn">
                      {{ 'kt.newsletter.button_label' | t }}
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <p class="kt-footer__newsletter-error" id="FooterNewsletter-error" role="alert">
                      {%- for field in form.errors -%}
                        {{ form.errors.messages[field] }}{% unless forloop.last %} · {% endunless %}
                      {%- endfor -%}
                    </p>
                  {%- endif -%}
                  {%- if shop.privacy_policy != blank -%}
                    <p class="kt-footer__newsletter-privacy">
                      <a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>
                    </p>
                  {%- endif -%}
                {%- endif -%}
              {%- endform -%}
            </div>

          {%- when 'image' -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: class: 'kt-footer__block-image', loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height, alt: block.settings.image.alt | default: '' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg kt-footer__block-image' }}
              {%- endif -%}
            </div>

          {%- when 'contact_info' -%}
            {%- comment -%}
              Shop-level contact details pulled dynamically from
              `shop.address` / `shop.email` / `shop.phone` — all of
              which Admin → Settings → General populates. Previously
              merchants had to repeat this info in a plain text block
              (easy to forget, goes stale on move). Each line gated on
              its own toggle so a merchant who doesn't want to surface
              (e.g.) their phone publicly can hide it.
            {%- endcomment -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="kt-footer__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              <ul class="kt-footer__contact list-unstyled" role="list">
                {%- if block.settings.show_address and shop.address.street != blank -%}
                  <li class="kt-footer__contact-item">
                    <address class="kt-footer__contact-address">{{ shop.address | format_address }}</address>
                  </li>
                {%- endif -%}
                {%- if block.settings.show_email and shop.email != blank -%}
                  <li class="kt-footer__contact-item">
                    <a href="mailto:{{ shop.email }}" class="kt-footer__contact-link">{{ shop.email }}</a>
                  </li>
                {%- endif -%}
                {%- if block.settings.show_phone and shop.phone != blank -%}
                  <li class="kt-footer__contact-item">
                    {%- comment -%}
                      tel: scheme strips non-digit chars for dial-
                      friendliness (Safari iOS is picky about spaces
                      and dashes in the href), while the visible text
                      keeps the merchant's formatting.
                    {%- endcomment -%}
                    <a href="tel:{{ shop.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}" class="kt-footer__contact-link">{{ shop.phone }}</a>
                  </li>
                {%- endif -%}
              </ul>
            </div>

          {%- when '@app' -%}
            <div class="kt-footer__column kt-footer__column--app" {{ block.shopify_attributes }}>
              {% render block %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Large Branding Text {%- endcomment -%}
    <div class="kt-footer__branding">
      {%- comment -%}
        Large editorial branding word at the bottom of the footer.
        Default fell back to the literal string 'KITCHERO' which is
        wrong on a non-Kitchero merchant install (theme reused in
        another store still reads "KITCHERO"). Default to the
        merchant's shop.name (uppercased to match the editorial
        treatment) so brand-new installs render the actual brand
        without manual setup. Merchants can still override with the
        branding_text setting.
      {%- endcomment -%}
      <span class="kt-footer__branding-text" aria-hidden="true">{{ section.settings.branding_text | default: shop.name | upcase }}</span>

      {%- comment -%} Bottom Bar {%- endcomment -%}
      <div class="kt-footer__bottom">
        {%- comment -%} Copyright {%- endcomment -%}
        <div class="kt-footer__copyright">
          <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</span>
          {%- comment -%}
            `{{ powered_by_link }}` emits a fully localized `<a>` tag
            pointing at the correct Shopify URL for the current locale,
            with the translated label from Shopify's own i18n tables —
            no hand-maintained locale key needed. Also removes the
            target="_blank" noopener attribute combo we were carrying
            manually (reviewer recommendation: don't force external
            target on the powered-by link, let the user choose).
          {%- endcomment -%}
          {{ powered_by_link }}
        </div>

        {%- comment -%} Language/Country Selectors (Shopify native localization) {%- endcomment -%}
        {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          <div class="kt-footer__selectors">
            {%- if localization.available_languages.size > 1 -%}
              {%- form 'localization', id: 'FooterLanguageForm', class: 'kt-footer__localization-form' -%}
                <div class="localization-selector">
                  <select name="locale_code" id="FooterLanguageSelector" aria-label="{{ 'kt.locale.language_label' | t | default: 'Language' }}">
                    {%- for language in localization.available_languages -%}
                      <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                        {{ language.endonym_name | capitalize }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <noscript>
                    <button type="submit" class="button button--secondary">{{ 'kt.locale.update' | t | default: 'Update' }}</button>
                  </noscript>
                </div>
              {%- endform -%}
            {%- endif -%}

            {%- if localization.available_countries.size > 1 -%}
              {%- form 'localization', id: 'FooterCountryForm', class: 'kt-footer__localization-form' -%}
                <div class="localization-selector">
                  <select name="country_code" id="FooterCountrySelector" aria-label="{{ 'kt.locale.country_label' | t | default: 'Country/region' }}">
                    {%- for country in localization.available_countries -%}
                      <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                        {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                      </option>
                    {%- endfor -%}
                  </select>
                  <noscript>
                    <button type="submit" class="button button--secondary">{{ 'kt.locale.update' | t | default: 'Update' }}</button>
                  </noscript>
                </div>
              {%- endform -%}
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Payment Icons (Shopify native) {%- endcomment -%}
        {%- if section.settings.show_payment_icons -%}
          <div class="kt-footer__payment">
            <span class="visually-hidden">{{ 'kt.general.footer.payment_methods' | t }}</span>
            <ul class="kt-footer__payment-list list-unstyled" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li>{{ type | payment_type_svg_tag: class: 'kt-footer__payment-icon' }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%}
        Shop policies row — renders only the policies the merchant has
        actually published in Admin → Settings → Policies. `shop.policies`
        already filters to published ones, so the `{% for %}` silently
        collapses to nothing on a store that has none. Keeps the legal
        links discoverable (a Theme Store review requirement) without
        forcing merchants to curate a separate menu.
      {%- endcomment -%}
      {%- if section.settings.show_policy_links and shop.policies.size > 0 -%}
        <nav class="kt-footer__policies" aria-label="{{ 'kt.general.footer.policies' | t | default: 'Legal' }}">
          <ul class="kt-footer__policies-list list-unstyled" role="list">
            {%- for policy in shop.policies -%}
              <li>
                <a href="{{ policy.url }}" class="kt-footer__policy-link">
                  {{ policy.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__brand.content"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.footer.settings.heading_line1.label",
      "default": "Let\u2019s build your"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.footer.settings.heading_line2.label",
      "default": "dream space."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.footer.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.footer.settings.description.label",
      "default": "Experience the perfect orchestration of engineering and tactile luxury in your own home."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.footer.settings.cta_text.label",
      "default": "Start a Project"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.footer.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__bottom.content"
    },
    {
      "type": "text",
      "id": "branding_text",
      "label": "t:sections.footer.settings.branding_text.label",
      "default": ""
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.settings.show_payment_icons.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy_links",
      "label": "t:sections.footer.settings.show_policy_links.label",
      "info": "t:sections.footer.settings.show_policy_links.info",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "default": "footer",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.footer.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.newsletter.settings.heading.label",
          "default": "Subscribe"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:sections.footer.blocks.image.name",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.footer.blocks.image.settings.image.label"
        }
      ]
    },
    {
      "type": "contact_info",
      "name": "t:sections.footer.blocks.contact_info.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.contact_info.settings.heading.label",
          "default": "Contact"
        },
        {
          "type": "checkbox",
          "id": "show_address",
          "label": "t:sections.footer.blocks.contact_info.settings.show_address.label",
          "info": "t:sections.footer.blocks.contact_info.settings.show_address.info",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_email",
          "label": "t:sections.footer.blocks.contact_info.settings.show_email.label",
          "info": "t:sections.footer.blocks.contact_info.settings.show_email.info",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_phone",
          "label": "t:sections.footer.blocks.contact_info.settings.show_phone.label",
          "info": "t:sections.footer.blocks.contact_info.settings.show_phone.info",
          "default": true
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Explore"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Company"
        }
      }
    ]
  }
}
{% endschema %}
