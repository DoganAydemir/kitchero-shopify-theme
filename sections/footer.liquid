<footer class="kt-footer color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  <div class="kt-footer__inner page-width">
    <div class="kt-footer__grid">
      {%- for block in section.blocks -%}
        <div class="kt-footer__block" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'link_list' -%}
              {%- if block.settings.menu != blank -%}
                <h3 class="kt-footer__heading">{{ block.settings.heading | default: block.settings.menu.title }}</h3>
                <ul class="kt-footer__list list-unstyled" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="kt-footer__link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            {%- when 'text' -%}
              <h3 class="kt-footer__heading">{{ block.settings.heading }}</h3>
              <div class="kt-footer__text rte">{{ block.settings.text }}</div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="kt-footer__bottom">
      <div class="kt-footer__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.footer.copyright' | t }}</small>
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="kt-footer__payment">
          <span class="visually-hidden">{{ 'general.footer.payment_methods' | t }}</span>
          <ul class="kt-footer__payment-list list-unstyled" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li>{{ type | payment_type_svg_tag: class: 'kt-footer__payment-icon' }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.settings.show_payment_icons.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "default": "footer",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label",
          "default": "About"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.footer.blocks.text.settings.text.label",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}
{% endschema %}
