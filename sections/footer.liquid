{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="kt-footer" data-section-id="{{ section.id }}">
  <div class="kt-footer__inner page-width">
    <div class="kt-footer__grid">

      {%- comment -%} Brand Column (always first) {%- endcomment -%}
      <div class="kt-footer__brand">
        <h2 class="kt-footer__brand-heading">
          {{ section.settings.heading_line1 | default: 'Let&rsquo;s build your' }}<br>{{ section.settings.heading_line2 | default: 'dream kitchen.' }}
        </h2>
        <p class="kt-footer__brand-text">
          {{ section.settings.description | default: 'Experience the perfect orchestration of engineering and tactile luxury in your own home.' }}
        </p>

        <div class="kt-footer__social">
          {% render 'social-icons' %}
        </div>

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="kt-footer__cta">
            <span>{{ section.settings.cta_text }}</span>
            <span class="kt-footer__cta-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Dynamic Link Columns via Blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              <h4 class="kt-footer__column-title">
                {{ block.settings.heading | default: block.settings.menu.title }}
              </h4>
              {%- if block.settings.menu != blank -%}
                <ul class="kt-footer__link-list list-unstyled" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="kt-footer__link">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            <div class="kt-footer__column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h4 class="kt-footer__column-title">{{ block.settings.heading }}</h4>
              {%- endif -%}
              <div class="kt-footer__text rte">{{ block.settings.text }}</div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Large Branding Text {%- endcomment -%}
    <div class="kt-footer__branding">
      <span class="kt-footer__branding-text" aria-hidden="true">{{ shop.name }}</span>

      {%- comment -%} Bottom Bar {%- endcomment -%}
      <div class="kt-footer__bottom">
        {%- comment -%} Copyright {%- endcomment -%}
        <div class="kt-footer__copyright">
          <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</span>
          <a href="https://www.shopify.com" target="_blank" rel="noopener">{{ 'general.footer.powered_by_shopify' | t | default: 'Powered by Shopify' }}</a>
        </div>

        {%- comment -%} Language/Country Selectors (Shopify native localization) {%- endcomment -%}
        {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          <div class="kt-footer__selectors">
            {%- if localization.available_languages.size > 1 -%}
              {%- form 'localization', id: 'FooterLanguageForm', class: 'kt-footer__localization-form' -%}
                <div class="localization-selector">
                  <select name="locale_code" id="FooterLanguageSelector" aria-label="{{ 'localization.language_label' | t | default: 'Language' }}">
                    {%- for language in localization.available_languages -%}
                      <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                        {{ language.endonym_name | capitalize }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <noscript>
                    <button type="submit" class="button button--secondary">{{ 'localization.update' | t | default: 'Update' }}</button>
                  </noscript>
                </div>
              {%- endform -%}
            {%- endif -%}

            {%- if localization.available_countries.size > 1 -%}
              {%- form 'localization', id: 'FooterCountryForm', class: 'kt-footer__localization-form' -%}
                <div class="localization-selector">
                  <select name="country_code" id="FooterCountrySelector" aria-label="{{ 'localization.country_label' | t | default: 'Country/region' }}">
                    {%- for country in localization.available_countries -%}
                      <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                        {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                      </option>
                    {%- endfor -%}
                  </select>
                  <noscript>
                    <button type="submit" class="button button--secondary">{{ 'localization.update' | t | default: 'Update' }}</button>
                  </noscript>
                </div>
              {%- endform -%}
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Payment Icons (Shopify native) {%- endcomment -%}
        {%- if section.settings.show_payment_icons -%}
          <div class="kt-footer__payment">
            <span class="visually-hidden">{{ 'general.footer.payment_methods' | t }}</span>
            <ul class="kt-footer__payment-list list-unstyled" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li>{{ type | payment_type_svg_tag: class: 'kt-footer__payment-icon' }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__brand.content"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.footer.settings.heading_line1.label",
      "default": "Let\u2019s build your"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.footer.settings.heading_line2.label",
      "default": "dream kitchen."
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.footer.settings.description.label",
      "default": "Experience the perfect orchestration of engineering and tactile luxury in your own home."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.footer.settings.cta_text.label",
      "default": "Start a Project"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.footer.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__bottom.content"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.settings.show_payment_icons.label",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "default": "footer",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.footer.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Explore"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Company"
        }
      }
    ]
  }
}
{% endschema %}
