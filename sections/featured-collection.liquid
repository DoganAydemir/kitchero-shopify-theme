{{ 'kt-section-featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'kt-card-product.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Featured Collection — single-collection product showcase.

  Theme Store basics tier — every commercial theme ships this section.
  Renders a configurable subset of products from ONE collection chosen
  by the merchant, with an optional "View all" link to the full
  collection page. Server-side rendered (no async fetch) because
  `collection.products` is available at section render time.

  Layout modes:
    - grid: standard responsive product grid (default)
    - carousel: horizontal-snap scroll on mobile, larger viewports
      stay grid (carousel-on-mobile is the modern pattern; full
      desktop carousel is a separate slider-* section)

  Empty states:
    - No collection picked + design_mode → onboarding hint, no
      products rendered
    - No collection picked + live → section emits nothing
    - Collection has 0 products + design_mode → onboarding hint
    - Collection has 0 products + live → section emits nothing

  Card-product snippet is reused (R97-R116 hardened) so accessibility,
  WCAG contrast, lazy-loading, and i18n behaviors are inherited.
{%- endcomment -%}

{%- liquid
  assign section_collection = section.settings.collection
  assign products_to_show = section.settings.products_count | default: 4
  assign cols_desktop = section.settings.columns_desktop | default: 4
  assign cols_mobile = section.settings.columns_mobile | default: 2
  assign layout = section.settings.layout | default: 'grid'
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_id = 'FeaturedCollectionTitle-' | append: section.id
  assign view_all_default = 'kt.section.featured_collection.view_all_default' | t
-%}

{%- comment -%}
  Live-storefront empty-state guard. When the merchant hasn't picked a
  collection, OR the collection is empty, suppress the section entirely
  on the live storefront so visitors never see a hollow band. The
  design_mode branch below shows a hint inside the editor so the
  merchant knows what to configure.
{%- endcomment -%}
{%- if section_collection == blank or section_collection.products_count == 0 -%}
  {%- if request.design_mode -%}
    <section
      class="kt-featured-collection kt-featured-collection--empty color-{{ section.settings.color_scheme | default: 'scheme-1' }} {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
      data-section-id="{{ section.id }}"
      style="--kt-section-padding-top: {{ section.settings.padding_top }}px; --kt-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
      aria-label="{{ 'kt.section.featured-collection.editor_hint_aria' | t | default: 'Featured collection — needs configuration' }}"
    >
      <div class="page-width">
        <p class="kt-featured-collection__editor-hint">
          {%- if section_collection == blank -%}
            {{ 'kt.section.featured-collection.editor_hint_empty' | t | default: 'Pick a collection in the section settings to populate this band.' }}
          {%- else -%}
            {{ 'kt.section.featured-collection.editor_hint_zero_products' | t | default: 'The selected collection has no products yet. Add products in the Shopify admin.' }}
          {%- endif -%}
        </p>
      </div>
    </section>
  {%- endif -%}
{%- else -%}
  <section
    class="kt-featured-collection kt-featured-collection--{{ layout }} color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
    data-section-id="{{ section.id }}"
    data-section-type="featured-collection"
    style="--kt-fc-cols-desktop: {{ cols_desktop }}; --kt-fc-cols-mobile: {{ cols_mobile }}; --kt-section-padding-top: {{ section.settings.padding_top }}px; --kt-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
    aria-labelledby="{{ heading_id }}"
  >
    <div class="page-width">
      <header class="kt-featured-collection__header">
        <div class="kt-featured-collection__heading-wrap">
          {%- if section.settings.eyebrow != blank -%}
            <p class="kt-featured-collection__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}

          <{{ heading_tag }}
            id="{{ heading_id }}"
            class="kt-featured-collection__title"
          >
            {{- section.settings.heading | default: section_collection.title | escape -}}
          </{{ heading_tag }}>

          {%- if section.settings.description != blank -%}
            <div class="kt-featured-collection__description rte">
              {{ section.settings.description }}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.show_view_all -%}
          {%- comment -%}
            R104 — Return-key advance not relevant for nav links;
            visible CTA only. Link goes to the full collection page.
          {%- endcomment -%}
          <a
            href="{{ section_collection.url }}"
            class="kt-featured-collection__view-all"
            aria-label="{{ 'kt.section.featured-collection.view_all_aria' | t: collection: section_collection.title | default: section_collection.title }}"
          >
            {{- section.settings.view_all_label | default: view_all_default | escape -}}
            {% render 'icon-arrow-right', stroke_width: 1.5 %}
          </a>
        {%- endif -%}
      </header>

      {%- comment -%}
        role="list" makes the grid an explicit listbox in the AT
        tree even though card-product is rendered as <div>. Each
        card-product internally carries role="listitem".
      {%- endcomment -%}
      <div class="kt-featured-collection__grid" role="list">
        {%- for product in section_collection.products limit: products_to_show -%}
          {%- render 'card-product',
              product: product,
              show_vendor: section.settings.show_vendor,
              show_secondary_image: section.settings.show_secondary_image,
              show_quote_button: section.settings.show_quote_button,
              index: forloop.index0
          -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all_mobile and section.settings.show_view_all -%}
        {%- comment -%}
          Mobile-only secondary CTA — the header CTA is visually
          hidden on mobile via CSS (the heading + description take
          full width). Repeating it below the grid keeps the
          discovery path clear without horizontal-scroll truncation.
        {%- endcomment -%}
        <a
          href="{{ section_collection.url }}"
          class="kt-featured-collection__view-all kt-featured-collection__view-all--mobile"
          aria-label="{{ 'kt.section.featured-collection.view_all_aria' | t: collection: section_collection.title | default: section_collection.title }}"
        >
          {{- section.settings.view_all_label | default: view_all_default | escape -}}
        </a>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.featured-collection.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ],
    "templates": [
      "cart",
      "search",
      "password",
      "gift_card",
      "404"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.featured-collection.settings.eyebrow.label",
      "info": "t:sections.featured-collection.settings.eyebrow.info",
      "default": "Featured Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured-collection.settings.heading.label",
      "info": "t:sections.featured-collection.settings.heading.info",
      "default": "Featured collection"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.featured-collection.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.featured-collection.settings.heading_tag.options__1.label"
        },
        {
          "value": "h3",
          "label": "t:sections.featured-collection.settings.heading_tag.options__2.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label",
      "default": "<p>Add a description for this section.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__layout.content"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.featured-collection.settings.layout.label",
      "info": "t:sections.featured-collection.settings.layout.info",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.featured-collection.settings.layout.options__grid.label"
        },
        {
          "value": "carousel",
          "label": "t:sections.featured-collection.settings.layout.options__carousel.label"
        }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.products_count.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.featured-collection.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__card.content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.featured-collection.settings.show_vendor.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.featured-collection.settings.show_secondary_image.label",
      "info": "t:sections.featured-collection.settings.show_secondary_image.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quote_button",
      "label": "t:sections.featured-collection.settings.show_quote_button.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__view_all.content"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.featured-collection.settings.show_view_all.label",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured-collection.settings.view_all_label.label",
      "default": "View all"
    },
    {
      "type": "checkbox",
      "id": "show_view_all_mobile",
      "label": "t:sections.featured-collection.settings.show_view_all_mobile.label",
      "info": "t:sections.featured-collection.settings.show_view_all_mobile.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__appearance.content"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.featured-collection.settings.padding_top.label",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.featured-collection.settings.padding_bottom.label",
      "default": 64
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        }
      ],
      "default": "auto"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-collection.presets.name",
      "category": "t:sections.categories.product.label"
    }
  ]
}
{% endschema %}
