{%- comment -%}
  Predictive Search — renders search-as-you-type results for the overlay.

  Hit via the Section Rendering API from assets/predictive-search.js:
    /search/suggest?q=<term>&resources[type]=product,article,page&section_id=predictive-search

  Shopify exposes the results via the `predictive_search` global so this
  section has no schema-driven settings — it is purely a render target.

  IMPORTANT — schema does NOT use `disabled_on: { templates: ["*"], groups:
  ["*"] }`. An earlier revision did, on the rationale of "this isn't a
  user-addable section, hide it from theme editor". User reproduced a
  bug where /search?q=test returned 4 results but the predictive overlay
  for the same query rendered "No results found" — a Shopify-side
  symptom of the disabled_on wildcard: the Section Rendering API
  respects the disabled_on gate and refuses to invoke the section's
  Liquid render path, so the response payload comes back without the
  predictive_search.performed branch ever executing.

  Section is still effectively hidden from the editor because it has
  no `presets` array — Shopify's "Add section" picker only surfaces
  sections with at least one preset.
{%- endcomment -%}

<div class="kt-predictive-search" data-predictive-search-root data-section-id="{{ section.id }}">
  {%- if predictive_search.performed -%}
    {%- assign results_count = predictive_search.resources.results_count -%}

    {%- if results_count > 0 -%}
      {%- comment -%}
        Products group. Per WAI-ARIA combobox + multi-listbox pattern
        the group <ul> carries role="listbox" + aria-labelledby
        pointing to the group <h2> id; each result <li> carries
        role="option" (NOT the inner <a>). This matches the example
        markup in Shopify's predictive-search docs and lets a
        screen-reader's combobox navigation announce the option
        landmark + group label, not the bare anchor text.
      {%- endcomment -%}
      {%- if predictive_search.resources.results.products.size > 0 -%}
        <div class="kt-predictive-search__group" data-group="products">
          <h2 class="kt-predictive-search__group-title" id="kt-predictive-search-products-heading">
            {{ 'kt.predictive_search.products' | t | default: 'Products' }}
          </h2>
          <ul class="kt-predictive-search__list" role="listbox" aria-labelledby="kt-predictive-search-products-heading">
            {%- for product in predictive_search.resources.results.products -%}
              <li class="predictive-search__item kt-predictive-search__item" role="option">
                <a
                  class="kt-predictive-search__link"
                  href="{{ product.url }}"
                  aria-label="{{ product.title | escape }}"
                >
                  {%- if product.featured_media != blank -%}
                    {{
                      product.featured_media
                      | image_url: width: 120
                      | image_tag:
                          loading: 'lazy',
                          widths: '60,120,180',
                          sizes: '60px',
                          width: 60,
                          height: 60,
                          class: 'kt-predictive-search__thumb',
                          alt: product.featured_media.alt | default: product.title
                    }}
                  {%- else -%}
                    <span class="kt-predictive-search__thumb kt-predictive-search__thumb--empty" aria-hidden="true">
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </span>
                  {%- endif -%}
                  <span class="kt-predictive-search__text">
                    <span class="kt-predictive-search__title">{{ product.title | escape }}</span>
                    {%- comment -%}
                      Free-product guard — surface "Free" instead of
                      "$0.00" for 0-priced products in dropdown results.
                      Matches the substitution applied in
                      `snippets/product-price.liquid` and
                      `snippets/card-product.liquid` for visual consistency
                      across the discovery surfaces.
                    {%- endcomment -%}
                    {%- if product.price_varies -%}
                      {%- comment -%}
                        R89 — Liquid filter-chain fix: pre-format
                        the money before t-interpolation so `| money`
                        lands on price_min, not on the t output.
                        Same R86/R88 SUB-05 class regression.
                      {%- endcomment -%}
                      {%- assign price_min_money = product.price_min | money -%}
                      <span class="kt-predictive-search__price">
                        {{ 'kt.predictive_search.from_price' | t: price: price_min_money }}
                      </span>
                    {%- elsif product.price == 0 -%}
                      <span class="kt-predictive-search__price">{{ 'kt.cart.free' | t | default: 'Free' }}</span>
                    {%- else -%}
                      <span class="kt-predictive-search__price">{{ product.price | money }}</span>
                    {%- endif -%}
                  </span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} Collections group — same listbox/option pattern as products. {%- endcomment -%}
      {%- if predictive_search.resources.results.collections.size > 0 -%}
        <div class="kt-predictive-search__group" data-group="collections">
          <h2 class="kt-predictive-search__group-title" id="kt-predictive-search-collections-heading">
            {{ 'kt.predictive_search.collections' | t | default: 'Collections' }}
          </h2>
          <ul class="kt-predictive-search__list" role="listbox" aria-labelledby="kt-predictive-search-collections-heading">
            {%- for collection in predictive_search.resources.results.collections -%}
              <li class="predictive-search__item kt-predictive-search__item" role="option">
                <a class="kt-predictive-search__link" href="{{ collection.url }}">
                  <span class="kt-predictive-search__text">
                    <span class="kt-predictive-search__title">{{ collection.title | escape }}</span>
                  </span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} Articles group — same listbox/option pattern. {%- endcomment -%}
      {%- if predictive_search.resources.results.articles.size > 0 -%}
        <div class="kt-predictive-search__group" data-group="articles">
          <h2 class="kt-predictive-search__group-title" id="kt-predictive-search-articles-heading">
            {{ 'kt.predictive_search.articles' | t | default: 'Articles' }}
          </h2>
          <ul class="kt-predictive-search__list" role="listbox" aria-labelledby="kt-predictive-search-articles-heading">
            {%- for article in predictive_search.resources.results.articles -%}
              <li class="predictive-search__item kt-predictive-search__item" role="option">
                <a class="kt-predictive-search__link" href="{{ article.url }}">
                  <span class="kt-predictive-search__text">
                    <span class="kt-predictive-search__title">{{ article.title | escape }}</span>
                    {%- if article.excerpt != blank -%}
                      <span class="kt-predictive-search__excerpt">{{ article.excerpt | strip_html | truncate: 80 }}</span>
                    {%- endif -%}
                  </span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} Pages group — same listbox/option pattern. {%- endcomment -%}
      {%- if predictive_search.resources.results.pages.size > 0 -%}
        <div class="kt-predictive-search__group" data-group="pages">
          <h2 class="kt-predictive-search__group-title" id="kt-predictive-search-pages-heading">
            {{ 'kt.predictive_search.pages' | t | default: 'Pages' }}
          </h2>
          <ul class="kt-predictive-search__list" role="listbox" aria-labelledby="kt-predictive-search-pages-heading">
            {%- for page in predictive_search.resources.results.pages -%}
              <li class="predictive-search__item kt-predictive-search__item" role="option">
                <a class="kt-predictive-search__link" href="{{ page.url }}">
                  <span class="kt-predictive-search__text">
                    <span class="kt-predictive-search__title">{{ page.title | escape }}</span>
                  </span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} View-all link {%- endcomment -%}
      <div class="kt-predictive-search__footer">
        <a href="{{ routes.search_url }}?q={{ predictive_search.terms | url_encode }}" class="kt-predictive-search__view-all">
          {{ 'kt.predictive_search.view_all' | t | default: 'View all results' }}
        </a>
      </div>
    {%- else -%}
      <p class="kt-predictive-search__empty" role="status">
        {%- comment -%}
          The `| t` filter auto-escapes interpolated `terms:` in the
          translated output, but the `| default:` fallback only fires
          when the key resolves to blank — and at that point
          `predictive_search.terms` (the raw `?q=` URL param) renders
          unescaped, reflecting whatever the visitor put in the URL.
          A crafted `?q=<svg onload=...>` survives the locale-miss
          fallback path. Applying `| escape` to the variable BEFORE
          the chain ensures both branches (translation-resolved and
          default-fallback) emit safe text. The translated branch
          would have escaped it again at no cost (idempotent).
        {%- endcomment -%}
        {%- assign safe_terms = predictive_search.terms | escape -%}
        {{ 'kt.predictive_search.no_results' | t: terms: safe_terms | default: safe_terms }}
      </p>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.predictive-search.name",
  "settings": []
}
{% endschema %}
