{%- comment -%}
  Mobile Dock — fixed bottom-of-viewport quick-access bar on
  mobile (and tablet portrait). Reference theme pattern: 3–5
  icon buttons (home / search / menu / cart / account) sit on
  a sticky bar that stays in the customer's thumb reach as they
  scroll through long PDPs / collection grids. Without it, the
  header's icons scroll out of view and the customer has to thumb
  all the way back up to reach the cart or menu — a measurable
  conversion drag on mobile-first storefronts.

  The dock triggers the SAME drawers the header uses (cart
  drawer, mobile menu panel) so the merchant doesn't have to
  reconfigure navigation; we just expose a second entry point.

  Visibility: hidden above the merchant-configurable breakpoint
  (defaults to 750px — anything tablet-portrait or smaller). The
  desktop header already exposes these icons; dock-on-desktop
  would just duplicate them.

  Merchant configures the dock by adding 3–5 blocks (home,
  search, menu, cart, account, link). `max_blocks: 5` keeps the
  bar uncrowded; 6+ icons at 60px-min width each overflow most
  phones.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  {{ 'kt-section-mobile-dock.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'kt-section-mobile-dock.js' | asset_url }}" defer="defer"></script>

  {%- comment -%}
    Per-section visibility breakpoint. CSS only paints the bar
    below this width; above it the section reserves no space.
  {%- endcomment -%}
  {%- assign hide_above = section.settings.hide_above | default: 750 -%}

  <nav
    class="kt-mobile-dock kt-mobile-dock--{{ section.blocks.size }}-col{% if section.settings.show_border %} kt-mobile-dock--border{% endif %}{% if section.settings.rounded %} kt-mobile-dock--rounded{% endif %}"
    style="--kt-dock-hide-above: {{ hide_above }}px;"
    aria-label="{{ 'kt.dock.label' | t | default: 'Quick navigation' }}"
    data-mobile-dock
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign block_title = block.settings.title | default: ''
        if block_title == blank
          case block.type
            when 'home'
              assign block_title = 'kt.dock.home' | t | default: 'Home'
            when 'search'
              assign block_title = 'kt.dock.search' | t | default: 'Search'
            when 'menu'
              assign block_title = 'kt.dock.menu' | t | default: 'Menu'
            when 'cart'
              assign block_title = 'kt.dock.cart' | t | default: 'Cart'
            when 'account'
              assign block_title = 'kt.dock.account' | t | default: 'Account'
            when 'link'
              assign block_title = 'kt.dock.link' | t | default: 'Link'
          endcase
        endif
      -%}
      {%- case block.type -%}
        {%- when 'home' -%}
          <a
            class="kt-mobile-dock__item"
            href="{{ routes.root_url }}"
            {{ block.shopify_attributes }}
          >
            <span class="kt-mobile-dock__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9.5L12 2l9 7.5"></path>
                <path d="M5 9v11a1 1 0 0 0 1 1h4v-7h4v7h4a1 1 0 0 0 1-1V9"></path>
              </svg>
            </span>
            <span class="kt-mobile-dock__label">{{ block_title | escape }}</span>
          </a>

        {%- when 'search' -%}
          {%- comment -%}
            Native link to /search so JS-off users still get a
            usable search page. JS upgrades to the predictive
            overlay / drawer via a click-intercept on
            `[data-search-trigger]`.
          {%- endcomment -%}
          <a
            class="kt-mobile-dock__item"
            href="{{ routes.search_url }}"
            data-search-trigger
            {{ block.shopify_attributes }}
          >
            <span class="kt-mobile-dock__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </span>
            <span class="kt-mobile-dock__label">{{ block_title | escape }}</span>
          </a>

        {%- when 'menu' -%}
          {%- comment -%}
            Menu opens the header's existing mobile panel. The
            dock JS programmatically clicks `.kt-header__menu-toggle`
            so we inherit the focus trap, ESC handler, and
            animation already shipped with kt-section-header-mobile-
            nav.js — no duplicated drawer logic.
          {%- endcomment -%}
          <button
            type="button"
            class="kt-mobile-dock__item"
            data-mobile-dock-menu
            aria-label="{{ block_title | escape }}"
            {{ block.shopify_attributes }}
          >
            <span class="kt-mobile-dock__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
              </svg>
            </span>
            <span class="kt-mobile-dock__label">{{ block_title | escape }}</span>
          </button>

        {%- when 'cart' -%}
          <a
            class="kt-mobile-dock__item kt-mobile-dock__item--cart"
            href="{{ routes.cart_url }}"
            aria-controls="cart-drawer"
            aria-haspopup="dialog"
            {{ block.shopify_attributes }}
          >
            <span class="kt-mobile-dock__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <path d="M16 10a4 4 0 0 1-8 0"></path>
              </svg>
              {%- comment -%}
                Cart count badge — shipped on every paint so JS
                cart count syncer can mutate textContent without
                a missing-node guard. Visually-hidden when zero
                so the dock doesn't paint a "0" pill.
              {%- endcomment -%}
              <span
                class="kt-mobile-dock__count"
                data-cart-count
                {% if cart.item_count == 0 %}hidden{% endif %}
              >{{ cart.item_count }}</span>
            </span>
            <span class="kt-mobile-dock__label">{{ block_title | escape }}</span>
          </a>

        {%- when 'account' -%}
          <a
            class="kt-mobile-dock__item"
            href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
            {{ block.shopify_attributes }}
          >
            <span class="kt-mobile-dock__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </span>
            <span class="kt-mobile-dock__label">{{ block_title | escape }}</span>
          </a>

        {%- when 'link' -%}
          {%- if block.settings.link != blank -%}
            <a
              class="kt-mobile-dock__item"
              href="{{ block.settings.link }}"
              {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              {{ block.shopify_attributes }}
            >
              <span class="kt-mobile-dock__icon" aria-hidden="true">
                {%- comment -%}
                  Generic link icon — merchant picks per-block via
                  the `icon` select setting. Each case below paints
                  a different SVG so the merchant has a sensible
                  default without uploading custom artwork. Custom
                  HTML icon would invite XSS — keep the icon set
                  curated.
                {%- endcomment -%}
                {%- case block.settings.icon -%}
                  {%- when 'star' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  {%- when 'heart' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                  {%- when 'tag' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                  {%- when 'phone' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  {%- when 'message' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                  {%- else -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                {%- endcase -%}
              </span>
              <span class="kt-mobile-dock__label">{{ block_title | escape }}</span>
            </a>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
  </nav>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.mobile-dock.name",
  "tag": "section",
  "class": "kt-section kt-section--mobile-dock",
  "limit": 1,
  "max_blocks": 5,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.mobile-dock.settings.info"
    },
    {
      "type": "select",
      "id": "hide_above",
      "label": "t:sections.mobile-dock.settings.hide_above.label",
      "info": "t:sections.mobile-dock.settings.hide_above.info",
      "options": [
        { "value": "600", "label": "t:sections.mobile-dock.settings.hide_above.options__600.label" },
        { "value": "750", "label": "t:sections.mobile-dock.settings.hide_above.options__750.label" },
        { "value": "990", "label": "t:sections.mobile-dock.settings.hide_above.options__990.label" }
      ],
      "default": "750"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "t:sections.mobile-dock.settings.show_border.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "label": "t:sections.mobile-dock.settings.rounded.label",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "home",
      "name": "t:sections.mobile-dock.blocks.home.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.mobile-dock.blocks.common.title_label",
          "default": "Home"
        }
      ]
    },
    {
      "type": "search",
      "name": "t:sections.mobile-dock.blocks.search.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.mobile-dock.blocks.common.title_label",
          "default": "Search"
        }
      ]
    },
    {
      "type": "menu",
      "name": "t:sections.mobile-dock.blocks.menu.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.mobile-dock.blocks.common.title_label",
          "default": "Menu"
        }
      ]
    },
    {
      "type": "cart",
      "name": "t:sections.mobile-dock.blocks.cart.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.mobile-dock.blocks.common.title_label",
          "default": "Cart"
        }
      ]
    },
    {
      "type": "account",
      "name": "t:sections.mobile-dock.blocks.account.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.mobile-dock.blocks.common.title_label",
          "default": "Account"
        }
      ]
    },
    {
      "type": "link",
      "name": "t:sections.mobile-dock.blocks.link.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.mobile-dock.blocks.common.title_label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.mobile-dock.blocks.link.settings.link.label"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.mobile-dock.blocks.link.settings.icon.label",
          "options": [
            { "value": "grid", "label": "t:sections.mobile-dock.blocks.link.settings.icon.options__grid.label" },
            { "value": "star", "label": "t:sections.mobile-dock.blocks.link.settings.icon.options__star.label" },
            { "value": "heart", "label": "t:sections.mobile-dock.blocks.link.settings.icon.options__heart.label" },
            { "value": "tag", "label": "t:sections.mobile-dock.blocks.link.settings.icon.options__tag.label" },
            { "value": "phone", "label": "t:sections.mobile-dock.blocks.link.settings.icon.options__phone.label" },
            { "value": "message", "label": "t:sections.mobile-dock.blocks.link.settings.icon.options__message.label" }
          ],
          "default": "grid"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "t:sections.mobile-dock.blocks.link.settings.open_in_new_tab.label",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.mobile-dock.name",
      "blocks": [
        { "type": "home" },
        { "type": "search" },
        { "type": "menu" },
        { "type": "cart" },
        { "type": "account" }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["custom.overlay"]
  }
}
{% endschema %}
