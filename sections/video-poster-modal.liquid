{%- comment -%}
  Video Poster + Modal (Variant C)
  ------------------------------------
  Dark framed section with a large poster image and a centered
  circular play button. Click opens the shared video modal
  (YouTube / Vimeo embed). If no `modal_video_url` is set, the
  poster renders as a still image with no click-to-play affordance.

  Uses the shared `{% render 'video-modal' %}` snippet + video-modal.js
  so the same modal controller powers every video lightbox on the page.
{%- endcomment -%}

{{ 'kt-section-video-poster-modal.css' | asset_url | stylesheet_tag }}
{{ 'kt-video-modal.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign modal_id = 'VideoModal-' | append: section.id
  assign padding = section.settings.vertical_padding | default: 80
-%}

<section
  class="kt-video-poster"
  data-section-id="{{ section.id }}"
  data-section-type="video-poster-modal"
  style="--kt-video-poster-padding: {{ padding }}px;"
>
  <div class="page-width">
    <div class="kt-video-poster__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kt-video-poster__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <div class="kt-video-poster__frame">
        {%- if section.settings.poster_image != blank -%}
          {{
            section.settings.poster_image
            | image_url: width: 1600
            | image_tag:
              class: 'kt-video-poster__image',
              loading: 'lazy',
              widths: '600, 900, 1200, 1600, 2000',
              sizes: '(min-width: 990px) 1100px, 100vw',
              width: section.settings.poster_image.width,
              height: section.settings.poster_image.height,
              alt: section.settings.heading | default: ''
          }}
        {%- else -%}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg kt-video-poster__image' }}
        {%- endif -%}

        <span class="kt-video-poster__frame-border" aria-hidden="true"></span>

        {%- if section.settings.modal_video_url != blank -%}
          <button
            type="button"
            class="kt-video-poster__play"
            data-modal-video-open="{{ section.settings.modal_video_url | escape }}"
            data-modal-target="{{ modal_id }}"
            aria-label="{{ 'kt.section.video_poster_modal.play_aria' | t | default: 'Play video' }}"
          >
            <span class="kt-video-poster__play-icon" aria-hidden="true">
              <svg aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </span>
          </button>
        {%- endif -%}
      </div>

      {%- if section.settings.heading != blank -%}
        <{{ heading_tag }} class="kt-video-poster__heading">
          {{ section.settings.heading }}
        </{{ heading_tag }}>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="kt-video-poster__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{%- if section.settings.modal_video_url != blank -%}
  {%- render 'video-modal', modal_id: modal_id -%}
  <script src="{{ 'video-modal.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.video_poster_modal.name",
  "tag": "div",
  "class": "section-video-poster-modal",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.video_poster_modal.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.video_poster_modal.settings.eyebrow.label",
      "default": "Variant C"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.video_poster_modal.settings.heading.label",
      "default": "A cinematic tour."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.video_poster_modal.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.video_poster_modal.settings.description.label",
      "default": "Press play for a three-minute walk through the Kitchero atelier, from first sketch to final hand-finish."
    },
    {
      "type": "header",
      "content": "t:sections.video_poster_modal.settings.header__media.content"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "t:sections.video_poster_modal.settings.poster_image.label"
    },
    {
      "type": "video_url",
      "id": "modal_video_url",
      "label": "t:sections.video_poster_modal.settings.modal_video_url.label",
      "info": "t:sections.video_poster_modal.settings.modal_video_url.info",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "header",
      "content": "t:sections.video_poster_modal.settings.header__layout.content"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "t:sections.video_poster_modal.settings.vertical_padding.label",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "t:sections.video_poster_modal.presets.name",
      "settings": {
        "eyebrow": "Variant C",
        "heading": "A cinematic tour.",
        "description": "Press play for a three-minute walk through the Kitchero atelier, from first sketch to final hand-finish."
      }
    }
  ]
}
{% endschema %}
