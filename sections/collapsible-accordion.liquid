{%- comment -%}
  Collapsible Content — Style 01 Bordered Accordion

  Vertical bordered list with numbered prefix, large serif title
  and circular +/- toggle. Progressive-enhancement friendly: uses
  native <details>/<summary> so content is accessible without JS.
  JS layers on single-open behavior, smooth height transitions and
  icon rotation.

  Settings:
    eyebrow            — small caps pretitle
    heading            — main heading
    heading_tag        — h2 / h3
    allow_multiple_open — true = independent disclosures
    numbering_style    — padded_two / none / plain

  Blocks:
    item — title (text), content (richtext), open (checkbox)
    @app — app blocks
{%- endcomment -%}

{{ 'kt-section-collapsible-accordion.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kt-section-collapsible-accordion.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign allow_multiple = section.settings.allow_multiple_open
  assign numbering_style = section.settings.numbering_style | default: 'padded_two'
  assign group_name = 'kt-collapsible-' | append: section.id
  assign faq_question_default = 'kt.section.faq.question_default' | t
  assign faq_answer_default = 'kt.section.faq.answer_default' | t
-%}

<section
  class="kt-collapsible-accordion {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-allow-multiple="{% if allow_multiple %}true{% else %}false{% endif %}"
>
  <div class="kt-collapsible-accordion__container">
    {%- if eyebrow != blank or heading != blank -%}
      <header class="kt-collapsible-accordion__header">
        {%- if eyebrow != blank -%}
          <span class="kt-collapsible-accordion__eyebrow">{{ eyebrow | escape }}</span>
        {%- endif -%}
        {%- if heading != blank -%}
          <{{ heading_tag }} class="kt-collapsible-accordion__heading">
            {{ heading | escape }}
          </{{ heading_tag }}>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="kt-collapsible-accordion__list">
      {%- assign item_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'item' -%}
            {%- assign item_index = item_index | plus: 1 -%}
            {%- assign label_prefix = '' -%}
            {%- case numbering_style -%}
              {%- when 'padded_two' -%}
                {%- assign label_prefix = item_index | prepend: '0' | slice: -2, 2 -%}
              {%- when 'plain' -%}
                {%- assign label_prefix = item_index | append: '' -%}
              {%- when 'none' -%}
                {%- assign label_prefix = '' -%}
            {%- endcase -%}

            <details
              class="kt-collapsible-accordion__item"
              name="{{ group_name }}"
              data-kt-accordion-item
              {% if block.settings.open %}open{% endif %}
              {{ block.shopify_attributes }}
            >
              <summary class="kt-collapsible-accordion__summary">
                <span class="kt-collapsible-accordion__label">
                  {%- if label_prefix != blank -%}
                    <span class="kt-collapsible-accordion__number" aria-hidden="true">
                      {{- label_prefix -}}
                    </span>
                  {%- endif -%}
                  <span class="kt-collapsible-accordion__title">
                    {%- assign collapsible_accordion_fallback = 'kt.section.collapsible_accordion.item_title_default' | t -%}
                    {{- block.settings.title | default: collapsible_accordion_fallback -}}
                  </span>
                </span>
                <span class="kt-collapsible-accordion__toggle" aria-hidden="true">
                  <span class="kt-collapsible-accordion__toggle-icon">
                    <span class="kt-collapsible-accordion__toggle-bar kt-collapsible-accordion__toggle-bar--h"></span>
                    <span class="kt-collapsible-accordion__toggle-bar kt-collapsible-accordion__toggle-bar--v"></span>
                  </span>
                </span>
              </summary>
              <div class="kt-collapsible-accordion__panel" data-kt-accordion-panel>
                <div class="kt-collapsible-accordion__content rte">
                  {%- if block.settings.content != blank -%}
                    {{ block.settings.content }}
                  {%- else -%}
                    <p>{{ 'kt.section.collapsible_accordion.item_content_default' | t }}</p>
                  {%- endif -%}
                </div>
              </div>
            </details>
          {%- when '@app' -%}
            <div class="kt-collapsible-accordion__app-block" {{ block.shopify_attributes }}>
              {% render block %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%}
  FAQ structured data (R139 / HG-1). When the merchant opts in via
  `enable_faq_schema` we emit a Schema.org FAQPage JSON-LD payload so
  Google can surface the questions as rich results in search.

  Default OFF — emitting FAQPage on a section that contains anything
  other than genuine FAQ content (returns policy, shipping table, etc.)
  triggers Google's "Misleading or incorrect content" penalty per
  https://developers.google.com/search/docs/appearance/structured-data/faqpage
  Merchants opt in only on real FAQ accordions.

  Implementation notes:
  - Two-pass loop. First pass counts `item` blocks so the second pass
    knows when to omit the trailing comma; @app blocks are skipped.
  - `strip_html` on title + content so Schema.org receives plain text
    (FAQ schema allows HTML in `acceptedAnswer.text`, but stripping
    keeps the payload compact and never trips on unbalanced markup).
  - `| json` emits a fully quoted, JSON-escape-safe string — handles
    embedded quotes / newlines / `<` characters without manual escaping.
{%- endcomment -%}
{%- if section.settings.enable_faq_schema -%}
  {%- assign faq_items_total = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'item' -%}
      {%- assign faq_items_total = faq_items_total | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if faq_items_total > 0 -%}
    {%- assign faq_item_index = 0 -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            {%- assign faq_item_index = faq_item_index | plus: 1 -%}
            {
              "@type": "Question",
              "name": {{ block.settings.title | default: faq_question_default | strip_html | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ block.settings.content | default: faq_answer_default | strip_html | json }}
              }
            }{% if faq_item_index < faq_items_total %},{% endif %}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collapsible_accordion.name",
  "tag": "div",
  "class": "section section--collapsible-accordion",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collapsible_accordion.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.collapsible_accordion.settings.eyebrow.label",
      "default": "Frequently Asked"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collapsible_accordion.settings.heading.label",
      "default": "Frequently asked questions"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.collapsible_accordion.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.collapsible_accordion.settings.heading_tag.options__h2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.collapsible_accordion.settings.heading_tag.options__h3.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible_accordion.settings.header_behavior.content"
    },
    {
      "type": "checkbox",
      "id": "allow_multiple_open",
      "label": "t:sections.collapsible_accordion.settings.allow_multiple_open.label",
      "info": "t:sections.collapsible_accordion.settings.allow_multiple_open.info",
      "default": false
    },
    {
      "type": "select",
      "id": "numbering_style",
      "label": "t:sections.collapsible_accordion.settings.numbering_style.label",
      "options": [
        {
          "value": "padded_two",
          "label": "t:sections.collapsible_accordion.settings.numbering_style.options__padded_two.label"
        },
        {
          "value": "plain",
          "label": "t:sections.collapsible_accordion.settings.numbering_style.options__plain.label"
        },
        {
          "value": "none",
          "label": "t:sections.collapsible_accordion.settings.numbering_style.options__none.label"
        }
      ],
      "default": "padded_two"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible_accordion.settings.header_seo.content"
    },
    {
      "type": "checkbox",
      "id": "enable_faq_schema",
      "label": "t:sections.collapsible_accordion.settings.enable_faq_schema.label",
      "info": "t:sections.collapsible_accordion.settings.enable_faq_schema.info",
      "default": false
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.collapsible_accordion.blocks.item.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.collapsible_accordion.blocks.item.settings.title.label",
          "default": "Question title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.collapsible_accordion.blocks.item.settings.content.label",
          "default": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "t:sections.collapsible_accordion.blocks.item.settings.open.label",
          "default": false
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.collapsible_accordion.presets.name",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Question 1",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>",
            "open": true
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Question 2",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Question 2",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
