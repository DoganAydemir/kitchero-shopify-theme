{{ 'kt-section-main-collection.css' | asset_url | stylesheet_tag }}
{{ 'kt-card-product.css' | asset_url | stylesheet_tag }}
{{ 'kt-collection-filters.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  R-collection-audit — Settings wiring for schema parity with the
  default collection template.
{%- endcomment -%}
{%- assign vert_cols_d = section.settings.cols_desktop | default: 3 -%}
{%- assign vert_cols_m = section.settings.cols_mobile | default: 2 -%}
{%- assign vert_pad_top = section.settings.padding_top | default: 0 -%}
{%- assign vert_pad_bot = section.settings.padding_bottom | default: 64 -%}
{%- assign vert_scheme = section.settings.color_scheme | default: 'scheme-1' -%}
<div
  class="kt-collection color-{{ vert_scheme }} kt-collection--cols-d-{{ vert_cols_d }} kt-collection--cols-m-{{ vert_cols_m }}"
  data-section-id="{{ section.id }}"
  data-section-type="main-collection"
  style="--kt-section-padding-top: {{ vert_pad_top }}px; --kt-section-padding-bottom: {{ vert_pad_bot }}px;"
>
  {%- comment -%} Hero Header (shared) {%- endcomment -%}
  <section class="kt-collection__hero" data-collection-hero>
    <div class="kt-collection__dots-base" aria-hidden="true"></div>
    <div class="kt-collection__dots-parallax" data-parallax-dots aria-hidden="true"></div>
    <div class="kt-collection__scanlines" aria-hidden="true"></div>
    <div class="kt-collection__markers" data-parallax-markers aria-hidden="true">
      <span class="kt-collection__marker kt-collection__marker--1" aria-hidden="true">+</span>
      <span class="kt-collection__marker kt-collection__marker--2" aria-hidden="true">+</span>
      <span class="kt-collection__marker kt-collection__marker--3" aria-hidden="true">+</span>
      <span class="kt-collection__marker kt-collection__marker--4" aria-hidden="true">+</span>
    </div>
    <div class="page-width">
      <div class="kt-collection__hero-inner">
        <div>
          <p class="kt-collection__label">{{ 'kt.section.collection.label' | t | default: 'The Archives' }}</p>
          <h1 class="kt-collection__title">{{ collection.title | escape }}</h1>
          {%- if section.settings.show_collection_description -%}
            {%- if collection.description != blank -%}
              {%- comment -%} <div>, not <p>: collection.description is rich HTML (its own <p> tags). Nesting <p> in <p> dropped the desc styling. {%- endcomment -%}
              <div class="kt-collection__desc">{{ collection.description | strip_html }}</div>
            {%- else -%}
              <p class="kt-collection__desc">{{ 'kt.section.collection.default_desc' | t }}</p>
            {%- endif -%}
          {%- endif -%}
        </div>
        <span class="kt-collection__count">
          {{ 'kt.section.collection.products_count' | t: count: collection.products_count }}
        </span>
      </div>
    </div>
  </section>

  {%- comment -%}
    Breadcrumb trail rendered after the vertical-layout hero and
    before the sticky control bar + product grid. Matches the
    treatment used by the other two collection templates so the
    trail always sits in the same visual slot.
  {%- endcomment -%}
  {%- if settings.kt_show_breadcrumbs -%}
    {%- render 'breadcrumbs', class_extra: 'kt-breadcrumbs-wrap' -%}
  {%- endif -%}

  {%- comment -%} Sticky Control Bar — sort only {%- endcomment -%}
  <div class="kt-collection__controls" data-collection-controls>
    <div class="page-width">
      <div class="kt-collection__controls-inner">
        <p class="kt-collection__results-count">
          {{ 'kt.section.collection.showing' | t | default: 'Showing' }}
          {{ collection.products.size }}
          {{ 'kt.section.collection.of' | t | default: 'of' }}
          {{ collection.products_count }}
        </p>
        {%- comment -%}
          Sort is wrapped in its own GET form so it works with JS off
          (the select's change handler is a JS enhancement). Active
          filter values are echoed as hidden inputs so picking a new
          sort order doesn't drop the shopper's current filters.
        {%- endcomment -%}
        <form action="{{ collection.url }}" method="get" class="kt-collection__sort" data-collection-sort-form>
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          {%- for filter in collection.filters -%}
            {%- for active_value in filter.active_values -%}
              <input type="hidden" name="{{ active_value.param_name }}" value="{{ active_value.value | escape }}">
            {%- endfor -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank -%}
                <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">
              {%- endif -%}
              {%- if filter.max_value.value != blank -%}
                <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <label for="SortBy-{{ section.id }}" class="kt-collection__sort-label">{{ 'kt.section.collection.sort_by' | t | default: 'Sort by' }}</label>
          <select id="SortBy-{{ section.id }}" name="sort_by" class="kt-collection__sort-select" data-collection-sort>
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
          <noscript>
            <button type="submit" class="kt-collection__sort-apply button">
              {{ 'kt.section.collection.apply' | t | default: 'Apply' }}
            </button>
          </noscript>
        </form>
      </div>

      {%- assign active_filters_count = 0 -%}
      {%- for filter in collection.filters -%}
        {%- assign active_filters_count = active_filters_count | plus: filter.active_values.size -%}
      {%- endfor -%}
      {%- if active_filters_count > 0 -%}
        <div class="kt-collection__active-filters">
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              <a
                href="{{ value.url_to_remove }}"
                class="kt-collection__active-filter"
                aria-label="{{ 'kt.section.collection.remove_filter' | t: filter: value.label }}"
              >
                {{ value.label | escape }}
                {% render 'icon-close', width: 12, height: 12 %}
              </a>
            {%- endfor -%}
          {%- endfor -%}
          <a href="{{ collection.url }}" class="kt-collection__clear-all">{{ 'kt.section.collection.clear_all' | t | default: 'Clear all' }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Sidebar + Grid layout {%- endcomment -%}
  <div class="page-width">
    <div class="kt-collection__vertical-layout">

      {%- comment -%}
        R105 — `aside` becomes a "complementary" landmark in the AT
        tree. Without an accessible name, screen readers announce it
        as bare "complementary" and AT users with multiple <aside>
        regions can't distinguish them. aria-labelledby points to
        the inner h2 so the SR announces "Filter, complementary".
      {%- endcomment -%}
      <aside class="kt-filter-sidebar" aria-labelledby="FilterSidebarTitle">
        <h2 id="FilterSidebarTitle" class="kt-filter-sidebar__title">{{ 'kt.section.collection.filter' | t | default: 'Filter' }}</h2>
        {%- render 'collection-filters', collection: collection -%}
      </aside>

      {%- comment -%} Right — Product Grid {%- endcomment -%}
      <div class="kt-collection__vertical-grid-wrap">
        {%- paginate collection.products by section.settings.products_per_page -%}
          {%- if collection.products.size > 0 -%}
            <div class="kt-collection__grid kt-collection__grid--cols-{{ vert_cols_d }} kt-collection__grid--cols-m-{{ vert_cols_m }}" id="product-grid-{{ section.id }}" data-product-grid role="list" aria-busy="false">
              {%- for product in collection.products -%}
                {%- render 'card-product', product: product, show_vendor: settings.kt_pdp_show_vendor, show_secondary_image: section.settings.show_secondary_image, show_quote_button: section.settings.show_quote_button, index: forloop.index0 -%}
              {%- endfor -%}
            </div>
            {%- if paginate.pages > 1 -%}
              <div class="kt-collection__pagination">
                {%- render 'pagination', paginate: paginate -%}
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="kt-collection__empty">
              <h2 class="kt-collection__empty-title">{{ 'kt.section.collection.no_products' | t | default: 'No products found' }}</h2>
              <p class="kt-collection__empty-text">{{ 'kt.section.collection.no_products_desc' | t }}</p>
              {%- if active_filters_count > 0 -%}
                <a href="{{ collection.url }}" class="kt-collection__clear-all">
                  {{ 'kt.section.collection.clear_all' | t | default: 'Clear all filters' }}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>

  {% comment %} App block slot — see main-collection.liquid for rationale. {% endcomment %}
  {% render 'section-app-blocks' %}
</div>

<script src="{{ 'kt-section-main-collection.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'collection-filters.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-collection-vertical.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 12,
      "label": "t:sections.main-collection-vertical.settings.products_per_page.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-vertical.settings.header__grid.content"
    },
    {
      "type": "select",
      "id": "cols_desktop",
      "label": "t:sections.main-collection-vertical.settings.cols_desktop.label",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "cols_mobile",
      "label": "t:sections.main-collection-vertical.settings.cols_mobile.label",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.main-collection-vertical.settings.show_secondary_image.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quote_button",
      "label": "t:sections.main-collection-vertical.settings.show_quote_button.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-vertical.settings.header__hero.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "t:sections.main-collection-vertical.settings.show_collection_description.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-vertical.settings.header__spacing.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "t:sections.main-collection-vertical.settings.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px",
      "label": "t:sections.main-collection-vertical.settings.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-vertical.settings.header__color.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.main-collection-vertical.settings.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
