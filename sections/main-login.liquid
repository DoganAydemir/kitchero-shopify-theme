{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}

<section class="kt-customer" data-section-id="{{ section.id }}">
  <div class="kt-customer__container">
    <h1 class="kt-customer__title">{{ 'kt.customer.login.title' | t }}</h1>

    {%- comment -%} Login Form {%- endcomment -%}
    {%- form 'customer_login', id: 'CustomerLoginForm' -%}
      {%- comment -%}
        Preserve the redirect target across the login POST. Shopify's
        customer_login form reads `checkout_url` (prioritized) or
        `return_to` as hidden inputs and redirects there on success.
        Without these, every successful login lands on /account —
        breaking the "click Sign in while shopping → return to the
        previous page" flow and the checkout-gated-login flow.
      {%- endcomment -%}
      {%- comment -%}
        theme-check complains about UndefinedObject for `checkout_url`
        and `return_to` because its static analyser doesn't know these
        are context-injected Liquid variables Shopify populates on
        /account/login when the customer arrives via a checkout
        redirect or a ?return_to=… query param. Suppress the noise
        only for this block — they ARE defined at runtime on this
        specific template. See Shopify docs: "Redirect users to a
        new page after they login".
      {%- endcomment -%}
      {% # theme-check-disable UndefinedObject %}
      {%- if checkout_url != blank -%}
        <input type="hidden" name="checkout_url" value="{{ checkout_url | escape }}">
      {%- elsif return_to != blank -%}
        <input type="hidden" name="return_to" value="{{ return_to | escape }}">
      {%- endif -%}
      {% # theme-check-enable UndefinedObject %}

      {%- if form.errors -%}
        <div class="kt-customer__errors" role="alert" tabindex="-1">
          <h2 class="kt-customer__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h2>
          <ul class="kt-customer__errors-list">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  <a href="#login-{{ field }}">
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="kt-customer__form">
        <div class="kt-customer__field">
          <label for="login-email" class="visually-hidden">{{ 'kt.customer.login.email' | t }}</label>
          <input
            type="email"
            id="login-email"
            name="customer[email]"
            class="kt-customer__input"
            placeholder="{{ 'kt.customer.login.email' | t }}"
            required
            autocomplete="email"
            {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="login-email-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'login-email-error' -%}
        </div>
        <div class="kt-customer__field">
          <label for="login-password" class="visually-hidden">{{ 'kt.customer.login.password' | t }}</label>
          <input
            type="password"
            id="login-password"
            name="customer[password]"
            class="kt-customer__input"
            placeholder="{{ 'kt.customer.login.password' | t }}"
            required
            autocomplete="current-password"
            {% if form.errors contains 'password' %}aria-invalid="true" aria-describedby="login-password-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'password', describedby_id: 'login-password-error' -%}
        </div>
        <button type="submit" class="kt-customer__submit">{{ 'kt.customer.login.sign_in' | t }}</button>

        <button type="button" class="kt-customer__forgot-link" data-toggle-forgot aria-expanded="false">
          {{ 'kt.customer.login.forgot_password' | t }}
        </button>

        <div class="kt-customer__alt">
          {{ 'kt.customer.login.guest_title' | t | default: 'New customer?' }}
          <a href="{{ routes.account_register_url }}">{{ 'kt.customer.register.title' | t }}</a>
        </div>
      </div>
    {%- endform -%}

    {%- comment -%} Forgot Password Modal {%- endcomment -%}
    <div class="kt-customer__modal" id="forgot-modal" aria-hidden="true">
      <div class="kt-customer__modal-overlay" data-close-forgot></div>
      <div class="kt-customer__modal-panel" role="dialog" aria-modal="true" aria-labelledby="forgot-modal-title">
        <button type="button" class="kt-customer__modal-close" data-close-forgot aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <h2 id="forgot-modal-title" class="kt-customer__modal-title">{{ 'kt.customer.login.reset_password' | t }}</h2>
        <p class="kt-customer__modal-desc">{{ 'kt.customer.login.reset_desc' | t | default: 'We will send you an email to reset your password.' }}</p>
        {%- form 'recover_customer_password', id: 'RecoverPasswordForm' -%}
          {%- if form.posted_successfully? -%}
            <p class="kt-customer__form-success" role="status">
              {{ 'kt.customer.login.reset_sent' | t | default: 'We’ve sent you an email with a link to update your password.' }}
            </p>
          {%- elsif form.errors -%}
            <div class="kt-customer__errors" role="alert" tabindex="-1">
              <ul class="kt-customer__errors-list">
                {%- for field in form.errors -%}
                  <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
          <div class="kt-customer__field">
            <label for="forgot-email" class="visually-hidden">{{ 'kt.customer.login.email' | t }}</label>
            <input
              type="email"
              id="forgot-email"
              name="email"
              class="kt-customer__input"
              placeholder="{{ 'kt.customer.login.email' | t }}"
              required
              autocomplete="email"
              {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="forgot-email-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'forgot-email-error' -%}
          </div>
          <button type="submit" class="kt-customer__submit">{{ 'kt.customer.login.reset_password' | t }}</button>
          <button type="button" class="kt-customer__cancel" data-close-forgot>{{ 'kt.customer.login.cancel' | t }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'customer-forms.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "tag": "section",
  "class": "section"
}
{% endschema %}
