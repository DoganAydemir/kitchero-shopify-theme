{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}

<section class="kt-customer" data-section-id="{{ section.id }}" data-section-type="main-login">
  <div class="kt-customer__container">
    <h1 class="kt-customer__title">{{ 'kt.customer.login.title' | t }}</h1>

    {%- comment -%} Login Form {%- endcomment -%}
    {%- form 'customer_login', id: 'CustomerLoginForm' -%}
      {%- comment -%}
        Preserve the redirect target across the login POST. Shopify's
        customer_login form reads `checkout_url` (prioritized) or
        `return_to` as hidden inputs and redirects there on success.
        Without these, every successful login lands on /account —
        breaking the "click Sign in while shopping → return to the
        previous page" flow and the checkout-gated-login flow.
      {%- endcomment -%}
      {%- comment -%}
        theme-check complains about UndefinedObject for `checkout_url`
        and `return_to` because its static analyser doesn't know these
        are context-injected Liquid variables Shopify populates on
        /account/login when the customer arrives via a checkout
        redirect or a ?return_to=… query param. Suppress the noise
        only for this block — they ARE defined at runtime on this
        specific template. See Shopify docs: "Redirect users to a
        new page after they login".
      {%- endcomment -%}
      {% # theme-check-disable UndefinedObject %}
      {%- if checkout_url != blank -%}
        <input type="hidden" name="checkout_url" value="{{ checkout_url | escape }}">
      {%- elsif return_to != blank -%}
        <input type="hidden" name="return_to" value="{{ return_to | escape }}">
      {%- endif -%}
      {% # theme-check-enable UndefinedObject %}

      {%- if form.errors -%}
        {%- comment -%}
          `role="alert"` is scoped to the dynamic UL, not the outer
          container. Previously the whole block (heading + list)
          carried the role, so NVDA/JAWS announced the heading AND
          every list item as one long run-on string on submit. Moving
          the live region to the UL lets the heading read normally
          through focus/Tab flow and only the error list triggers
          the alert announcement. The outer div keeps tabindex="-1"
          so the form-error-focus helper in global.js can still
          programmatically move focus to the summary on server-render
          failure.
        {%- endcomment -%}
        <div class="kt-customer__errors" data-form-error-summary tabindex="-1">
          <h2 class="kt-customer__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h2>
          <ul class="kt-customer__errors-list" role="alert">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.translated_messages[field] }}
                {%- else -%}
                  <a href="#login-{{ field }}">
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="kt-customer__form">
        <div class="kt-customer__field">
          {%- comment -%}
            Visible label (not visually-hidden) per WCAG 2.5.3 Label
            in Name + WCAG 3.3.2 Labels or Instructions. Low-vision
            users and cognitive-disability users who rely on the
            label persisting during typing were previously left with
            only the placeholder, which disappears the moment they
            start entering an address and blanks the field's purpose.
            Placeholder is retained alongside the label as an example
            hint, per current a11y best practice.
          {%- endcomment -%}
          <label for="login-email" class="kt-customer__label kt-form__label--required">{{ 'kt.customer.login.email' | t }}</label>
          {%- comment -%}
            `value="..."` preserves the typed email on server-side
            validation failure. Shopify redirects back to the page
            with `form.email` populated; without the explicit value
            binding the input renders empty and the user has to
            retype. Password field stays empty for security.
          {%- endcomment -%}
          <input
            type="email"
            id="login-email"
            name="customer[email]"
            class="kt-customer__input"
            placeholder="{{ 'kt.customer.login.email' | t }}"
            value="{{ form.email | escape }}"
            required
            aria-required="true"
            inputmode="email"
            {%- comment -%}
              R104 — Return key advances to password field on mobile.
            {%- endcomment -%}
            enterkeyhint="next"
            autocomplete="email"
            {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="login-email-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'login-email-error' -%}
        </div>
        <div class="kt-customer__field">
          <label for="login-password" class="kt-customer__label kt-form__label--required">{{ 'kt.customer.login.password' | t }}</label>
          <input
            type="password"
            id="login-password"
            name="customer[password]"
            class="kt-customer__input"
            placeholder="{{ 'kt.customer.login.password' | t }}"
            required
            aria-required="true"
            {%- comment -%}
              R104 — Return key fires Sign in.
            {%- endcomment -%}
            enterkeyhint="go"
            autocomplete="current-password"
            {% if form.errors contains 'password' %}aria-invalid="true" aria-describedby="login-password-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'password', describedby_id: 'login-password-error' -%}
        </div>
        <button type="submit" class="kt-customer__submit">{{ 'kt.customer.login.sign_in' | t }}</button>

        {%- comment -%}
          The forgot-password trigger opens a modal dialog (#forgot-modal,
          role="dialog" aria-modal="true"), not an inline disclosure.
          aria-expanded is reserved for inline collapsible widgets where
          the controlled region remains in the natural reading flow;
          modals require aria-haspopup="dialog" + aria-controls so the
          screen reader announces the dialog relationship correctly.
          Pattern matches header.liquid search overlay trigger which
          uses the same aria-haspopup="dialog" + aria-controls combo.
        {%- endcomment -%}
        <button type="button" class="kt-customer__forgot-link" data-toggle-forgot aria-haspopup="dialog" aria-controls="forgot-modal">
          {{ 'kt.customer.login.forgot_password' | t }}
        </button>

        <div class="kt-customer__alt">
          {{ 'kt.customer.login.guest_title' | t | default: 'New customer?' }}
          <a href="{{ routes.account_register_url }}">{{ 'kt.customer.register.title' | t }}</a>
        </div>
      </div>
    {%- endform -%}

    {%- comment -%}
      Forgot Password — rendered as a modal for JS-enabled visitors
      (bindModal in customer-forms.js sets aria-hidden="true" on
      init; the toggle button flips it to false). For no-JS
      visitors the `html:not(.js) .kt-customer__modal` CSS rule
      flips it to a plain inline section and hides the toggle
      button. NOT emitting `aria-hidden="true"` in markup: JS users
      get it set by the script before paint (inline no-js→js swap
      runs first, but aria-hidden init happens at bindModal); no-JS
      users never get it applied, so SR correctly reads the form.
    {%- endcomment -%}
    <div class="kt-customer__modal" id="forgot-modal">
      <div class="kt-customer__modal-overlay" data-close-forgot></div>
      <div class="kt-customer__modal-panel" role="dialog" aria-modal="true" aria-labelledby="forgot-modal-title" tabindex="-1">
        <button type="button" class="kt-customer__modal-close" data-close-forgot aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <h2 id="forgot-modal-title" class="kt-customer__modal-title">{{ 'kt.customer.login.reset_password' | t }}</h2>
        <p class="kt-customer__modal-desc">{{ 'kt.customer.login.reset_desc' | t | default: 'We will send you an email to reset your password.' }}</p>
        {%- form 'recover_customer_password', id: 'RecoverPasswordForm' -%}
          {%- if form.posted_successfully? -%}
            <p class="kt-customer__form-success" role="status">
              {{ 'kt.customer.login.reset_sent' | t | default: 'We’ve sent you an email with a link to update your password.' }}
            </p>
          {%- elsif form.errors -%}
            <div class="kt-customer__errors" role="alert" tabindex="-1">
              <ul class="kt-customer__errors-list">
                {%- for field in form.errors -%}
                  <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
          <div class="kt-customer__field">
            <label for="forgot-email" class="visually-hidden">{{ 'kt.customer.login.email' | t }}</label>
            <input
              type="email"
              id="forgot-email"
              name="email"
              class="kt-customer__input"
              placeholder="{{ 'kt.customer.login.email' | t }}"
              required
              aria-required="true"
              inputmode="email"
              autocomplete="email"
              {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="forgot-email-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'forgot-email-error' -%}
          </div>
          <button type="submit" class="kt-customer__submit">{{ 'kt.customer.login.reset_password' | t }}</button>
          <button type="button" class="kt-customer__cancel" data-close-forgot>{{ 'kt.customer.login.cancel' | t }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'customer-forms.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/login"]
  }
}
{% endschema %}
