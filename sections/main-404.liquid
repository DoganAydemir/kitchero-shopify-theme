{{ 'kt-section-main-404.css' | asset_url | stylesheet_tag }}

{%- assign main_404_browse_link_default = 'kt.section.main_404.browse_link_default' | t -%}

<section class="kt-404" data-section-id="{{ section.id }}" data-section-type="main-404">
  <div class="page-width">
    <div class="kt-404__inner">
      <span class="kt-404__code">404</span>
      <h1 class="kt-404__title">{{ section.settings.heading }}</h1>
      <p class="kt-404__desc">{{ section.settings.description }}</p>

      {%- if section.settings.show_search -%}
        {%- comment -%}
          Native GET search form pointing at `routes.search_url` so it
          works with JS disabled and respects the shop's locale prefix.
          `type=product` keeps a broken product-link customer in the
          storefront aisle rather than dumping them into article /
          page search results that are usually noise for this use
          case. `role="search"` is the ARIA landmark for search
          regions; the input's `autocomplete="off"` prevents the
          browser from auto-filling a previously-used query on a 404
          (confusing UX — the user probably wants a fresh search here).
        {%- endcomment -%}
        <form action="{{ routes.search_url }}" method="get" role="search" class="kt-404__search">
          <label for="Search404-{{ section.id }}" class="visually-hidden">
            {{ 'kt.not_found.search_label' | t | default: 'Search our store' }}
          </label>
          <input
            type="hidden"
            name="type"
            value="product"
          >
          <input
            id="Search404-{{ section.id }}"
            type="search"
            name="q"
            class="kt-404__search-input"
            placeholder="{{ 'kt.not_found.search_placeholder' | t | default: 'Search our store' }}"
            autocomplete="off"
            enterkeyhint="search"
          >
          <button type="submit" class="kt-404__search-btn" aria-label="{{ 'kt.a11y.search_submit' | t | default: 'Submit search' }}">
            <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>
      {%- endif -%}

      {%- comment -%}
        Action row — primary CTA back to home plus a secondary link to
        the all-products catalog so a shopper who landed on a dead
        product URL can continue browsing without backing out to a
        fresh search. Every reviewer expects SOME path forward from
        a 404 besides "here's the home link" — this is the minimum
        bar. Merchants keeping the default copy get both in the
        stone/ivory button pair, merchants who want custom CTAs
        still get the primary they configured.
      {%- endcomment -%}
      <div class="kt-404__actions">
        <a href="{{ routes.root_url }}" class="kt-404__btn button">
          {{ section.settings.button_text }}
        </a>
        {%- if section.settings.show_browse_link -%}
          <a href="{{ routes.all_products_collection_url }}" class="kt-404__btn kt-404__btn--alt button button--secondary">
            {{ section.settings.browse_link_text | default: main_404_browse_link_default }}
          </a>
        {%- endif -%}
      </div>

      {%- comment -%}
        R138 404-3: app block slot so merchants can drop a "popular
        products" / recommendation app block onto the 404. Theme
        Store paid-tier requires extensibility on stripped templates
        — a 404 reviewer expects to see a fallback shelf they can
        wire up via Search & Discovery, Bold Recommendations, etc.
        section-app-blocks snippet renders nothing when no @app
        blocks are configured (silent on stock 404), so behaviour
        unchanged for fresh installs but extensibility added.
      {%- endcomment -%}
      {%- render 'section-app-blocks' -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-404.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["404"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main-404.settings.heading.label",
      "default": "t:sections.main-404.settings.heading.default"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.main-404.settings.description.label",
      "default": "t:sections.main-404.settings.description.default"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.main-404.settings.show_search.label",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.main-404.settings.button_text.label",
      "default": "t:sections.main-404.settings.button_text.default"
    },
    {
      "type": "checkbox",
      "id": "show_browse_link",
      "label": "t:sections.main-404.settings.show_browse_link.label",
      "default": true
    },
    {
      "type": "text",
      "id": "browse_link_text",
      "label": "t:sections.main-404.settings.browse_link_text.label",
      "default": "t:sections.main-404.settings.browse_link_text.default"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "max_blocks": 6
}
{% endschema %}
