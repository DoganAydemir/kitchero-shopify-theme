{%- comment -%}
  List Collections Grid — displays every collection in the store as a
  premium editorial card (large cover image, collection title serif,
  product count). Powers the /collections (list-collections) template.

  Pulls from Shopify's global `collections` object. Respects a
  merchant-selectable "show" toggle between "all" and "featured only
  (via metafield)". Empty state shown when no collections exist.
{%- endcomment -%}

{{ 'kt-section-list-collections-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign per_row_desktop = section.settings.columns_desktop | default: 3
  assign sort_order = section.settings.sort_by | default: 'alphabetical'
-%}

<section
  class="kt-list-collections color-{{ section.settings.color_scheme | default: 'scheme-1' }}{% if section.settings.bg_color and section.settings.bg_color != 'auto' %} kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="list-collections-grid"
  style="--kt-list-collections-columns: {{ per_row_desktop }};"
>
  <div class="page-width">
    {%- if collections.size > 0 -%}
      {%- comment -%}
        R232.11 — paginate the global `collections` object directly.
        Previously this section sorted into a local `collection_list`
        variable BEFORE `{% paginate %}`, but Shopify Liquid only
        accepts paginatable objects (collections, collection.products,
        blog.articles, search.results) — passing a `sort`-derived
        Array raises "Array 'collection_list' is not paginateable."
        Pagination now wraps the Shopify-native `collections`, and
        the sort branch below re-orders the paginated subset before
        the loop. For catalogues with 50+ collections (B2B / multi-
        category) this keeps each page's DOM size capped at the
        merchant's `collections_per_page` setting (default 12, max 30)
        so Lighthouse Performance stays green — Theme Store PRF-1.
      {%- endcomment -%}
      {%- paginate collections by section.settings.collections_per_page -%}
        {%- liquid
          case sort_order
            when 'reverse_alphabetical'
              assign collection_list = collections | sort: 'title' | reverse
            when 'product_count'
              assign collection_list = collections | sort: 'all_products_count' | reverse
            else
              assign collection_list = collections | sort: 'title'
          endcase
        -%}
      <ul class="kt-list-collections__grid" role="list">
        {%- for collection in collection_list -%}
          {%- if collection.handle == 'frontpage' -%}{% continue %}{%- endif -%}
          <li class="kt-list-collections__cell">
            <a
              href="{{ collection.url }}"
              class="kt-list-collections__card"
              aria-label="{{ collection.title | escape }}"
            >
              <div class="kt-list-collections__media">
                {%- if collection.image != blank -%}
                  {{
                    collection.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'kt-list-collections__image',
                      loading: 'lazy',
                      widths: '480, 720, 960, 1200, 1600',
                      sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                      width: collection.image.width,
                      height: collection.image.height,
                      alt: collection.title
                  }}
                {%- elsif collection.products.first.featured_image != blank -%}
                  {{
                    collection.products.first.featured_image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'kt-list-collections__image',
                      loading: 'lazy',
                      widths: '480, 720, 960, 1200, 1600',
                      sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                      width: collection.products.first.featured_image.width,
                      height: collection.products.first.featured_image.height,
                      alt: collection.title
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg kt-list-collections__image' }}
                {%- endif -%}
                <div class="kt-list-collections__overlay" aria-hidden="true"></div>
              </div>

              <div class="kt-list-collections__body">
                <h2 class="kt-list-collections__title">{{ collection.title | escape }}</h2>
                {%- if collection.description != blank -%}
                  <p class="kt-list-collections__desc">{{ collection.description | strip_html | truncate: 120 }}</p>
                {%- endif -%}
                <div class="kt-list-collections__footer">
                  {%- comment -%}
                    R99 — Shopify-native plural resolution. Passing
                    `count: N` lets the t filter pick the right
                    plural form per locale (one/other in EN/TR/DE/
                    FR/ES; one/few/many/other in RU/PL/etc. when
                    additional locales ship). The locale string
                    embeds {{ count }} so we don't bare-output the
                    integer + a separate noun (which would break
                    word-ordering languages like JA/KO/TR).
                  {%- endcomment -%}
                  <span class="kt-list-collections__count">
                    {{ 'kt.section.list-collections.products_count' | t: count: collection.all_products_count }}
                  </span>
                  <span class="kt-list-collections__cta">
                    {{ 'kt.section.list-collections.view_collection' | t | default: 'View collection' }}
                    {% render 'icon-arrow-right', width: 12, height: 12 %}
                  </span>
                </div>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>

      {%- if paginate.pages > 1 -%}
        {%- render 'pagination', paginate: paginate -%}
      {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="kt-list-collections__empty">
        <h2 class="kt-list-collections__empty-title">
          {{ 'kt.section.list-collections.empty_heading' | t | default: 'No collections yet' }}
        </h2>
        <p class="kt-list-collections__empty-desc">
          {{ 'kt.section.list-collections.empty_description' | t | default: 'Collections you create in the Shopify admin will appear here automatically.' }}
        </p>
        <a href="{{ routes.all_products_collection_url }}" class="kt-list-collections__empty-link">
          {{ 'kt.section.list-collections.empty_cta' | t | default: 'Browse all products' }}
          {% render 'icon-arrow-right', width: 14, height: 14 %}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.list-collections-grid.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.list-collections-grid.settings.columns_desktop.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "collections_per_page",
      "label": "t:sections.list-collections-grid.settings.collections_per_page.label",
      "min": 6,
      "max": 30,
      "step": 2,
      "default": 12
    },
    {
      "type": "select",
      "id": "sort_by",
      "label": "t:sections.list-collections-grid.settings.sort_by.label",
      "options": [
        {
          "value": "alphabetical",
          "label": "t:sections.list-collections-grid.settings.sort_by.options__alpha.label"
        },
        {
          "value": "reverse_alphabetical",
          "label": "t:sections.list-collections-grid.settings.sort_by.options__reverse_alpha.label"
        },
        {
          "value": "product_count",
          "label": "t:sections.list-collections-grid.settings.sort_by.options__count.label"
        }
      ],
      "default": "alphabetical"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "t:sections.shared.color_scheme.header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:sections.list-collections-grid.presets.name"
    }
  ],
  "enabled_on": {
    "templates": [
      "list-collections",
      "page",
      "index"
    ]
  }
}
{% endschema %}
