{{ 'kt-section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Multicolumn — N-column layout with image / icon + text + link
  per column. Theme Store baseline (3-of-3 reference theme intake).

  Common use cases:
    - Feature highlights (icon + label + 1-line description × 3-4)
    - Service tiers (image + heading + description + CTA × 3)
    - Brand pillars / values (icon + heading + paragraph × 3-4)

  Block-driven so merchants can mix column count + content. Each
  block is one column; max_blocks 6 keeps the editor responsive.
{%- endcomment -%}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop | default: 3
  assign columns_mobile = section.settings.columns_mobile | default: 1
  assign image_ratio = section.settings.image_ratio | default: 'adapt'
  assign image_shape = section.settings.image_shape | default: 'square'
  assign content_alignment = section.settings.content_alignment | default: 'center'
  assign heading_tag = section.settings.heading_tag | default: 'h2'
-%}

<section
  class="kt-multicolumn color-{{ section.settings.color_scheme | default: 'scheme-1' }} kt-multicolumn--align-{{ content_alignment }} kt-multicolumn--shape-{{ image_shape }} {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="multicolumn"
  style="--kt-mc-cols-desktop: {{ columns_desktop }}; --kt-mc-cols-mobile: {{ columns_mobile }}; --kt-section-padding-top: {{ section.settings.padding_top }}px; --kt-section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  {% if section.settings.heading != blank %}aria-labelledby="MulticolumnHeading-{{ section.id }}"{% endif %}
>
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="kt-multicolumn__header">
        {%- if section.settings.subheading != blank -%}
          <p class="kt-multicolumn__eyebrow">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }}
            id="MulticolumnHeading-{{ section.id }}"
            class="kt-multicolumn__title"
          >
            {{- section.settings.heading | escape -}}
          </{{ heading_tag }}>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size == 0 and request.design_mode -%}
      <p class="kt-multicolumn__editor-hint">
        {{ 'kt.section.multicolumn.editor_hint' | t | default: 'Add a column block to populate this layout.' }}
      </p>
    {%- else -%}
      <ul class="kt-multicolumn__grid" role="list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'column' -%}
              <li class="kt-multicolumn__column" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    case image_ratio
                      when 'square'
                        assign ratio_value = '1 / 1'
                      when 'portrait'
                        assign ratio_value = '3 / 4'
                      when 'landscape'
                        assign ratio_value = '4 / 3'
                      else
                        assign ratio_value = block.settings.image.aspect_ratio | default: '1' | append: ' / 1'
                    endcase
                  -%}
                  <div class="kt-multicolumn__media" style="aspect-ratio: {{ ratio_value }};">
                    {{ block.settings.image | image_url: width: 1000 | image_tag:
                        loading: 'lazy',
                        widths: '375, 550, 750, 1000, 1500',
                        sizes: '(min-width: 750px) calc(100vw / var(--kt-mc-cols-desktop, 3)), 100vw',
                        width: block.settings.image.width,
                        height: block.settings.image.height,
                        class: 'kt-multicolumn__image',
                        alt: block.settings.image.alt | default: block.settings.heading | default: '' }}
                  </div>
                {%- elsif block.settings.icon_image != blank -%}
                  {%- comment -%}
                    R283c — Custom icon upload takes priority over
                    the preset select. Merchant uploads any SVG /
                    PNG / JPG; we render it as a constrained-size
                    image inside the icon slot. Shopify natively
                    accepts SVG uploads (sanitised) so brand-mark
                    glyphs go through without any extra plumbing.
                    Sized small (max 96px source, rendered ~3.5-
                    4rem via CSS) since the slot is an icon, not
                    a hero.
                  {%- endcomment -%}
                  <div class="kt-multicolumn__icon kt-multicolumn__icon--image" aria-hidden="true">
                    {{ block.settings.icon_image | image_url: width: 192 | image_tag:
                        loading: 'lazy',
                        widths: '96, 144, 192',
                        sizes: '96px',
                        width: 96,
                        height: 96,
                        class: 'kt-multicolumn__icon-image',
                        alt: '' }}
                  </div>
                {%- elsif block.settings.icon != blank and block.settings.icon != 'none' -%}
                  {%- comment -%}
                    R283c — Preset icon library. Mirrors the
                    pattern in why-choose-us-product.liquid (line-
                    icon SVG case statement keyed on a `select`
                    block setting). Twelve options cover the
                    common "Why us / Benefits" copy for kitchen /
                    cabinet brands: trust signals (shield, award),
                    delivery (truck, clock), craft (ruler, zap),
                    emotional (heart, gift, leaf), and three
                    decorative (star, sparkle, check). Stroke
                    width 1.5 matches the established theme line-
                    icon weight. `currentColor` lets the icon
                    inherit the column's text colour so it
                    re-tints under scheme swaps.
                  {%- endcomment -%}
                  <div class="kt-multicolumn__icon" aria-hidden="true">
                    {%- case block.settings.icon -%}
                      {%- when 'star' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- when 'sparkle' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.7 6.3L20 11l-6.3 1.7L12 19l-1.7-6.3L4 11l6.3-1.7L12 3z"/></svg>
                      {%- when 'check' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
                      {%- when 'shield' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                      {%- when 'truck' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      {%- when 'clock' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {%- when 'award' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                      {%- when 'heart' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                      {%- when 'leaf' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3 -2 14.94 -8.2 17.04Z"/><path d="M2 21c0 -3 1.85 -5.36 5.08 -6"/></svg>
                      {%- when 'gift' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                      {%- when 'ruler' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 8.7 8.7 21.3a2.4 2.4 0 0 1 -3.4 0L2.7 18.7a2.4 2.4 0 0 1 0 -3.4L15.3 2.7a2.4 2.4 0 0 1 3.4 0l2.6 2.6a2.4 2.4 0 0 1 0 3.4Z"/><path d="m7.5 10.5 2 2"/><path d="m10.5 7.5 2 2"/><path d="m13.5 4.5 2 2"/><path d="m4.5 13.5 2 2"/></svg>
                      {%- when 'zap' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    {%- endcase -%}
                  </div>
                {%- else -%}
                  {%- comment -%}
                    Empty-state placeholder rule: when the
                    merchant hasn't picked an image AND hasn't filled
                    in an icon character, fall through to Shopify's
                    SVG placeholder so the column never ships as a
                    blank media slot. Mirrors the placeholder pattern
                    used elsewhere in the theme (rich-text variants,
                    multicolumn-with-image, banner sections).
                  {%- endcomment -%}
                  {%- liquid
                    case image_ratio
                      when 'square'
                        assign ratio_value = '1 / 1'
                      when 'portrait'
                        assign ratio_value = '3 / 4'
                      when 'landscape'
                        assign ratio_value = '4 / 3'
                      else
                        assign ratio_value = '1 / 1'
                    endcase
                  -%}
                  <div class="kt-multicolumn__media" style="aspect-ratio: {{ ratio_value }};">
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg kt-multicolumn__image' }}
                  </div>
                {%- endif -%}

                <div class="kt-multicolumn__text">
                  {%- if block.settings.heading != blank -%}
                    {%- assign block_heading_tag = block.settings.heading_tag | default: 'h3' -%}
                    <{{ block_heading_tag }} class="kt-multicolumn__column-heading">
                      {{- block.settings.heading | escape -}}
                    </{{ block_heading_tag }}>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="kt-multicolumn__column-text rte">
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                  {%- comment -%}
                    R284 — CTA rendering policy.

                    Previous (R162) approach: only render the link
                    when BOTH label AND url were supplied; missing
                    url surfaced an editor-only hint paragraph
                    ("Add a link URL to enable this CTA.") in
                    place of the styled link. Reporter pointed
                    out the hint clutters every empty-URL column
                    and breaks the visual rhythm — they prefer to
                    see the actual link element so they can
                    evaluate spacing / alignment / centring in the
                    editor.

                    New behaviour: render the styled link as soon
                    as the merchant supplies a `link_label`. When
                    `link_url` is blank, fall back to `href="#"` —
                    user explicitly opted in ("ya # olur ya da
                    boş bırakırsın"). On the live storefront an
                    empty-URL column with the # fallback scrolls
                    to top; merchant is expected to fill the URL
                    before publishing. Theme Store reviewers do
                    occasionally flag `href="#"` placeholders,
                    but the merchant-facing trade-off (clear
                    visual feedback in the editor) is acceptable
                    per direct request.
                  {%- endcomment -%}
                  {%- if block.settings.link_label != blank -%}
                    <a
                      href="{{ block.settings.link_url | default: '#' | escape }}"
                      class="kt-multicolumn__column-link"
                    >
                      {{- block.settings.link_label | escape -}}
                      {% render 'icon-arrow-right', width: 14, height: 14, stroke_width: 1.8 %}
                    </a>
                  {%- endif -%}
                </div>
              </li>

            {%- when '@app' -%}
              <li class="kt-multicolumn__column kt-multicolumn__column--app" {{ block.shopify_attributes }}>
                {%- render block -%}
              </li>
          {%- endcase -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ],
    "templates": [
      "password"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.multicolumn.settings.subheading.label",
      "info": "t:sections.multicolumn.settings.subheading.info",
      "default": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.multicolumn.settings.heading.label",
      "default": "Why choose us"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.multicolumn.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header__layout.content"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "t:sections.multicolumn.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.multicolumn.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:sections.multicolumn.settings.content_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.multicolumn.settings.content_alignment.options__left.label"
        },
        {
          "value": "center",
          "label": "t:sections.multicolumn.settings.content_alignment.options__center.label"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header__media.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.multicolumn.settings.image_ratio.label",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__adapt.label"
        },
        {
          "value": "square",
          "label": "t:sections.multicolumn.settings.image_ratio.options__square.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.multicolumn.settings.image_ratio.options__portrait.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.multicolumn.settings.image_ratio.options__landscape.label"
        }
      ],
      "default": "square"
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "t:sections.multicolumn.settings.image_shape.label",
      "options": [
        {
          "value": "square",
          "label": "t:sections.multicolumn.settings.image_shape.options__square.label"
        },
        {
          "value": "rounded",
          "label": "t:sections.multicolumn.settings.image_shape.options__rounded.label"
        },
        {
          "value": "circle",
          "label": "t:sections.multicolumn.settings.image_shape.options__circle.label"
        }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header__appearance.content"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.multicolumn.settings.padding_top.label",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.multicolumn.settings.padding_bottom.label",
      "default": 64
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.multicolumn.blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.multicolumn.blocks.column.settings.image.label",
          "info": "t:sections.multicolumn.blocks.column.settings.image.info"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "t:sections.multicolumn.blocks.column.settings.icon_image.label",
          "info": "t:sections.multicolumn.blocks.column.settings.icon_image.info"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.multicolumn.blocks.column.settings.icon.label",
          "info": "t:sections.multicolumn.blocks.column.settings.icon.info",
          "options": [
            { "value": "none",    "label": "t:sections.multicolumn.blocks.column.settings.icon.options__none.label" },
            { "value": "star",    "label": "t:sections.multicolumn.blocks.column.settings.icon.options__star.label" },
            { "value": "sparkle", "label": "t:sections.multicolumn.blocks.column.settings.icon.options__sparkle.label" },
            { "value": "check",   "label": "t:sections.multicolumn.blocks.column.settings.icon.options__check.label" },
            { "value": "shield",  "label": "t:sections.multicolumn.blocks.column.settings.icon.options__shield.label" },
            { "value": "truck",   "label": "t:sections.multicolumn.blocks.column.settings.icon.options__truck.label" },
            { "value": "clock",   "label": "t:sections.multicolumn.blocks.column.settings.icon.options__clock.label" },
            { "value": "award",   "label": "t:sections.multicolumn.blocks.column.settings.icon.options__award.label" },
            { "value": "heart",   "label": "t:sections.multicolumn.blocks.column.settings.icon.options__heart.label" },
            { "value": "leaf",    "label": "t:sections.multicolumn.blocks.column.settings.icon.options__leaf.label" },
            { "value": "gift",    "label": "t:sections.multicolumn.blocks.column.settings.icon.options__gift.label" },
            { "value": "ruler",   "label": "t:sections.multicolumn.blocks.column.settings.icon.options__ruler.label" },
            { "value": "zap",     "label": "t:sections.multicolumn.blocks.column.settings.icon.options__zap.label" }
          ],
          "default": "sparkle"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.multicolumn.blocks.column.settings.heading.label",
          "default": "Column heading"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "t:sections.multicolumn.blocks.column.settings.heading_tag.label",
          "options": [
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            }
          ],
          "default": "h3"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.multicolumn.blocks.column.settings.text.label",
          "default": "<p>Use columns to highlight features, services, or brand pillars.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "t:sections.multicolumn.blocks.column.settings.link_label.label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "t:sections.multicolumn.blocks.column.settings.link_url.label"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.multicolumn.presets.name",
      "category": "t:sections.categories.text.label",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
