{{ 'section-home-financing.css' | asset_url | stylesheet_tag }}

<section class="kt-home-financing" data-section-id="{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    {{ section.settings.background_image | image_url: width: 1600 | image_tag: class: 'kt-home-financing__bg-image', loading: 'lazy', alt: '' }}
  {%- endif -%}
  <div class="kt-home-financing__gradient-overlay" aria-hidden="true"></div>

  <div class="page-width">
    <div class="kt-home-financing__content">
      {%- if section.settings.label != blank -%}
        <p class="kt-home-financing__label">{{ section.settings.label }}</p>
      {%- endif -%}
      <h2 class="kt-home-financing__title">{{ section.settings.heading | default: 'Design your dream today, pay over time' }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="kt-home-financing__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="kt-home-financing__partners">
          {%- for block in section.blocks -%}
            {%- if block.type == 'partner' -%}
              <div class="kt-home-financing__partner" {{ block.shopify_attributes }}>
                <h3 class="kt-home-financing__partner-name">{{ block.settings.name }}</h3>
                <p class="kt-home-financing__partner-desc">{{ block.settings.description }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="button kt-home-financing__cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Financing promo",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Flexible Ownership" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Design your dream today, pay over time" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Flexible financing options with our trusted partners. Get pre-approved in minutes." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Explore Financing Options" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "Financing partner",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "name", "label": "Partner name", "default": "Affirm" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Pay in 4 interest-free installments. No hidden fees." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Financing promo",
      "blocks": [
        { "type": "partner", "settings": { "name": "Affirm", "description": "Pay in 4 interest-free installments. No hidden fees, no impact on your credit score." } },
        { "type": "partner", "settings": { "name": "Bread Pay", "description": "Flexible monthly payments up to 60 months. Pre-qualify without affecting your credit." } }
      ]
    }
  ]
}
{% endschema %}
