{{ 'kt-section-home-financing.css' | asset_url | stylesheet_tag }}

<section class="kt-home-financing" data-section-id="{{ section.id }}">
  {%- comment -%} Background image (right half only) {%- endcomment -%}
  <div class="kt-home-financing__bg">
    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 1200 | image_tag: class: 'kt-home-financing__bg-image', loading: 'lazy', widths: '550, 750, 1100, 1500, 1780', sizes: '(min-width: 750px) 50vw, 100vw', width: section.settings.background_image.width, height: section.settings.background_image.height, alt: '' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg kt-home-financing__bg-image' }}
    {%- endif -%}
    <div class="kt-home-financing__bg-gradient" aria-hidden="true"></div>
  </div>

  <div class="page-width">
    <div class="kt-home-financing__content">
      {%- if section.settings.label != blank -%}
        <span class="kt-home-financing__label">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-home-financing__title">
        {{ section.settings.heading_line1 | default: 'kt.section.home_financing.heading_line1_default' | t }}
        <span class="kt-home-financing__title-sub">{{ section.settings.heading_line2 | default: 'kt.section.home_financing.heading_line2_default' | t }}</span>
      </{{ heading_tag }}>

      {%- if section.settings.description != blank -%}
        <p class="kt-home-financing__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="kt-home-financing__partners">
          {%- for block in section.blocks -%}
            {%- if block.type == 'partner' -%}
              <div class="kt-home-financing__partner" {{ block.shopify_attributes }}>
                {%- comment -%}
                  Partner card heading — promoted from h4 to h3 so it
                  sits properly under the section's h2 (home-financing
                  headline). Was jumping from h2 to h4 and tripping
                  Lighthouse heading-order.
                {%- endcomment -%}
                <h3 class="kt-home-financing__partner-header">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  {{ block.settings.name }}
                </h3>
                <p class="kt-home-financing__partner-desc">{{ block.settings.description }}</p>
                {%- if block.settings.badge != blank -%}
                  <div class="kt-home-financing__partner-badge">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    {{ block.settings.badge }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="kt-home-financing__cta-row">
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: routes.root_url | escape }}" class="kt-home-financing__cta">
            {{ section.settings.cta_text }}
            {% render 'icon-arrow-right' %}
          </a>
        {%- endif -%}

        {%- assign partner_blocks = section.blocks | where: 'type', 'partner' -%}
        {%- if partner_blocks.size > 0 -%}
          <div class="kt-home-financing__partner-logos" aria-hidden="true">
            {%- for block in partner_blocks -%}
              {%- if block.settings.logo_image != blank -%}
                {%- assign logo_width = block.settings.logo_image.width | times: 24 | divided_by: block.settings.logo_image.height -%}
                {{ block.settings.logo_image | image_url: height: 48 | image_tag: class: 'kt-home-financing__partner-logo-img', loading: 'lazy', width: logo_width, height: 24, alt: block.settings.name }}
              {%- else -%}
                <span>{{ block.settings.name }}</span>
              {%- endif -%}
              {%- unless forloop.last -%}
                <div class="kt-home-financing__partner-logos-divider"></div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.home-financing.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.home-financing.settings.label.label"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.home-financing.settings.heading_line1.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.home-financing.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.home-financing.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.home-financing.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.home-financing.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.home-financing.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.home-financing.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.home-financing.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.home-financing.settings.heading_line2.label"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.home-financing.settings.description.label"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.home-financing.settings.cta_text.label",
      "default": "Explore Financing Options"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.home-financing.settings.cta_link.label"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.home-financing.settings.background_image.label"
    }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "t:sections.home-financing.blocks.partner.name",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.home-financing.blocks.partner.settings.name.label",
          "default": "Lender name"
        },
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "t:sections.home-financing.blocks.partner.settings.logo_image.label"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.home-financing.blocks.partner.settings.description.label"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "t:sections.home-financing.blocks.partner.settings.badge.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.home-financing.presets.name",
      "category": "t:sections.categories.image.label",
      "blocks": [
        {
          "type": "partner",
          "settings": {
            "name": "Lender 1",
            "description": ""
          }
        },
        {
          "type": "partner",
          "settings": {
            "name": "Lender 2",
            "description": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
