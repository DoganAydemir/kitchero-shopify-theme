{{ 'section-home-financing.css' | asset_url | stylesheet_tag }}

<section class="kt-home-financing" data-section-id="{{ section.id }}">
  {%- comment -%} Background image (right half only) {%- endcomment -%}
  <div class="kt-home-financing__bg">
    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 1200 | image_tag: class: 'kt-home-financing__bg-image', loading: 'lazy', alt: '' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg kt-home-financing__bg-image' }}
    {%- endif -%}
    <div class="kt-home-financing__bg-gradient" aria-hidden="true"></div>
  </div>

  <div class="page-width">
    <div class="kt-home-financing__content">
      {%- if section.settings.label != blank -%}
        <span class="kt-home-financing__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <h2 class="kt-home-financing__title">
        {{ section.settings.heading_line1 | default: 'Design your dream today,' }}
        <span class="kt-home-financing__title-sub">{{ section.settings.heading_line2 | default: 'Pay over time.' }}</span>
      </h2>

      {%- if section.settings.description != blank -%}
        <p class="kt-home-financing__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="kt-home-financing__partners">
          {%- for block in section.blocks -%}
            {%- if block.type == 'partner' -%}
              <div class="kt-home-financing__partner" {{ block.shopify_attributes }}>
                <h4 class="kt-home-financing__partner-header">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  {{ block.settings.name }}
                </h4>
                <p class="kt-home-financing__partner-desc">{{ block.settings.description }}</p>
                {%- if block.settings.badge != blank -%}
                  <div class="kt-home-financing__partner-badge">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    {{ block.settings.badge }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="kt-home-financing__cta-row">
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="kt-home-financing__cta">
            {{ section.settings.cta_text }}
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        {%- endif -%}

        <div class="kt-home-financing__partner-logos" aria-hidden="true">
          <span>affirm</span>
          <div class="kt-home-financing__partner-logos-divider"></div>
          <span>bread pay&reg;</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Financing promo",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Flexible Ownership" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "Design your dream today," },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2 (italic)", "default": "Pay over time." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Experience Kitchero luxury now with transparent, predictable payment plans. Choose from leading partners like Affirm and Bread Pay." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Explore Financing Options" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "image_picker", "id": "background_image", "label": "Background image (right side)" }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "Financing partner",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "name", "label": "Partner name", "default": "Affirm" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Simple monthly payments without hidden fees or surprises. See if you qualify in seconds." },
        { "type": "text", "id": "badge", "label": "Badge text", "default": "0% APR Available" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Financing promo",
      "blocks": [
        { "type": "partner", "settings": { "name": "Affirm", "description": "Simple monthly payments without hidden fees or surprises. See if you qualify in seconds.", "badge": "0% APR Available" } },
        { "type": "partner", "settings": { "name": "Bread Pay\u00ae", "description": "Tailored financing solutions that work for your budget. Clear terms with no impact on credit score for pre-qualification.", "badge": "Fast Pre-approval" } }
      ]
    }
  ]
}
{% endschema %}
