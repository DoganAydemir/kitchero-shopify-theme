{{ 'kt-section-image-with-text-alternating.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Image with Text — Alternating Grid (Style 03)

  Multiple rows, each image/text pair. Rows alternate image-left / image-right
  via CSS :nth-child(even). Square imagery by default, selectable aspect ratio.
  No JavaScript — pure CSS responsive layout.
{%- endcomment -%}

{%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
{%- assign row_gap = section.settings.row_gap | default: 80 -%}
{%- assign image_aspect = section.settings.image_aspect | default: '1 / 1' -%}
{%- assign padding_top = section.settings.padding_top | default: 0 -%}
{%- assign padding_bottom = section.settings.padding_bottom | default: 0 -%}

{%- capture aspect_value -%}
  {%- case image_aspect -%}
    {%- when '4/5' -%}4 / 5
    {%- when '16/10' -%}16 / 10
    {%- else -%}1 / 1
  {%- endcase -%}
{%- endcapture -%}

{%- assign has_header = false -%}
{%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
  {%- assign has_header = true -%}
{%- endif -%}

{%- assign row_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'row' -%}
    {%- assign row_count = row_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<section
  class="kt-iwt-alternating color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
  data-section-id="{{ section.id }}"
  data-section-type="image-with-text-alternating"
  style="--kt-row-gap: {{ row_gap }}px; --kt-image-aspect: {{ aspect_value | strip }}; --kt-iwt-pad-top: {{ padding_top }}px; --kt-iwt-pad-bottom: {{ padding_bottom }}px;"
>
  <div class="kt-iwt-alternating__inner page-width">
    {%- if has_header -%}
      <header class="kt-iwt-alternating__header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kt-iwt-alternating__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="kt-iwt-alternating__heading">{{ section.settings.heading }}</{{ heading_tag }}>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="kt-iwt-alternating__rows">
      {%- for block in section.blocks -%}
        {%- if block.type == 'row' -%}
          {%- assign row_index = forloop.index -%}
          {%- assign cta_text = block.settings.item_cta_text -%}
          {%- assign cta_link = block.settings.item_cta_link -%}
          {%- assign item_heading = block.settings.item_heading -%}
          {%- assign item_eyebrow = block.settings.item_eyebrow -%}
          {%- assign item_description = block.settings.item_description -%}

          <article
            class="kt-iwt-alternating__row"
            {{ block.shopify_attributes }}
          >
            <div class="kt-iwt-alternating__media">
              {%- if block.settings.image != blank -%}
                {%- assign image_alt = block.settings.image.alt | default: item_heading -%}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag:
                    class: 'kt-iwt-alternating__image',
                    loading: 'lazy',
                    widths: '375, 550, 750, 1100, 1400',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    width: block.settings.image.width,
                    height: block.settings.image.height,
                    alt: image_alt
                }}
              {%- else -%}
                {%- case row_index -%}
                  {%- when 1 -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg kt-iwt-alternating__image' }}
                  {%- when 2 -%}
                    {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg kt-iwt-alternating__image' }}
                  {%- when 3 -%}
                    {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg kt-iwt-alternating__image' }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-iwt-alternating__image' }}
                {%- endcase -%}
              {%- endif -%}
            </div>

            <div class="kt-iwt-alternating__text">
              {%- if item_eyebrow != blank -%}
                <span class="kt-iwt-alternating__item-eyebrow">{{ item_eyebrow }}</span>
              {%- endif -%}

              {%- if item_heading != blank -%}
                <h3 class="kt-iwt-alternating__item-heading">{{ item_heading }}</h3>
              {%- endif -%}

              {%- if item_description != blank -%}
                <p class="kt-iwt-alternating__item-description">{{ item_description }}</p>
              {%- endif -%}

              {%- if cta_text != blank -%}
                <a
                  href="{{ cta_link | default: routes.root_url | escape }}"
                  class="kt-iwt-alternating__item-cta"
                >
                  <span class="kt-iwt-alternating__item-cta-label">{{ cta_text }}</span>
                  {% render 'icon-arrow-right', width: 14, height: 14, stroke_width: 1.5, class: 'kt-iwt-alternating__item-cta-icon' %}
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}

      {%- if row_count == 0 -%}
        <article class="kt-iwt-alternating__row">
          <div class="kt-iwt-alternating__media">
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg kt-iwt-alternating__image' }}
          </div>
          <div class="kt-iwt-alternating__text">
            <span class="kt-iwt-alternating__item-eyebrow">{{ 'kt.section.image_with_text_alternating.placeholder.eyebrow' | t: default: 'Chapter 01' }}</span>
            <h3 class="kt-iwt-alternating__item-heading">{{ 'kt.section.image_with_text_alternating.placeholder.heading' | t: default: 'Add rows to tell your story.' }}</h3>
            <p class="kt-iwt-alternating__item-description">{{ 'kt.section.image_with_text_alternating.placeholder.description' | t: default: 'Use the theme editor to add alternating rows of imagery and copy.' }}</p>
          </div>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%} Render @app blocks merchant added (schema declares "@app"). {%- endcomment -%}
{% render 'section-app-blocks' %}

{% schema %}
{
  "name": "t:sections.image_with_text_alternating.name",
  "tag": "div",
  "class": "section-image-with-text-alternating",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.image_with_text_alternating.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.image_with_text_alternating.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image_with_text_alternating.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.image_with_text_alternating.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "t:sections.image_with_text_alternating.settings.heading_tag.options.h2" },
        { "value": "h3", "label": "t:sections.image_with_text_alternating.settings.heading_tag.options.h3" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text_alternating.settings.header__layout.content"
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "t:sections.image_with_text_alternating.settings.row_gap.label",
      "min": 32,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "select",
      "id": "image_aspect",
      "label": "t:sections.image_with_text_alternating.settings.image_aspect.label",
      "options": [
        { "value": "1/1", "label": "t:sections.image_with_text_alternating.settings.image_aspect.options.square" },
        { "value": "4/5", "label": "t:sections.image_with_text_alternating.settings.image_aspect.options.portrait" },
        { "value": "16/10", "label": "t:sections.image_with_text_alternating.settings.image_aspect.options.landscape" }
      ],
      "default": "1/1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings_schema.global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_bottom.label",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "row",
      "name": "t:sections.image_with_text_alternating.blocks.row.name",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.image_with_text_alternating.blocks.row.settings.image.label"
        },
        {
          "type": "text",
          "id": "item_eyebrow",
          "label": "t:sections.image_with_text_alternating.blocks.row.settings.item_eyebrow.label",
          "default": "Chapter 01"
        },
        {
          "type": "text",
          "id": "item_heading",
          "label": "t:sections.image_with_text_alternating.blocks.row.settings.item_heading.label",
          "default": "Block heading"
        },
        {
          "type": "textarea",
          "id": "item_description",
          "label": "t:sections.image_with_text_alternating.blocks.row.settings.item_description.label"
        },
        {
          "type": "text",
          "id": "item_cta_text",
          "label": "t:sections.image_with_text_alternating.blocks.row.settings.item_cta_text.label",
          "info": "t:sections.image_with_text_alternating.blocks.row.settings.item_cta_text.info"
        },
        {
          "type": "url",
          "id": "item_cta_link",
          "label": "t:sections.image_with_text_alternating.blocks.row.settings.item_cta_link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_with_text_alternating.presets.name",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "item_eyebrow": "Chapter 01",
            "item_heading": "Block heading",
            "item_description": "Add a description for this block.",
            "item_cta_text": "Learn more"
          }
        },
        {
          "type": "row",
          "settings": {
            "item_eyebrow": "Chapter 02",
            "item_heading": "Block heading",
            "item_description": "Add a description for this block.",
            "item_cta_text": "Learn more"
          }
        },
        {
          "type": "row",
          "settings": {
            "item_eyebrow": "Chapter 03",
            "item_heading": "Block heading",
            "item_description": "Add a description for this block.",
            "item_cta_text": "Learn more"
          }
        }
      ]
    }
  ]
}
{% endschema %}
