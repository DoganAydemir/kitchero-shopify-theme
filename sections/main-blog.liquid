{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Main Blog — listing template. Birebir from Next.js /blog page:
  dotted editorial header + staggered 2-column masonry grid (odd
  items get a vertical offset so the rhythm feels crafted, not
  mechanical). Article thumbs are portrait 3:4 with a category pill
  and a "Read Article →" slide reveal on hover.

  Pagination is standard Shopify {% paginate %}. Falls back cleanly
  without JS.
{%- endcomment -%}

{%- if section.settings.show_header -%}
  {%- liquid
    assign blog_eyebrow = section.settings.eyebrow
    if blog_eyebrow == blank
      assign blog_eyebrow = 'The Archives'
    endif
    assign blog_heading = section.settings.heading
    if blog_heading == blank
      assign blog_heading = blog.title
    endif
    assign blog_heading_tag = section.settings.heading_tag | default: 'h1'
    assign blog_count = blog.articles_count | append: ' Articles'
  -%}
  {%- render 'page-header-dotted',
    eyebrow: blog_eyebrow,
    title: blog_heading,
    description: section.settings.description,
    count_text: blog_count,
    heading_tag: blog_heading_tag
  -%}
{%- endif -%}

<section class="kt-blog" data-section-id="{{ section.id }}">
  <div class="page-width kt-blog__body">
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      {%- if blog.articles.size > 0 -%}
        <div class="kt-blog__grid">
          {%- for article in blog.articles -%}
            <div class="kt-blog__cell{% if forloop.index0 | modulo: 2 == 1 %} kt-blog__cell--offset{% endif %}">
              {%- render 'article-card',
                article: article,
                show_author: section.settings.show_author,
                show_date: section.settings.show_date,
                show_excerpt: section.settings.show_excerpt,
                index: forloop.index0
              -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="kt-blog__pagination">
            {%- render 'pagination', paginate: paginate -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="kt-blog__empty">
          <p>{{ 'sections.blog.no_articles' | t | default: 'No articles yet.' }}</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header__header.content"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "t:sections.main-blog.settings.show_header.label",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.main-blog.settings.eyebrow.label",
      "default": "The Archives"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main-blog.settings.heading.label",
      "default": "The Journal."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-blog.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.main-blog.settings.description.label",
      "default": "A curated record of architectural breakthroughs, design philosophies, and the evolution of the modern kitchen."
    },
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header__grid.content"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 2,
      "max": 24,
      "step": 2,
      "default": 8,
      "label": "t:sections.main-blog.settings.articles_per_page.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.main-blog.settings.show_author.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.main-blog.settings.show_date.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.main-blog.settings.show_excerpt.label",
      "default": true
    }
  ]
}
{% endschema %}
