{{ 'kt-section-main-blog.css' | asset_url | stylesheet_tag }}
{{ 'kt-article-card.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Main Blog — listing template. Birebir from Next.js /blog page:
  dotted editorial header + staggered 2-column masonry grid (odd
  items get a vertical offset so the rhythm feels crafted, not
  mechanical). Article thumbs are portrait 3:4 with a category pill
  and a "Read Article →" slide reveal on hover.

  Pagination is standard Shopify {% paginate %}. Falls back cleanly
  without JS.
{%- endcomment -%}

{%- if section.settings.show_header -%}
  {%- liquid
    assign blog_eyebrow = section.settings.eyebrow
    if blog_eyebrow == blank
      # Merchant hasn't set a custom eyebrow — fall back to a
      # localized default so TR/DE/FR/ES visitors don't see raw
      # English. Key lives alongside the other kt.section.blog.*
      # strings.
      assign blog_eyebrow = 'kt.section.blog.default_eyebrow' | t
    endif
    assign blog_heading = section.settings.heading
    if blog_heading == blank
      assign blog_heading = blog.title
    endif
    assign blog_heading_tag = section.settings.heading_tag | default: 'h1'
    comment
      Use the pluralized locale key so TR/DE/ES/FR shoppers see the
      correct singular/plural noun. `append: ' Articles'` hardcoded
      English regardless of request locale.
    endcomment
    assign blog_count = 'kt.blog.count' | t: count: blog.articles_count
  -%}
  {%- render 'page-header-dotted',
    eyebrow: blog_eyebrow,
    title: blog_heading,
    description: section.settings.description,
    count_text: blog_count,
    heading_tag: blog_heading_tag
  -%}
{%- else -%}
  {%- comment -%}
    Header off, but the page still needs an h1 for outline + SEO.
    Article cards render as h2/h3, so without this the blog
    template ships with zero h1s — Lighthouse a11y + Theme Store
    structural audit both flag it. Visually-hidden so the merchant's
    "header off" choice is still respected.
  {%- endcomment -%}
  <h1 class="visually-hidden">{{ blog.title | escape }}</h1>
{%- endif -%}

<section class="kt-blog" data-section-id="{{ section.id }}" data-section-type="main-blog">
  {%- comment -%}
    Breadcrumb moved to layout/theme.liquid (global render at the top
    of <main>) so every page type gets it consistently. Removed the
    section-level render here to avoid duplicating the nav.
  {%- endcomment -%}
  <div class="page-width kt-blog__body">
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      {%- if blog.articles.size > 0 -%}
        <div class="kt-blog__grid">
          {%- for article in blog.articles -%}
            {%- assign cell_parity = forloop.index0 | modulo: 2 -%}
            <div class="kt-blog__cell{% if cell_parity == 1 %} kt-blog__cell--offset{% endif %}">
              {%- render 'article-card',
                article: article,
                show_author: section.settings.show_author,
                show_date: section.settings.show_date,
                show_excerpt: section.settings.show_excerpt,
                index: forloop.index0
              -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="kt-blog__pagination">
            {%- render 'pagination', paginate: paginate -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="kt-blog__empty">
          <p>{{ 'kt.section.blog.no_articles' | t | default: 'No articles yet.' }}</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}

    {%- comment -%}
      App-block slot. Merchants can drop in newsletter-signup apps,
      related-topics apps, etc. below the article grid. block.shopify_attributes
      is required so the theme editor highlights the block when selected.
    {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="kt-blog__app-blocks">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              <div class="kt-blog__app-block" {{ block.shopify_attributes }}>
                {%- render block -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["blog"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header__header.content"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "t:sections.main-blog.settings.show_header.label",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.main-blog.settings.eyebrow.label",
      "default": "The Archives"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main-blog.settings.heading.label",
      "default": "Blog"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-blog.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.main-blog.settings.description.label",
      "default": "Add a short description for this section."
    },
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header__grid.content"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 2,
      "max": 24,
      "step": 2,
      "default": 8,
      "label": "t:sections.main-blog.settings.articles_per_page.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.main-blog.settings.show_author.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.main-blog.settings.show_date.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.main-blog.settings.show_excerpt.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
