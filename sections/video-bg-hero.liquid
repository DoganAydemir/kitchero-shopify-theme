{{ 'kt-section-video-bg-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kt-section-video-bg-hero.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign height_class = 'kt-video-bg-hero--full'
  case section.settings.height
    when 'large'
      assign height_class = 'kt-video-bg-hero--large'
    when 'medium'
      assign height_class = 'kt-video-bg-hero--medium'
  endcase

  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign heading_tag = section.settings.heading_tag | default: 'h1'
-%}

<section
  class="kt-video-bg-hero {{ height_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="video-bg-hero"
  style="--kt-video-bg-hero-overlay: {{ overlay_opacity }};"
>
  <div class="kt-video-bg-hero__media" aria-hidden="true">
    {%- if section.settings.video_file != blank -%}
      {%- comment -%}
        WCAG 1.2.2 / A11Y-15 — Captions Required is satisfied by
        exclusion: this is a decorative, muted, autoplaying loop
        with `controls: false`. WCAG 1.2.2 normative scope is
        "prerecorded synchronized media (audio + visual that are
        synchronized to present the same information)". A muted
        background video without audio is NOT synchronized media
        and therefore exempt — explicitly documented in WCAG 2.1
        Understanding 1.2.2 (note "Movie clips that have no audio
        information"). The `muted: true` flag on every render
        below is the gating condition that keeps this section out
        of scope. Section schema description (locale key
        `kt.section.video_bg_hero.muted_note`) reminds merchants
        not to use this section for audio-bearing content;
        video-poster-modal / video-split-modal are the surfaces
        for content with sound and need merchant-supplied caption
        tracks (handled by Vimeo/YouTube on the embed side).
      {%- endcomment -%}
      {%- if section.settings.poster_image != blank -%}
        {%- assign poster_url = section.settings.poster_image | image_url: width: 2000 -%}
        {{
          section.settings.video_file
          | video_tag:
            image_size: '2000x',
            loop: true,
            autoplay: true,
            muted: true,
            playsinline: true,
            controls: false,
            preload: 'metadata',
            class: 'kt-video-bg-hero__video',
            poster: poster_url
        }}
      {%- else -%}
        {{
          section.settings.video_file
          | video_tag:
            image_size: '2000x',
            loop: true,
            autoplay: true,
            muted: true,
            playsinline: true,
            controls: false,
            preload: 'metadata',
            class: 'kt-video-bg-hero__video'
        }}
      {%- endif -%}

      {%- if section.settings.poster_image != blank -%}
        {{
          section.settings.poster_image
          | image_url: width: 2000
          | image_tag:
            class: 'kt-video-bg-hero__poster-fallback',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '750, 1100, 1500, 2000',
            sizes: '100vw',
            width: section.settings.poster_image.width,
            height: section.settings.poster_image.height,
            alt: ''
        }}
      {%- endif -%}
    {%- elsif section.settings.poster_image != blank -%}
      {{
        section.settings.poster_image
        | image_url: width: 2000
        | image_tag:
          class: 'kt-video-bg-hero__poster',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw',
          width: section.settings.poster_image.width,
          height: section.settings.poster_image.height,
          alt: ''
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg kt-video-bg-hero__poster' }}
    {%- endif -%}

    <div class="kt-video-bg-hero__overlay"></div>

    {%- comment -%}
      WCAG 2.2.2 Pause, Stop, Hide — auto-playing background video
      longer than 5 seconds MUST offer a user-controllable pause. Button
      is positioned above the overlay so it's reachable both by mouse
      and keyboard. Only emitted when there is actually a video to
      control (skipped for poster-only / placeholder states). JS in
      kt-section-video-bg-hero.js toggles playback + swaps aria-label
      and also respects prefers-reduced-motion (auto-paused on first
      paint for that cohort).
    {%- endcomment -%}
    {%- if section.settings.video_file != blank -%}
      <button
        type="button"
        class="kt-video-bg-hero__toggle"
        data-video-bg-hero-toggle
        aria-label="{{ 'kt.section.video_bg_hero.pause' | t | default: 'Pause background video' }}"
        data-label-pause="{{ 'kt.section.video_bg_hero.pause' | t | default: 'Pause background video' }}"
        data-label-play="{{ 'kt.section.video_bg_hero.play' | t | default: 'Play background video' }}"
      >
        <span class="kt-video-bg-hero__toggle-icon kt-video-bg-hero__toggle-icon--pause" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
        </span>
        <span class="kt-video-bg-hero__toggle-icon kt-video-bg-hero__toggle-icon--play" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </span>
      </button>
    {%- endif -%}
  </div>

  <div class="kt-video-bg-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="kt-video-bg-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- comment -%}
      `inline_richtext` lets merchants drop in an explicit `<br>` for
      line breaks without the hackier `newline_to_br` filter (which
      only worked on textarea types and silently no-op'd on the old
      `text` type we had here). The setting now accepts simple inline
      HTML (em, strong, br, a) — the theme renders it as-is.
    {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <{{ heading_tag }} class="kt-video-bg-hero__heading">
        {{ section.settings.heading }}
      </{{ heading_tag }}>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="kt-video-bg-hero__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="kt-video-bg-hero__actions">
        <a
          href="{{ section.settings.cta_link | default: routes.root_url | escape }}"
          class="kt-video-bg-hero__cta"
        >
          <span>{{ section.settings.cta_text }}</span>
          {% render 'icon-arrow-right', width: 14, height: 14, class: 'kt-video-bg-hero__cta-icon' %}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.video_bg_hero.name",
  "tag": "div",
  "class": "section-video-bg-hero",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.video_bg_hero.settings.header__media.content"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "t:sections.video_bg_hero.settings.video_file.label",
      "info": "t:sections.video_bg_hero.settings.video_file.info"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "t:sections.video_bg_hero.settings.poster_image.label",
      "info": "t:sections.video_bg_hero.settings.poster_image.info"
    },
    {
      "type": "header",
      "content": "t:sections.video_bg_hero.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.video_bg_hero.settings.eyebrow.label",
      "default": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.video_bg_hero.settings.heading.label",
      "info": "t:sections.video_bg_hero.settings.heading.info",
      "default": "Heading line 1"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.video_bg_hero.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "t:sections.video_bg_hero.settings.heading_tag.options__h1.label" },
        { "value": "h2", "label": "t:sections.video_bg_hero.settings.heading_tag.options__h2.label" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.video_bg_hero.settings.description.label",
      "default": "Add a short tagline that describes your brand."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.video_bg_hero.settings.cta_text.label",
      "default": "Watch story"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.video_bg_hero.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.video_bg_hero.settings.header__layout.content"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.video_bg_hero.settings.height.label",
      "options": [
        { "value": "full_viewport", "label": "t:sections.video_bg_hero.settings.height.options__full.label" },
        { "value": "large", "label": "t:sections.video_bg_hero.settings.height.options__large.label" },
        { "value": "medium", "label": "t:sections.video_bg_hero.settings.height.options__medium.label" }
      ],
      "default": "full_viewport"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "%",
      "label": "t:sections.video_bg_hero.settings.overlay_opacity.label",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "t:sections.video_bg_hero.presets.name",
      "settings": {
        "eyebrow": "Variant A / Local Cinema Background",
        "heading": "The Local Advantage.",
        "description": "Add a short tagline that describes your brand.",
        "cta_text": "Experience high definition",
        "overlay_opacity": 50,
        "height": "full_viewport",
        "heading_tag": "h1"
      }
    }
  ]
}
{% endschema %}
