{{ 'section-video-bg-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign height_class = 'kt-video-bg-hero--full'
  case section.settings.height
    when 'large'
      assign height_class = 'kt-video-bg-hero--large'
    when 'medium'
      assign height_class = 'kt-video-bg-hero--medium'
  endcase

  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign heading_tag = section.settings.heading_tag | default: 'h1'
-%}

<section
  class="kt-video-bg-hero {{ height_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="video-bg-hero"
  style="--kt-video-bg-hero-overlay: {{ overlay_opacity }};"
>
  <div class="kt-video-bg-hero__media" aria-hidden="true">
    {%- if section.settings.video_file != blank -%}
      {%- if section.settings.poster_image != blank -%}
        {%- assign poster_url = section.settings.poster_image | image_url: width: 2000 -%}
        {{
          section.settings.video_file
          | video_tag:
            image_size: '2000x',
            loop: true,
            autoplay: true,
            muted: true,
            playsinline: true,
            controls: false,
            preload: 'metadata',
            class: 'kt-video-bg-hero__video',
            poster: poster_url
        }}
      {%- else -%}
        {{
          section.settings.video_file
          | video_tag:
            image_size: '2000x',
            loop: true,
            autoplay: true,
            muted: true,
            playsinline: true,
            controls: false,
            preload: 'metadata',
            class: 'kt-video-bg-hero__video'
        }}
      {%- endif -%}

      {%- if section.settings.poster_image != blank -%}
        {{
          section.settings.poster_image
          | image_url: width: 2000
          | image_tag:
            class: 'kt-video-bg-hero__poster-fallback',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '750, 1100, 1500, 2000',
            sizes: '100vw',
            width: section.settings.poster_image.width,
            height: section.settings.poster_image.height,
            alt: ''
        }}
      {%- endif -%}
    {%- elsif section.settings.poster_image != blank -%}
      {{
        section.settings.poster_image
        | image_url: width: 2000
        | image_tag:
          class: 'kt-video-bg-hero__poster',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw',
          width: section.settings.poster_image.width,
          height: section.settings.poster_image.height,
          alt: ''
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg kt-video-bg-hero__poster' }}
    {%- endif -%}

    <div class="kt-video-bg-hero__overlay"></div>
  </div>

  <div class="kt-video-bg-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="kt-video-bg-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <{{ heading_tag }} class="kt-video-bg-hero__heading">
        {{ section.settings.heading | newline_to_br }}
      </{{ heading_tag }}>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="kt-video-bg-hero__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="kt-video-bg-hero__actions">
        <a
          href="{{ section.settings.cta_link | default: routes.root_url }}"
          class="kt-video-bg-hero__cta"
        >
          <span>{{ section.settings.cta_text }}</span>
          <svg class="kt-video-bg-hero__cta-icon" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.video_bg_hero.name",
  "tag": "section",
  "class": "section-video-bg-hero",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.video_bg_hero.settings.header__media.content"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "t:sections.video_bg_hero.settings.video_file.label",
      "info": "t:sections.video_bg_hero.settings.video_file.info"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "t:sections.video_bg_hero.settings.poster_image.label",
      "info": "t:sections.video_bg_hero.settings.poster_image.info"
    },
    {
      "type": "header",
      "content": "t:sections.video_bg_hero.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.video_bg_hero.settings.eyebrow.label",
      "default": "Variant A / Local Cinema Background"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.video_bg_hero.settings.heading.label",
      "default": "The Local Advantage."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.video_bg_hero.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "t:sections.video_bg_hero.settings.heading_tag.options__h1.label" },
        { "value": "h2", "label": "t:sections.video_bg_hero.settings.heading_tag.options__h2.label" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.video_bg_hero.settings.description.label",
      "default": "Experience the perfect orchestration of cinema and tactile luxury in your own home."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.video_bg_hero.settings.cta_text.label",
      "default": "Experience High Definition"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.video_bg_hero.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.video_bg_hero.settings.header__layout.content"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.video_bg_hero.settings.height.label",
      "options": [
        { "value": "full_viewport", "label": "t:sections.video_bg_hero.settings.height.options__full.label" },
        { "value": "large", "label": "t:sections.video_bg_hero.settings.height.options__large.label" },
        { "value": "medium", "label": "t:sections.video_bg_hero.settings.height.options__medium.label" }
      ],
      "default": "full_viewport"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "%",
      "label": "t:sections.video_bg_hero.settings.overlay_opacity.label",
      "default": 50
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "t:sections.video_bg_hero.presets.name",
      "settings": {
        "eyebrow": "Variant A / Local Cinema Background",
        "heading": "The Local Advantage.",
        "description": "Experience the perfect orchestration of cinema and tactile luxury in your own home.",
        "cta_text": "Experience High Definition",
        "overlay_opacity": 50,
        "height": "full_viewport",
        "heading_tag": "h1"
      }
    }
  ]
}
{% endschema %}
