{{ 'kt-section-main-collection-banner.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Main Collection Banner — full-width hero banner positioned above the
  collection grid section on collection templates. Modular section so a
  merchant can reorder, hide, or fully replace the editorial header on a
  per-collection basis without touching `main-collection`.

  R138 / HG-4 — Concept and Essence both ship a dedicated banner section
  separate from the collection grid (`main-collection-banner.liquid` in
  both); Kitchero collapsed banner + grid into a single section, which
  blocked merchants from reordering the visual hero or swapping it out
  for, e.g., a video block on a single collection. Splitting them
  closes the parity gap.

  Image source priority:
    1. section.settings.image  →  merchant override
    2. collection.image  →  Shopify-native collection cover image
    3. SVG placeholder  →  fresh-install fallback
{%- endcomment -%}

{%- assign banner_pad_top = section.settings.padding_top | default: 0 -%}
{%- assign banner_pad_bottom = section.settings.padding_bottom | default: 0 -%}
{%- assign banner_scheme = section.settings.color_scheme | default: 'scheme-1' -%}
{%- assign banner_height = section.settings.height | default: 'medium' -%}
{%- assign banner_align = section.settings.text_alignment | default: 'center' -%}
{%- assign banner_overlay = section.settings.overlay_opacity | default: 35 -%}
{%- assign banner_image = section.settings.image | default: collection.image -%}
{%- assign heading_tag = section.settings.heading_tag | default: 'h1' -%}
{%- assign eyebrow_default = 'kt.section.main_collection.eyebrow_default' | t -%}

<section
  class="kt-collection-banner kt-collection-banner--{{ banner_height }} kt-collection-banner--align-{{ banner_align }} color-{{ banner_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="main-collection-banner"
  data-allows-transparent-header="true"
  style="--kt-cb-pad-top: {{ banner_pad_top }}px; --kt-cb-pad-bottom: {{ banner_pad_bottom }}px; --kt-cb-overlay: {{ banner_overlay | divided_by: 100.0 }};"
>
  <div class="kt-collection-banner__media" aria-hidden="true">
    {%- if banner_image != blank -%}
      {{
        banner_image
        | image_url: width: 2400
        | image_tag:
          class: 'kt-collection-banner__image',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '480, 768, 1100, 1500, 1800, 2400',
          sizes: '100vw',
          width: banner_image.width,
          height: banner_image.height,
          alt: ''
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-collection-banner__image' }}
    {%- endif -%}
    <div class="kt-collection-banner__overlay" aria-hidden="true"></div>
  </div>

  <div class="kt-collection-banner__inner page-width">
    <div class="kt-collection-banner__content">
      {%- if section.settings.show_eyebrow -%}
        <p class="kt-collection-banner__eyebrow">
          {{- section.settings.eyebrow | default: eyebrow_default | escape -}}
        </p>
      {%- endif -%}

      {%- if section.settings.show_heading -%}
        <{{ heading_tag }} class="kt-collection-banner__heading">
          {{- section.settings.heading | default: collection.title | escape -}}
        </{{ heading_tag }}>
      {%- endif -%}

      {%- if section.settings.show_description -%}
        {%- if section.settings.description != blank -%}
          <p class="kt-collection-banner__description">{{ section.settings.description }}</p>
        {%- elsif collection.description != blank -%}
          <div class="kt-collection-banner__description rte">{{ collection.description }}</div>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.show_count -%}
        <p class="kt-collection-banner__count">
          {{ 'kt.section.collection.products_count' | t: count: collection.products_count }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%}
  Breadcrumb is NOT rendered here. The banner is optional (the
  default collection.json no longer ships it; merchants add it
  manually from the theme editor when they want the editorial
  intro). Rendering the breadcrumb in main-collection instead
  guarantees the trail always shows up on /collections/* —
  whether the merchant uses the banner or not. See sections/
  main-collection.liquid for the breadcrumb render.
{%- endcomment -%}

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": [
      "collection"
    ]
  },
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-collection-banner.settings.header__content.content"
    },
    {
      "type": "checkbox",
      "id": "show_eyebrow",
      "label": "t:sections.main-collection-banner.settings.show_eyebrow.label",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.main-collection-banner.settings.eyebrow.label",
      "default": "The Archives"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "t:sections.main-collection-banner.settings.show_heading.label",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main-collection-banner.settings.heading.label",
      "info": "t:sections.main-collection-banner.settings.heading.info"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-collection-banner.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        }
      ],
      "default": "h1"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.main-collection-banner.settings.show_description.label",
      "default": true
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.main-collection-banner.settings.description.label",
      "info": "t:sections.main-collection-banner.settings.description.info"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "t:sections.main-collection-banner.settings.show_count.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-banner.settings.header__media.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.main-collection-banner.settings.image.label",
      "info": "t:sections.main-collection-banner.settings.image.info"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.main-collection-banner.settings.height.label",
      "options": [
        {
          "value": "small",
          "label": "t:sections.main-collection-banner.settings.height.options__1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.main-collection-banner.settings.height.options__2.label"
        },
        {
          "value": "large",
          "label": "t:sections.main-collection-banner.settings.height.options__3.label"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.main-collection-banner.settings.text_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.main-collection-banner.settings.text_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.main-collection-banner.settings.text_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.main-collection-banner.settings.text_alignment.options__3.label"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.main-collection-banner.settings.overlay_opacity.label",
      "info": "t:sections.main-collection-banner.settings.overlay_opacity.info",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__appearance.content"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_bottom.label",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-collection-banner.presets.name"
    }
  ]
}
{% endschema %}
