{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}
{{ 'kt-section-customer-account.css' | asset_url | stylesheet_tag }}

<section class="kt-customer kt-customer--wide" data-section-id="{{ section.id }}">
  <div class="kt-customer__container kt-customer__container--wide">
    <a href="{{ routes.account_url }}" class="kt-order__back">
      &larr; {{ 'kt.customer.order.back_to_account' | t }}
    </a>

    {%- comment -%}
      Preformat the order date BEFORE handing it to the translation
      filter. Previously the line read
        {{ 'kt.customer.order.date_html' | t: date: order.created_at | date: format: 'date' }}
      which parses as
        (('...' | t: date: order.created_at) | date: format: 'date')
      — i.e. the `| date` filter runs on the already-interpolated
      translation STRING ("Placed on 2026-01-01…"), not the
      order.created_at timestamp. Output was garbled or unchanged
      depending on locale. Split the pipeline so `date` filter runs
      on the raw timestamp first.
    {%- endcomment -%}
    {%- assign order_date_formatted = order.created_at | date: format: 'date' -%}
    <header class="kt-account__header kt-order__title-block">
      <h1 class="kt-customer__title kt-order__title-heading">
        {{ 'kt.customer.order.title' | t: name: order.name }}
      </h1>
      <p class="kt-account__greeting">
        {{ 'kt.customer.order.date_html' | t: date: order_date_formatted }}
      </p>
    </header>

    {%- comment -%}
      Cancelled-order banner. `order.cancelled_at` is set when the
      merchant (or customer-support agent) cancels the order.
      `cancel_reason_label` is localised by Shopify. Without this
      banner the only visual cue a cancelled order gives is the
      financial_status pill reading "Refunded" — not enough to
      distinguish "shipped and refunded" from "cancelled before
      fulfillment". Surfacing the cancellation date + reason here
      prevents the "why hasn't my order shipped" support ticket.
    {%- endcomment -%}
    {%- if order.cancelled_at != blank -%}
      {%- assign cancelled_date = order.cancelled_at | date: format: 'date' -%}
      <div class="kt-order__cancelled" role="note">
        <p class="kt-order__cancelled-heading">
          {{ 'kt.customer.order.cancelled_heading' | t: date: cancelled_date }}
        </p>
        {%- if order.cancel_reason_label != blank -%}
          <p class="kt-order__cancelled-reason">
            {{ 'kt.customer.order.cancelled_reason' | t: reason: order.cancel_reason_label }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kt-order__meta" role="group" aria-label="{{ 'kt.customer.order.title' | t: name: order.name }}">
      <div class="kt-order__meta-item">
        <span class="kt-order__meta-label">{{ 'kt.customer.order.payment_status' | t }}</span>
        <span class="kt-order__meta-value">
          <span class="kt-account__pill kt-account__pill--{{ order.financial_status }}">
            {{ order.financial_status_label }}
          </span>
        </span>
      </div>
      <div class="kt-order__meta-item">
        <span class="kt-order__meta-label">{{ 'kt.customer.order.fulfillment_status' | t }}</span>
        <span class="kt-order__meta-value">
          <span class="kt-account__pill kt-account__pill--{{ order.fulfillment_status | default: 'unfulfilled' }}">
            {{ order.fulfillment_status_label }}
          </span>
        </span>
      </div>
    </div>

    {%- comment -%}
      Shipment tracking links. `order.fulfillments` is populated once
      the order is partially/fully fulfilled; each fulfillment carries
      a carrier + tracking number + tracking URL. Without this block
      the customer has no way to track their package from the order
      page — they have to dig into the shipping-confirmation email.
      Gate on fulfillments.size so pending orders render nothing
      extra.
    {%- endcomment -%}
    {%- if order.fulfillments.size > 0 -%}
      <div class="kt-order__tracking" aria-label="{{ 'kt.customer.order.tracking_heading' | t }}">
        <h2 class="kt-order__tracking-heading">{{ 'kt.customer.order.tracking_heading' | t }}</h2>
        <ul class="kt-order__tracking-list" role="list">
          {%- for fulfillment in order.fulfillments -%}
            <li class="kt-order__tracking-item">
              {%- if fulfillment.tracking_company != blank -%}
                <span class="kt-order__tracking-carrier">{{ fulfillment.tracking_company }}</span>
              {%- endif -%}
              {%- if fulfillment.tracking_url != blank -%}
                <a href="{{ fulfillment.tracking_url }}" class="kt-order__tracking-link" target="_blank" rel="noopener noreferrer">
                  {%- if fulfillment.tracking_number != blank -%}
                    {{ 'kt.customer.order.track_package_with_number' | t: number: fulfillment.tracking_number }}
                  {%- else -%}
                    {{ 'kt.customer.order.track_package' | t }}
                  {%- endif -%}
                </a>
              {%- elsif fulfillment.tracking_number != blank -%}
                <span class="kt-order__tracking-number">{{ fulfillment.tracking_number }}</span>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="kt-order__layout">
      {%- comment -%} Line items {%- endcomment -%}
      <div class="kt-order__items" role="table" aria-label="{{ 'kt.customer.order.product' | t }}">
        {%- for line_item in order.line_items -%}
          <div class="kt-order__item" role="row">
            {%- if line_item.image -%}
              {{ line_item.image | image_url: width: 160 | image_tag:
                loading: 'lazy',
                width: 80,
                height: 80,
                class: 'kt-order__item-image',
                alt: line_item.image.alt | default: line_item.title
              }}
            {%- else -%}
              <div class="kt-order__item-image"></div>
            {%- endif -%}

            <div>
              <p class="kt-order__item-title">
                {%- if line_item.url != blank -%}
                  <a href="{{ line_item.url }}">{{ line_item.product.title | default: line_item.title }}</a>
                {%- else -%}
                  {{ line_item.product.title | default: line_item.title }}
                {%- endif -%}
              </p>
              {%- unless line_item.product.has_only_default_variant -%}
                <p class="kt-order__item-variant">{{ line_item.variant.title }}</p>
              {%- endunless -%}
              {%- if line_item.sku != blank -%}
                <p class="kt-order__item-sku">{{ 'kt.customer.order.sku' | t: sku: line_item.sku }}</p>
              {%- endif -%}
              <p class="kt-order__item-qty">{{ 'kt.customer.order.qty' | t: qty: line_item.quantity }}</p>

              {%- comment -%}
                Per-line fulfillment status. When an order ships in
                waves — 2 of 3 items today, the third in 4 days —
                `order.fulfillment_status` only reports the aggregate
                ("partial") and the customer can't tell which item
                belongs to which shipment. `line_item.fulfillment`
                resolves to the specific fulfillment covering this
                line; if it's nil, the line is still unfulfilled.
              {%- endcomment -%}
              {%- if line_item.fulfillment -%}
                <p class="kt-order__item-fulfillment kt-order__item-fulfillment--shipped">
                  {%- assign line_fulfilled_date = line_item.fulfillment.created_at | date: format: 'date' -%}
                  {{ 'kt.customer.order.line_fulfilled_on' | t: date: line_fulfilled_date }}
                </p>
              {%- elsif line_item.successfully_fulfilled_quantity > 0 and line_item.successfully_fulfilled_quantity < line_item.quantity -%}
                <p class="kt-order__item-fulfillment kt-order__item-fulfillment--partial">
                  {{ 'kt.customer.order.line_partial' | t: shipped: line_item.successfully_fulfilled_quantity, total: line_item.quantity }}
                </p>
              {%- endif -%}
            </div>

            <div class="kt-order__item-price">
              {{ line_item.final_line_price | money }}
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Totals {%- endcomment -%}
      <aside class="kt-order__totals" aria-label="{{ 'kt.customer.order.total' | t }}">
        <div class="kt-order__totals-row">
          <span>{{ 'kt.customer.order.subtotal' | t }}</span>
          <span>{{ order.line_items_subtotal_price | money }}</span>
        </div>

        {%- comment -%}
          Discount breakdown. Previously surfaced only an aggregate
          "Discount: -$X" line; customers filing disputes or cross-
          checking promotional emails had no way to see which codes
          actually applied. `order.cart_level_discount_applications`
          lists each applied code with its localised title and saved
          amount. Fall back to the aggregate row when no code-level
          attributions exist (e.g., an automatic discount that the
          API doesn't attribute to an individual code).
        {%- endcomment -%}
        {%- if order.cart_level_discount_applications.size > 0 -%}
          {%- for discount in order.cart_level_discount_applications -%}
            <div class="kt-order__totals-row kt-order__totals-row--discount">
              <span>{{ 'kt.customer.order.discount' | t }} ({{ discount.title }})</span>
              <span>-{{ discount.total_allocated_amount | money }}</span>
            </div>
          {%- endfor -%}
        {%- elsif order.total_discounts > 0 -%}
          <div class="kt-order__totals-row">
            <span>{{ 'kt.customer.order.discount' | t }}</span>
            <span>-{{ order.total_discounts | money }}</span>
          </div>
        {%- endif -%}

        {%- for shipping_method in order.shipping_methods -%}
          <div class="kt-order__totals-row">
            <span>{{ 'kt.customer.order.shipping' | t }}{% if shipping_method.title %} ({{ shipping_method.title }}){% endif %}</span>
            <span>{{ shipping_method.price | money }}</span>
          </div>
        {%- endfor -%}

        {%- for tax_line in order.tax_lines -%}
          <div class="kt-order__totals-row">
            <span>{{ 'kt.customer.order.tax' | t }}{% if tax_line.title %} ({{ tax_line.title }}){% endif %}</span>
            <span>{{ tax_line.price | money }}</span>
          </div>
        {%- endfor -%}

        <div class="kt-order__totals-row kt-order__totals-row--grand">
          <span>{{ 'kt.customer.order.total' | t }}</span>
          <span>{{ order.total_price | money_with_currency }}</span>
        </div>
      </aside>
    </div>

    {%- comment -%} Addresses {%- endcomment -%}
    <div class="kt-order__addresses">
      {%- if order.shipping_address -%}
        <div class="kt-order__address-card">
          <h3 class="kt-order__address-title">{{ 'kt.customer.order.shipping_address' | t }}</h3>
          <address class="kt-order__address-body">{{ order.shipping_address | format_address }}</address>
        </div>
      {%- endif -%}

      {%- if order.billing_address -%}
        <div class="kt-order__address-card">
          <h3 class="kt-order__address-title">{{ 'kt.customer.order.billing_address' | t }}</h3>
          <address class="kt-order__address-body">{{ order.billing_address | format_address }}</address>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%}
      Customer-facing order note. The `cart.note` the customer wrote
      on checkout lands on `order.note`. Before this block the note
      was invisible on the account order page — a known support-ticket
      driver ("Did you see my delivery instructions?"). Rendered
      read-only; customers edit via contacting support, not here.
    {%- endcomment -%}
    {%- if order.note != blank -%}
      <div class="kt-order__note">
        <h3 class="kt-order__note-title">{{ 'kt.customer.order.note_heading' | t | default: 'Order note' }}</h3>
        <p class="kt-order__note-body">{{ order.note | newline_to_br }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-order.name",
  "tag": "section",
  "class": "section"
}
{% endschema %}
