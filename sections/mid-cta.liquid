{{ 'kt-section-mid-cta.css' | asset_url | stylesheet_tag }}

<section
  class="kt-mid-cta color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
  data-section-id="{{ section.id }}"
  data-section-type="mid-cta"
  style="--kt-mid-cta-pad-top: {{ section.settings.padding_top | default: 60 }}px; --kt-mid-cta-pad-bottom: {{ section.settings.padding_bottom | default: 60 }}px;"
>
  <div class="kt-mid-cta__text">
    {%- if section.settings.label != blank -%}
      <span class="kt-mid-cta__label">{{ section.settings.label }}</span>
    {%- endif -%}
    {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
    <{{ heading_tag }} class="kt-mid-cta__heading">{{ section.settings.heading }}</{{ heading_tag }}>
    {%- if section.settings.description != blank -%}
      <p class="kt-mid-cta__desc">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_link | default: routes.root_url | escape }}" class="button kt-mid-cta__btn">
        {{ section.settings.cta_text }}
        {% render 'icon-arrow-right' %}
      </a>
    {%- endif -%}
  </div>
  <div class="kt-mid-cta__image-col">
    <div class="kt-mid-cta__measure-overlay" aria-hidden="true">
      <div class="kt-mid-cta__measure-h"></div>
      <div class="kt-mid-cta__measure-v"></div>
    </div>
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          class: 'kt-mid-cta__image',
          loading: 'lazy',
          widths: '375, 550, 750, 1100',
          sizes: '(min-width: 750px) 50vw, 100vw',
          width: section.settings.image.width,
          height: section.settings.image.height,
          alt: section.settings.heading | default: ''
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-mid-cta__image' }}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.mid-cta.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.mid-cta.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.mid-cta.settings.label.label",
      "default": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.mid-cta.settings.heading.label",
      "default": "Section <em>heading</em>"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.mid-cta.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.mid-cta.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.mid-cta.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.mid-cta.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.mid-cta.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.mid-cta.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.mid-cta.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.mid-cta.settings.description.label",
      "default": "Add a short description for this section."
    },
    {
      "type": "header",
      "content": "t:sections.mid-cta.settings.header__cta.content"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.mid-cta.settings.cta_text.label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.mid-cta.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.mid-cta.settings.header__media.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.mid-cta.settings.image.label"
    },
    {
      "type": "header",
      "content": "t:sections.mid-cta.settings.header__appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.mid-cta.settings.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.mid-cta.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "t:sections.mid-cta.settings.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "t:sections.mid-cta.settings.padding_bottom.label"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.mid-cta.presets.name",
      "category": "t:sections.categories.image.label"
    }
  ]
}
{% endschema %}
