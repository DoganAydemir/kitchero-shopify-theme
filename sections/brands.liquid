{{ 'kt-section-brands.css' | asset_url | stylesheet_tag }}

<section class="kt-brands" data-section-id="{{ section.id }}">
  <div class="kt-brands__fade-left" aria-hidden="true"></div>
  <div class="kt-brands__fade-right" aria-hidden="true"></div>

  <div class="kt-brands__track" aria-label="{{ 'kt.section.brands.label' | t }}">
    {%- comment -%} Render blocks twice for seamless loop {%- endcomment -%}
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' -%}
          <div class="kt-brands__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: height: 80 | image_tag: class: 'kt-brands__logo', loading: 'lazy', width: 120, height: 40, alt: block.settings.alt | default: 'kt.section.brands.logo_alt' | t }}
            {%- else -%}
              <div class="kt-brands__placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- if block.settings.alt != blank -%}
                  <span class="kt-brands__placeholder-name">{{ block.settings.alt }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.brands.name",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "logo",
      "name": "t:sections.brands.blocks.logo.name",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.brands.blocks.logo.settings.image.label"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "t:sections.brands.blocks.logo.settings.alt.label",
          "default": "Brand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.brands.presets.name",
      "blocks": [
        {
          "type": "logo",
          "settings": {
            "alt": "Caesarstone"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Silestone"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Blum"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Hettich"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Cosentino"
          }
        }
      ]
    }
  ]
}
{% endschema %}
