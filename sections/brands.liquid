{{ 'kt-section-brands.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  R115 — brands marquee has no visible heading (just a logo
  parade), so aria-label provides the AT landmark name.
{%- endcomment -%}
{%- comment -%}
  R274 — `logo_opacity` + `logo_style` merchant settings drive the
  logo dim + grayscale via two CSS custom properties on the
  section root. CSS consumes them in kt-section-brands.css. The
  previous hardcoded `opacity: 0.4` on `.kt-brands__logo` is
  preserved as the default value here so existing stores look
  identical until the merchant chooses to opt out. `logo_style:
  grayscale` is the new default — most logo strips read better in
  uniform B&W even on color sites because brand palettes clash
  with each other when paraded side by side.
{%- endcomment -%}
{%- assign brands_logo_opacity = section.settings.logo_opacity | default: 40 | divided_by: 100.0 -%}
{%- if section.settings.logo_style == 'color' -%}
  {%- assign brands_logo_filter = 'none' -%}
{%- else -%}
  {%- assign brands_logo_filter = 'grayscale(100%)' -%}
{%- endif -%}
<section
  class="kt-brands color-{{ section.settings.color_scheme | default: 'scheme-1' }} {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="brands"
  data-marquee-pause-host
  data-marquee-pause-modifier="kt-brands--paused"
  style="--kt-brands-pad-top: {{ section.settings.padding_top | default: 40 }}px; --kt-brands-pad-bottom: {{ section.settings.padding_bottom | default: 40 }}px; --kt-brands-logo-opacity: {{ brands_logo_opacity }}; --kt-brands-logo-filter: {{ brands_logo_filter }};"
  aria-label="{{ 'kt.section.brands.aria_label' | t | default: 'Featured brands' }}"
>
  {%- comment -%}
    Empty-block guard. The brands marquee renders empty fade gradients
    over a blank track when the merchant has 0 logo blocks; in the
    Theme Editor that reads as "is this section broken?". Show an
    explicit hint in design_mode and suppress the marquee entirely
    on the production storefront so an unconfigured section doesn't
    publish a 0-content row to public visitors.
  {%- endcomment -%}
  {%- if section.blocks.size == 0 -%}
    {%- if request.design_mode -%}
      <p class="kt-brands__editor-hint">
        {{ 'kt.section.brands.editor_hint_empty' | t | default: 'Add one or more logo blocks in the theme editor to populate this brands strip.' }}
      </p>
    {%- endif -%}
  {%- else -%}
  <div class="kt-brands__fade-left" aria-hidden="true"></div>
  <div class="kt-brands__fade-right" aria-hidden="true"></div>

  <div class="kt-brands__track" aria-label="{{ 'kt.section.brands.label' | t }}">
    {%- comment -%} Render blocks twice for seamless loop {%- endcomment -%}
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' -%}
          <div class="kt-brands__item" {{ block.shopify_attributes }}>
            {%- comment -%}
              Alt fallback — pre-resolve the localized string into a
              variable so `| default:` sees a translated value. The
              previous one-liner ran `| t` AFTER `| default:`, which
              meant non-English locales got the translation-missing
              warning instead of the fallback.
            {%- endcomment -%}
            {%- assign brand_alt_fallback = 'kt.section.brands.logo_alt' | t -%}
            {%- if block.settings.image != blank -%}
              {%- comment -%}
                Compute width from merchant upload's aspect ratio at
                40px render height. Previously hardcoded `width: 120,
                height: 40` (3:1) stretched narrow or tall logos and
                caused a CLS flash before the `.kt-brands__logo` CSS
                `max-height: 100%; width: auto` overrode. Using the
                real aspect keeps width+height truthful for Theme
                Check and prevents the reflow.
              {%- endcomment -%}
              {%- assign brand_logo_width = block.settings.image.width | times: 40 | divided_by: block.settings.image.height -%}
              {{ block.settings.image | image_url: height: 80 | image_tag: class: 'kt-brands__logo', loading: 'lazy', width: brand_logo_width, height: 40, alt: block.settings.alt | default: brand_alt_fallback }}
            {%- else -%}
              {%- comment -%}
                R197 — dropped the placeholder_svg from the no-image
                fallback. The svg + name pair was creating a stacked
                column inside the fixed-height marquee item, and the
                svg's intrinsic viewBox padding shifted the visual
                centre off the row's baseline. Brand text alone is a
                cleaner fallback (matches the Next.js source pattern)
                and centres exactly inside .kt-brands__item without
                any extra layout math.
              {%- endcomment -%}
              {%- if block.settings.alt != blank -%}
                <span class="kt-brands__placeholder-name">{{ block.settings.alt }}</span>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
  {%- comment -%}
    WCAG 2.2.2 Pause control — infinite logo marquee with no pause
    affordance is a Theme Store reject vector for touch / screen-
    reader users (hover/focus pause only mitigates pointer + Tab).
    The shared `assets/kt-marquee-pause.js` handler toggles the
    `kt-brands--paused` modifier declared on the section root.
  {%- endcomment -%}
  <button
    type="button"
    class="kt-brands__pause-toggle"
    data-marquee-pause-toggle
    aria-pressed="true"
    aria-label="{{ 'kt.a11y.carousel_pause' | t | default: 'Pause or play marquee' }}"
  >
    <svg data-marquee-icon-pause aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="6" y="4" width="4" height="16"></rect>
      <rect x="14" y="4" width="4" height="16"></rect>
    </svg>
    <svg data-marquee-icon-play aria-hidden="true" hidden width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="5 3 19 12 5 21 5 3"></polygon>
    </svg>
  </button>
  {%- endif -%}
</section>

<script src="{{ 'kt-marquee-pause.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.brands.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.brands.settings.header__appearance.content"
    },
    {
      "type": "select",
      "id": "logo_style",
      "label": "t:sections.brands.settings.logo_style.label",
      "info": "t:sections.brands.settings.logo_style.info",
      "options": [
        {
          "value": "grayscale",
          "label": "t:sections.brands.settings.logo_style.options__grayscale.label"
        },
        {
          "value": "color",
          "label": "t:sections.brands.settings.logo_style.options__color.label"
        }
      ],
      "default": "grayscale"
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "t:sections.brands.settings.logo_opacity.label",
      "info": "t:sections.brands.settings.logo_opacity.info",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:sections.brands.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "t:sections.brands.settings.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "t:sections.brands.settings.padding_bottom.label"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        {
          "value": "stone_100",
          "label": "t:sections.shared.bg_color.options__stone_100.label"
        }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "t:sections.shared.color_scheme.header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:sections.brands.blocks.logo.name",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.brands.blocks.logo.settings.image.label"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "t:sections.brands.blocks.logo.settings.alt.label",
          "default": "Brand"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ],
    "templates": [
      "cart",
      "search",
      "password",
      "gift_card",
      "404"
    ]
  },
  "max_blocks": 16,
  "presets": [
    {
      "name": "t:sections.brands.presets.name",
      "category": "t:sections.categories.image.label",
      "blocks": [
        {
          "type": "logo",
          "settings": {
            "alt": "Brand 1"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Brand 2"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Brand 3"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Brand 4"
          }
        },
        {
          "type": "logo",
          "settings": {
            "alt": "Brand 5"
          }
        }
      ]
    }
  ]
}
{% endschema %}
