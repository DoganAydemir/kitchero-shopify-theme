{{ 'section-guide-teaser.css' | asset_url | stylesheet_tag }}

<section class="kt-guide-teaser color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}" data-section-type="guide-teaser">
  <div class="page-width">
    <div class="kt-guide-teaser__header">
      <div>
        {%- if section.settings.label != blank -%}
          <p class="kt-guide-teaser__label">{{ section.settings.label }}</p>
        {%- endif -%}
        {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
        <{{ heading_tag }} class="kt-guide-teaser__title">{{ section.settings.heading | default: 'Inspiration & Guides' }}</{{ heading_tag }}>
      </div>
      {%- if section.settings.blog != blank -%}
        {%- assign blog_obj = blogs[section.settings.blog] -%}
        {%- if blog_obj -%}
          <a href="{{ blog_obj.url }}" class="kt-guide-teaser__view-all">
            {{ 'sections.guide_teaser.view_all' | t | default: 'View All Journals' }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="kt-guide-teaser__grid">
      {%- if section.settings.blog != blank -%}
        {%- assign blog_obj = blogs[section.settings.blog] -%}
        {%- if blog_obj and blog_obj.articles_count > 0 -%}
          {%- for article in blog_obj.articles limit: section.settings.posts_count -%}
            <a href="{{ article.url }}" class="kt-guide-teaser__card">
              <div class="kt-guide-teaser__card-image-wrap">
                {%- if article.image -%}
                  {{ article.image | image_url: width: 800 | image_tag: class: 'kt-guide-teaser__card-image', loading: 'lazy', widths: '375, 550, 800', sizes: '(min-width: 750px) 33vw, 100vw', width: article.image.width, height: article.image.height, alt: article.title }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg kt-guide-teaser__card-image' }}
                {%- endif -%}
              </div>
              <div class="kt-guide-teaser__card-content">
                {%- if section.settings.show_category and article.tags.size > 0 -%}
                  <p class="kt-guide-teaser__card-category">{{ article.tags.first }}</p>
                {%- endif -%}
                <h3 class="kt-guide-teaser__card-title">{{ article.title }}</h3>
                {%- if section.settings.show_excerpt and article.excerpt_or_content != blank -%}
                  <p class="kt-guide-teaser__card-desc">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
                {%- endif -%}
                <div class="kt-guide-teaser__card-meta">
                  {%- if section.settings.show_author -%}
                    <span class="kt-guide-teaser__card-author">{{ article.author }}</span>
                  {%- endif -%}
                  {%- if section.settings.show_date -%}
                    <time class="kt-guide-teaser__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{ article.published_at | date: format: 'abbreviated_date' }}
                    </time>
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Blog selected but no articles — show placeholders {%- endcomment -%}
          {%- for i in (1..3) -%}
            <div class="kt-guide-teaser__card">
              <div class="kt-guide-teaser__card-image-wrap">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg kt-guide-teaser__card-image' }}
              </div>
              <div class="kt-guide-teaser__card-content">
                <p class="kt-guide-teaser__card-category">{{ 'onboarding.collection_title' | t }}</p>
                <h3 class="kt-guide-teaser__card-title">{{ 'onboarding.product_title' | t }}</h3>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- else -%}
        {%- comment -%} No blog selected — use manual blocks {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'article' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="kt-guide-teaser__card" {{ block.shopify_attributes }}>
              <div class="kt-guide-teaser__card-image-wrap">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag: class: 'kt-guide-teaser__card-image', loading: 'lazy', widths: '375, 550, 800', sizes: '(min-width: 750px) 33vw, 100vw', width: block.settings.image.width, height: block.settings.image.height, alt: block.settings.title | default: '' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg kt-guide-teaser__card-image' }}
                {%- endif -%}
              </div>
              <div class="kt-guide-teaser__card-content">
                {%- if block.settings.volume != blank -%}
                  <p class="kt-guide-teaser__card-category">{{ block.settings.volume }}</p>
                {%- endif -%}
                <h3 class="kt-guide-teaser__card-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="kt-guide-teaser__card-desc">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- if block.settings.author != blank or block.settings.date != blank -%}
                  <div class="kt-guide-teaser__card-meta">
                    {%- if section.settings.show_author and block.settings.author != blank -%}
                      <span class="kt-guide-teaser__card-author">{{ block.settings.author }}</span>
                    {%- endif -%}
                    {%- if section.settings.show_date and block.settings.date != blank -%}
                      <time class="kt-guide-teaser__card-date">{{ block.settings.date }}</time>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script src="{{ 'section-guide-teaser.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Curated Reading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Inspiration & Guides"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Blog source"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Number of posts to show"
    },
    {
      "type": "header",
      "content": "Card display"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show category tag",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article card (manual)",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "volume",
          "label": "Category label",
          "default": "Volume 1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Modern Minimalism: The Secret to Serene Kitchens"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Explore how restraint in design creates the most impactful kitchen spaces."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Kitchero Team"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "Apr 2026"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog posts",
      "settings": {
        "posts_count": 3,
        "show_category": true,
        "show_excerpt": true,
        "show_author": true,
        "show_date": true
      },
      "blocks": [
        {
          "type": "article",
          "settings": {
            "volume": "Design",
            "title": "Modern Minimalism: The Secret to Serene Kitchens",
            "description": "Explore how restraint in design creates the most impactful kitchen spaces.",
            "author": "Kitchero Team",
            "date": "Apr 2026"
          }
        },
        {
          "type": "article",
          "settings": {
            "volume": "Materials",
            "title": "Material Guide: Choosing the Perfect Countertop",
            "description": "From quartz to marble, understand the pros and cons of every surface.",
            "author": "Kitchero Team",
            "date": "Mar 2026"
          }
        },
        {
          "type": "article",
          "settings": {
            "volume": "Small Spaces",
            "title": "Small Space, Big Impact: Kitchen Solutions Under 150sqft",
            "description": "Clever storage and layout tricks that transform compact kitchens.",
            "author": "Kitchero Team",
            "date": "Feb 2026"
          }
        }
      ]
    }
  ]
}
{% endschema %}
