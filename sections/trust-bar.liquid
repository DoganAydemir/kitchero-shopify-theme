{{ 'kt-section-trust-bar.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Trust bar — pre-flight pass to detect whether the merchant has
  configured any stat. A block whose value is still the schema
  default "0" AND label is still "Stat label" reads as
  "unconfigured" — we skip rendering it on the storefront so the
  page never ships with a broken-looking placeholder strip
  ("0 STAT LABEL" repeated four times).

  In the theme editor we DO render every block (gated on
  `request.design_mode`) so the merchant can click through and
  fill in copy, plus an "Add real numbers" hint when every
  block is at default. Live shoppers see nothing for an empty
  bar — the section quietly disappears until populated.
{%- endcomment -%}
{%- assign trust_configured_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'stat' -%}
    {%- assign stat_value = block.settings.value | default: '' -%}
    {%- assign stat_label = block.settings.label | default: '' -%}
    {%- assign stat_prefix = block.settings.prefix | default: '' -%}
    {%- comment -%}
      Configured = label is set to anything other than the placeholder
      "Stat label" OR a prefix is set OR value is something other than
      bare "0". A merchant who legitimately wants to display "0%
      commission" only needs to set the label and prefix; that path
      passes the check via the label/prefix branch.
    {%- endcomment -%}
    {%- if stat_label != 'Stat label' and stat_label != blank -%}
      {%- assign trust_configured_count = trust_configured_count | plus: 1 -%}
    {%- elsif stat_prefix != blank -%}
      {%- assign trust_configured_count = trust_configured_count | plus: 1 -%}
    {%- elsif stat_value != '0' and stat_value != blank -%}
      {%- assign trust_configured_count = trust_configured_count | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if trust_configured_count > 0 or request.design_mode -%}
{%- comment -%}
  R115 — `<section>` is a region landmark in the AT tree. Adding
  aria-label gives the trust-bar an accessible name so SR users
  navigating landmarks (NVDA D / VO Ctrl+Opt+U) hear "Trust
  signals, region" instead of an unnamed section. Trust-bar has
  no visible heading (just stat tiles), so aria-label is the
  correct pattern here (vs aria-labelledby for sections with a
  visible heading).
{%- endcomment -%}
<section
  class="kt-trust-bar {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="trust-bar"
  aria-label="{{ 'kt.section.trust-bar.aria_label' | t | default: 'Trust signals' }}"
>
  <div class="page-width">
    {%- if trust_configured_count == 0 and request.design_mode -%}
      {%- comment -%}
        Hardcoded inline `style="color: #57534e"` was a Theme Store
        deceptive-code/design rule violation: contrast-critical text
        rendering an inline color bypasses the merchant color
        scheme + locks reviewers' override capability. Class moved
        to assets/kt-section-trust-bar.css with `color: rgb(var(--kt-c-fg))`
        so the editor hint inherits the active scheme.
      {%- endcomment -%}
      <p class="kt-trust-bar__editor-hint">
        {{ 'kt.section.trust-bar.editor_hint' | t | default: 'Edit each stat block to add real numbers and labels — empty stats are hidden on the live storefront.' }}
      </p>
    {%- endif -%}
    <div class="kt-trust-bar__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          {%- assign stat_value = block.settings.value | default: '' -%}
          {%- assign stat_label = block.settings.label | default: '' -%}
          {%- assign stat_prefix = block.settings.prefix | default: '' -%}
          {%- assign stat_is_default = false -%}
          {%- if stat_label == 'Stat label' or stat_label == blank -%}
            {%- if stat_prefix == blank -%}
              {%- if stat_value == '0' or stat_value == blank -%}
                {%- assign stat_is_default = true -%}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
          {%- comment -%}
            Live storefront: skip default-only blocks entirely.
            Theme editor: render every block (with `--placeholder`
            modifier on default-only ones) so the merchant can
            click into it and fill in copy.
          {%- endcomment -%}
          {%- if stat_is_default == false or request.design_mode -%}
            <div class="kt-trust-bar__stat{% if stat_is_default %} kt-trust-bar__stat--placeholder{% endif %}" {{ block.shopify_attributes }}>
              <div class="kt-trust-bar__line" aria-hidden="true"></div>
              <div class="kt-trust-bar__stat-content">
                <div class="kt-trust-bar__value-row">
                  <span
                    class="kt-trust-bar__number"
                    data-count-to="{{ block.settings.value | escape }}"
                  >
                    {{ block.settings.value }}
                  </span>
                  {%- if block.settings.prefix != blank -%}
                    <span class="kt-trust-bar__prefix">{{ block.settings.prefix }}</span>
                  {%- endif -%}
                </div>
                {%- comment -%}
                  Stat label — not a page-outline heading. Previously
                  h3 and tripping Lighthouse's heading-order audit on
                  pages where the preceding section is h1/h2 and the
                  stat label jumps to h3 without intermediate h2s.
                  <p> reads as stat caption in the a11y tree instead
                  of competing in the heading outline.
                {%- endcomment -%}
                <p class="kt-trust-bar__label">{{ block.settings.label }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<script src="{{ 'kt-section-trust-bar.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.trust-bar.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        }
      ],
      "default": "auto"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "stat",
      "name": "t:sections.trust-bar.blocks.stat.name",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "t:sections.trust-bar.blocks.stat.settings.value.label",
          "default": "0"
        },
        {
          "type": "text",
          "id": "prefix",
          "label": "t:sections.trust-bar.blocks.stat.settings.prefix.label",
          "default": "Prefix"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.trust-bar.blocks.stat.settings.label.label",
          "default": "Stat label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ],
    "templates": [
      "cart",
      "search",
      "password",
      "gift_card",
      "404"
    ]
  },
  "presets": [
    {
      "name": "t:sections.trust-bar.presets.name",
      "category": "t:sections.categories.text.label",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "0",
            "prefix": "",
            "label": "Stat label"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "0",
            "prefix": "",
            "label": "Stat label"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "0",
            "prefix": "",
            "label": "Stat label"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "0",
            "prefix": "",
            "label": "Stat label"
          }
        }
      ]
    }
  ]
}
{% endschema %}
