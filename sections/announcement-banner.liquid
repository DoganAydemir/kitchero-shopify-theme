{{ 'kt-section-announcement-banner.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-announcement-banner.js' | asset_url }}" defer="defer"></script>

{%- comment -%}
  Announcement Banner — single centered message, optional inline link.

  Architecture: each merchant message is its own block. With one block
  the bar is a static thin promotional strip; with two or more blocks
  it cross-fades between them on a configurable interval (auto-rotate
  off by default to match a "calm by default" stance — merchants who
  want rotation enable it explicitly).

  Rationale: the previous bar layered a coloured badge, primary copy,
  greyed-out secondary copy, and a separate CTA pill in one strip —
  four competing visual weights inside ~40px of vertical space. Premium
  Theme Store themes (Prestige, Impulse, Empire) and DTC stores at the
  Apple / Allbirds / Glossier tier all converge on the same simpler
  pattern: one short sentence, centered, the whole sentence is the
  link if anything is clickable. We follow that pattern.
{%- endcomment -%}

{%- liquid
  assign announcement_blocks = section.blocks | where: 'type', 'announcement'
  assign block_count = announcement_blocks | size
  assign rotate_speed_ms = section.settings.rotate_speed | times: 1000
  assign should_rotate = false
  if section.settings.auto_rotate and block_count > 1
    assign should_rotate = true
  endif
-%}

<announcement-banner
  class="kt-announcement-banner"
  data-color-theme="{{ section.settings.color_theme }}"
  data-alignment="{{ section.settings.alignment }}"
  data-section-id="{{ section.id }}"
  data-block-count="{{ block_count }}"
  data-auto-rotate="{{ should_rotate }}"
  data-rotate-speed="{{ rotate_speed_ms }}"
  role="region"
  aria-label="{{ 'kt.section.announcement-banner.aria_label' | t }}"
>
  {%- if block_count > 0 -%}
    {%- comment -%}
      aria-live="polite" so screen readers announce the new message
      when the bar rotates, but only after the active screen-reader
      task is idle (won't interrupt mid-sentence).
    {%- endcomment -%}
    <div
      class="kt-announcement-banner__track"
      aria-live="polite"
      aria-atomic="true"
    >
      {%- comment -%}
        announcement_index counts only announcement-type blocks so the
        first announcement always gets the --active modifier even when
        the merchant has reordered an @app block ahead of it. forloop.first
        would have been wrong in that case.
      {%- endcomment -%}
      {%- assign announcement_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'announcement' -%}
            <div
              class="kt-announcement-banner__slide{% if announcement_index == 0 %} kt-announcement-banner__slide--active{% endif %}"
              data-slide-index="{{ announcement_index }}"
              {% if announcement_index > 0 %}aria-hidden="true"{% endif %}
              {{ block.shopify_attributes }}
            >
              {%- comment -%}
                Inactive slides have aria-hidden="true"; their inner
                anchors must also leave the keyboard tab order, otherwise
                Tab cycles through invisible links (WCAG 4.1.2). The
                tabindex="-1" on the link below mirrors the active-slide
                attribute when the slide is hidden. JS goTo() syncs both
                attributes when active slide changes.
              {%- endcomment -%}
              {%- if block.settings.link != blank and block.settings.text != blank -%}
                <a href="{{ block.settings.link | escape }}" class="kt-announcement-banner__link"{% if announcement_index > 0 %} tabindex="-1"{% endif %}>
                  <span class="kt-announcement-banner__text">{{ block.settings.text | escape }}</span>
                  {% render 'icon-arrow-right', width: 14, height: 14, class: 'kt-announcement-banner__arrow' %}
                </a>
              {%- elsif block.settings.text != blank -%}
                <span class="kt-announcement-banner__text">{{ block.settings.text | escape }}</span>
              {%- endif -%}
            </div>
            {%- assign announcement_index = announcement_index | plus: 1 -%}
          {%- when '@app' -%}
            <div class="kt-announcement-banner__app-block" {{ block.shopify_attributes }}>
              {%- render block -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%}
      Pause/play toggle — required by WCAG 2.2.2 for any auto-rotating
      content. Only renders when auto-rotate is on and there's > 1
      slide. Mirrors hero / slider-cinematic-hero pattern.
    {%- endcomment -%}
    {%- if should_rotate and block_count > 1 -%}
      <button
        type="button"
        class="kt-announcement-banner__play-toggle"
        data-announcement-play-toggle
        aria-pressed="true"
        aria-label="{{ 'kt.section.announcement-banner.toggle_autoplay' | t | default: 'Pause or play announcements' }}"
      >
        <svg class="kt-announcement-banner__icon kt-announcement-banner__icon--pause" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="6" y="4" width="4" height="16"></rect>
          <rect x="14" y="4" width="4" height="16"></rect>
        </svg>
        <svg class="kt-announcement-banner__icon kt-announcement-banner__icon--play" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
      </button>
    {%- endif -%}
  {%- endif -%}
</announcement-banner>

{% schema %}
{
  "name": "t:sections.announcement-banner.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.announcement-banner.settings.header_appearance.content"
    },
    {
      "type": "select",
      "id": "color_theme",
      "label": "t:sections.announcement-banner.settings.color_theme.label",
      "options": [
        {
          "value": "dark",
          "label": "t:sections.announcement-banner.settings.color_theme.options__1.label"
        },
        {
          "value": "light",
          "label": "t:sections.announcement-banner.settings.color_theme.options__2.label"
        },
        {
          "value": "accent",
          "label": "t:sections.announcement-banner.settings.color_theme.options__3.label"
        }
      ],
      "default": "light"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:sections.announcement-banner.settings.alignment.label",
      "options": [
        {
          "value": "center",
          "label": "t:sections.announcement-banner.settings.alignment.options__1.label"
        },
        {
          "value": "left",
          "label": "t:sections.announcement-banner.settings.alignment.options__2.label"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.announcement-banner.settings.header_rotation.content"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.announcement-banner.settings.auto_rotate.label",
      "info": "t:sections.announcement-banner.settings.auto_rotate.info",
      "default": false
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "label": "t:sections.announcement-banner.settings.rotate_speed.label",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.auto_rotate }}"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-banner.blocks.announcement.name",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.announcement-banner.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-banner.blocks.announcement.settings.link.label",
          "info": "t:sections.announcement-banner.blocks.announcement.settings.link.info"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "max_blocks": 5,
  "enabled_on": {
    "groups": ["header"]
  },
  "presets": [
    {
      "name": "t:sections.announcement-banner.presets.name",
      "settings": {
        "color_theme": "light",
        "alignment": "center",
        "auto_rotate": false,
        "rotate_speed": 5
      },
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
