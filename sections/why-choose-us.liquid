{{ 'section-why-choose-us.css' | asset_url | stylesheet_tag }}

<section class="kt-why-choose-us" data-section-id="{{ section.id }}" data-section-type="why-choose-us">
  <div class="page-width">

    {%- comment -%} Header: title left, description right {%- endcomment -%}
    <div class="kt-why-choose-us__header">
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-why-choose-us__title">
        {{ section.settings.heading_line1 | default: 'The' }}<br>{{ section.settings.heading_line2 | default: 'Standard.' }}
      </{{ heading_tag }}>
      {%- if section.settings.description != blank -%}
        <p class="kt-why-choose-us__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Cinematic Image with parallax {%- endcomment -%}
    <div class="kt-why-choose-us__image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'kt-why-choose-us__image', loading: 'lazy', widths: '750, 1100, 1600', sizes: '100vw', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.heading_line1 | append: ' ' | append: section.settings.heading_line2 }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="kt-why-choose-us__image-overlay" aria-hidden="true"></div>
    </div>

    {%- comment -%} 3-column feature grid {%- endcomment -%}
    <div class="kt-why-choose-us__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="kt-why-choose-us__feature" {{ block.shopify_attributes }}>
            <span class="kt-why-choose-us__feature-label">{{ block.settings.label }}</span>
            <h3 class="kt-why-choose-us__feature-title">{{ block.settings.title }}</h3>
            <p class="kt-why-choose-us__feature-desc">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script src="{{ 'section-why-choose-us.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "The Standard",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "The" },
    { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"},{"value":"h4","label":"H4"},{"value":"h5","label":"H5"},{"value":"h6","label":"H6"}], "default": "h2" },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2", "default": "Standard." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "We do not assemble, we orchestrate. Every material is hand-selected. Every grain matched perfectly." },
    { "type": "image_picker", "id": "image", "label": "Cinematic image" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "01 / Craftsmanship" },
        { "type": "text", "id": "title", "label": "Title", "default": "Tactile Luxury" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "From the moment you touch the handle-less drawers, you realize that true luxury is tactile." }
      ]
    }
  ],
  "presets": [
    {
      "name": "The Standard",
      "blocks": [
        { "type": "feature", "settings": { "label": "01 / Craftsmanship", "title": "Tactile Luxury", "description": "From the moment you touch the handle-less drawers, you realize that true luxury is tactile. The soft-close physics feel deliberate and engineered to perfection." } },
        { "type": "feature", "settings": { "label": "02 / Materials", "title": "Absolute Grade", "description": "Only A-grade veneers, robust European mechanics, and absolutely flawless quartz make it past our rigorous selection process. No compromises." } },
        { "type": "feature", "settings": { "label": "03 / Guarantee", "title": "Built to Outlast", "description": "Patience and precision equal longevity. A culinary space built not just for a decade, but for generations. Fully supported by our lifetime warranty." } }
      ]
    }
  ]
}
{% endschema %}
