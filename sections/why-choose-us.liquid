{{ 'section-why-choose-us.css' | asset_url | stylesheet_tag }}

<section class="kt-why-choose-us" data-section-id="{{ section.id }}" data-section-type="why-choose-us">
  <div class="kt-why-choose-us__hero">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'kt-why-choose-us__hero-image', loading: 'lazy', widths: '750, 1100, 1600', sizes: '100vw', width: section.settings.image.width, height: section.settings.image.height, alt: '' }}
    {%- endif -%}
    <h2 class="kt-why-choose-us__hero-title">{{ section.settings.heading | default: 'Why Kitchero' }}</h2>
  </div>

  <div class="kt-why-choose-us__features page-width">
    {%- for block in section.blocks -%}
      {%- if block.type == 'feature' -%}
        <div class="kt-why-choose-us__feature" {{ block.shopify_attributes }}>
          <p class="kt-why-choose-us__feature-number">{{ block.settings.number | default: forloop.index | prepend: '0' }}</p>
          <h3 class="kt-why-choose-us__feature-title">{{ block.settings.title }}</h3>
          <p class="kt-why-choose-us__feature-desc">{{ block.settings.description }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script src="{{ 'section-why-choose-us.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Why choose us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Kitchero" },
    { "type": "image_picker", "id": "image", "label": "Background image" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Feature description." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why choose us",
      "blocks": [
        { "type": "feature", "settings": { "number": "01", "title": "Handcrafted Quality", "description": "Every cabinet is built by master artisans using time-honored joinery techniques and premium materials." } },
        { "type": "feature", "settings": { "number": "02", "title": "Lifetime Warranty", "description": "We stand behind our craftsmanship with a comprehensive lifetime warranty on all structural components." } },
        { "type": "feature", "settings": { "number": "03", "title": "Sustainable Materials", "description": "Responsibly sourced hardwoods and eco-friendly finishes for a kitchen that respects the planet." } }
      ]
    }
  ]
}
{% endschema %}
