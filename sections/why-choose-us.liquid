{{ 'kt-section-why-choose-us.css' | asset_url | stylesheet_tag }}

<section class="kt-why-choose-us" data-section-id="{{ section.id }}" data-section-type="why-choose-us">
  <div class="page-width">

    {%- comment -%} Header: title left, description right {%- endcomment -%}
    <div class="kt-why-choose-us__header">
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-why-choose-us__title">
        {{ section.settings.heading_line1 | default: 'The' }}<br>{{ section.settings.heading_line2 | default: 'Standard.' }}
      </{{ heading_tag }}>
      {%- if section.settings.description != blank -%}
        <p class="kt-why-choose-us__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Cinematic Image with parallax {%- endcomment -%}
    <div class="kt-why-choose-us__image-wrap">
      {%- if section.settings.image != blank -%}
        {%- assign image_alt = section.settings.heading_line1 | append: ' ' | append: section.settings.heading_line2 -%}
        {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'kt-why-choose-us__image', loading: 'lazy', widths: '550, 750, 1100, 1600, 2000', sizes: '100vw', width: section.settings.image.width, height: section.settings.image.height, alt: image_alt }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="kt-why-choose-us__image-overlay" aria-hidden="true"></div>
    </div>

    {%- comment -%} 3-column feature grid {%- endcomment -%}
    <div class="kt-why-choose-us__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="kt-why-choose-us__feature" {{ block.shopify_attributes }}>
            <span class="kt-why-choose-us__feature-label">{{ block.settings.label }}</span>
            <h3 class="kt-why-choose-us__feature-title">{{ block.settings.title }}</h3>
            <p class="kt-why-choose-us__feature-desc">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script src="{{ 'kt-section-why-choose-us.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.why-choose-us.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.why-choose-us.settings.heading_line1.label",
      "default": "The"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.why-choose-us.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.why-choose-us.settings.heading_line2.label",
      "default": "Standard."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.why-choose-us.settings.description.label",
      "default": "We do not assemble, we orchestrate. Every material is hand-selected. Every grain matched perfectly."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.why-choose-us.settings.image.label"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.why-choose-us.blocks.feature.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.why-choose-us.blocks.feature.settings.label.label",
          "default": "01 / Craftsmanship"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.why-choose-us.blocks.feature.settings.title.label",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.why-choose-us.blocks.feature.settings.description.label",
          "default": "From the moment you touch the handle-less drawers, you realize that true luxury is tactile."
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.why-choose-us.presets.name",
      "category": "t:sections.categories.text.label",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "label": "01 / Craftsmanship",
            "title": "Feature title",
            "description": "From the moment you touch the handle-less drawers, you realize that true luxury is tactile. The soft-close physics feel deliberate and engineered to perfection."
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "02 / Materials",
            "title": "Absolute Grade",
            "description": "Only A-grade veneers, robust European mechanics, and absolutely flawless quartz make it past our rigorous selection process. No compromises."
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "03 / Guarantee",
            "title": "Built to Outlast",
            "description": "Patience and precision equal longevity. Built not just for a decade, but for generations."
          }
        }
      ]
    }
  ]
}
{% endschema %}
