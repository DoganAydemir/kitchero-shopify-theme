{{ 'kt-section-why-choose-us.css' | asset_url | stylesheet_tag }}

{%- assign why_choose_us_heading_line1_default = 'kt.section.why_choose_us.heading_line1_default' | t -%}
{%- assign why_choose_us_heading_line2_default = 'kt.section.why_choose_us.heading_line2_default' | t -%}

{%- comment -%}
  R232.51 — Default `scheme-4` (Dark Editorial). Section was
  originally designed on stone-950 surface with cream typography +
  decorative dividers; defaulting to scheme-1 made the editorial
  contrast vanish. Merchants override per-section if needed.
{%- endcomment -%}
<section class="kt-why-choose-us color-{{ section.settings.color_scheme | default: 'scheme-4' }}{% if section.settings.bg_color and section.settings.bg_color != 'auto' %} kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}" data-section-id="{{ section.id }}" data-section-type="why-choose-us" style="{% if section.settings.bg_color == 'custom' and section.settings.bg_color_custom != blank %}--kt-section-bg-custom: {{ section.settings.bg_color_custom }};{% endif %}">
  <div class="page-width">

    {%- comment -%} Header: title left, description right {%- endcomment -%}
    <div class="kt-why-choose-us__header">
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-why-choose-us__title">
        {{ section.settings.heading_line1 | default: why_choose_us_heading_line1_default }}<br>{{ section.settings.heading_line2 | default: why_choose_us_heading_line2_default }}
      </{{ heading_tag }}>
      {%- if section.settings.description != blank -%}
        <p class="kt-why-choose-us__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Cinematic Image with parallax {%- endcomment -%}
    <div class="kt-why-choose-us__image-wrap">
      {%- if section.settings.image != blank -%}
        {%- assign image_alt = section.settings.heading_line1 | append: ' ' | append: section.settings.heading_line2 -%}
        {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'kt-why-choose-us__image', loading: 'lazy', widths: '550, 750, 1100, 1600, 2000', sizes: '100vw', width: section.settings.image.width, height: section.settings.image.height, alt: image_alt }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="kt-why-choose-us__image-overlay" aria-hidden="true"></div>
    </div>

    {%- comment -%} 3-column feature grid {%- endcomment -%}
    <div class="kt-why-choose-us__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="kt-why-choose-us__feature" {{ block.shopify_attributes }}>
            <span class="kt-why-choose-us__feature-label">{{ block.settings.label | escape }}</span>
            <h3 class="kt-why-choose-us__feature-title">{{ block.settings.title | escape }}</h3>
            <p class="kt-why-choose-us__feature-desc">{{ block.settings.description | escape }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script src="{{ 'kt-section-why-choose-us.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.why-choose-us.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.why-choose-us.settings.heading_line1.label",
      "default": "The"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.why-choose-us.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.why-choose-us.settings.heading_tag.options__3.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.why-choose-us.settings.heading_line2.label",
      "default": "Standard."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.why-choose-us.settings.description.label",
      "default": "A short paragraph that introduces this section to your visitors and supports the heading above."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.why-choose-us.settings.image.label"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        { "value": "auto", "label": "t:sections.shared.bg_color.options__auto.label" },
        { "value": "white", "label": "t:sections.shared.bg_color.options__white.label" },
        { "value": "stone_50", "label": "t:sections.shared.bg_color.options__stone_50.label" },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" },
        { "value": "custom", "label": "t:sections.shared.bg_color.options__custom.label" }
      ],
      "default": "auto"
    },
    {
      "type": "color",
      "id": "bg_color_custom",
      "label": "t:sections.shared.bg_color_custom.label",
      "info": "t:sections.shared.bg_color_custom.info",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.bg_color == 'custom' }}"},
    {
      "type": "header",
      "content": "t:sections.shared.color_scheme.header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.shared.color_scheme.label",
      "default": "scheme-4"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.why-choose-us.blocks.feature.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.why-choose-us.blocks.feature.settings.label.label",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.why-choose-us.blocks.feature.settings.title.label",
          "default": "Crafted in small batches"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.why-choose-us.blocks.feature.settings.description.label",
          "default": "A short paragraph that introduces this section to your visitors and supports the heading above."
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "presets": [
    {
      "name": "t:sections.why-choose-us.presets.name",
      "category": "Story",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "label": "01",
            "title": "Feature title",
            "description": "Add a description for this feature."
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "02",
            "title": "Feature title",
            "description": "Add a description for this feature."
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "03",
            "title": "Feature title",
            "description": "Add a description for this feature."
          }
        }
      ]
    }
  ]
}
{% endschema %}
