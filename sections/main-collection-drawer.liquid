{{ 'kt-section-main-collection.css' | asset_url | stylesheet_tag }}
{{ 'kt-card-product.css' | asset_url | stylesheet_tag }}
{{ 'kt-collection-filters.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  `kt-collection--drawer-template` is the modifier class the drawer-only
  template hangs off. The shared kt-collection-filters.css ships a
  desktop rule (`@media (min-width:990px) .kt-filter-drawer { display:
  none }`) that hides the drawer on desktop because the DEFAULT template
  pairs the drawer (mobile) with an inline sidebar (desktop). This
  template has no inline sidebar — the drawer IS the only filter UI on
  every breakpoint — so we re-enable it on desktop via the modifier.
  Without the class the FILTERS button is dead silent on desktop: JS
  toggles aria-hidden correctly, but the parent stays display:none and
  nothing paints.

  data-section-type stays "main-collection" so the shared
  kt-section-main-collection.js (sticky bar + GSAP parallax + base
  drawer wiring) finds and binds this section.
{%- endcomment -%}
<div class="kt-collection kt-collection--drawer-template" data-section-id="{{ section.id }}" data-section-type="main-collection">
  {%- comment -%} Hero Header (shared) {%- endcomment -%}
  <section class="kt-collection__hero" data-collection-hero>
    <div class="kt-collection__dots-base" aria-hidden="true"></div>
    <div class="kt-collection__dots-parallax" data-parallax-dots aria-hidden="true"></div>
    <div class="kt-collection__scanlines" aria-hidden="true"></div>
    <div class="kt-collection__markers" data-parallax-markers aria-hidden="true">
      <span class="kt-collection__marker kt-collection__marker--1" aria-hidden="true">+</span>
      <span class="kt-collection__marker kt-collection__marker--2" aria-hidden="true">+</span>
      <span class="kt-collection__marker kt-collection__marker--3" aria-hidden="true">+</span>
      <span class="kt-collection__marker kt-collection__marker--4" aria-hidden="true">+</span>
    </div>
    <div class="page-width">
      <div class="kt-collection__hero-inner">
        <div>
          <p class="kt-collection__label">{{ 'kt.section.collection.label' | t | default: 'The Archives' }}</p>
          <h1 class="kt-collection__title">{{ collection.title | escape }}</h1>
          {%- if collection.description != blank -%}
            <p class="kt-collection__desc">{{ collection.description }}</p>
          {%- else -%}
            <p class="kt-collection__desc">{{ 'kt.section.collection.default_desc' | t }}</p>
          {%- endif -%}
        </div>
        <span class="kt-collection__count">
          {{ 'kt.section.collection.products_count' | t: count: collection.products_count }}
        </span>
      </div>
    </div>
  </section>

  {%- comment -%}
    Breadcrumb trail rendered immediately after the drawer hero
    closes and before the filter bar + product grid. Mirrors the
    placement used in the default collection template (main-
    collection-banner) so the visual rhythm reads identically
    regardless of which collection layout the merchant picks.
  {%- endcomment -%}
  {%- if settings.kt_show_breadcrumbs -%}
    {%- render 'breadcrumbs', class_extra: 'kt-breadcrumbs-wrap' -%}
  {%- endif -%}

  {%- comment -%} Sticky Control Bar — simple with Filter button {%- endcomment -%}
  <div class="kt-collection__controls" data-collection-controls>
    <div class="page-width">
      <div class="kt-collection__controls-inner">
        <p class="kt-collection__results-count">
          {{ 'kt.section.collection.showing' | t | default: 'Showing' }}
          {{ collection.products.size }}
          {{ 'kt.section.collection.of' | t | default: 'of' }}
          {{ collection.products_count }}
        </p>

        {%- assign active_filters_count = 0 -%}
        {%- for filter in collection.filters -%}
          {%- assign active_filters_count = active_filters_count | plus: filter.active_values.size -%}
        {%- endfor -%}

        <button class="kt-collection__filter-btn" data-open-filter-drawer type="button">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line></svg>
          <span>{{ 'kt.section.collection.filters' | t | default: 'Filters' }}{% if active_filters_count > 0 %} ({{ active_filters_count }}){% endif %}</span>
        </button>

        {%- comment -%}
          Sort dropdown — Theme Store Section 7 collection requirement.
          Auto-submits via the assets/collection-filters.js change handler
          (data-collection-sort selector). Must appear on every collection
          layout, not just the vertical/list variants.
        {%- endcomment -%}
        {%- assign drawer_sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <form class="kt-collection__sort-form" method="get" action="{{ collection.url }}" data-collection-sort-form>
          <label for="SortByDrawer" class="kt-collection__sort-label">{{ 'kt.section.collection.sort_by' | t | default: 'Sort by' }}</label>
          <select id="SortByDrawer" name="sort_by" class="kt-collection__sort-select" data-collection-sort>
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == drawer_sort_by %}selected{% endif %}>
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
          </select>
        </form>
      </div>

      {%- comment -%} Active filters {%- endcomment -%}
      {%- if active_filters_count > 0 -%}
        <div class="kt-collection__active-filters">
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              <a
                href="{{ value.url_to_remove }}"
                class="kt-collection__active-filter"
                aria-label="{{ 'kt.section.collection.remove_filter' | t: filter: value.label }}"
              >
                {{ value.label | escape }}
                {% render 'icon-close', width: 12, height: 12 %}
              </a>
            {%- endfor -%}
          {%- endfor -%}
          <a href="{{ collection.url }}" class="kt-collection__clear-all">{{ 'kt.section.collection.clear_all' | t | default: 'Clear all' }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Filter Drawer (glassmorphic right panel) {%- endcomment -%}
  {%- comment -%}
    Initial state: aria-hidden="true" (matches main-collection.liquid's
    default template + the CSS opacity-fade rule), role/aria-modal/
    aria-labelledby on the parent so SR users hear the dialog framing
    when JS sets aria-hidden="false". The overlay div uses the
    `__backdrop` BEM class — `__overlay` was a stale name that the
    shared kt-collection-filters.css never styled, leaving the click-
    outside-to-close target invisible.
  {%- endcomment -%}
  <div
    class="kt-filter-drawer"
    id="filter-drawer"
    data-filter-drawer
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-labelledby="FilterDrawerPanelTitle"
    tabindex="-1"
    inert
  >
    <div class="kt-filter-drawer__backdrop" data-close-filter-drawer aria-hidden="true"></div>
    <div class="kt-filter-drawer__panel">
      <div class="kt-filter-drawer__header">
        <h2 class="kt-filter-drawer__title" id="FilterDrawerPanelTitle">{{ 'kt.section.collection.refine' | t | default: 'Refine Search' }}</h2>
        <button type="button" class="kt-filter-drawer__close" data-close-filter-drawer aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
          {% render 'icon-close', width: 28, height: 28, stroke_width: 1.5 %}
        </button>
      </div>
      <div class="kt-filter-drawer__body" data-lenis-prevent="true">
        {%- render 'collection-filters', collection: collection -%}
      </div>
      <div class="kt-filter-drawer__footer">
        <div class="kt-filter-drawer__footer-info">
          <span class="kt-filter-drawer__footer-count">{{ collection.products_count }} {{ 'kt.section.collection.matches' | t | default: 'Matches Found' }}</span>
          {%- if active_filters_count > 0 -%}
            <a href="{{ collection.url }}" class="kt-filter__reset">{{ 'kt.section.collection.clear_all' | t | default: 'Clear All' }}</a>
          {%- endif -%}
        </div>
        {%- comment -%}
          R149 FILTER-DRAWER-JS-OFF-1: button must `type="submit"` so
          JS-off customers can submit the filter form natively.
          Previously `type="button"` paired with `data-close-filter-
          drawer` only ran the JS close handler — JS-off shoppers had
          no way to apply filter selections. The form's surrounding
          submit handles GET method navigation; the close drawer
          attribute is preserved for JS-on UX.
        {%- endcomment -%}
        <button type="submit" class="kt-filter-drawer__apply" data-close-filter-drawer>
          {{ 'kt.section.collection.show_results' | t | default: 'Show Results' }}
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} Product Grid {%- endcomment -%}
  <div class="page-width">
    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="kt-collection__grid" id="product-grid" role="list" aria-busy="false">
          {%- for product in collection.products -%}
            {%- render 'card-product', product: product, show_vendor: section.settings.kt_pdp_show_vendor, show_secondary_image: section.settings.show_secondary_image, show_quote_button: section.settings.show_quote_button, index: forloop.index0 -%}
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <div class="kt-collection__pagination">
            {%- render 'pagination', paginate: paginate -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="kt-collection__empty">
          <h2 class="kt-collection__empty-title">{{ 'kt.section.collection.no_products' | t | default: 'No products found' }}</h2>
          <p class="kt-collection__empty-text">{{ 'kt.section.collection.no_products_desc' | t }}</p>
          {%- if active_filters_count > 0 -%}
            <a href="{{ collection.url }}" class="kt-collection__clear-all">
              {{ 'kt.section.collection.clear_all' | t | default: 'Clear all filters' }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>

  {% comment %} App block slot — see main-collection.liquid for rationale. {% endcomment %}
  {% render 'section-app-blocks' %}
</div>

<script src="{{ 'kt-section-main-collection.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'collection-filters.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'collection-drawer-filter.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-collection-drawer.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 12,
      "label": "t:sections.main-collection-drawer.settings.products_per_page.label"
    },
    {
      "type": "checkbox",
      "id": "kt_pdp_show_vendor",
      "label": "t:sections.main-collection-drawer.settings.kt_pdp_show_vendor.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.main-collection-drawer.settings.show_secondary_image.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quote_button",
      "label": "t:sections.main-collection-drawer.settings.show_quote_button.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
