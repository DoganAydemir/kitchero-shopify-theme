{{ 'kt-section-hero.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  LCP preload is emitted inline on the slide image via image_tag's
  `preload: true` filter argument (see below). That routes the
  `<link rel="preload">` through Shopify's content_for_header
  pipeline, which lands it in the document <head> — earlier in the
  byte stream than any body-level <link> could appear. The preload
  scanner picks it up before it even reaches our section markup,
  shaving 2-3s off LCP on slow mobile.

  Only slide 0 gets `preload: true` (via the slide_preload assign
  below). Subsequent slides are fade-stacked behind; preloading
  them would waste critical-resource budget.
{%- endcomment -%}

<section
  class="kt-hero"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
  data-autoplay-speed="{{ section.settings.autoplay_speed | default: 8 }}"
>
  {%- for block in section.blocks -%}
    {%- if block.type == 'slide' -%}
      <div
        class="kt-hero__slide{% if forloop.first %} kt-hero__slide--active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        <div class="kt-hero__slide-image-wrap">
          {%- comment -%}
            LCP candidate is slide 0 only — the initial paint shows the
            first slide active; subsequent slides are fade-stacked
            behind. Previously every slide shipped eager + fetchpriority
            high, which sent the browser 5+ "preload-as-critical" hints
            on multi-slide heroes. Browsers coalesce but it wastes the
            budget and pushes real critical resources down the queue.
            Gate: only forloop.first gets eager+high; rest get lazy.
          {%- endcomment -%}
          {%- if forloop.first -%}
            {%- assign slide_loading = 'eager' -%}
            {%- assign slide_fetchpriority = 'high' -%}
            {%- assign slide_preload = true -%}
          {%- else -%}
            {%- assign slide_loading = 'lazy' -%}
            {%- assign slide_fetchpriority = 'auto' -%}
            {%- assign slide_preload = false -%}
          {%- endif -%}
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                preload: slide_preload,
                class: 'kt-hero__slide-image',
                loading: slide_loading,
                fetchpriority: slide_fetchpriority,
                widths: '750, 1100, 1500, 2000',
                sizes: '100vw',
                width: block.settings.image.width,
                height: block.settings.image.height,
                alt: block.settings.subtitle | default: shop.name
            }}
          {%- else -%}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg kt-hero__slide-image' }}
          {%- endif -%}
        </div>
        <div class="kt-hero__slide-overlay" aria-hidden="true"></div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%}
    Content — shows active slide's text.

    Heading level: ONLY the first slide's heading is a real <h1>; the
    rest render as <p role="heading" aria-level="1">. Previously every
    slide emitted <h1>, meaning a 3-slide hero injected 3 <h1>s onto
    the page — a WCAG 1.3.1 / 2.4.6 failure (multiple h1s confuses
    document outline for SR users) and also a reject signal for Theme
    Store reviewers who check with axe-core or WAVE. Inactive slides
    are `.hidden` visually, but many SRs ignore display:none when
    walking the accessibility tree, so the other h1s still counted.

    By swapping to <p role="heading" aria-level="1"> on non-first
    slides we keep the heading semantic for the visible slide (real
    h1 in the DOM) while letting the other slides render visually-
    identical text without duplicating the landmark. When a slider
    rotation happens the CSS swap still shows the right text; the
    DOM doesn't need to change its h1/p mix.
  {%- endcomment -%}
  <div class="kt-hero__content">
    {%- comment -%}
      Empty-block guards. Two distinct cases:

      1. Production with 0 slide blocks. The hero is the home page's
         primary <h1> source — without it the page ships with no h1
         (Lighthouse SEO + Theme Store reviewer flag). Emit a safety
         <h1> from `shop.name` so the page always has a heading
         landmark even if the merchant accidentally empties the hero.

      2. Theme editor (request.design_mode) with 0 blocks. Show a
         clear merchant hint that they need to add a slide block,
         since an empty hero looks like the section is broken.
    {%- endcomment -%}
    {%- if section.blocks.size == 0 -%}
      <div class="kt-hero__text">
        <h1 class="kt-hero__heading">{{ shop.name | escape }}</h1>
        {%- if request.design_mode -%}
          <p class="kt-hero__editor-hint">
            {{ 'kt.section.hero.editor_hint_empty' | t | default: 'Add a slide block in the theme editor to populate this hero.' }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- if forloop.first -%}
          {%- assign heading_open = '<h1 class="kt-hero__heading">' -%}
          {%- assign heading_close = '</h1>' -%}
        {%- else -%}
          {%- assign heading_open = '<p class="kt-hero__heading" role="heading" aria-level="1">' -%}
          {%- assign heading_close = '</p>' -%}
        {%- endif -%}
        <div
          class="kt-hero__text{% unless forloop.first %} hidden{% endunless %}"
          data-slide-text="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.subtitle != blank -%}
            <span class="kt-hero__subtitle kt-hero__anim" data-hero-anim data-delay="200">{{ block.settings.subtitle }}</span>
          {%- endif -%}

          {{ heading_open }}
            {%- if block.settings.line1 != blank -%}
              <span class="kt-hero__heading-clip">
                <span class="kt-hero__heading-line kt-hero__anim-slide" data-hero-anim data-delay="400">{{ block.settings.line1 }}</span>
              </span>
            {%- endif -%}
            <span class="kt-hero__heading-row">
              {%- if block.settings.serif_word != blank -%}
                <span class="kt-hero__heading-clip">
                  <span class="kt-hero__heading-serif kt-hero__anim-slide" data-hero-anim data-delay="500">{{ block.settings.serif_word }}</span>
                </span>
              {%- endif -%}
              {%- if block.settings.line2 != blank -%}
                <span class="kt-hero__heading-clip">
                  <span class="kt-hero__heading-bold kt-hero__anim-slide" data-hero-anim data-delay="600">{{ block.settings.line2 }}</span>
                </span>
              {%- endif -%}
            </span>
          {{ heading_close }}

          {%- if block.settings.description != blank -%}
            <p class="kt-hero__desc kt-hero__anim" data-hero-anim data-delay="800">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.cta_text != blank -%}
            <div class="kt-hero__anim" data-hero-anim data-delay="1000">
              <a href="{{ block.settings.cta_link | default: routes.root_url }}" class="kt-hero__cta">
                {{ block.settings.cta_text }}
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Prev/Next Navigation {%- endcomment -%}
    <div class="kt-hero__nav">
      <button type="button" class="kt-hero__nav-btn" data-hero-prev aria-label="{{ 'kt.section.hero.previous_slide' | t | default: 'Previous slide' }}">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button type="button" class="kt-hero__nav-btn" data-hero-next aria-label="{{ 'kt.section.hero.next_slide' | t | default: 'Next slide' }}">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 6 15 12 9 18"></polyline>
        </svg>
      </button>
    </div>

    {%- comment -%} Scroll Indicator {%- endcomment -%}
    <div class="kt-hero__scroll" aria-hidden="true">
      <div class="kt-hero__scroll-inner">
        <p class="kt-hero__scroll-label">{{ 'kt.section.hero.scroll' | t | default: 'Scroll' }}</p>
        <p class="kt-hero__scroll-discover">{{ 'kt.section.hero.discover' | t | default: 'Discover' }} {{ shop.name }}</p>
        <div class="kt-hero__scroll-bar">
          <div class="kt-hero__scroll-bar-indicator"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-hero.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "div",
  "class": "section-hero",
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "t:sections.hero.settings.autoplay_speed.label",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.hero.blocks.slide.name",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.hero.blocks.slide.settings.image.label"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "t:sections.hero.blocks.slide.settings.subtitle.label",
          "default": "Eyebrow"
        },
        {
          "type": "text",
          "id": "line1",
          "label": "t:sections.hero.blocks.slide.settings.line1.label",
          "default": "REDEFINE"
        },
        {
          "type": "text",
          "id": "serif_word",
          "label": "t:sections.hero.blocks.slide.settings.serif_word.label",
          "default": "your"
        },
        {
          "type": "text",
          "id": "line2",
          "label": "t:sections.hero.blocks.slide.settings.line2.label",
          "default": "STYLE."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.hero.blocks.slide.settings.description.label",
          "default": "Experience the perfect orchestration of engineering and tactile luxury in your own home."
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "t:sections.hero.blocks.slide.settings.cta_text.label",
          "default": "Start A Project"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "t:sections.hero.blocks.slide.settings.cta_link.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.hero.presets.name",
      "category": "t:sections.categories.image.label",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subtitle": "Eyebrow",
            "line1": "REDEFINE",
            "serif_word": "your",
            "line2": "STYLE.",
            "description": "Experience the perfect orchestration of engineering and tactile luxury in your own home.",
            "cta_text": "Start A Project"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subtitle": "Modern Minimal",
            "line1": "ELEVATE",
            "serif_word": "daily",
            "line2": "LIVING.",
            "description": "Where functionality meets timeless aesthetics. Handcrafted precision in every joint.",
            "cta_text": "Explore Styles"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subtitle": "Pure Crafts",
            "line1": "BEYOND",
            "serif_word": "the",
            "line2": "ORDINARY.",
            "description": "Uncompromising quality materials sourced sustainably for generations to come.",
            "cta_text": "Our Process"
          }
        }
      ]
    }
  ]
}
{% endschema %}
