{{ 'kt-section-hero.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  R144 — Slide 0 LCP optimisation. Eager loading + fetchpriority=high
  prioritise the LCP image as soon as the HTML parser reaches the
  <img> tag — equivalent treatment without spending one of the
  template's two resource-hint slots on a `<link rel="preload">`.

  `preload: true` was previously emitted on slide 0 to inject a
  preload link via Shopify's content_for_header pipeline. Combined
  with the two font preloads in layout/theme.liquid that put the
  homepage at 3 preloads/template, exceeding PRF-3's "max two
  resource hints per template" cap (Theme Store performance rule).
  The font preloads stay (heading + body fonts are render-blocking
  via @font-face); image discovery via fetchpriority is good enough
  for LCP — Lighthouse's "Preload LCP image" hint goes from green
  to amber but the metric itself stays well within budget.
{%- endcomment -%}

{%- comment -%}
  R-density: pre-compute style-vars from new merchant settings.
  Inline `style` attribute carries CSS custom properties that
  the kt-section-hero.css (and inline rules below) consume.
  Defaults match the previous hardcoded behaviour so existing
  storefronts don't regress visually after this density bump.
{%- endcomment -%}
{%- liquid
  assign hero_height_d = section.settings.section_height_desktop | default: 90
  assign hero_height_m = section.settings.section_height_mobile | default: 70
  assign hero_position = section.settings.content_position | default: 'middle-center'
  assign hero_overlay_color = section.settings.overlay_color | default: '#000000'
  assign hero_overlay_opacity = section.settings.overlay_opacity | default: 30 | divided_by: 100.0
  assign hero_text_color = section.settings.text_color | default: '#ffffff'
  assign hero_autoplay = section.settings.autoplay
  if hero_autoplay == nil
    assign hero_autoplay = true
  endif
-%}
<section
  class="kt-hero kt-hero--position-{{ hero_position }}{% unless hero_autoplay %} kt-hero--no-autoplay{% endunless %} color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
  data-autoplay="{{ hero_autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | default: 8 }}"
  data-show-pagination="{{ section.settings.show_pagination | default: true }}"
  style="--kt-hero-height-d: {{ hero_height_d }}vh; --kt-hero-height-m: {{ hero_height_m }}vh; --kt-hero-text: {{ hero_text_color }}; --kt-hero-overlay: {{ hero_overlay_color }}; --kt-hero-overlay-op: {{ hero_overlay_opacity }};"
  {%- comment -%}
    R93 — every `<section>` landmark needs an accessible name so SR
    landmarks navigation (NVDA Insert+F7, VoiceOver rotor) lists
    something more useful than "region". For sections with a
    visible heading, prefer aria-labelledby pointing to its id;
    for landmark-without-heading sections, use a literal aria-label.
    Hero is heading-driven (slide H1 announces page topic).
  {%- endcomment -%}
  aria-label="{{ 'kt.section.hero.region_label' | t | default: 'Hero' }}"
>
  {%- for block in section.blocks -%}
    {%- if block.type == 'slide' -%}
      <div
        class="kt-hero__slide{% if forloop.first %} kt-hero__slide--active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        <div class="kt-hero__slide-image-wrap">
          {%- comment -%}
            LCP candidate is slide 0 only — the initial paint shows the
            first slide active; subsequent slides are fade-stacked
            behind. Previously every slide shipped eager + fetchpriority
            high, which sent the browser 5+ "preload-as-critical" hints
            on multi-slide heroes. Browsers coalesce but it wastes the
            budget and pushes real critical resources down the queue.
            Gate: only forloop.first gets eager+high; rest get lazy.
          {%- endcomment -%}
          {%- if forloop.first -%}
            {%- assign slide_loading = 'eager' -%}
            {%- assign slide_fetchpriority = 'high' -%}
          {%- else -%}
            {%- assign slide_loading = 'lazy' -%}
            {%- assign slide_fetchpriority = 'auto' -%}
          {%- endif -%}
          {%- if block.settings.image != blank -%}
            {%- assign hero_focal = block.settings.image.presentation.focal_point | default: 'center center' -%}
            {%- comment -%}
              Pre-assign style — inline `style: 'object-position: ' |
              append: hero_focal, alt: ...` makes Liquid read the
              comma after `hero_focal` as a second arg to `append`,
              producing "wrong number of arguments (given 3, expected
              2)".
            {%- endcomment -%}
            {%- assign hero_image_style = 'object-position: ' | append: hero_focal -%}
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                class: 'kt-hero__slide-image',
                loading: slide_loading,
                fetchpriority: slide_fetchpriority,
                widths: '750, 1100, 1500, 2000',
                sizes: '100vw',
                width: block.settings.image.width,
                height: block.settings.image.height,
                style: hero_image_style,
                alt: block.settings.subtitle | default: shop.name
            }}
          {%- else -%}
            {%- comment -%}
              R182 PLACEHOLDER-VERTICAL-1: `hero-apparel-1` is
              Shopify's fashion-vertical placeholder (mannequin /
              apparel imagery). Using it on a generic kitchen /
              home-goods theme produces an off-brand first
              impression for reviewers and merchants who don't
              run apparel stores. `lifestyle-1` is the vertical-
              neutral interior/space placeholder, suitable for
              kitchen, home goods, furniture, and other lifestyle
              verticals — same set Shopify uses across Skeleton.
            {%- endcomment -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-hero__slide-image' }}
          {%- endif -%}
        </div>
        <div class="kt-hero__slide-overlay" aria-hidden="true"></div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%}
    Content — shows active slide's text.

    Heading level: ONLY the first slide's heading is a real <h1>; the
    rest render as <p role="heading" aria-level="1">. Previously every
    slide emitted <h1>, meaning a 3-slide hero injected 3 <h1>s onto
    the page — a WCAG 1.3.1 / 2.4.6 failure (multiple h1s confuses
    document outline for SR users) and also a reject signal for Theme
    Store reviewers who check with axe-core or WAVE. Inactive slides
    are `.hidden` visually, but many SRs ignore display:none when
    walking the accessibility tree, so the other h1s still counted.

    By swapping to <p role="heading" aria-level="1"> on non-first
    slides we keep the heading semantic for the visible slide (real
    h1 in the DOM) while letting the other slides render visually-
    identical text without duplicating the landmark. When a slider
    rotation happens the CSS swap still shows the right text; the
    DOM doesn't need to change its h1/p mix.
  {%- endcomment -%}
  <div class="kt-hero__content">
    {%- comment -%}
      Empty-block guards. Two distinct cases:

      1. Production with 0 slide blocks. The hero is the home page's
         primary <h1> source — without it the page ships with no h1
         (Lighthouse SEO + Theme Store reviewer flag). Emit a safety
         <h1> from `shop.name` so the page always has a heading
         landmark even if the merchant accidentally empties the hero.

      2. Theme editor (request.design_mode) with 0 blocks. Show a
         clear merchant hint that they need to add a slide block,
         since an empty hero looks like the section is broken.
    {%- endcomment -%}
    {%- if section.blocks.size == 0 -%}
      <div class="kt-hero__text">
        <h1 class="kt-hero__heading">{{ shop.name | escape }}</h1>
        {%- if request.design_mode -%}
          <p class="kt-hero__editor-hint">
            {{ 'kt.section.hero.editor_hint_empty' | t | default: 'Add a slide block in the theme editor to populate this hero.' }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- if forloop.first -%}
          {%- assign heading_open = '<h1 class="kt-hero__heading">' -%}
          {%- assign heading_close = '</h1>' -%}
        {%- else -%}
          {%- assign heading_open = '<p class="kt-hero__heading" role="heading" aria-level="1">' -%}
          {%- assign heading_close = '</p>' -%}
        {%- endif -%}
        <div
          class="kt-hero__text{% unless forloop.first %} hidden{% endunless %}"
          data-slide-text="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.subtitle != blank -%}
            <span class="kt-hero__subtitle kt-hero__anim" data-hero-anim data-delay="200">{{ block.settings.subtitle }}</span>
          {%- endif -%}

          {{ heading_open }}
            {%- if block.settings.line1 != blank -%}
              <span class="kt-hero__heading-clip">
                <span class="kt-hero__heading-line kt-hero__anim-slide" data-hero-anim data-delay="400">{{ block.settings.line1 }}</span>
              </span>
            {%- endif -%}
            <span class="kt-hero__heading-row">
              {%- if block.settings.serif_word != blank -%}
                <span class="kt-hero__heading-clip">
                  <span class="kt-hero__heading-serif kt-hero__anim-slide" data-hero-anim data-delay="500">{{ block.settings.serif_word }}</span>
                </span>
              {%- endif -%}
              {%- if block.settings.line2 != blank -%}
                <span class="kt-hero__heading-clip">
                  <span class="kt-hero__heading-bold kt-hero__anim-slide" data-hero-anim data-delay="600">{{ block.settings.line2 }}</span>
                </span>
              {%- endif -%}
            </span>
          {{ heading_close }}

          {%- if block.settings.description != blank -%}
            <p class="kt-hero__desc kt-hero__anim" data-hero-anim data-delay="800">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.cta_text != blank -%}
            <div class="kt-hero__anim" data-hero-anim data-delay="1000">
              <a href="{{ block.settings.cta_link | default: routes.root_url | escape }}" class="kt-hero__cta">
                {{ block.settings.cta_text }}
                {% render 'icon-arrow-right' %}
              </a>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Prev/Next Navigation {%- endcomment -%}
    <div class="kt-hero__nav">
      <button type="button" class="kt-hero__nav-btn" data-hero-prev aria-label="{{ 'kt.section.hero.previous_slide' | t | default: 'Previous slide' }}">
        {% render 'icon-chevron-left', width: 20, height: 20, stroke_width: 1.5 %}
      </button>
      <button type="button" class="kt-hero__nav-btn" data-hero-next aria-label="{{ 'kt.section.hero.next_slide' | t | default: 'Next slide' }}">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 6 15 12 9 18"></polyline>
        </svg>
      </button>
      {%- comment -%}
        Pause/play toggle — required by WCAG 2.2.2 for any auto-
        advancing content. Renders only when autoplay > 0 and there's
        more than one slide. Mirrors slider-cinematic-hero pattern.
      {%- endcomment -%}
      {%- if section.settings.show_play_toggle and section.settings.autoplay_speed > 0 and section.blocks.size > 1 -%}
        <button
          type="button"
          class="kt-hero__nav-btn kt-hero__nav-btn--play"
          data-hero-play-toggle
          aria-pressed="true"
          aria-label="{{ 'kt.section.hero.toggle_autoplay' | t | default: 'Pause or play slideshow' }}"
        >
          <svg class="kt-hero__icon kt-hero__icon--pause" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="4" width="4" height="16"></rect>
            <rect x="14" y="4" width="4" height="16"></rect>
          </svg>
          <svg class="kt-hero__icon kt-hero__icon--play" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
        </button>
      {%- endif -%}
    </div>

    {%- comment -%} Scroll Indicator {%- endcomment -%}
    <div class="kt-hero__scroll" aria-hidden="true">
      <div class="kt-hero__scroll-inner">
        <p class="kt-hero__scroll-label">{{ 'kt.section.hero.scroll' | t | default: 'Scroll' }}</p>
        <p class="kt-hero__scroll-discover">{{ 'kt.section.hero.discover' | t | default: 'Discover' }} {{ shop.name | escape }}</p>
        <div class="kt-hero__scroll-bar">
          <div class="kt-hero__scroll-bar-indicator"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-hero.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "div",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__layout.content"
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero.settings.section_height_desktop.label",
      "info": "t:sections.hero.settings.section_height_desktop.info",
      "default": 90
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero.settings.section_height_mobile.label",
      "default": 70
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:sections.hero.settings.content_position.label",
      "options": [
        { "value": "top-left", "label": "t:sections.hero.settings.content_position.options__top_left.label" },
        { "value": "top-center", "label": "t:sections.hero.settings.content_position.options__top_center.label" },
        { "value": "top-right", "label": "t:sections.hero.settings.content_position.options__top_right.label" },
        { "value": "middle-left", "label": "t:sections.hero.settings.content_position.options__middle_left.label" },
        { "value": "middle-center", "label": "t:sections.hero.settings.content_position.options__middle_center.label" },
        { "value": "middle-right", "label": "t:sections.hero.settings.content_position.options__middle_right.label" },
        { "value": "bottom-left", "label": "t:sections.hero.settings.content_position.options__bottom_left.label" },
        { "value": "bottom-center", "label": "t:sections.hero.settings.content_position.options__bottom_center.label" },
        { "value": "bottom-right", "label": "t:sections.hero.settings.content_position.options__bottom_right.label" }
      ],
      "default": "middle-center"
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__autoplay.content"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.hero.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "t:sections.hero.settings.autoplay_speed.label",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_play_toggle",
      "label": "t:sections.hero.settings.show_play_toggle.label",
      "info": "t:sections.hero.settings.show_play_toggle.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "t:sections.hero.settings.show_pagination.label",
      "info": "t:sections.hero.settings.show_pagination.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__overlay.content"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.hero.settings.overlay_color.label",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero.settings.overlay_opacity.label",
      "info": "t:sections.hero.settings.overlay_opacity.info",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.hero.settings.color_scheme.label",
      "info": "t:sections.hero.settings.color_scheme.info",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.hero.settings.text_color.label",
      "info": "t:sections.hero.settings.text_color.info",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.hero.blocks.slide.name",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.hero.blocks.slide.settings.image.label"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "t:sections.hero.blocks.slide.settings.subtitle.label"
        },
        {
          "type": "text",
          "id": "line1",
          "label": "t:sections.hero.blocks.slide.settings.line1.label",
          "default": "REDEFINE"
        },
        {
          "type": "text",
          "id": "serif_word",
          "label": "t:sections.hero.blocks.slide.settings.serif_word.label",
          "default": "your"
        },
        {
          "type": "text",
          "id": "line2",
          "label": "t:sections.hero.blocks.slide.settings.line2.label",
          "default": "STYLE."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.hero.blocks.slide.settings.description.label"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "t:sections.hero.blocks.slide.settings.cta_text.label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "t:sections.hero.blocks.slide.settings.cta_link.label"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.hero.presets.name",
      "category": "t:sections.categories.image.label",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subtitle": "Eyebrow",
            "line1": "REDEFINE",
            "serif_word": "your",
            "line2": "STYLE.",
            "description": "Add a short tagline that describes your brand.",
            "cta_text": "Shop now"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subtitle": "Featured",
            "line1": "ELEVATE",
            "serif_word": "daily",
            "line2": "LIVING.",
            "description": "Add a description for this slide.",
            "cta_text": "Learn more"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subtitle": "Featured",
            "line1": "BEYOND",
            "serif_word": "the",
            "line2": "ORDINARY.",
            "description": "Add a description for this slide.",
            "cta_text": "Learn more"
          }
        }
      ]
    }
  ]
}
{% endschema %}
