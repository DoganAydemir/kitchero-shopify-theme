{{ 'kt-section-testimonials.css' | asset_url | stylesheet_tag }}

{%- assign testimonials_heading_line1_default = 'kt.section.testimonials.heading_line1_default' | t -%}
{%- assign testimonials_heading_line2_default = 'kt.section.testimonials.heading_line2_default' | t -%}
{%- assign testimonials_cta_heading_line1_default = 'kt.section.testimonials.cta_heading_line1_default' | t -%}
{%- assign testimonials_cta_heading_line2_default = 'kt.section.testimonials.cta_heading_line2_default' | t -%}

{%- comment -%} Testimonials section {%- endcomment -%}
<section
  class="kt-testimonials"
  data-section-id="{{ section.id }}"
  data-section-type="testimonials"
>
  {%- comment -%} Layer 1: Dimmed background base {%- endcomment -%}
  <div
    class="kt-testimonials__bg-base{% if section.settings.background_image == blank %} kt-testimonials__bg-base--placeholder{% endif %}"
    {%- if section.settings.background_image != blank -%}
      style="background-image: url('{{ section.settings.background_image | image_url: width: 1400 }}');"
    {%- endif -%}
    aria-hidden="true"
  >
    {%- if section.settings.background_image == blank -%}
      {%- comment -%}
        R209 — back to `'lifestyle-1'` (kitchen scene line-art).
        R207 had switched to `'image'` (generic Shopify mountain-
        frame); R208 wrapped that in a light grey panel — both
        broke the section's dark cinematic mood. Now the
        kitchen-scene svg renders inside the bg-base layer at
        full white fill, and the parent's existing 0.1/0.2 dim
        cascade does its job exactly as it would with a real
        merchant photo: faintly visible by default, slightly
        brighter on hover. Spotlight reveal handled by the
        sibling layer below.
      {%- endcomment -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  {%- comment -%} Layer 2: Spotlight reveal (mouse follow) {%- endcomment -%}
  {%- comment -%}
    Note: data-testimonials-spotlight has an explicit "" value so that the
    {%- if -%} whitespace-strip below does NOT mash the boolean attribute
    name together with `style=` on the next line. Without the `=""`, the
    rendered HTML becomes `data-testimonials-spotlightstyle="..."` which
    silently breaks both the selector and the inline background image.
  {%- endcomment -%}
  {%- comment -%}
    R210 — spotlight layer in placeholder state is just a flat
    white wash. R209 tried rendering the lifestyle-1 svg as an
    inline child here, but `mask-image` reliably clips an
    element's CSS background (color or image) — propagation to
    inline-svg children is browser-inconsistent, and Chrome on
    the user's setup wasn't masking the svg. Net effect: no
    visible spotlight reveal.

    Switched to a flat `background-color` instead; the JS-driven
    radial-gradient mask clips it cleanly into the feathered
    mouse-follow circle. The CSS rule lives on the
    `--placeholder` modifier so the merchant-image branch
    (which uses background-image url) is untouched.
  {%- endcomment -%}
  <div
    class="kt-testimonials__spotlight{% if section.settings.background_image == blank %} kt-testimonials__spotlight--placeholder{% endif %}"
    data-testimonials-spotlight=""
    {%- if section.settings.background_image != blank -%}
      style="background-image: url('{{ section.settings.background_image | image_url: width: 1400 }}');"
    {%- endif -%}
    aria-hidden="true"
  ></div>

  <div class="page-width kt-testimonials__content">
    {%- comment -%} Header {%- endcomment -%}
    <div class="kt-testimonials__header">
      <div>
        {%- if section.settings.label != blank -%}
          <p class="kt-testimonials__label">{{ section.settings.label }}</p>
        {%- endif -%}
        {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
        <{{ heading_tag }} class="kt-testimonials__title">
          {{ section.settings.heading_line1 | default: testimonials_heading_line1_default }}<br>{{ section.settings.heading_line2 | default: testimonials_heading_line2_default }}
        </{{ heading_tag }}>
      </div>
      {%- if section.settings.description != blank -%}
        <p class="kt-testimonials__header-desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Testimonial cards {%- endcomment -%}
    <div class="kt-testimonials__grid">
      {%- if section.blocks.size == 0 and request.design_mode -%}
        <p class="kt-testimonials__editor-hint">
          {{ 'kt.section.testimonials.editor_hint_empty' | t | default: 'Add testimonial blocks in the theme editor to populate this section.' }}
        </p>
      {%- endif -%}
      {%- for block in section.blocks -%}
        {%- comment -%}
          R167 DEMO-PLACEHOLDER-COPY-1: skip blocks where the
          merchant hasn't supplied a quote yet. Prior behaviour
          rendered an empty `&ldquo;&rdquo;` blockquote — visible
          to Theme Store reviewers as a "broken" demo card on the
          storefront preview. With the schema defaults stripped of
          instruction-style placeholder copy ("Add your customer's
          testimonial here…"), an unconfigured block now has an
          empty quote field and we cleanly elide it instead of
          shipping an empty-quote card.
        {%- endcomment -%}
        {%- if block.type == 'testimonial' and block.settings.quote != blank -%}
          <div class="kt-testimonials__card" {{ block.shopify_attributes }}>
            <div class="kt-testimonials__quote-icon" aria-hidden="true">
              <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
            </div>

            <blockquote class="kt-testimonials__quote-text">
              &ldquo;{{ block.settings.quote }}&rdquo;
            </blockquote>

            {%- comment -%}
              Author block — only render when the merchant has
              filled in at least the name. Without this gate, an
              author-less testimonial (a brand-voice quote, for
              example) would render an empty `<cite>` with the
              avatar placeholder still drawn beside it, which
              looks like a broken card in production previews.
            {%- endcomment -%}
            {%- if block.settings.name != blank or block.settings.avatar != blank -%}
              <div class="kt-testimonials__author">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 96 | image_tag: class: 'kt-testimonials__avatar', loading: 'lazy', width: 48, height: 48, alt: block.settings.name | default: '' }}
                {%- elsif block.settings.name != blank -%}
                  {%- comment -%}
                    Avatar is optional; when the merchant gave us a
                    name but no image we render an inline user
                    silhouette so the card composition stays
                    balanced. R207 swapped Shopify's lifestyle-1
                    placeholder out — squashing a kitchen scene
                    SVG into a 48px circle read as visual noise
                    rather than "no avatar yet". A simple
                    head-and-shoulders glyph (lucide User pattern)
                    centred inside the same circular slot makes
                    the missing-photo state unambiguous.
                  {%- endcomment -%}
                  <div class="kt-testimonials__avatar kt-testimonials__avatar--placeholder" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  </div>
                {%- endif -%}
                {%- if block.settings.name != blank -%}
                  <div>
                    <cite class="kt-testimonials__author-name">{{ block.settings.name }}</cite>
                    {%- if block.settings.role != blank -%}
                      <p class="kt-testimonials__author-role">{{ block.settings.role }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} CTA Block — "READY TO BEGIN?" with text masking {%- endcomment -%}
{%- if section.settings.show_cta_block -%}
  <section class="kt-testimonials-cta">
    <div class="page-width kt-testimonials-cta__inner">
      {%- comment -%}
        Title uses `background-clip: text` so the CTA headline becomes a
        window onto whatever background-image is set. When the merchant
        picks an image we emit the inline style (the image URL is
        dynamic, so it must be inline); otherwise the default fallback
        gradient from the CSS file takes over — no inline style needed.
      {%- endcomment -%}
      <{{ heading_tag }} class="kt-testimonials-cta__title"
        {%- if section.settings.cta_background_image != blank -%}
          style="background-image: url('{{ section.settings.cta_background_image | image_url: width: 1600 }}');"
        {%- endif -%}
      >
        {{ section.settings.cta_heading_line1 | default: testimonials_cta_heading_line1_default }}<br>{{ section.settings.cta_heading_line2 | default: testimonials_cta_heading_line2_default }}
      </{{ heading_tag }}>

      {%- if section.settings.cta_button_text != blank -%}
        <div class="kt-testimonials-cta__action">
          <a href="{{ section.settings.cta_button_link | default: routes.root_url | escape }}" class="kt-testimonials-cta__btn">
            <span>{{ section.settings.cta_button_text }}</span>
            <span class="kt-testimonials-cta__btn-arrow" aria-hidden="true">
              <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

<script src="{{ 'kt-section-testimonials.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.testimonials.settings.header__header.content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.testimonials.settings.label.label",
      "default": "Customer voices"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.testimonials.settings.heading_line1.label",
      "default": "What our customers"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.testimonials.settings.heading_line2.label",
      "default": "are saying"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.testimonials.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.testimonials.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.testimonials.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.testimonials.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.testimonials.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.testimonials.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.testimonials.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.testimonials.settings.description.label"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.testimonials.settings.background_image.label"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.settings.header__cta.content"
    },
    {
      "type": "checkbox",
      "id": "show_cta_block",
      "label": "t:sections.testimonials.settings.show_cta_block.label",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_heading_line1",
      "label": "t:sections.testimonials.settings.cta_heading_line1.label",
      "visible_if": "{{ section.settings.show_cta_block }}",
      "default": "Ready to"
    },
    {
      "type": "text",
      "id": "cta_heading_line2",
      "label": "t:sections.testimonials.settings.cta_heading_line2.label",
      "visible_if": "{{ section.settings.show_cta_block }}",
      "default": "begin?"
    },
    {
      "type": "image_picker",
      "id": "cta_background_image",
      "label": "t:sections.testimonials.settings.cta_background_image.label",
      "visible_if": "{{ section.settings.show_cta_block }}"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "t:sections.testimonials.settings.cta_button_text.label",
      "visible_if": "{{ section.settings.show_cta_block }}",
      "default": "Get in touch"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "t:sections.testimonials.settings.cta_button_link.label",
      "visible_if": "{{ section.settings.show_cta_block }}"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "limit": 9,
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.settings.quote.label"
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.testimonials.blocks.testimonial.settings.name.label"
        },
        {
          "type": "text",
          "id": "role",
          "label": "t:sections.testimonials.blocks.testimonial.settings.role.label"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "t:sections.testimonials.blocks.testimonial.settings.avatar.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.testimonials.presets.name",
      "category": "t:sections.categories.text.label",
      "settings": {
        "label": "Customer voices",
        "heading_line1": "What our customers",
        "heading_line2": "are saying",
        "description": "We believe great spaces are the heart of the home. Here is how customers experience the convergence of form and function.",
        "show_cta_block": true,
        "cta_heading_line1": "Ready to",
        "cta_heading_line2": "begin?",
        "cta_button_text": "Button label"
      },
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Quality you can see, craftsmanship you can feel."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Designed for your home, built to last."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "From design to delivery, every detail matters."
          }
        }
      ]
    }
  ]
}
{% endschema %}
