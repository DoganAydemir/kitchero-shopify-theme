{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}
{{ 'kt-section-customer-account.css' | asset_url | stylesheet_tag }}

<section class="kt-password" data-section-id="{{ section.id }}">
  {%- if section.settings.logo != blank -%}
    {{ section.settings.logo | image_url: width: 320 | image_tag:
      loading: 'eager',
      fetchpriority: 'high',
      width: section.settings.logo.width,
      height: section.settings.logo.height,
      class: 'kt-password__logo',
      alt: section.settings.logo.alt | default: shop.name
    }}
  {%- else -%}
    <h1 class="kt-password__shop-name">{{ shop.name }}</h1>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="kt-password__heading">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  {%- if section.settings.message != blank -%}
    <div class="kt-password__message rte">{{ section.settings.message }}</div>
  {%- endif -%}

  {%- form 'storefront_password', class: 'kt-password__form' -%}
    {%- comment -%}
      Per-field error pattern — same as the other customer forms (login,
      register, reset_password). `form.errors | default_errors` was a
      quick-start but it renders in a generic container and doesn't
      associate the error with the password input via aria-describedby,
      so SR users who land on the input after a failed submit hear no
      error context. The id below is consumed by the input's
      aria-describedby guard.
    {%- endcomment -%}
    {%- if form.errors -%}
      <div
        id="PasswordForm-error"
        class="kt-password__errors"
        role="alert"
        tabindex="-1"
      >
        {{ 'kt.password.error' | t | default: 'Incorrect password — please try again.' }}
      </div>
    {%- endif -%}

    <label for="PasswordInput" class="visually-hidden">{{ 'kt.password.label' | t }}</label>
    <input
      type="password"
      id="PasswordInput"
      name="password"
      class="kt-password__input"
      placeholder="{{ 'kt.password.label' | t }}"
      autocomplete="current-password"
      required
      aria-invalid="{% if form.errors %}true{% else %}false{% endif %}"
      {%- if form.errors %} aria-describedby="PasswordForm-error"{% endif -%}
    >

    <button type="submit" class="kt-customer__submit">
      {{ 'kt.password.submit' | t }}
    </button>
  {%- endform -%}

  {%- comment -%}
    Newsletter — uses Shopify's built-in `customer` form with a
    `contact[tags]=newsletter` hidden input so the submitter lands in
    the "Accepts marketing" customer list tagged "newsletter". The same
    pattern is used in the footer; sharing the tag lets merchants run a
    single pre-launch mailing list for both surfaces. Shown only when
    the merchant hasn't turned it off in the editor.
  {%- endcomment -%}
  {%- if section.settings.show_newsletter -%}
    <div class="kt-password__newsletter">
      {%- if section.settings.newsletter_heading != blank -%}
        <h3 class="kt-password__newsletter-heading">{{ section.settings.newsletter_heading }}</h3>
      {%- endif -%}
      {%- form 'customer', id: 'PasswordNewsletter', class: 'kt-password__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="kt-password__newsletter-success" role="status" tabindex="-1">
            {{ 'kt.section.newsletter-popup.success' | t | default: 'Thanks for subscribing.' }}
          </p>
        {%- else -%}
          <div class="kt-password__newsletter-row">
            <label for="PasswordNewsletterEmail" class="visually-hidden">{{ 'kt.newsletter.label' | t }}</label>
            <input
              type="email"
              id="PasswordNewsletterEmail"
              name="contact[email]"
              class="kt-password__input kt-password__newsletter-input"
              placeholder="{{ 'kt.newsletter.label' | t }}"
              autocomplete="email"
              required
              aria-invalid="{% if form.errors %}true{% else %}false{% endif %}"
              {%- comment -%}
                Only link aria-describedby to the error paragraph when the
                paragraph actually renders (the `{%- if form.errors -%}`
                block below). Previously the attribute was unconditional,
                leaving a dangling id ref on successful first load → WCAG
                4.1.2 failure flagged by axe/WAVE.
              {%- endcomment -%}
              {%- if form.errors %} aria-describedby="PasswordNewsletter-error"{% endif -%}
            >
            <button type="submit" class="kt-customer__submit kt-password__newsletter-btn">
              {{ 'kt.newsletter.button_label' | t }}
            </button>
          </div>
          {%- if form.errors -%}
            <p class="kt-password__newsletter-error" id="PasswordNewsletter-error" role="alert">
              {%- for field in form.errors -%}
                {{ form.errors.messages[field] }}{% unless forloop.last %} · {% endunless %}
              {%- endfor -%}
            </p>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </div>
  {%- endif -%}

  {%- comment -%}
    Social links — pulls from the global theme settings (settings.
    kt_social_*), identical to the footer so the merchant only
    configures them once. Snippet self-suppresses when all settings
    are blank, so the wrapper <div> appears empty in that case; we
    still gate on the checkbox so merchants can hide icons on the
    coming-soon page even when the live store shows them.
  {%- endcomment -%}
  {%- if section.settings.show_social -%}
    <div class="kt-password__social">
      {%- render 'social-icons' -%}
    </div>
  {%- endif -%}

  <p class="kt-password__footer">
    {{ 'kt.password.owner_html' | t: admin_url: shop.url | append: '/admin' }}
    &middot;
    {{ powered_by_link }}
  </p>
</section>

{% schema %}
{
  "name": "t:sections.main-password.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.main-password.settings.logo.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main-password.settings.heading.label"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "t:sections.main-password.settings.message.label",
      "default": "<p>Opening soon. Sign up to get notified.</p>"
    },
    {
      "type": "header",
      "content": "t:sections.main-password.settings.header__newsletter.content"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.main-password.settings.show_newsletter.label",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:sections.main-password.settings.newsletter_heading.label",
      "default": "Get notified when we open"
    },
    {
      "type": "header",
      "content": "t:sections.main-password.settings.header__social.content"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:sections.main-password.settings.show_social.label",
      "info": "t:sections.main-password.settings.show_social.info",
      "default": true
    }
  ]
}
{% endschema %}
