{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}
{{ 'kt-section-customer-account.css' | asset_url | stylesheet_tag }}

<section class="kt-customer kt-customer--wide" data-section-id="{{ section.id }}" data-section-type="main-account">
  <div class="kt-customer__container kt-customer__container--wide">
    <header class="kt-account__header">
      <h1 class="kt-customer__title">{{ 'kt.customer.account.title' | t }}</h1>
      {%- if customer.first_name != blank -%}
        <p class="kt-account__greeting">
          {%- comment -%}
            The translation key is `_html`-suffixed so the full t-output
            is intentionally rendered as HTML (the localized string
            wraps the name in <strong>). That trust applies to the
            translation template, NOT to the interpolated `name:`
            argument — customer.first_name is set during account
            creation and is user-supplied. Pre-escape the variable
            before passing into t so the _html branch can't reflect
            raw markup from a malicious sign-up.
          {%- endcomment -%}
          {%- assign safe_first_name = customer.first_name | escape -%}
          {{ 'kt.customer.account.greeting_html' | t: name: safe_first_name }}
        </p>
      {%- endif -%}

      {%- comment -%}
        B2B customer hint. `customer.b2b?` is true when the signed-in
        customer is a Shopify B2B (wholesale) buyer. When they're
        logged in on behalf of a company, `customer.current_location`
        exposes the active company/location. Without this surface,
        a B2B buyer has no visual confirmation which company they're
        placing orders for — a real concern for anyone with purchasing
        rights at multiple legal entities. Gated on the presence of
        the B2B object so the pill never renders for retail customers.
      {%- endcomment -%}
      {%- if customer.b2b? -%}
        <div class="kt-account__b2b" role="note">
          <span class="kt-account__b2b-badge">{{ 'kt.customer.account.b2b_badge' | t | default: 'Business account' }}</span>
          {%- if customer.current_location and customer.current_location.company.name != blank -%}
            <span class="kt-account__b2b-company">
              {{ 'kt.customer.account.b2b_company' | t: name: customer.current_location.company.name | default: customer.current_location.company.name }}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </header>

    <div class="kt-account__layout">
      {%- render 'account-nav', current: 'details' -%}

      {%- comment -%} Main content: orders list {%- endcomment -%}
      <div class="kt-account__content">
        <h2 class="kt-account__section-title">{{ 'kt.customer.account.orders' | t }}</h2>

        {%- paginate customer.orders by 20 -%}
          {%- if customer.orders.size > 0 -%}
            <div class="kt-account__orders-wrap">
              {%- comment -%}
                Native &lt;table&gt; already carries implicit role="table".
                Explicit `role="table"` on a real table is redundant
                ARIA and fails axe-core's `aria-allowed-role` check
                (WCAG 4.1.2). The scope="col"/scope="row" + caption
                below give SR users the structure they need.
              {%- endcomment -%}
              <table class="kt-account__orders">
                <caption class="visually-hidden">{{ 'kt.customer.orders.caption' | t }}</caption>
                <thead>
                  <tr>
                    <th scope="col">{{ 'kt.customer.orders.order_number' | t }}</th>
                    <th scope="col">{{ 'kt.customer.orders.date' | t }}</th>
                    <th scope="col">{{ 'kt.customer.orders.payment_status' | t }}</th>
                    <th scope="col">{{ 'kt.customer.orders.fulfillment_status' | t }}</th>
                    <th scope="col" class="kt-account__col-right">{{ 'kt.customer.orders.total' | t }}</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for order in customer.orders -%}
                    <tr>
                      <th scope="row" data-label="{{ 'kt.customer.orders.order_number' | t }}">
                        <a href="{{ order.customer_url }}" class="kt-account__order-link">
                          {{ order.name }}
                        </a>
                      </th>
                      <td data-label="{{ 'kt.customer.orders.date' | t }}">
                        <time datetime="{{ order.created_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
                          {{ order.created_at | date: format: 'date' }}
                        </time>
                      </td>
                      <td data-label="{{ 'kt.customer.orders.payment_status' | t }}">
                        <span class="kt-account__pill kt-account__pill--{{ order.financial_status }}">
                          {{ order.financial_status_label }}
                        </span>
                      </td>
                      <td data-label="{{ 'kt.customer.orders.fulfillment_status' | t }}">
                        <span class="kt-account__pill kt-account__pill--{{ order.fulfillment_status | default: 'unfulfilled' }}">
                          {{ order.fulfillment_status_label }}
                        </span>
                      </td>
                      <td data-label="{{ 'kt.customer.orders.total' | t }}" class="kt-account__col-right">
                        {{ order.total_price | money }}
                      </td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>

            {%- if paginate.pages > 1 -%}
              {%- render 'pagination', paginate: paginate -%}
            {%- endif -%}
          {%- else -%}
            <div class="kt-account__empty">
              <p>{{ 'kt.customer.orders.none' | t }}</p>
              <a href="{{ routes.all_products_collection_url }}" class="kt-account__cta">
                {{ 'kt.customer.orders.start_shopping' | t }}
              </a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>

  {%- comment -%}
    App-block render slot — sits BELOW the orders table so merchants can
    append loyalty widgets, referral CTAs, rewards summaries, etc. The
    `{"type": "@app"}` in the schema below is a Theme Store hard
    requirement — without it, loyalty / referral app vendors can't
    attach UI to the customer account.
  {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="kt-account__app-blocks">
      <div class="page-width">
        {%- for block in section.blocks -%}
          {%- if block.type == '@app' -%}
            <div class="kt-account__app-block" {{ block.shopify_attributes }}>
              {%- render block -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/account"]
  },
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
