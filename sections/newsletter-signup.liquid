{{ 'kt-section-newsletter-signup.css' | asset_url | stylesheet_tag }}

<section class="kt-newsletter-page" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="kt-newsletter-page__inner">
      <span class="kt-newsletter-page__label">{{ section.settings.label | default: 'Stay Connected' }}</span>
      {%- assign heading_tag = section.settings.heading_tag | default: 'h1' -%}
      <{{ heading_tag }} class="kt-newsletter-page__title">{{ section.settings.heading | default: 'Join the Kitchero Circle' }}</{{ heading_tag }}>
      <p class="kt-newsletter-page__desc">{{ section.settings.description | default: 'Be the first to receive new collection launches, exclusive design insights, and member-only offers.' }}</p>

      {%- form 'customer', id: 'NewsletterPageForm', class: 'kt-newsletter-page__form-wrap' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="kt-newsletter-page__success" role="status">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4 4 10-10"/></svg>
            <span>{{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}</span>
          </div>
        {%- else -%}
          <div class="kt-newsletter-page__form">
            <label for="newsletter-page-email" class="visually-hidden">{{ 'newsletter.label' | t }}</label>
            <input
              type="email"
              id="newsletter-page-email"
              name="contact[email]"
              class="kt-newsletter-page__input"
              placeholder="{{ 'newsletter.label' | t | default: 'Email' }}"
              required
              autocomplete="email"
              aria-invalid="{% if form.errors %}true{% else %}false{% endif %}"
              aria-describedby="NewsletterPageForm-error"
            >
            <button type="submit" class="kt-newsletter-page__btn" name="commit">
              {{ 'newsletter.button_label' | t | default: 'Subscribe' }}
            </button>
          </div>

          {%- if form.errors -%}
            <p class="kt-newsletter-page__error" id="NewsletterPageForm-error" role="alert">
              {%- for field in form.errors -%}
                {{ form.errors.messages[field] }}{% unless forloop.last %} · {% endunless %}
              {%- endfor -%}
            </p>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}

      <p class="kt-newsletter-page__note">{{ section.settings.note | default: 'We respect your privacy. Unsubscribe at any time.' }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.newsletter-signup.name",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "t:sections.newsletter-signup.settings.label.label", "default": "Stay Connected" },
    { "type": "text", "id": "heading", "label": "t:sections.newsletter-signup.settings.heading.label", "default": "Join the Kitchero Circle" },
    { "type": "select", "id": "heading_tag", "label": "t:sections.newsletter-signup.settings.heading_tag.label", "options": [{"value":"h1","label":"t:sections.newsletter-signup.settings.heading_tag.options__1.label"},{"value":"h2","label":"t:sections.newsletter-signup.settings.heading_tag.options__2.label"}], "default": "h1" },
    { "type": "textarea", "id": "description", "label": "t:sections.newsletter-signup.settings.description.label", "default": "Be the first to receive new collection launches, exclusive design insights, and member-only offers." },
    { "type": "text", "id": "note", "label": "t:sections.newsletter-signup.settings.note.label", "default": "We respect your privacy. Unsubscribe at any time." }
  ]
}
{% endschema %}
