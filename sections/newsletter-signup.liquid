{{ 'kt-section-newsletter-signup.css' | asset_url | stylesheet_tag }}

{%- assign newsletter_signup_label_default = 'kt.section.newsletter_signup.label_default' | t -%}
{%- assign newsletter_signup_heading_default = 'kt.section.newsletter_signup.heading_default' | t -%}
{%- assign newsletter_signup_description_default = 'kt.section.newsletter_signup.description_default' | t -%}
{%- assign newsletter_signup_consent_label_default = 'kt.section.newsletter.consent_label_default' | t -%}
{%- assign newsletter_signup_note_default = 'kt.section.newsletter_signup.note_default' | t -%}

<section class="kt-newsletter-page {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="kt-newsletter-page__inner">
      <span class="kt-newsletter-page__label">{{ section.settings.label | default: newsletter_signup_label_default }}</span>
      {%- comment -%}
        R105 — fallback aligned with schema default (h2). Schema's
        `heading_tag` setting defaults to "h2" but the liquid
        fallback was "h1" — if a merchant programmatically cleared
        the value, the page would emit a duplicate h1 (next to
        page-header-dotted's h1) and break heading hierarchy.
      {%- endcomment -%}
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-newsletter-page__title">{{ section.settings.heading | default: newsletter_signup_heading_default }}</{{ heading_tag }}>
      <p class="kt-newsletter-page__desc">{{ section.settings.description | default: newsletter_signup_description_default }}</p>

      {%- form 'customer', id: 'NewsletterPageForm', class: 'kt-newsletter-page__form-wrap' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- comment -%}
          Removed the `contact[accepts_marketing]=true` hidden field.
          Pre-flagging marketing consent via a server-forced default
          violates GDPR Article 7 / ePrivacy (consent must be
          explicit, granular, informed) and is a Theme Store reject
          signal. Submitting this form creates the customer record;
          the merchant's Shopify-native double-opt-in confirmation
          email is what produces the legally-valid consent. Follows
          Shopify's recommended GDPR-compliant marketing-consent flow.
        {%- endcomment -%}

        {%- if form.posted_successfully? -%}
          <div class="kt-newsletter-page__success" role="status">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4 4 10-10"/></svg>
            <span>{{ 'kt.newsletter.success' | t | default: 'Thanks for subscribing!' }}</span>
          </div>
        {%- else -%}
          <div class="kt-newsletter-page__form">
            {%- comment -%}
              The email field and Subscribe button must stay together
              on one row (flex parent). The consent <p> used to be a
              sibling of the input+button — which made it a 3rd flex
              item that ate horizontal space and forced the long
              "I agree to receive..." copy to wrap word-by-word,
              squashing the button into a square. Splitting the row
              into its own wrapper isolates the input/button flex
              context; the consent paragraph lives one level up and
              flows naturally on its own line BELOW the row.
            {%- endcomment -%}
            <div class="kt-newsletter-page__form-row">
            <label for="newsletter-page-email" class="visually-hidden">{{ 'kt.newsletter.label' | t }}</label>
            <input
              type="email"
              autocapitalize="off"
              autocorrect="off"
              spellcheck="false"
              id="newsletter-page-email"
              name="contact[email]"
              class="kt-newsletter-page__input"
              placeholder="{{ 'kt.newsletter.label' | t | default: 'Email' }}"
              required
              aria-required="true"
              maxlength="254"
              inputmode="email"
              {%- comment -%}
                R104 — `enterkeyhint="send"` swaps the iOS/Android Return
                key glyph to a "Send" affordance, so the customer doesn't
                have to dismiss the keyboard and reach for the Subscribe
                button. Single-field newsletter submits straight from the
                keyboard.
              {%- endcomment -%}
              enterkeyhint="send"
              autocomplete="email"
              {%- comment -%}
                R96 — preserve typed email across validation errors.
              {%- endcomment -%}
              value="{{ form.email | escape }}"
              {%- comment -%}
                R139 ARIA-DBY-1: only emit aria-describedby when the
                referenced error region actually renders. The
                `<p id="NewsletterPageForm-error">` only exists inside
                `{%- if form.errors -%}`; emitting the attribute
                unconditionally pointed at a missing ID and NVDA logged
                a "described element not found" warning while AXE
                flagged it as a 4.1.2 issue. Conditional emission keeps
                the binding sound while still describing the field
                whenever errors render.
              {%- endcomment -%}
              {%- if form.errors -%}
                aria-invalid="true"
                aria-describedby="NewsletterPageForm-error"
              {%- else -%}
                aria-invalid="false"
              {%- endif -%}
            >

            {%- comment -%}
              Honeypot — invisible to humans, populated by naive bots.
              Backend can reject submissions where contact[website] is
              non-empty. Field uses .kt-form__honeypot positioning trick
              (off-screen, not display:none) so determined bots that
              skip hidden fields still trip it.
            {%- endcomment -%}
            <p class="kt-form__honeypot" aria-hidden="true" inert>
              <label for="newsletter-page-website-trap">{{ 'kt.a11y.honeypot' | t | default: 'Leave this field empty' }}</label>
              <input type="text" id="newsletter-page-website-trap" name="contact[website]" tabindex="-1" autocomplete="off" aria-hidden="true">
            </p>
            <button type="submit" class="kt-newsletter-page__btn" name="commit">
              {{ 'kt.newsletter.button_label' | t | default: 'Subscribe' }}
            </button>
            </div>
            {%- comment -%}
              R122 — Explicit GDPR/UK GDPR/CCPA consent checkbox.
              Initially UNCHECKED + HTML5 `required` so submission
              is gated on affirmative customer opt-in (per GDPR
              Art. 7 — consent must be freely given, specific,
              informed, unambiguous). Merchants outside EU/UK who
              don't need this can disable via the section setting.
              We deliberately do NOT submit `contact[accepts_marketing]`
              — Shopify's native double-opt-in confirmation email
              is what produces the legally-valid consent record;
              this checkbox is purely the front-of-form gate.
              See R96 comment block for the pre-existing rationale.

              Sibling of __form-row (not inside it) so the consent
              copy gets the FULL form width as a single line of text
              instead of being squeezed into a flex column.
            {%- endcomment -%}
            {%- if section.settings.show_consent_checkbox -%}
              {%- comment -%}
                Wrapper is a <div>, NOT a <p>. The richtext consent
                label renders as `<p>I agree…</p>`. Putting that
                inside an outer <p> is invalid nesting; the HTML5
                parser auto-closes the outer <p> the moment it sees
                the inner one, which orphans the label's text into
                a sibling block AND splits it from the checkbox.
                That's why the visible output collapsed to:

                  ☐
                  I agree to receive marketing emails. I can…
                  (text centered, sitting under the box)

                The richtext's surrounding <p> tags are also stripped
                here so the label's *contents* (inline phrasing only)
                sit cleanly inside the <label> element — `<p>` is
                invalid inside <label> (phrasing-content model), and
                even where browsers tolerate it the block-level <p>
                forces a line break before the text. Inline strong/
                em/a tags from the richtext editor pass through
                untouched.
              {%- endcomment -%}
              {%- assign consent_html = section.settings.consent_label | default: newsletter_signup_consent_label_default -%}
              {%- assign consent_html = consent_html | replace: '<p>', '' | replace: '</p>', '' -%}
              <div class="kt-newsletter-page__consent">
                <input
                  type="checkbox"
                  id="newsletter-page-consent"
                  name="contact[accepts_marketing]"
                  value="true"
                  required
                  aria-required="true"
                >
                <label for="newsletter-page-consent" class="kt-newsletter-page__consent-label">
                  {{- consent_html -}}
                </label>
              </div>
            {%- endif -%}
          </div>

          {%- if form.errors -%}
            <p class="kt-newsletter-page__error" id="NewsletterPageForm-error" role="alert">
              {%- for field in form.errors -%}
                {{ form.errors.translated_messages[field] }}{% unless forloop.last %} · {% endunless %}
              {%- endfor -%}
            </p>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}

      <p class="kt-newsletter-page__note">
        {{ section.settings.note | default: newsletter_signup_note_default }}
        {%- if shop.privacy_policy != blank %}
          <a href="{{ shop.privacy_policy.url }}" class="kt-newsletter-page__note-link">{{ shop.privacy_policy.title }}</a>
        {%- endif -%}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.newsletter-signup.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.newsletter-signup.settings.label.label",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.newsletter-signup.settings.heading.label",
      "default": "Join our newsletter"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.newsletter-signup.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.newsletter-signup.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.newsletter-signup.settings.heading_tag.options__2.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.newsletter-signup.settings.description.label",
      "default": "Add a description for this section."
    },
    {
      "type": "text",
      "id": "note",
      "label": "t:sections.newsletter-signup.settings.note.label",
      "default": "We respect your privacy. Unsubscribe at any time."
    },
    {
      "type": "header",
      "content": "t:sections.newsletter-signup.settings.header__consent.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.newsletter-signup.settings.header__consent.info"
    },
    {
      "type": "checkbox",
      "id": "show_consent_checkbox",
      "label": "t:sections.newsletter-signup.settings.show_consent_checkbox.label",
      "info": "t:sections.newsletter-signup.settings.show_consent_checkbox.info",
      "default": false
    },
    {
      "type": "richtext",
      "id": "consent_label",
      "label": "t:sections.newsletter-signup.settings.consent_label.label",
      "info": "t:sections.newsletter-signup.settings.consent_label.info",
      "default": "<p>I agree to receive marketing emails. I can unsubscribe at any time.</p>"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter-signup.presets.name"
    }
  ]
}
{% endschema %}
