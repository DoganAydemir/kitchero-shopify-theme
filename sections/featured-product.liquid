{{ 'kt-section-featured-product.css' | asset_url | stylesheet_tag }}
{{ 'kt-product-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = all_products[section.settings.product]
  assign current_variant = product.selected_or_first_available_variant
  if product != blank and product.featured_media != blank
    assign media_ratio = product.featured_media.preview_image.aspect_ratio | default: 1
    assign media_height = 1200 | divided_by: media_ratio | round
  endif
-%}

<section
  class="kt-featured-product color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
  data-section-id="{{ section.id }}"
  data-section-type="featured-product"
  aria-label="{{ 'kt.section.featured_product.region_label' | t | default: 'Featured product' }}"
>
  <div class="page-width">
    <div class="kt-featured-product__layout">
      {%- comment -%} Media {%- endcomment -%}
      <div class="kt-featured-product__media">
        {%- if product != blank and product.featured_media != blank -%}
          {%- assign media_alt = product.featured_media.alt | default: product.title -%}
          {{
            product.featured_media
            | image_url: width: 1200
            | image_tag:
              class: 'kt-featured-product__image',
              widths: '400, 600, 900, 1200',
              sizes: '(min-width: 1024px) 50vw, 100vw',
              width: 1200,
              height: media_height,
              alt: media_alt,
              loading: 'lazy'
          }}
        {%- else -%}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg kt-featured-product__image' }}
        {%- endif -%}
      </div>

      {%- comment -%} Info — block-driven {%- endcomment -%}
      <div class="kt-featured-product__info">
        {%- if section.settings.eyebrow != blank -%}
          <p class="kt-featured-product__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'title' -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
              <{{ heading_tag }} class="kt-featured-product__title" {{ block.shopify_attributes }}>
                {%- if product != blank -%}
                  {{ product.title }}
                {%- else -%}
                  {{ 'kt.onboarding.product_title' | t | default: 'Example product title' }}
                {%- endif -%}
              </{{ heading_tag }}>

            {%- when 'price' -%}
              <div class="kt-featured-product__price" {{ block.shopify_attributes }}>
                {%- if product != blank -%}
                  {%- render 'product-price', product: product, variant: current_variant -%}
                {%- else -%}
                  {%- comment -%} Currency-neutral placeholder — uses the store's money format. {%- endcomment -%}
                  <span class="kt-price">{{ 0 | money }}</span>
                {%- endif -%}
              </div>

            {%- when 'description' -%}
              <div class="kt-featured-product__description rte" {{ block.shopify_attributes }}>
                {%- if product != blank -%}
                  {%- comment -%}
                    R87 — pre-assign word_limit_safe so the `default`
                    fallback lands on the variable, not on the
                    truncatewords output. Default 40 matches main-
                    product schema.
                  {%- endcomment -%}
                  {%- assign word_limit_safe = block.settings.word_limit | default: 40 -%}
                  {{ product.description | strip_html | truncatewords: word_limit_safe }}
                {%- else -%}
                  {{ 'kt.onboarding.product_description' | t | default: 'Example product description goes here.' }}
                {%- endif -%}
              </div>

            {%- when 'variant_picker' -%}
              {%- if product != blank -%}
                <div class="kt-featured-product__variants" {{ block.shopify_attributes }}>
                  {%- render 'product-variant-picker', product: product -%}
                </div>
              {%- endif -%}

            {%- when 'buy_button' -%}
              {%- comment -%}
                `data-product-form` on the wrapper is the hook
                assets/product-form.js uses to find the form (it avoids
                hyphenated {% form %} kwargs for robustness — see
                snippets/product-form.liquid). The hidden variant input
                gets `data-variant-id` so the JS can rewrite it when the
                customer picks a variant, and the submit button exposes
                `data-add-to-cart` + `data-add-to-cart-text` so the JS
                can toggle loading / sold-out / success labels without
                hand-querying by class name.

                `{{ form | payment_button }}` emits Shopify's Dynamic
                Checkout Buttons (Shop Pay, PayPal, Google Pay, Apple
                Pay) — Theme Store explicitly requires these on any
                section that sells a product, and they only render when
                the merchant has express-checkout methods enabled, so
                the gate below hides the entire block if the merchant
                has opted out.
              {%- endcomment -%}
              <div class="kt-featured-product__form" data-product-form data-product-id="{{ product.id }}" data-product-url="{{ product.url }}" {{ block.shopify_attributes }}>
                {%- if product != blank -%}
                  {%- comment -%}
                    Quantity rule + selling plan + error sentinel parity
                    with snippets/product-form.liquid. Earlier the buy-
                    button block here was a hand-rolled `<input id> +
                    submit` pair, which silently broke three flows:
                      · subscription-only products (requires_selling_plan)
                        — POSTed to /cart/add without `selling_plan`,
                        Shopify rejected with no UI feedback
                      · variants with quantity_rule (e.g. case-of-6) —
                        always sent qty=1, /cart/change.js error path
                        rejected the order
                      · /cart/add.js errors — assets/product-form.js looks
                        for [data-product-form-error] on the form; when
                        absent, error events fire-and-forget into the
                        DOM with no surface to render on
                    Resolved here so the Featured Product section is
                    transactionally equivalent to the main PDP form.
                  {%- endcomment -%}
                  {%- form 'product', product, id: 'FeaturedProductForm-' | append: section.id -%}
                    <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

                    {%- if product.selling_plan_groups.size > 0 -%}
                      {%- render 'product-selling-plans', product: product, current_variant: current_variant, section: section -%}
                    {%- endif -%}

                    {%- assign qty_min = current_variant.quantity_rule.min | default: 1 -%}
                    {%- assign qty_step = current_variant.quantity_rule.increment | default: 1 -%}
                    {%- assign qty_max = current_variant.quantity_rule.max -%}
                    <div class="kt-featured-product__qty-row">
                      <label for="FeaturedQuantity-{{ section.id }}" class="visually-hidden">{{ 'kt.product.quantity.label' | t }}</label>
                      <input
                        type="number"
                        name="quantity"
                        id="FeaturedQuantity-{{ section.id }}"
                        value="{{ qty_min }}"
                        min="{{ qty_min }}"
                        step="{{ qty_step }}"
                        {% if qty_max != blank %}max="{{ qty_max }}"{% endif %}
                        inputmode="numeric"
                        pattern="[0-9]*"
                        class="kt-featured-product__qty-input"
                        data-qty-input
                        data-qty-min="{{ qty_min }}"
                        data-qty-step="{{ qty_step }}"
                        {% if qty_max != blank %}data-qty-max="{{ qty_max }}"{% endif %}
                      >
                      <button
                        type="submit"
                        name="add"
                        class="kt-featured-product__submit button button--primary"
                        data-add-to-cart
                        {% unless current_variant.available %}disabled{% endunless %}
                      >
                        <span data-add-to-cart-text>
                          {%- if current_variant.available -%}
                            {{ block.settings.button_text | default: 'Add to cart' }}
                          {%- else -%}
                            {{ 'kt.product.sold_out' | t | default: 'Sold out' }}
                          {%- endif -%}
                        </span>
                      </button>
                    </div>

                    {%- comment -%}
                      Pre-order indicator — variant out of stock with
                      inventory_policy:'continue' (back-order allowed).
                      Without it, the customer can't tell "in stock now"
                      from "ships when restocked".
                    {%- endcomment -%}
                    {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity <= 0 and current_variant.inventory_policy == 'continue' -%}
                      <p class="kt-featured-product__preorder" role="note">{{ 'kt.product.preorder' | t }}</p>
                    {%- endif -%}

                    <div class="kt-featured-product__error" data-product-form-error role="alert" hidden></div>

                    {%- if block.settings.show_dynamic_checkout -%}
                      {{ form | payment_button }}
                      {%- comment -%}
                        R97 — Shop Pay Installments / Klarna / Afterpay
                        messaging. {{ form | payment_terms }} renders the
                        merchant's installment provider banner inside the
                        product form. Shopify auto-hides if no provider is
                        active or product price is below threshold. Required
                        on every product form for full Theme Store payment
                        UX parity.
                      {%- endcomment -%}
                      {{ form | payment_terms }}
                    {%- endif -%}
                  {%- endform -%}
                {%- else -%}
                  <button type="button" class="kt-featured-product__submit button button--primary" disabled>
                    <span>{{ block.settings.button_text | default: 'Add to cart' }}</span>
                  </button>
                {%- endif -%}
              </div>

            {%- when 'text' -%}
              <div class="kt-featured-product__text rte" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>

            {%- when 'liquid' -%}
              {%- comment -%}
                Custom Liquid block — Theme Store requires Custom Liquid
                blocks alongside @app blocks so merchants without a packaged
                app extension can still drop arbitrary Liquid into the
                featured product card.
              {%- endcomment -%}
              <div class="kt-featured-product__custom-liquid" {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>

            {%- when '@app' -%}
              {%- comment -%}
                R87 — Theme Store rule: every block must wrap in
                an element carrying `block.shopify_attributes` so
                the editor can highlight + scroll-to the block on
                merchant click. Bare `{% render block %}` works
                functionally but breaks the editor "select block"
                affordance entirely.
              {%- endcomment -%}
              <div class="kt-featured-product__app-block" {{ block.shopify_attributes }}>
                {%- render block -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}

        {%- if section.settings.view_product_link and product != blank -%}
          <a href="{{ product.url }}" class="kt-featured-product__view-link">
            {{ 'kt.product.view_details' | t | default: 'View full details' }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.featured-product.name",
  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.featured-product.settings.product.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.featured-product.settings.eyebrow.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "view_product_link",
      "label": "t:sections.featured-product.settings.view_product_link.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "t:sections.featured-product.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "heading_tag",
          "label": "t:sections.featured-product.blocks.title.settings.heading_tag.label",
          "options": [
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "price",
      "name": "t:sections.featured-product.blocks.price.name",
      "limit": 1
    },
    {
      "type": "description",
      "name": "t:sections.featured-product.blocks.description.name",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "word_limit",
          "min": 10,
          "max": 100,
          "step": 5,
          "default": 40,
          "label": "t:sections.featured-product.blocks.description.settings.word_limit.label"
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "t:sections.featured-product.blocks.variant_picker.name",
      "limit": 1
    },
    {
      "type": "buy_button",
      "name": "t:sections.featured-product.blocks.buy_button.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "t:sections.featured-product.blocks.buy_button.settings.button_text.label",
          "default": "Add to cart"
        },
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "t:sections.featured-product.blocks.buy_button.settings.show_dynamic_checkout.label",
          "info": "t:sections.featured-product.blocks.buy_button.settings.show_dynamic_checkout.info",
          "default": true
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.featured-product.blocks.text.name",
      "limit": 4,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.featured-product.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "liquid",
      "name": "t:sections.featured-product.blocks.liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.featured-product.blocks.liquid.settings.custom_liquid.label",
          "info": "t:sections.featured-product.blocks.liquid.settings.custom_liquid.info"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "t:sections.featured-product.presets.name",
      "blocks": [
        { "type": "title" },
        { "type": "price" },
        { "type": "description" },
        { "type": "variant_picker" },
        { "type": "buy_button" }
      ]
    }
  ]
}
{% endschema %}
