{{ 'section-ecosystem.css' | asset_url | stylesheet_tag }}

<section class="kt-ecosystem" data-section-id="{{ section.id }}" data-section-type="ecosystem">
  {%- comment -%} Background grid pattern {%- endcomment -%}
  <div class="kt-ecosystem__grid-pattern" aria-hidden="true">
    <svg fill="none" width="100%" height="100%">
      <defs>
        <pattern id="tech-grid-{{ section.id }}" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 40V.5H40" fill="none" stroke="white" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#tech-grid-{{ section.id }})" />
    </svg>
    <div class="kt-ecosystem__grid-fade"></div>
  </div>

  <div class="page-width">
    <div class="kt-ecosystem__layout">
      {%- comment -%} Left Column — Scrolling Text {%- endcomment -%}
      <div class="kt-ecosystem__text-col">
        <div class="kt-ecosystem__title-block">
          {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
          <{{ heading_tag }} class="kt-ecosystem__title">{{ section.settings.heading_line1 | default: 'High-Tech' }}<br>{{ section.settings.heading_line2 | default: 'Storage.' }}</{{ heading_tag }}>
          {%- if section.settings.subtitle != blank -%}
            <p class="kt-ecosystem__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}
        </div>

        <div class="kt-ecosystem__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="kt-ecosystem__feature eco-item" {{ block.shopify_attributes }}>
                <h3 class="kt-ecosystem__feature-title">{{ block.settings.number | default: forloop.index | prepend: '0' }} / {{ block.settings.title }}</h3>
                <p class="kt-ecosystem__feature-desc">{{ block.settings.description }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- if section.settings.cta_text != blank -%}
            <div class="eco-item kt-ecosystem__cta-wrap">
              <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="kt-ecosystem__cta">
                {{ section.settings.cta_text }}
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Right Column — Pinned Image {%- endcomment -%}
      <div class="kt-ecosystem__image-col">
        <div class="kt-ecosystem__image-wrap">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'kt-ecosystem__image', loading: 'lazy', widths: '375, 750, 1100', sizes: '(min-width: 990px) 50vw, 100vw', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.heading | default: '' }}
          {%- else -%}
            {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg kt-ecosystem__image' }}
          {%- endif -%}
          <div class="kt-ecosystem__image-overlay" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'section-ecosystem.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Image with features",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "High-Tech"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2",
      "default": "Storage."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "A kitchen is a machine for living. We precision-engineer every drawer and hinge for absolute perfection."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured image"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Explore Smart Kitchens"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "number": "01",
            "title": "Invisible Automation",
            "description": "Handle-less drawers that open with a gentle touch. Powered by whisper-quiet electric mechanisms hidden within the dark wood frame."
          }
        },
        {
          "type": "feature",
          "settings": {
            "number": "02",
            "title": "Integrated LED",
            "description": "Motion-sensing ambient lighting embedded directly into the cabinetry, illuminating exactly what you need, exactly when you need it."
          }
        },
        {
          "type": "feature",
          "settings": {
            "number": "03",
            "title": "Perfect Organization",
            "description": "Custom laser-cut organizers designed precisely for your exact utensils, pans, and ingredients. No space is wasted."
          }
        }
      ]
    }
  ]
}
{% endschema %}
