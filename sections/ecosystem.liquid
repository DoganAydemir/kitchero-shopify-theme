{{ 'section-ecosystem.css' | asset_url | stylesheet_tag }}

<section class="kt-ecosystem" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="kt-ecosystem__layout">
      <div class="kt-ecosystem__text-col">
        <h2 class="kt-ecosystem__title">{{ section.settings.heading | default: 'High-Tech Storage.' }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="kt-ecosystem__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <div class="kt-ecosystem__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="kt-ecosystem__feature" {{ block.shopify_attributes }}>
                <p class="kt-ecosystem__feature-number">{{ block.settings.number | default: forloop.index | prepend: '0' }}</p>
                <h3 class="kt-ecosystem__feature-title">{{ block.settings.title }}</h3>
                <p class="kt-ecosystem__feature-desc">{{ block.settings.description }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="kt-ecosystem__cta">
            {{ section.settings.cta_text }}
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        {%- endif -%}
      </div>

      <div class="kt-ecosystem__image-col">
        <div class="kt-ecosystem__image-wrap">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'kt-ecosystem__image', loading: 'lazy', widths: '375, 750, 1100', sizes: '(min-width: 990px) 50vw, 100vw', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.heading | default: '' }}
          {%- else -%}
            {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg kt-ecosystem__image' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ecosystem",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "High-Tech Storage." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Intelligent storage systems that transform the way you organize your kitchen." },
    { "type": "image_picker", "id": "image", "label": "Featured image" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Explore Smart Kitchens" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Feature description goes here." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ecosystem",
      "blocks": [
        { "type": "feature", "settings": { "number": "01", "title": "Motorized Lift Systems", "description": "Upper cabinets with soft-close electric lift mechanisms for effortless access." } },
        { "type": "feature", "settings": { "number": "02", "title": "Internal LED Lighting", "description": "Motion-activated LED strips illuminate every drawer and cabinet interior." } },
        { "type": "feature", "settings": { "number": "03", "title": "Integrated Charging", "description": "Built-in USB-C and wireless charging stations hidden within drawer organizers." } }
      ]
    }
  ]
}
{% endschema %}
