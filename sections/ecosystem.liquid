{{ 'kt-section-ecosystem.css' | asset_url | stylesheet_tag }}

<section class="kt-ecosystem" data-section-id="{{ section.id }}" data-section-type="ecosystem">
  {%- comment -%} Background grid pattern {%- endcomment -%}
  <div class="kt-ecosystem__grid-pattern" aria-hidden="true">
    <svg fill="none" width="100%" height="100%">
      <defs>
        <pattern id="tech-grid-{{ section.id }}" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 40V.5H40" fill="none" stroke="white" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#tech-grid-{{ section.id }})" />
    </svg>
    <div class="kt-ecosystem__grid-fade"></div>
  </div>

  <div class="page-width">
    <div class="kt-ecosystem__layout">
      {%- comment -%} Left Column — Scrolling Text {%- endcomment -%}
      <div class="kt-ecosystem__text-col">
        <div class="kt-ecosystem__title-block">
          {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
          {%- liquid
            # Prefer the new unified `heading` (inline_richtext with <br>
            # allowed). Fall back to the legacy two-field pair so we don't
            # wipe existing merchant content.
            assign resolved_heading = section.settings.heading
            if resolved_heading == blank
              assign part1 = section.settings.heading_line1 | default: 'High-Tech'
              assign part2 = section.settings.heading_line2 | default: 'Storage.'
              assign resolved_heading = part1 | append: '<br>' | append: part2
            endif
          -%}
          <{{ heading_tag }} class="kt-ecosystem__title">{{ resolved_heading }}</{{ heading_tag }}>
          {%- if section.settings.subtitle != blank -%}
            <p class="kt-ecosystem__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}
        </div>

        <div class="kt-ecosystem__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="kt-ecosystem__feature eco-item" {{ block.shopify_attributes }}>
                {%- comment -%}
                  Feature title is now a single string. Legacy entries that
                  still have a separate `number` setting are stitched back
                  together so existing merchant data doesn't break.
                {%- endcomment -%}
                {%- assign feature_title = block.settings.title -%}
                {%- if block.settings.number != blank and feature_title != blank -%}
                  {%- unless feature_title contains '/' -%}
                    {%- assign feature_title = block.settings.number | append: ' / ' | append: feature_title -%}
                  {%- endunless -%}
                {%- endif -%}
                <h3 class="kt-ecosystem__feature-title">{{ feature_title }}</h3>
                <p class="kt-ecosystem__feature-desc">{{ block.settings.description }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- if section.settings.cta_text != blank -%}
            <div class="eco-item kt-ecosystem__cta-wrap">
              <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="kt-ecosystem__cta">
                {{ section.settings.cta_text }}
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Right Column — Pinned Image {%- endcomment -%}
      <div class="kt-ecosystem__image-col">
        <div class="kt-ecosystem__image-wrap">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'kt-ecosystem__image', loading: 'lazy', widths: '375, 550, 750, 1100', sizes: '(min-width: 750px) 50vw, 100vw', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.heading | default: '' }}
          {%- else -%}
            {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg kt-ecosystem__image' }}
          {%- endif -%}
          <div class="kt-ecosystem__image-overlay" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-ecosystem.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.ecosystem.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.ecosystem.settings.heading.label",
      "info": "t:sections.ecosystem.settings.heading.info",
      "default": "High-Tech Storage."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.ecosystem.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.ecosystem.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.ecosystem.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.ecosystem.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.ecosystem.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.ecosystem.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.ecosystem.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "t:sections.ecosystem.settings.subtitle.label",
      "default": "A kitchen is a machine for living. We precision-engineer every drawer and hinge for absolute perfection."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.ecosystem.settings.image.label"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.ecosystem.settings.cta_text.label",
      "default": "Explore Smart Kitchens"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.ecosystem.settings.cta_link.label"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.ecosystem.blocks.feature.name",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.ecosystem.blocks.feature.settings.title.label",
          "default": "01 / Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.ecosystem.blocks.feature.settings.description.label",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.ecosystem.presets.name",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "01 / Invisible Automation",
            "description": "Handle-less drawers that open with a gentle touch. Powered by whisper-quiet electric mechanisms hidden within the dark wood frame."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "02 / Integrated LED",
            "description": "Motion-sensing ambient lighting embedded directly into the cabinetry, illuminating exactly what you need, exactly when you need it."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "03 / Perfect Organization",
            "description": "Custom laser-cut organizers designed precisely for your exact utensils, pans, and ingredients. No space is wasted."
          }
        }
      ]
    }
  ]
}
{% endschema %}
