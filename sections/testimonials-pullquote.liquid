{{ 'kt-section-testimonials-pullquote.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Testimonials Pullquote — single or multi-quote editorial band.
  If blocks of type `quote` are present they take priority and render
  as a slider (prev/next + dots). Otherwise the legacy single-quote
  settings still work so merchants with existing data don't lose it.
{%- endcomment -%}

{%- assign heading_tag = section.settings.heading_tag | default: 'h3' -%}
{%- assign vertical_padding = section.settings.vertical_padding | default: 128 -%}
{%- assign quote_blocks = section.blocks | where: 'type', 'quote' -%}

<section
  class="kt-testimonials-pullquote{% if quote_blocks.size > 1 %} kt-testimonials-pullquote--slider{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="testimonials-pullquote"
  style="--kt-pullquote-padding: {{ vertical_padding }}px;"
  {%- comment -%}
    When quote blocks render as a slider, the inner slides carry
    aria-roledescription="slide" — that's only valid inside a
    carousel composite widget (WAI-ARIA Authoring Practices). The
    parent must declare aria-roledescription="carousel" + an
    accessible name so screen readers announce the orphan-slide
    semantics correctly. Single-quote variant skips both attrs
    (no slider, no carousel).
  {%- endcomment -%}
  {%- if quote_blocks.size > 1 -%}
    aria-roledescription="{{ 'kt.a11y.carousel' | t | default: 'carousel' }}"
    aria-label="{{ 'kt.a11y.testimonials_carousel' | t | default: 'Testimonials carousel' }}"
  {%- endif -%}
>
  <div class="page-width kt-testimonials-pullquote__inner">
    <div class="kt-testimonials-pullquote__icon" aria-hidden="true">
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
        <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/>
        <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
      </svg>
    </div>

    {%- if quote_blocks.size > 0 -%}
      <div class="kt-testimonials-pullquote__track" data-pullquote-track>
        {%- for block in quote_blocks -%}
          <article
            class="kt-testimonials-pullquote__slide{% if forloop.first %} kt-testimonials-pullquote__slide--active{% endif %}"
            id="{{ section.id }}-pullquote-slide-{{ forloop.index0 }}"
            data-pullquote-slide="{{ forloop.index0 }}"
            role="tabpanel"
            aria-labelledby="{{ section.id }}-pullquote-dot-{{ forloop.index0 }}"
            aria-roledescription="slide"
            aria-label="{{ forloop.index }} / {{ quote_blocks.size }}"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.quote != blank -%}
              <blockquote class="kt-testimonials-pullquote__quote-wrap">
                <{{ heading_tag }} class="kt-testimonials-pullquote__quote">
                  &ldquo;{{ block.settings.quote }}&rdquo;
                </{{ heading_tag }}>
              </blockquote>
            {%- endif -%}

            {%- if block.settings.author_name != blank or block.settings.author_title != blank -%}
              <div class="kt-testimonials-pullquote__attribution">
                <span class="kt-testimonials-pullquote__divider" aria-hidden="true"></span>
                {%- if block.settings.author_name != blank -%}
                  <cite class="kt-testimonials-pullquote__author">{{ block.settings.author_name }}</cite>
                {%- endif -%}
                {%- if block.settings.author_title != blank -%}
                  <span class="kt-testimonials-pullquote__author-title">{{ block.settings.author_title }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>

      {%- if quote_blocks.size > 1 -%}
        <div class="kt-testimonials-pullquote__controls">
          <button
            type="button"
            class="kt-testimonials-pullquote__nav kt-testimonials-pullquote__nav--prev"
            data-pullquote-prev
            aria-label="{{ 'kt.section.testimonials-pullquote.previous' | t | default: 'Previous testimonial' }}"
          >
            {% render 'icon-chevron-left' %}
          </button>

          <div class="kt-testimonials-pullquote__dots" role="tablist" aria-label="{{ 'kt.section.testimonials-pullquote.pagination' | t | default: 'Testimonials' }}">
            {%- for block in quote_blocks -%}
              <button
                type="button"
                class="kt-testimonials-pullquote__dot{% if forloop.first %} kt-testimonials-pullquote__dot--active{% endif %}"
                id="{{ section.id }}-pullquote-dot-{{ forloop.index0 }}"
                data-pullquote-dot="{{ forloop.index0 }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="{{ section.id }}-pullquote-slide-{{ forloop.index0 }}"
                aria-label="{{ 'kt.section.testimonials-pullquote.go_to' | t: index: forloop.index | default: 'Go to testimonial' }}"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
              ></button>
            {%- endfor -%}
          </div>

          <button
            type="button"
            class="kt-testimonials-pullquote__nav kt-testimonials-pullquote__nav--next"
            data-pullquote-next
            aria-label="{{ 'kt.section.testimonials-pullquote.next' | t | default: 'Next testimonial' }}"
          >
            {% render 'icon-chevron-right' %}
          </button>
        </div>
      {%- endif -%}
    {%- elsif section.settings.quote != blank -%}
      {%- comment -%} Legacy single-quote fallback {%- endcomment -%}
      <blockquote class="kt-testimonials-pullquote__quote-wrap">
        <{{ heading_tag }} class="kt-testimonials-pullquote__quote">
          &ldquo;{{ section.settings.quote }}&rdquo;
        </{{ heading_tag }}>
      </blockquote>
      {%- if section.settings.author_name != blank or section.settings.author_title != blank -%}
        <div class="kt-testimonials-pullquote__attribution">
          <span class="kt-testimonials-pullquote__divider" aria-hidden="true"></span>
          {%- if section.settings.author_name != blank -%}
            <cite class="kt-testimonials-pullquote__author">{{ section.settings.author_name }}</cite>
          {%- endif -%}
          {%- if section.settings.author_title != blank -%}
            <span class="kt-testimonials-pullquote__author-title">{{ section.settings.author_title }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{%- if quote_blocks.size > 1 -%}
  <script src="{{ 'kt-section-testimonials-pullquote.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.testimonials-pullquote.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.testimonials-pullquote.settings.header__content.content"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "t:sections.testimonials-pullquote.settings.quote.label",
      "info": "t:sections.testimonials-pullquote.settings.quote.info"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "t:sections.testimonials-pullquote.settings.author_name.label"
    },
    {
      "type": "text",
      "id": "author_title",
      "label": "t:sections.testimonials-pullquote.settings.author_title.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.testimonials-pullquote.settings.heading_tag.label",
      "info": "t:sections.testimonials-pullquote.settings.heading_tag.info",
      "options": [
        { "value": "h2", "label": "t:sections.testimonials-pullquote.settings.heading_tag.options__1.label" },
        { "value": "h3", "label": "t:sections.testimonials-pullquote.settings.heading_tag.options__2.label" },
        { "value": "blockquote", "label": "t:sections.testimonials-pullquote.settings.heading_tag.options__3.label" }
      ],
      "default": "h3"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials-pullquote.settings.header__layout.content"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "t:sections.testimonials-pullquote.settings.vertical_padding.label",
      "min": 40,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "t:sections.testimonials-pullquote.blocks.quote.name",
      "limit": 10,
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials-pullquote.blocks.quote.settings.quote.label"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:sections.testimonials-pullquote.blocks.quote.settings.author_name.label"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "t:sections.testimonials-pullquote.blocks.quote.settings.author_title.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials-pullquote.presets.name",
      "settings": {
        "heading_tag": "h3",
        "vertical_padding": 128
      },
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "quote": "Where timeless materials meet modern living."
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote": "Real materials, real craft, real homes."
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote": "Created for the moments that matter at home."
          }
        }
      ]
    }
  ]
}
{% endschema %}
