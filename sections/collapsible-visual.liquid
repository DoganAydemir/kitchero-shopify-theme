{%- comment -%}
  Collapsible Content — Style 02 Full-Width Visual Reveal

  Dark two-column section. Left column holds a list of "feature"
  items that work as a single-open accordion. Right column cross-
  fades through each feature's image, synced to whichever item
  is currently active. The right column is sticky on desktop
  so the visual stays in view while users scan the features.

  Progressive enhancement: without JS the first item is visible
  with its content expanded; other items remain collapsed but
  their content is still in the DOM (screen readers can reach it
  through the native button semantics and aria-expanded states
  set by JS on load).

  Settings:
    eyebrow       — small caps pretitle
    heading       — main heading
    heading_tag   — h2 / h3
    description   — optional subtitle paragraph

  Blocks:
    feature — image, title, content, item_eyebrow
    @app    — app blocks
{%- endcomment -%}

{{ 'kt-section-collapsible-visual.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kt-section-collapsible-visual.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign description = section.settings.description
-%}

<section
  class="kt-collapsible-visual"
  data-section-id="{{ section.id }}"
  data-kt-collapsible-visual
>
  <div class="kt-collapsible-visual__container">
    {%- if eyebrow != blank or heading != blank or description != blank -%}
      <header class="kt-collapsible-visual__header">
        {%- if eyebrow != blank -%}
          <span class="kt-collapsible-visual__eyebrow">{{ eyebrow | escape }}</span>
        {%- endif -%}
        {%- if heading != blank -%}
          <{{ heading_tag }} class="kt-collapsible-visual__heading">
            {{ heading | escape }}
          </{{ heading_tag }}>
        {%- endif -%}
        {%- if description != blank -%}
          <p class="kt-collapsible-visual__description">{{ description | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="kt-collapsible-visual__grid">
      {%- comment -%} Left column: feature items {%- endcomment -%}
      <div class="kt-collapsible-visual__items" data-kt-visual-items>
        {%- assign feature_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'feature' -%}
              {%- assign is_first = forloop.first -%}
              <button
                type="button"
                class="kt-collapsible-visual__item{% if is_first %} is-active{% endif %}"
                data-visual-item
                data-index="{{ feature_index }}"
                aria-expanded="{% if is_first %}true{% else %}false{% endif %}"
                aria-controls="kt-visual-panel-{{ section.id }}-{{ feature_index }}"
                id="kt-visual-trigger-{{ section.id }}-{{ feature_index }}"
                {{ block.shopify_attributes }}
              >
                <span class="kt-collapsible-visual__item-head">
                  {%- if block.settings.item_eyebrow != blank -%}
                    <span class="kt-collapsible-visual__item-eyebrow">
                      {{- block.settings.item_eyebrow | escape -}}
                    </span>
                  {%- endif -%}
                  <span class="kt-collapsible-visual__item-title">
                    {%- assign collapsible_visual_fallback = 'kt.section.collapsible_visual.feature_title_default' | t -%}
                    {{- block.settings.title | default: collapsible_visual_fallback -}}
                  </span>
                </span>
                <span
                  class="kt-collapsible-visual__panel"
                  id="kt-visual-panel-{{ section.id }}-{{ feature_index }}"
                  data-visual-panel
                  role="region"
                  aria-labelledby="kt-visual-trigger-{{ section.id }}-{{ feature_index }}"
                >
                  <span class="kt-collapsible-visual__content">
                    {%- if block.settings.content != blank -%}
                      {{ block.settings.content | escape | newline_to_br }}
                    {%- else -%}
                      {{ 'kt.section.collapsible_visual.feature_content_default' | t }}
                    {%- endif -%}
                  </span>
                </span>
              </button>
              {%- assign feature_index = feature_index | plus: 1 -%}
            {%- when '@app' -%}
              <div class="kt-collapsible-visual__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Right column: cross-fading visuals {%- endcomment -%}
      <div class="kt-collapsible-visual__visual" data-kt-visual-images>
        <div class="kt-collapsible-visual__visual-inner">
          {%- assign image_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              {%- assign is_first_image = forloop.first -%}
              <div
                class="kt-collapsible-visual__image{% if is_first_image %} is-active{% endif %}"
                data-visual-image
                data-index="{{ image_index }}"
                aria-hidden="{% if is_first_image %}false{% else %}true{% endif %}"
              >
                {%- if block.settings.image != blank -%}
                  {%- if is_first_image -%}
                    {%- comment -%}
                      `fetchpriority: 'auto'` (not 'high') — this section
                      is reused across home / about / collection pages
                      and rarely sits above the fold. The first block's
                      image still gets `loading: 'eager'` so it's not
                      lazy-queued when visible, but we let the browser
                      own priority.
                    {%- endcomment -%}
                    {{
                      block.settings.image
                      | image_url: width: 1600
                      | image_tag:
                        loading: 'eager',
                        fetchpriority: 'auto',
                        width: block.settings.image.width,
                        height: block.settings.image.height,
                        sizes: '(min-width: 1024px) 50vw, 100vw',
                        widths: '400, 600, 800, 1000, 1200, 1600',
                        alt: block.settings.image.alt | default: block.settings.title | default: ''
                    }}
                  {%- else -%}
                    {{
                      block.settings.image
                      | image_url: width: 1600
                      | image_tag:
                        loading: 'lazy',
                        width: block.settings.image.width,
                        height: block.settings.image.height,
                        sizes: '(min-width: 1024px) 50vw, 100vw',
                        widths: '400, 600, 800, 1000, 1200, 1600',
                        alt: block.settings.image.alt | default: block.settings.title | default: ''
                    }}
                  {%- endif -%}
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'kt-collapsible-visual__placeholder-svg' }}
                {%- endif -%}
                <span class="kt-collapsible-visual__image-overlay" aria-hidden="true"></span>
              </div>
              {%- assign image_index = image_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.collapsible_visual.name",
  "tag": "div",
  "class": "section section--collapsible-visual",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collapsible_visual.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.collapsible_visual.settings.eyebrow.label",
      "default": "Style 02"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collapsible_visual.settings.heading.label",
      "default": "Full-width visual reveal"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.collapsible_visual.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "t:sections.collapsible_visual.settings.heading_tag.options__h2.label" },
        { "value": "h3", "label": "t:sections.collapsible_visual.settings.heading_tag.options__h3.label" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.collapsible_visual.settings.description.label",
      "default": "Click each feature to reveal its story — and watch the visual change alongside."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.collapsible_visual.blocks.feature.name",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.collapsible_visual.blocks.feature.settings.image.label"
        },
        {
          "type": "text",
          "id": "item_eyebrow",
          "label": "t:sections.collapsible_visual.blocks.feature.settings.item_eyebrow.label",
          "default": "Material"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.collapsible_visual.blocks.feature.settings.title.label",
          "default": "Design philosophy"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "t:sections.collapsible_visual.blocks.feature.settings.content.label",
          "default": "Add a short description"
        }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "t:sections.collapsible_visual.presets.name",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "item_eyebrow": "Philosophy",
            "title": "Design philosophy",
            "content": "Add a short description"
          }
        },
        {
          "type": "feature",
          "settings": {
            "item_eyebrow": "Material",
            "title": "Material integrity",
            "content": "Describe a key material or principle of your products."
          }
        },
        {
          "type": "feature",
          "settings": {
            "item_eyebrow": "Promise",
            "title": "Quality warranty",
            "content": "Describe your warranty or quality guarantee here."
          }
        }
      ]
    }
  ]
}
{% endschema %}
