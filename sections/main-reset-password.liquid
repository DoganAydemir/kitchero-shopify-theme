{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}

<section class="kt-customer" data-section-id="{{ section.id }}">
  <div class="kt-customer__container">
    <h1 class="kt-customer__title">{{ 'kt.customer.reset_password.title' | t }}</h1>
    <p class="kt-customer__subtitle">{{ 'kt.customer.reset_password.subtext' | t }}</p>

    {%- form 'reset_customer_password', id: 'ResetPasswordForm' -%}
      {%- if form.errors -%}
        <div class="kt-customer__errors" role="alert" tabindex="-1">
          <h2 class="kt-customer__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h2>
          <ul class="kt-customer__errors-list">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  <a href="#reset-{{ field }}">
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="kt-customer__form">
        <div class="kt-customer__field">
          <label for="reset-password" class="kt-customer__label">
            {{ 'kt.customer.reset_password.password' | t }}
          </label>
          <input
            type="password"
            id="reset-password"
            name="customer[password]"
            class="kt-customer__input"
            required
            autocomplete="new-password"
            aria-required="true"
            {% if form.errors contains 'password' %}aria-invalid="true" aria-describedby="reset-password-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'password', describedby_id: 'reset-password-error' -%}
        </div>

        <div class="kt-customer__field">
          <label for="reset-password-confirm" class="kt-customer__label">
            {{ 'kt.customer.reset_password.password_confirm' | t }}
          </label>
          <input
            type="password"
            id="reset-password-confirm"
            name="customer[password_confirmation]"
            class="kt-customer__input"
            required
            autocomplete="new-password"
            aria-required="true"
            {% if form.errors contains 'password_confirmation' %}aria-invalid="true" aria-describedby="reset-password-confirm-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'password_confirmation', describedby_id: 'reset-password-confirm-error' -%}
        </div>

        <button type="submit" class="kt-customer__submit">
          {{ 'kt.customer.reset_password.submit' | t }}
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-reset-password.name",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
