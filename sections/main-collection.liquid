{{ 'kt-section-main-collection.css' | asset_url | stylesheet_tag }}
{{ 'kt-card-product.css' | asset_url | stylesheet_tag }}
{{ 'kt-collection-filters.css' | asset_url | stylesheet_tag }}

<div class="kt-collection" data-section-id="{{ section.id }}" data-section-type="main-collection">
  {%- comment -%}
    Visible breadcrumb that mirrors the BreadcrumbList JSON-LD emitted
    by snippets/structured-data.liquid. Google Search Console warns
    when structured data declares a breadcrumb the page doesn't show;
    this snippet closes that parity gap across collection/article/
    blog/page templates.
  {%- endcomment -%}
  {%- comment -%}
    Breadcrumb moved to layout/theme.liquid (global render).
  {%- endcomment -%}

  {%- comment -%} Hero Header {%- endcomment -%}
  <section class="kt-collection__hero" data-collection-hero>
    {%- comment -%} Layer 1: Base matrix grid (small dots, static) {%- endcomment -%}
    <div class="kt-collection__dots-base" aria-hidden="true"></div>

    {%- comment -%} Layer 2: Major parallax dots (large dots, moves on scroll) {%- endcomment -%}
    <div class="kt-collection__dots-parallax" data-parallax-dots aria-hidden="true"></div>

    {%- comment -%} Layer 3: Subtle scanlines {%- endcomment -%}
    <div class="kt-collection__scanlines" aria-hidden="true"></div>

    {%- comment -%} Layer 4: Technical + markers (parallax) {%- endcomment -%}
    <div class="kt-collection__markers" data-parallax-markers aria-hidden="true">
      <span class="kt-collection__marker" style="top: 2.5rem; left: 15%;">+</span>
      <span class="kt-collection__marker" style="top: 35%; right: 10%;">+</span>
      <span class="kt-collection__marker" style="bottom: 2.5rem; left: 40%;">+</span>
      <span class="kt-collection__marker" style="top: 13rem; right: 45%;">+</span>
    </div>
    <div class="page-width">
      <div class="kt-collection__hero-inner">
        <div>
          <p class="kt-collection__label">{{ 'kt.section.collection.label' | t | default: 'The Archives' }}</p>
          {%- assign heading_tag = section.settings.heading_tag | default: 'h1' -%}
          <{{ heading_tag }} class="kt-collection__title">{{ collection.title }}</{{ heading_tag }}>
          {%- if collection.description != blank -%}
            <p class="kt-collection__desc">{{ collection.description }}</p>
          {%- else -%}
            <p class="kt-collection__desc">{{ 'kt.section.collection.default_desc' | t | default: 'Browse our masterfully crafted designs, filtered to your exact architectural specifications.' }}</p>
          {%- endif -%}
        </div>
        <span class="kt-collection__count">
          {{ 'kt.section.collection.products_count' | t: count: collection.products_count }}
        </span>
      </div>
    </div>
  </section>

  {%- comment -%} Sticky Control Bar {%- endcomment -%}
  <div class="kt-collection__controls" data-collection-controls>
    <div class="page-width">
      <div class="kt-collection__controls-inner">
        {%- comment -%} Desktop: horizontal filter dropdowns {%- endcomment -%}
        <div class="kt-filter-bar">
          <span class="kt-filter-bar__label">{{ 'kt.section.collection.filter' | t | default: 'Filter:' }}</span>
          {%- for filter in collection.filters -%}
            {%- comment -%}
              Three filter types Shopify exposes: `list` (checkbox set),
              `boolean` (same shape as list with yes/no values), and
              `price_range` (min/max number inputs). The desktop pill
              bar previously rendered only `list`; merchants who set up
              a price filter or a boolean metafield filter saw the
              filter on the vertical-sidebar template (which uses the
              snippet that handles all three) but on the default
              collection template's pill bar it silently disappeared.
            {%- endcomment -%}
            {%- if filter.type == 'list' or filter.type == 'boolean' -%}
              <div class="kt-filter-bar__dropdown">
                <button class="kt-filter-bar__trigger" type="button">
                  <span>{{ filter.label }}</span>
                  {%- if filter.active_values.size > 0 -%}
                    <span class="kt-filter__count">{{ filter.active_values.size }}</span>
                  {%- endif -%}
                  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div class="kt-filter-bar__panel">
                  <div class="kt-filter-bar__panel-inner">
                    <div class="kt-filter-bar__panel-header">
                      <span class="kt-filter-bar__panel-count">{{ filter.active_values.size }} {{ 'kt.section.collection.selected' | t | default: 'selected' }}</span>
                      {%- if filter.active_values.size > 0 -%}
                        <a href="{{ filter.url_to_remove }}" class="kt-filter__reset">{{ 'kt.section.collection.reset' | t | default: 'Reset' }}</a>
                      {%- endif -%}
                    </div>
                    <form id="FilterBar-{{ filter.param_name }}" action="{{ collection.url }}" method="get" data-collection-filters-form>
                      <ul
                        class="kt-filter__list list-unstyled"
                        role="group"
                        aria-label="{{ filter.label | escape }}"
                      >
                        {%- for value in filter.values -%}
                          <li>
                            <label class="kt-filter__option" for="Bar-{{ filter.param_name }}-{{ forloop.index }}">
                              <input
                                type="checkbox"
                                id="Bar-{{ filter.param_name }}-{{ forloop.index }}"
                                name="{{ value.param_name }}"
                                value="{{ value.value }}"
                                {% if value.active %}checked{% endif %}
                                class="kt-filter__checkbox"
                                data-filter-checkbox
                              >
                              <span class="kt-filter__checkbox-visual">
                                {%- if value.active -%}
                                  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                {%- endif -%}
                              </span>
                              <span class="kt-filter__label">{{ value.label }}</span>
                              <span class="kt-filter__value-count">({{ value.count }})</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>
                      {%- comment -%}
                        JS-off fallback. Desktop has one <form> per filter
                        category (one per accordion panel), so submitting
                        this form without JS would drop every other active
                        filter and the current sort order. Re-emit them as
                        hidden inputs so GET submission preserves the full
                        query state.

                        The JS path (collection-filters.js::buildFilterUrl)
                        ignores hidden inputs — it walks
                        `[data-filter-checkbox]:checked` + `[data-filter-price]`
                        directly off the document, so this duplication only
                        costs HTML bytes, never leads to double-params on
                        the fetch request.
                      {%- endcomment -%}
                      {%- if collection.sort_by != blank -%}
                        <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
                      {%- endif -%}
                      {%- for other_filter in collection.filters -%}
                        {%- if other_filter.param_name != filter.param_name -%}
                          {%- for active_value in other_filter.active_values -%}
                            <input type="hidden" name="{{ active_value.param_name }}" value="{{ active_value.value }}">
                          {%- endfor -%}
                          {%- if other_filter.type == 'price_range' -%}
                            {%- if other_filter.min_value.value != blank -%}
                              <input type="hidden" name="{{ other_filter.min_value.param_name }}" value="{{ other_filter.min_value.value }}">
                            {%- endif -%}
                            {%- if other_filter.max_value.value != blank -%}
                              <input type="hidden" name="{{ other_filter.max_value.param_name }}" value="{{ other_filter.max_value.value }}">
                            {%- endif -%}
                          {%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}
                      <noscript>
                        <button type="submit" class="kt-filter__apply-btn button">
                          {{ 'kt.section.collection.apply' | t | default: 'Apply' }}
                        </button>
                      </noscript>
                    </form>
                  </div>
                </div>
              </div>
            {%- elsif filter.type == 'price_range' -%}
              {%- comment -%}
                Price-range pill — opens a dropdown panel containing two
                number inputs (min, max) and an Apply button. Visual
                shape mirrors the list pills above so the row reads as
                one continuous filter set. Min/max can be left blank;
                Shopify treats blank as "no constraint" on that side.
                Sibling list/boolean values + sort_by are echoed as
                hidden inputs so the JS-off Apply submit preserves the
                rest of the query state.
              {%- endcomment -%}
              {%- assign has_price_active = false -%}
              {%- if filter.min_value.value or filter.max_value.value -%}
                {%- assign has_price_active = true -%}
              {%- endif -%}
              <div class="kt-filter-bar__dropdown">
                <button class="kt-filter-bar__trigger" type="button">
                  <span>{{ filter.label }}</span>
                  {%- if has_price_active -%}
                    <span class="kt-filter__count" aria-label="{{ 'kt.section.collection.selected' | t | default: 'selected' }}">•</span>
                  {%- endif -%}
                  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div class="kt-filter-bar__panel">
                  <div class="kt-filter-bar__panel-inner">
                    <div class="kt-filter-bar__panel-header">
                      <span class="kt-filter-bar__panel-count">{{ filter.label }}</span>
                      {%- if has_price_active -%}
                        <a href="{{ filter.url_to_remove }}" class="kt-filter__reset">{{ 'kt.section.collection.reset' | t | default: 'Reset' }}</a>
                      {%- endif -%}
                    </div>
                    <form id="FilterBar-{{ filter.param_name }}" action="{{ collection.url }}" method="get" data-collection-filters-form>
                      <div class="kt-filter__price-range">
                        <div class="kt-filter__price-field">
                          <label for="Bar-{{ filter.min_value.param_name }}" class="visually-hidden">{{ 'kt.section.collection.price_min' | t | default: 'From' }}</label>
                          <span class="kt-filter__price-prefix" aria-hidden="true">{{ cart.currency.symbol }}</span>
                          <input
                            type="number"
                            id="Bar-{{ filter.min_value.param_name }}"
                            name="{{ filter.min_value.param_name }}"
                            value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                            placeholder="0"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            inputmode="decimal"
                            class="kt-filter__price-input"
                            data-filter-price
                          >
                        </div>
                        <span class="kt-filter__price-separator" aria-hidden="true">—</span>
                        <div class="kt-filter__price-field">
                          <label for="Bar-{{ filter.max_value.param_name }}" class="visually-hidden">{{ 'kt.section.collection.price_max' | t | default: 'To' }}</label>
                          <span class="kt-filter__price-prefix" aria-hidden="true">{{ cart.currency.symbol }}</span>
                          <input
                            type="number"
                            id="Bar-{{ filter.max_value.param_name }}"
                            name="{{ filter.max_value.param_name }}"
                            value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                            placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            inputmode="decimal"
                            class="kt-filter__price-input"
                            data-filter-price
                          >
                        </div>
                      </div>
                      {%- comment -%}
                        Sibling-state preservation for JS-off Apply.
                        Same pattern as the list/boolean pills above:
                        echo every OTHER filter's active values as
                        hidden inputs so submitting this form doesn't
                        wipe the rest of the query.
                      {%- endcomment -%}
                      {%- if collection.sort_by != blank -%}
                        <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
                      {%- endif -%}
                      {%- for other_filter in collection.filters -%}
                        {%- if other_filter.param_name != filter.param_name -%}
                          {%- for active_value in other_filter.active_values -%}
                            <input type="hidden" name="{{ active_value.param_name }}" value="{{ active_value.value }}">
                          {%- endfor -%}
                        {%- endif -%}
                      {%- endfor -%}
                      <noscript>
                        <button type="submit" class="kt-filter__apply-btn button">
                          {{ 'kt.section.collection.apply' | t | default: 'Apply' }}
                        </button>
                      </noscript>
                    </form>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Mobile: filter button (opens drawer) {%- endcomment -%}
        <div class="kt-collection__mobile-filter-bar">
          <p class="kt-collection__results-count">
            {{ 'kt.section.collection.showing_of' | t: showing: collection.products.size, total: collection.products_count }}
          </p>
          <button class="kt-collection__filter-btn" data-open-filter-drawer type="button">
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line></svg>
            <span>{{ 'kt.section.collection.filters' | t | default: 'Filters' }}</span>
          </button>
        </div>

        {%- comment -%} Desktop right: sort + grid toggle + count {%- endcomment -%}
        <div class="kt-collection__controls-right">
          {%- comment -%}
            Sort is wrapped in its own GET form so it works with JS off
            (the select's change handler is a JS enhancement). Active
            filter values are echoed as hidden inputs so picking a new
            sort order doesn't drop the shopper's current filters —
            critical for the JS-off path since changing sort would
            otherwise navigate to `?sort_by=price-asc` and lose the
            `?filter.v.option.color=Black` already in the URL.
          {%- endcomment -%}
          <form action="{{ collection.url }}" method="get" class="kt-collection__sort" data-collection-sort-form>
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- for filter in collection.filters -%}
              {%- for active_value in filter.active_values -%}
                <input type="hidden" name="{{ active_value.param_name }}" value="{{ active_value.value }}">
              {%- endfor -%}
              {%- if filter.type == 'price_range' -%}
                {%- if filter.min_value.value != blank -%}
                  <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">
                {%- endif -%}
                {%- if filter.max_value.value != blank -%}
                  <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            <label for="SortBy" class="kt-collection__sort-label">{{ 'kt.section.collection.sort_by' | t | default: 'Sort by:' }}</label>
            <select id="SortBy" name="sort_by" class="kt-collection__sort-select" data-collection-sort>
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
            <noscript>
              <button type="submit" class="kt-collection__sort-apply button">
                {{ 'kt.section.collection.apply' | t | default: 'Apply' }}
              </button>
            </noscript>
          </form>

          <div class="kt-collection__grid-toggle" aria-label="{{ 'kt.section.collection.grid_view' | t | default: 'Grid view' }}">
            {%- comment -%} 2-col: two tall rectangles side by side {%- endcomment -%}
            <button class="kt-collection__grid-btn kt-collection__grid-btn--active" data-grid-cols="2" title="{{ 'kt.a11y.grid_columns.two' | t }}" type="button">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="1" y="1" width="7" height="16" rx="1" fill="currentColor"/>
                <rect x="10" y="1" width="7" height="16" rx="1" fill="currentColor"/>
              </svg>
            </button>
            {%- comment -%} 3-col: three vertical bars (from source) {%- endcomment -%}
            <button class="kt-collection__grid-btn" data-grid-cols="3" title="{{ 'kt.a11y.grid_columns.three' | t }}" type="button">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="1" y="1" width="4" height="16" rx="1" fill="currentColor"/>
                <rect x="7" y="1" width="4" height="16" rx="1" fill="currentColor"/>
                <rect x="13" y="1" width="4" height="16" rx="1" fill="currentColor"/>
              </svg>
            </button>
            {%- comment -%} 4-col: four narrow bars {%- endcomment -%}
            <button class="kt-collection__grid-btn" data-grid-cols="4" title="{{ 'kt.a11y.grid_columns.four' | t }}" type="button">
              <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="1" y="1" width="3" height="16" rx="0.5" fill="currentColor"/>
                <rect x="5.5" y="1" width="3" height="16" rx="0.5" fill="currentColor"/>
                <rect x="10" y="1" width="3" height="16" rx="0.5" fill="currentColor"/>
                <rect x="14.5" y="1" width="3" height="16" rx="0.5" fill="currentColor"/>
              </svg>
            </button>
          </div>

          <span class="kt-collection__bar-count">
            {{ 'kt.section.collection.products_count' | t: count: collection.products_count }}
          </span>
        </div>
      </div>

      {%- comment -%} Active filters {%- endcomment -%}
      {%- if collection.filters != empty -%}
        {%- assign active_filters_count = 0 -%}
        {%- for filter in collection.filters -%}
          {%- assign active_filters_count = active_filters_count | plus: filter.active_values.size -%}
        {%- endfor -%}

        {%- if active_filters_count > 0 -%}
          <div class="kt-collection__active-filters">
            {%- for filter in collection.filters -%}
              {%- for value in filter.active_values -%}
                <a
                  href="{{ value.url_to_remove }}"
                  class="kt-collection__active-filter"
                  aria-label="{{ 'kt.section.collection.remove_filter' | t: filter: value.label }}"
                >
                  {{ value.label }}
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </a>
              {%- endfor -%}
            {%- endfor -%}
            <a href="{{ collection.url }}" class="kt-collection__clear-all">
              {{ 'kt.section.collection.clear_all' | t | default: 'Clear all' }}
            </a>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}
    Mobile filter drawer — slides in from the right on phones only.
    Mirrors the desktop filter bar but uses checkbox lists grouped by
    filter. Opened by [data-open-filter-drawer] in the sticky bar.
  {%- endcomment -%}
  {%- if collection.filters != empty -%}
    <div
      class="kt-filter-drawer"
      data-filter-drawer
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="FilterDrawerTitle"
      tabindex="-1"
    >
      <div class="kt-filter-drawer__backdrop" data-close-filter-drawer aria-hidden="true"></div>

      <aside class="kt-filter-drawer__panel">
        <header class="kt-filter-drawer__header">
          <h3 id="FilterDrawerTitle" class="kt-filter-drawer__title">
            {{ 'kt.section.collection.refine' | t | default: 'Refine Search' }}
          </h3>
          <button
            type="button"
            class="kt-filter-drawer__close"
            data-close-filter-drawer
            aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </header>

        <form
          id="FilterDrawerForm"
          action="{{ collection.url }}"
          method="get"
          class="kt-filter-drawer__body"
          data-filter-drawer-form
        >
          {%- comment -%} Preserve sort_by across filter submissions {%- endcomment -%}
          {%- if collection.sort_by != blank -%}
            <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
          {%- endif -%}

          {%- for filter in collection.filters -%}
            {%- comment -%}
              Three filter types Shopify exposes on the storefront:
              `list` (multi-select checkboxes — color/size/etc.),
              `boolean` (filterable boolean metafield, same value shape
              as list — yes/no), and `price_range` (min/max number
              inputs).

              The drawer previously only rendered `list`; merchants who
              configured a price filter in admin saw it on the desktop
              vertical sidebar (which uses snippets/collection-filters
              and handles all three types) but on mobile the drawer was
              silent — Theme-Store reviewers test mobile filtering and
              flag the missing types as a feature gap.
            {%- endcomment -%}
            {%- if filter.type == 'list' or filter.type == 'boolean' -%}
              {%- comment -%}
                Filter drawer group wrapped in a <section> with the h4 title.
                The <ul> is a checkbox group whose label is the h4 above —
                role="group" + aria-labelledby pins the group name to the
                visible heading, matching the <fieldset><legend> pattern
                CLAUDE.md requires without a structural rewrite.
              {%- endcomment -%}
              <section class="kt-filter-drawer__group">
                <h4 class="kt-filter-drawer__group-title" id="FilterDrawerGroup-{{ filter.param_name }}">{{ filter.label }}</h4>
                <ul
                  class="kt-filter-drawer__options list-unstyled"
                  role="group"
                  aria-labelledby="FilterDrawerGroup-{{ filter.param_name }}"
                >
                  {%- comment -%}
                    Drawer-scoped unique id per checkbox so SR users
                    get label↔input linkage even though the label
                    also wraps. forloop.index is stable per filter
                    group, prefixed with FilterDrawer- to avoid
                    collision with the sidebar snippet's `Filter-*`
                    ids (if both are ever rendered on one page).
                  {%- endcomment -%}
                  {%- for value in filter.values -%}
                    {%- assign drawer_filter_id = 'FilterDrawer-' | append: filter.param_name | append: '-' | append: forloop.index -%}
                    <li class="kt-filter-drawer__option">
                      <label class="kt-filter-drawer__check" for="{{ drawer_filter_id }}">
                        <input
                          type="checkbox"
                          id="{{ drawer_filter_id }}"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        >
                        <span class="kt-filter-drawer__check-box" aria-hidden="true">
                          <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                        <span class="kt-filter-drawer__check-text">{{ value.label }}</span>
                        <span class="kt-filter-drawer__check-count">({{ value.count }})</span>
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              </section>
            {%- elsif filter.type == 'price_range' -%}
              {%- comment -%}
                Price-range filter — two number inputs (min, max) bound
                to filter.min_value.param_name + filter.max_value.param_name.
                Empty inputs let Shopify treat them as "no constraint";
                no need to gate the input rendering itself.
              {%- endcomment -%}
              <section
                class="kt-filter-drawer__group kt-filter-drawer__group--price"
                role="group"
                aria-labelledby="FilterDrawerGroup-{{ filter.param_name }}"
              >
                <h4 class="kt-filter-drawer__group-title" id="FilterDrawerGroup-{{ filter.param_name }}">{{ filter.label }}</h4>
                <div class="kt-filter-drawer__price-range">
                  <div class="kt-filter-drawer__price-field">
                    <label for="FilterDrawer-{{ filter.min_value.param_name }}" class="visually-hidden">{{ 'kt.section.collection.price_min' | t | default: 'From' }}</label>
                    <input
                      type="number"
                      id="FilterDrawer-{{ filter.min_value.param_name }}"
                      name="{{ filter.min_value.param_name }}"
                      value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                      placeholder="0"
                      min="0"
                      max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      inputmode="decimal"
                      class="kt-filter-drawer__price-input"
                    >
                  </div>
                  <span class="kt-filter-drawer__price-separator" aria-hidden="true">—</span>
                  <div class="kt-filter-drawer__price-field">
                    <label for="FilterDrawer-{{ filter.max_value.param_name }}" class="visually-hidden">{{ 'kt.section.collection.price_max' | t | default: 'To' }}</label>
                    <input
                      type="number"
                      id="FilterDrawer-{{ filter.max_value.param_name }}"
                      name="{{ filter.max_value.param_name }}"
                      value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                      placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      min="0"
                      max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      inputmode="decimal"
                      class="kt-filter-drawer__price-input"
                    >
                  </div>
                </div>
              </section>
            {%- endif -%}
          {%- endfor -%}
        </form>

        <footer class="kt-filter-drawer__footer">
          <a href="{{ collection.url }}" class="kt-filter-drawer__clear">
            {{ 'kt.section.collection.clear_all' | t | default: 'Clear all' }}
          </a>
          <button
            type="submit"
            form="FilterDrawerForm"
            class="kt-filter-drawer__apply"
            data-filter-drawer-apply
          >
            {{ 'kt.section.collection.show_results' | t | default: 'Show results' }}
          </button>
        </footer>
      </aside>
    </div>
  {%- endif -%}

  {%- comment -%} Product Grid {%- endcomment -%}
  <div class="page-width">
    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="kt-collection__grid" id="product-grid" role="list" aria-live="polite" aria-busy="false">
          {%- for product in collection.products -%}
            {%- render 'card-product', product: product, show_vendor: section.settings.kt_pdp_show_vendor, show_secondary_image: section.settings.show_secondary_image, show_quote_button: section.settings.show_quote_button, index: forloop.index0 -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="kt-collection__pagination">
            {%- render 'pagination', paginate: paginate -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="kt-collection__empty">
          <h3 class="kt-collection__empty-title">{{ 'kt.section.collection.no_products' | t | default: 'No products found' }}</h3>
          <p class="kt-collection__empty-text">{{ 'kt.section.collection.no_products_desc' | t | default: 'Try adjusting your filters to discover more products.' }}</p>
          {%- if active_filters_count > 0 -%}
            <a href="{{ collection.url }}" class="kt-collection__clear-all">
              {{ 'kt.section.collection.clear_all' | t | default: 'Clear all filters' }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>

  {%- comment -%}
    App block slot — schema declares `{"type": "@app"}`; this renders
    any app blocks the merchant has dragged in (Judge.me star ratings,
    wishlist widgets, etc.). Kept outside the product grid so the
    app's markup doesn't break the grid layout.
  {%- endcomment -%}
  {% render 'section-app-blocks' %}
</div>

<script src="{{ 'kt-section-main-collection.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'collection-filters.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'countdown.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-collection.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-collection.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.main-collection.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.main-collection.settings.heading_tag.options__2.label"
        }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 12,
      "label": "t:sections.main-collection.settings.products_per_page.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection.settings.header__product_card.content"
    },
    {
      "type": "checkbox",
      "id": "kt_pdp_show_vendor",
      "label": "t:sections.main-collection.settings.kt_pdp_show_vendor.label",
      "info": "t:sections.main-collection.settings.kt_pdp_show_vendor.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.main-collection.settings.show_secondary_image.label",
      "info": "t:sections.main-collection.settings.show_secondary_image.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quote_button",
      "label": "t:sections.main-collection.settings.show_quote_button.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
