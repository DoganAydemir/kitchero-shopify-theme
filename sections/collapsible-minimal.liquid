{%- comment -%}
  Collapsible Content — Minimal Floating (Style 03).

  Two-column grid of floating cards. Each card is a native
  <details>/<summary> disclosure with a rotating plus icon.
  100% CSS-driven: no JS needed. Independent disclosures — any
  number can be open at once.

  Visual reference: collapsible style 03.
{%- endcomment -%}

{{ 'kt-section-collapsible-minimal.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign col_count = section.settings.column_count_desktop | default: 2
-%}

<section
  class="kt-collapsible-minimal"
  data-section-id="{{ section.id }}"
  style="--kt-col-count: {{ col_count }};"
  aria-labelledby="CollapsibleMinimal-{{ section.id }}-heading"
>
  <div class="kt-collapsible-minimal__inner">
    {%- if eyebrow != blank or heading != blank -%}
      <header class="kt-collapsible-minimal__header">
        {%- if eyebrow != blank -%}
          <span class="kt-collapsible-minimal__eyebrow">{{ eyebrow }}</span>
        {%- endif -%}
        {%- if heading != blank -%}
          <{{ heading_tag }}
            id="CollapsibleMinimal-{{ section.id }}-heading"
            class="kt-collapsible-minimal__title"
          >
            {{ heading }}
          </{{ heading_tag }}>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="kt-collapsible-minimal__grid" role="list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'item' -%}
              <details
                class="kt-collapsible-minimal__item"
                role="listitem"
                {% if block.settings.open %}open{% endif %}
                {{ block.shopify_attributes }}
              >
                <summary class="kt-collapsible-minimal__summary">
                  <span class="kt-collapsible-minimal__item-title">
                    {%- if block.settings.title != blank -%}
                      {{- block.settings.title -}}
                    {%- else -%}
                      {{- 'kt.general.untitled' | t -}}
                    {%- endif -%}
                  </span>
                  <span class="kt-collapsible-minimal__icon" aria-hidden="true">
                    <span class="kt-collapsible-minimal__icon-h"></span>
                    <span class="kt-collapsible-minimal__icon-v"></span>
                  </span>
                </summary>
                <div class="kt-collapsible-minimal__panel">
                  <div class="kt-collapsible-minimal__content rte">
                    {{ block.settings.content }}
                  </div>
                </div>
              </details>
            {%- when '@app' -%}
              {%- comment -%}
                R87 — shopify_attributes wrapper for editor
                highlight on app-block select.
              {%- endcomment -%}
              <div class="kt-collapsible-minimal__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.collapsible_minimal.name",
  "tag": "div",
  "class": "section-collapsible-minimal",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collapsible_minimal.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.collapsible_minimal.settings.eyebrow.label",
      "default": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collapsible_minimal.settings.heading.label",
      "default": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.collapsible_minimal.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "t:sections.collapsible_minimal.settings.heading_tag.options__1.label" },
        { "value": "h3", "label": "t:sections.collapsible_minimal.settings.heading_tag.options__2.label" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible_minimal.settings.header_layout.content"
    },
    {
      "type": "range",
      "id": "column_count_desktop",
      "label": "t:sections.collapsible_minimal.settings.column_count_desktop.label",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.collapsible_minimal.blocks.item.name",
      "limit": 16,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.collapsible_minimal.blocks.item.settings.title.label",
          "default": "Technical Specification"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.collapsible_minimal.blocks.item.settings.content.label",
          "default": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "t:sections.collapsible_minimal.blocks.item.settings.open.label",
          "default": false
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible_minimal.presets.name",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Technical Specification 01",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Technical Specification 02",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Technical Specification 03",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Technical Specification 04",
            "content": "<p>Add the answer to this question. Use specific details that reflect your shop's actual practices and policies.</p>"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
