{%- comment -%}
  Financing Panel — detail block for a single lender (Affirm, BreadPay…).
  Split two-column layout (image on one side, copy on the other) ported
  from the Next.js /financing page. Supports a light and a dark variant,
  a checklist of promises, an optional 3-column "how it works" footer
  row, a 2-column icon feature grid, an optional floating prequalified
  card, and a single CTA button.

  Content is driven by blocks to keep the schema flexible:
    - feature (checkmark bullet, used for the Affirm panel)
    - step (icon + title + desc, "how it works" row)
    - highlight (icon + title + desc, BreadPay 2x2 grid)
{%- endcomment -%}

{{ 'section-financing-panel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h3'
  assign invert = section.settings.invert_colors
  assign image_position = section.settings.image_position | default: 'right'
  assign variant_class = 'kt-financing-panel'
  if invert
    assign variant_class = 'kt-financing-panel kt-financing-panel--inverted'
  endif
  if image_position == 'left'
    assign variant_class = variant_class | append: ' kt-financing-panel--image-left'
  endif

  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign highlight_blocks = section.blocks | where: 'type', 'highlight'
-%}

<section
  class="{{ variant_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="financing-panel"
>
  {%- if invert and section.settings.background_image != blank -%}
    <div class="kt-financing-panel__bg" aria-hidden="true">
      {{
        section.settings.background_image
        | image_url: width: 2000
        | image_tag:
          class: 'kt-financing-panel__bg-image',
          loading: 'lazy',
          widths: '800, 1200, 1800, 2400',
          sizes: '100vw',
          width: section.settings.background_image.width,
          height: section.settings.background_image.height,
          alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="page-width kt-financing-panel__wrap">
    <div class="kt-financing-panel__grid">
      {%- comment -%} ── Media column ────────────────────────── {%- endcomment -%}
      <div class="kt-financing-panel__media-col">
        <div class="kt-financing-panel__media">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1200
              | image_tag:
                class: 'kt-financing-panel__image',
                loading: 'lazy',
                widths: '480, 720, 960, 1200, 1600',
                sizes: '(min-width: 990px) 44vw, 100vw',
                width: section.settings.image.width,
                height: section.settings.image.height,
                alt: section.settings.image.alt | default: section.settings.eyebrow
            }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg kt-financing-panel__image' }}
          {%- endif -%}
          {%- unless invert -%}
            <div class="kt-financing-panel__media-gradient" aria-hidden="true"></div>
          {%- endunless -%}
        </div>

        {%- if section.settings.show_floating_card -%}
          <div class="kt-financing-panel__floating-card" aria-hidden="false">
            {%- if section.settings.floating_eyebrow != blank -%}
              <span class="kt-financing-panel__floating-eyebrow">{{ section.settings.floating_eyebrow }}</span>
            {%- endif -%}
            {%- if section.settings.floating_value != blank -%}
              <p class="kt-financing-panel__floating-value">{{ section.settings.floating_value }}</p>
            {%- endif -%}
            {%- if section.settings.floating_description != blank -%}
              <p class="kt-financing-panel__floating-desc">{{ section.settings.floating_description }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Text column ─────────────────────────── {%- endcomment -%}
      <div class="kt-financing-panel__text-col">
        {%- if section.settings.eyebrow != blank -%}
          <div class="kt-financing-panel__eyebrow-row">
            {%- unless invert -%}
              <span class="kt-financing-panel__eyebrow-rule" aria-hidden="true"></span>
            {%- endunless -%}
            <span class="kt-financing-panel__eyebrow kt-financing-panel__eyebrow--{{ section.settings.eyebrow_style | default: 'default' }}">
              {%- if section.settings.eyebrow_style == 'bread' -%}
                <span class="kt-financing-panel__eyebrow-mark">{{ section.settings.eyebrow }}<sup>&reg;</sup></span>
              {%- else -%}
                {{ section.settings.eyebrow }}
              {%- endif -%}
            </span>
          </div>
        {%- endif -%}

        <{{ heading_tag }} class="kt-financing-panel__title">
          {%- if section.settings.heading_line1 != blank -%}
            <span class="kt-financing-panel__title-line">{{ section.settings.heading_line1 }}</span>
          {%- endif -%}
          {%- if section.settings.heading_line2 != blank -%}
            <span class="kt-financing-panel__title-line kt-financing-panel__title-line--accent kt-financing-panel__title-line--{{ section.settings.heading_accent_style | default: 'italic' }}">
              {{- section.settings.heading_line2 -}}
            </span>
          {%- endif -%}
        </{{ heading_tag }}>

        {%- if section.settings.description != blank -%}
          <p class="kt-financing-panel__desc">{{ section.settings.description }}</p>
        {%- endif -%}

        {%- if feature_blocks.size > 0 -%}
          <ul class="kt-financing-panel__features" role="list">
            {%- for block in feature_blocks -%}
              <li class="kt-financing-panel__feature" {{ block.shopify_attributes }}>
                <span class="kt-financing-panel__feature-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                <p class="kt-financing-panel__feature-text">{{ block.settings.text }}</p>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if highlight_blocks.size > 0 -%}
          <div class="kt-financing-panel__highlights">
            {%- for block in highlight_blocks -%}
              <div class="kt-financing-panel__highlight" {{ block.shopify_attributes }}>
                <div class="kt-financing-panel__highlight-icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'zap' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>
                    {%- when 'clock' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {%- when 'check' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-6"/></svg>
                    {%- when 'card' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    {%- when 'calculator' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="8" y2="10"/><line x1="12" y1="10" x2="12" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  {%- endcase -%}
                </div>
                <div class="kt-financing-panel__highlight-body">
                  <h5 class="kt-financing-panel__highlight-title">{{ block.settings.title }}</h5>
                  <p class="kt-financing-panel__highlight-desc">{{ block.settings.description }}</p>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if step_blocks.size > 0 -%}
          <div class="kt-financing-panel__steps">
            {%- for block in step_blocks -%}
              <div class="kt-financing-panel__step" {{ block.shopify_attributes }}>
                <div class="kt-financing-panel__step-icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'card' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    {%- when 'calculator' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="6" x2="15" y2="6"/><circle cx="9" cy="11" r="0.5"/><circle cx="12" cy="11" r="0.5"/><circle cx="15" cy="11" r="0.5"/><circle cx="9" cy="14" r="0.5"/><circle cx="12" cy="14" r="0.5"/><circle cx="15" cy="14" r="0.5"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
                    {%- when 'clock' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                  {%- endcase -%}
                </div>
                <h5 class="kt-financing-panel__step-title">{{ block.settings.title }}</h5>
                <p class="kt-financing-panel__step-desc">{{ block.settings.description }}</p>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <div class="kt-financing-panel__cta-row">
            <a
              href="{{ section.settings.cta_link | default: '#' }}"
              class="kt-financing-panel__cta"
            >
              {{ section.settings.cta_text }}
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.financing-panel.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.financing-panel.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.financing-panel.settings.eyebrow.label",
      "default": "affirm"
    },
    {
      "type": "select",
      "id": "eyebrow_style",
      "label": "t:sections.financing-panel.settings.eyebrow_style.label",
      "options": [
        { "value": "default", "label": "t:sections.financing-panel.settings.eyebrow_style.options__default.label" },
        { "value": "bread", "label": "t:sections.financing-panel.settings.eyebrow_style.options__bread.label" }
      ],
      "default": "default"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.financing-panel.settings.heading_line1.label",
      "default": "Buy now, pay over time."
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.financing-panel.settings.heading_line2.label",
      "default": "Starting at 0% APR."
    },
    {
      "type": "select",
      "id": "heading_accent_style",
      "label": "t:sections.financing-panel.settings.heading_accent_style.label",
      "options": [
        { "value": "italic", "label": "t:sections.financing-panel.settings.heading_accent_style.options__italic.label" },
        { "value": "muted", "label": "t:sections.financing-panel.settings.heading_accent_style.options__muted.label" }
      ],
      "default": "italic"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.financing-panel.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.financing-panel.settings.description.label",
      "default": "Affirm keeps it simple. No hidden fees, no surprises. Just a clear path to the kitchen you've always envisioned."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.financing-panel.settings.cta_text.label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.financing-panel.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.financing-panel.settings.header__media.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.financing-panel.settings.image.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.financing-panel.settings.image_position.label",
      "options": [
        { "value": "right", "label": "t:sections.financing-panel.settings.image_position.options__right.label" },
        { "value": "left", "label": "t:sections.financing-panel.settings.image_position.options__left.label" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "t:sections.financing-panel.settings.header__floating_card.content"
    },
    {
      "type": "checkbox",
      "id": "show_floating_card",
      "label": "t:sections.financing-panel.settings.show_floating_card.label",
      "default": false
    },
    {
      "type": "text",
      "id": "floating_eyebrow",
      "label": "t:sections.financing-panel.settings.floating_eyebrow.label",
      "default": "Prequalified"
    },
    {
      "type": "text",
      "id": "floating_value",
      "label": "t:sections.financing-panel.settings.floating_value.label",
      "default": "$30,000"
    },
    {
      "type": "textarea",
      "id": "floating_description",
      "label": "t:sections.financing-panel.settings.floating_description.label",
      "default": "Available to use instantly for your cabinetry project."
    },
    {
      "type": "header",
      "content": "t:sections.financing-panel.settings.header__appearance.content"
    },
    {
      "type": "checkbox",
      "id": "invert_colors",
      "label": "t:sections.financing-panel.settings.invert_colors.label",
      "info": "t:sections.financing-panel.settings.invert_colors.info",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.financing-panel.settings.background_image.label",
      "info": "t:sections.financing-panel.settings.background_image.info"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.financing-panel.blocks.feature.name",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.financing-panel.blocks.feature.settings.text.label",
          "default": "Clear total upfront. Your balance will never increase."
        }
      ]
    },
    {
      "type": "step",
      "name": "t:sections.financing-panel.blocks.step.name",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.financing-panel.blocks.step.settings.icon.label",
          "options": [
            { "value": "card", "label": "t:sections.financing-panel.blocks.step.settings.icon.options__card.label" },
            { "value": "calculator", "label": "t:sections.financing-panel.blocks.step.settings.icon.options__calculator.label" },
            { "value": "clock", "label": "t:sections.financing-panel.blocks.step.settings.icon.options__clock.label" }
          ],
          "default": "card"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.financing-panel.blocks.step.settings.title.label",
          "default": "Select Affirm"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.financing-panel.blocks.step.settings.description.label",
          "default": "Choose at checkout"
        }
      ]
    },
    {
      "type": "highlight",
      "name": "t:sections.financing-panel.blocks.highlight.name",
      "limit": 8,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.financing-panel.blocks.highlight.settings.icon.label",
          "options": [
            { "value": "zap", "label": "t:sections.financing-panel.blocks.highlight.settings.icon.options__zap.label" },
            { "value": "shield", "label": "t:sections.financing-panel.blocks.highlight.settings.icon.options__shield.label" },
            { "value": "clock", "label": "t:sections.financing-panel.blocks.highlight.settings.icon.options__clock.label" },
            { "value": "check", "label": "t:sections.financing-panel.blocks.highlight.settings.icon.options__check.label" },
            { "value": "card", "label": "t:sections.financing-panel.blocks.highlight.settings.icon.options__card.label" },
            { "value": "calculator", "label": "t:sections.financing-panel.blocks.highlight.settings.icon.options__calculator.label" }
          ],
          "default": "zap"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.financing-panel.blocks.highlight.settings.title.label",
          "default": "Instant Prequalification"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.financing-panel.blocks.highlight.settings.description.label",
          "default": "No impact on your credit score to see your options."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.financing-panel.presets.name"
    }
  ]
}
{% endschema %}
