{{ 'kt-section-main-article.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Main Article — individual journal entry template. Birebir from
  Next.js /blog/[slug] page:

    1. Hero header — centered meta row (category + rule + date),
       editorial 5xl-7xl serif H1, lead excerpt
    2. Full-bleed featured image (60vh mobile, 80vh desktop)
    3. Rich-text article body (rte) — Shopify article.content with
       editorial typography (serif h2/h3, large body)
    4. Share row (Facebook + X)
    5. Comments — list of approved comments, nested-reply-capable
       visual structure, {% form 'new_comment' %} with floating
       labels and a black submit button
    6. Back-to-blog link
{%- endcomment -%}

<article class="kt-article" data-section-id="{{ section.id }}" data-section-type="main-article">
  {%- comment -%}
    Visible breadcrumb that mirrors the BreadcrumbList JSON-LD from
    structured-data.liquid. Rendered above the article hero so
    readers orient themselves ("Home > Journal > This article")
    before entering the long-form content.
  {%- endcomment -%}
  <div class="page-width">
    {%- render 'breadcrumbs', class_extra: 'kt-article__breadcrumbs' -%}
  </div>

  {%- comment -%} Hero Header — centered, editorial {%- endcomment -%}
  <header class="kt-article__header">
    <div class="page-width">
      <div class="kt-article__header-inner">
        <div class="kt-article__meta">
          {%- comment -%}
            Underscore-prefixed tags are Shopify's hidden-meta
            convention (_featured etc.) — filter them out so
            internal curation tags don't leak to readers.
          {%- endcomment -%}
          {%- assign article_primary_tag = blank -%}
          {%- for tag in article.tags -%}
            {%- assign tag_first_char = tag | slice: 0 -%}
            {%- unless tag_first_char == '_' -%}
              {%- assign article_primary_tag = tag -%}
              {%- break -%}
            {%- endunless -%}
          {%- endfor -%}
          {%- if article_primary_tag != blank -%}
            <span class="kt-article__meta-item">{{ article_primary_tag }}</span>
            <span class="kt-article__meta-rule" aria-hidden="true"></span>
          {%- endif -%}
          <time class="kt-article__meta-item" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
            {{ article.published_at | date: format: 'abbreviated_date' }}
          </time>
          {%- comment -%}
            Author byline — Google's NewsArticle/BlogPosting rich result
            heavily weights a visible author string; without it, Search
            Console reports "Missing field 'author'" on every article.
            Shopify's native `article | structured_data` filter already
            populates the JSON-LD author — this adds the human-visible
            byline so the page itself matches the structured data.
          {%- endcomment -%}
          {%- if article.author != blank -%}
            <span class="kt-article__meta-rule" aria-hidden="true"></span>
            <span class="kt-article__meta-item kt-article__meta-author">
              {{ 'kt.blog.article.by_author_html' | t: author: article.author }}
            </span>
          {%- endif -%}
        </div>

        <h1 class="kt-article__title">{{ article.title }}</h1>

        {%- if article.excerpt != blank -%}
          <p class="kt-article__excerpt">{{ article.excerpt | strip_html }}</p>
        {%- endif -%}
      </div>
    </div>
  </header>

  {%- comment -%}
    Full-bleed featured image. Previously gated entirely on
    article.image — articles without a cover rendered no hero and
    (via snippets/structured-data.liquid's article | structured_data
    filter) may have emitted JSON-LD with an empty `image` field,
    which Google Search Console flags "Missing field 'image'" for
    BlogPosting. Falls back to the Shopify placeholder SVG so the
    layout reserves the LCP space AND structured data has a usable
    URL (Shopify's placeholder URL resolves at its CDN).
  {%- endcomment -%}
  <div class="kt-article__hero-image">
    {%- if article.image -%}
      {%- comment -%}
        Article hero is the article's LCP element — full-bleed above
        the fold on every template variant. `preload: true` routes a
        <link rel="preload" as="image"> through content_for_header so
        the browser discovers the image before the HTML parser reaches
        the <img> tag. Eager + fetchpriority already ensure immediate
        fetch; preload closes the discovery-latency gap that keeps
        Lighthouse's "Preload LCP image" from turning green.
      {%- endcomment -%}
      {{
        article.image
        | image_url: width: 2400
        | image_tag:
          class: 'kt-article__hero-img',
          loading: 'eager',
          fetchpriority: 'high',
          preload: true,
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          width: article.image.width,
          height: article.image.height,
          alt: article.title | escape
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-article__hero-img' }}
    {%- endif -%}
  </div>

  {%- comment -%} Body / rich-text content {%- endcomment -%}
  <div class="kt-article__body">
    <div class="page-width">
      <div class="kt-article__content rte">
        {{ article.content }}
      </div>

      {%- comment -%}
        App blocks — merchants can drop in review-widget /
        related-post / post-comment-reaction apps just below the
        article body. `block.shopify_attributes` is required so the
        theme editor highlights the block when selected.
      {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="kt-article__app-blocks">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                <div class="kt-article__app-block" {{ block.shopify_attributes }}>
                  {%- render block -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Share row {%- endcomment -%}
      <div class="kt-article__share">
        <span class="kt-article__share-label">{{ 'kt.share.title' | t | default: 'Share' }}</span>
        <div class="kt-article__share-links">
          <a
            href="https://www.facebook.com/sharer/sharer.php?u={{ article.url | prepend: request.origin | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="kt-article__share-link"
            aria-label="{{ 'kt.a11y.social.facebook' | t | default: 'Share on Facebook' }}"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://twitter.com/intent/tweet?url={{ article.url | prepend: request.origin | url_encode }}&text={{ article.title | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="kt-article__share-link"
            aria-label="{{ 'kt.a11y.social.x' | t | default: 'Share on X' }}"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%}
    Previous / next article navigation. Shopify exposes
    `blog.previous_article` and `blog.next_article` automatically for
    article templates, ordered by publication date. Without this
    readers finishing an article have to manually navigate back to
    the blog index + scan the grid. Standard editorial-theme pattern.
    Gated on EITHER being present so the row doesn't render empty on
    the first/last article in the blog.
  {%- endcomment -%}
  {%- if blog.previous_article or blog.next_article -%}
    <nav class="kt-article__pager" aria-label="{{ 'kt.blog.article.pager_label' | t | default: 'More articles' }}">
      <div class="page-width">
        <div class="kt-article__pager-inner">
          {%- if blog.previous_article -%}
            <a href="{{ blog.previous_article.url }}" class="kt-article__pager-link kt-article__pager-link--prev" rel="prev">
              <span class="kt-article__pager-eyebrow">{{ 'kt.blog.article.previous' | t | default: 'Previous' }}</span>
              <span class="kt-article__pager-title">{{ blog.previous_article.title }}</span>
            </a>
          {%- else -%}
            <span class="kt-article__pager-spacer" aria-hidden="true"></span>
          {%- endif -%}
          {%- if blog.next_article -%}
            <a href="{{ blog.next_article.url }}" class="kt-article__pager-link kt-article__pager-link--next" rel="next">
              <span class="kt-article__pager-eyebrow">{{ 'kt.blog.article.next' | t | default: 'Next' }}</span>
              <span class="kt-article__pager-title">{{ blog.next_article.title }}</span>
            </a>
          {%- else -%}
            <span class="kt-article__pager-spacer" aria-hidden="true"></span>
          {%- endif -%}
        </div>
      </div>
    </nav>
  {%- endif -%}

  {%- comment -%} Comments {%- endcomment -%}
  {%- if blog.comments_enabled? -%}
    <section class="kt-article__comments-section" id="comments">
      <div class="page-width">
        <div class="kt-article__comments-inner">
          <div class="kt-article__comments-head">
            <span class="kt-article__comments-eyebrow">
              {{ 'kt.blog.article.discussion' | t | default: 'Discussion' }}
            </span>
            <h2 class="kt-article__comments-title">
              {{ 'kt.blog.article.comments_label' | t | default: 'Comments' }}
              <span class="kt-article__comments-count">({{ article.comments_count }})</span>
            </h2>
          </div>

          {%- if article.comments.size > 0 -%}
            {%- paginate article.comments by 10 -%}
              <ol class="kt-article__comments-list" role="list">
                {%- for comment in article.comments -%}
                  <li class="kt-article__comment">
                    <div class="kt-article__comment-avatar" aria-hidden="true">
                      {{ comment.author | slice: 0, 1 | upcase | escape }}
                    </div>
                    <div class="kt-article__comment-body">
                      <div class="kt-article__comment-meta">
                        <span class="kt-article__comment-author">{{ comment.author | escape }}</span>
                        <time class="kt-article__comment-date" datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">
                          {{ comment.created_at | date: format: 'abbreviated_date' }}
                        </time>
                      </div>
                      <div class="kt-article__comment-content rte">{{ comment.content }}</div>
                    </div>
                  </li>
                {%- endfor -%}
              </ol>
              {%- if paginate.pages > 1 -%}
                <div class="kt-article__comments-pagination">
                  {%- render 'pagination', paginate: paginate, anchor: '#comments' -%}
                </div>
              {%- endif -%}
            {%- endpaginate -%}
          {%- else -%}
            <p class="kt-article__comments-empty">
              {{ 'kt.blog.article.no_comments' | t | default: 'No comments yet. Be the first to join the discussion.' }}
            </p>
          {%- endif -%}

          {%- comment -%} Comment form — uses Shopify {% form 'new_comment' %} {%- endcomment -%}
          <div class="kt-article__comment-form-card">
            <h3 class="kt-article__comment-form-title">
              {{ 'kt.blog.article.leave_comment' | t | default: 'Leave a comment' }}
            </h3>

            {%- form 'new_comment', article, id: 'CommentForm' -%}
              {%- if form.errors -%}
                <div class="kt-article__comment-form-error" role="alert">
                  {{ form.errors | default_errors }}
                </div>
              {%- endif -%}
              {%- if form.posted_successfully? -%}
                <div class="kt-article__comment-form-success" role="status">
                  {{ 'kt.blog.article.success' | t | default: 'Your comment was posted successfully! Thank you!' }}
                </div>
              {%- endif -%}

              {%- comment -%}
                All inputs preserve the typed values via `value=` /
                textarea inner-text. Shopify re-renders the article
                page with form.* populated on validation failure;
                without these bindings the customer retypes their
                comment, which is a known Theme-Store reject per the
                CLAUDE.md progressive-enhancement rule.
              {%- endcomment -%}
              <div class="kt-article__comment-form-grid">
                <div class="kt-article__comment-field">
                  <input
                    type="text"
                    id="comment-author"
                    name="comment[author]"
                    class="kt-article__comment-input"
                    value="{{ form.author | default: '' | escape }}"
                    required
                    autocomplete="name"
                    placeholder=" "
                    {% if form.errors contains 'author' %}aria-invalid="true" aria-describedby="comment-author-error"{% endif %}
                  >
                  <label for="comment-author" class="kt-article__comment-label">
                    {{ 'kt.blog.article.name' | t | default: 'Name' }}
                  </label>
                  {%- render 'form-field-error', form: form, field: 'author', describedby_id: 'comment-author-error' -%}
                </div>
                <div class="kt-article__comment-field">
                  <input
                    type="email"
                    id="comment-email"
                    name="comment[email]"
                    class="kt-article__comment-input"
                    value="{{ form.email | default: '' | escape }}"
                    required
                    autocomplete="email"
                    placeholder=" "
                    {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="comment-email-error"{% endif %}
                  >
                  <label for="comment-email" class="kt-article__comment-label">
                    {{ 'kt.blog.article.email' | t | default: 'Email' }}
                  </label>
                  {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'comment-email-error' -%}
                </div>
              </div>

              <div class="kt-article__comment-field kt-article__comment-field--full">
                <textarea
                  id="comment-body"
                  name="comment[body]"
                  class="kt-article__comment-textarea"
                  rows="4"
                  required
                  placeholder=" "
                  {% if form.errors contains 'body' %}aria-invalid="true" aria-describedby="comment-body-error"{% endif %}
                >{{ form.body | default: '' | escape }}</textarea>
                <label for="comment-body" class="kt-article__comment-label">
                  {{ 'kt.blog.article.comment' | t | default: 'Your Comment' }}
                </label>
                {%- render 'form-field-error', form: form, field: 'body', describedby_id: 'comment-body-error' -%}
              </div>

              {%- if blog.moderated? -%}
                <p class="kt-article__comment-moderation-note">
                  {{ 'kt.blog.article.moderated' | t | default: 'Please note, comments must be approved before they are published.' }}
                </p>
              {%- endif -%}

              <button type="submit" class="kt-article__comment-submit">
                {{ 'kt.blog.article.post_comment' | t | default: 'Post Comment' }}
              </button>
            {%- endform -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} Back-to-blog link {%- endcomment -%}
  <div class="kt-article__back-wrap">
    <div class="page-width">
      <a href="{{ blog.url }}" class="kt-article__back">
        <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {{ 'kt.blog.article.back_to_blog' | t: title: blog.title }}
      </a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "t:sections.main-article.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["article"]
  },
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
