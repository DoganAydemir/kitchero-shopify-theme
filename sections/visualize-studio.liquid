{{ 'kt-section-visualize-studio.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Visualize Studio — "Lumina Visual Studio" pro upgrade block.
  Birebir from showroom/[id]/page.tsx bottom CTA section.
  Immersive dark background + text on left, glassmorphic contact form on right.

  Uses Shopify {% form 'contact' %} for no-JS submission fallback.
{%- endcomment -%}

<section
  class="kt-visualize-studio"
  data-section-id="{{ section.id }}"
  data-section-type="visualize-studio"
>
  {%- comment -%} Immersive background {%- endcomment -%}
  <div class="kt-visualize-studio__bg" aria-hidden="true">
    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: class: 'kt-visualize-studio__bg-img', loading: 'lazy', widths: '750, 1100, 1600, 2000', sizes: '100vw', width: section.settings.background_image.width, height: section.settings.background_image.height, alt: '' }}
    {%- else -%}
      <div class="kt-visualize-studio__bg-placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
    <div class="kt-visualize-studio__bg-overlay"></div>
    <div class="kt-visualize-studio__bg-gradient"></div>
  </div>

  <div class="page-width kt-visualize-studio__content">
    <div class="kt-visualize-studio__grid">

      {%- comment -%} LEFT: heading + description {%- endcomment -%}
      <div class="kt-visualize-studio__text">
        <div class="kt-visualize-studio__eyebrow-row">
          <span class="kt-visualize-studio__rule" aria-hidden="true"></span>
          {%- if section.settings.eyebrow != blank -%}
            {%- comment -%}
              Eyebrow is decorative label (kicker), not a page-outline
              heading. Previously emitted as <h2> which placed it
              above the actual section heading at line 43 (default
              h3) — outline went h2 → h3 (kicker as parent of the
              real heading). Switched to <p> with a presentation-only
              class so the visual "uppercase small caps" treatment
              persists without polluting the heading hierarchy.
            {%- endcomment -%}
            <p class="kt-visualize-studio__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
        </div>

        {%- comment -%}
          R115 — default flipped to h2 (matches schema default
          flip below). h3 was the previous default but if a
          merchant reordered the home page so this section is
          the first one after main-product or any h1 surface,
          h1 → h3 was an invalid heading-skip per WCAG 1.3.1.
          h2 is the safe default for stackable sections; merchants
          who genuinely want h3 can still pick it.
        {%- endcomment -%}
        {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
        {%- if section.settings.heading_line1 != blank or section.settings.heading_line2 != blank -%}
          <{{ heading_tag }} class="kt-visualize-studio__heading">
            {{ section.settings.heading_line1 }}
            {%- if section.settings.heading_line2 != blank -%}
              <br><span class="kt-visualize-studio__heading-italic">{{ section.settings.heading_line2 }}</span>
            {%- endif -%}
          </{{ heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="kt-visualize-studio__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT: glassmorphic form {%- endcomment -%}
      <div class="kt-visualize-studio__form-wrap">
        <div class="kt-visualize-studio__form-card">
          {%- if section.settings.form_heading != blank -%}
            <h3 class="kt-visualize-studio__form-heading">{{ section.settings.form_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.form_subheading != blank -%}
            <p class="kt-visualize-studio__form-subheading">{{ section.settings.form_subheading }}</p>
          {%- endif -%}

          {%- comment -%}
            R151 VISUALIZE-STUDIO-SWAP-1: when form posts
            successfully, swap the form for the success message
            instead of rendering both. Pattern matches
            newsletter-signup / footer newsletter / main-register
            which all use `{%- if posted -%}…{%- else -%}…{%- endif -%}`
            so the customer doesn't see a "Thanks" message ABOVE
            an unfilled form (looks like submission failed).
            R148 audit caught this. Single-form-instance success
            UX is the codebase convention.
          {%- endcomment -%}
          {%- form 'contact', id: 'visualize-studio-form', class: 'kt-visualize-studio__form' -%}
            {%- if form.posted_successfully? -%}
              <p class="kt-visualize-studio__success" role="status">
                {{ 'kt.contact.form.post_success' | t | default: 'Thanks — we will get back to you soon.' }}
              </p>
            {%- else -%}
            {%- if form.errors -%}
              {%- comment -%}
                R297 — `data-form-error-summary` + anchor-wrapped
                field errors. Both visible inputs (Name, Email) are
                section-id-suffixed per R296 (`VisualizeStudioName-
                {{section.id}}`); the anchors must mirror those IDs.
              {%- endcomment -%}
              <div class="kt-form__error-summary" data-form-error-summary tabindex="-1">
                <p class="kt-form__error-title" role="alert">{{ 'kt.section.contact.error_title' | t | default: 'Please correct the following:' }}</p>
                <ul class="kt-form__error-list">
                  {%- for field in form.errors -%}
                    <li>
                      {%- if field == 'form' -%}
                        {{ form.errors.translated_messages[field] }}
                      {%- elsif field == 'name' or field == 'email' -%}
                        {%- assign vs_field_id = 'VisualizeStudioName' -%}
                        {%- if field == 'email' -%}{%- assign vs_field_id = 'VisualizeStudioEmail' -%}{%- endif -%}
                        <a href="#{{ vs_field_id }}-{{ section.id }}">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}</a>
                      {%- else -%}
                        {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            <div class="kt-visualize-studio__field">
              <label for="VisualizeStudioName-{{ section.id }}" class="visually-hidden">
                {{ 'kt.contact.form.name' | t | default: 'Name' }}
              </label>
              <input
                type="text"
                id="VisualizeStudioName-{{ section.id }}"
                name="contact[name]"
                placeholder="{{ 'kt.contact.form.name_placeholder' | t | default: 'Your Name' }}"
                autocomplete="name"
                required
                aria-required="true"
                {% if form.errors contains 'name' %}aria-invalid="true" aria-describedby="VisualizeStudioName-{{ section.id }}-error"{% endif %}
              >
              {%- render 'form-field-error', form: form, field: 'name', describedby_id: 'VisualizeStudioName-' | append: section.id | append: '-error' -%}
            </div>

            <div class="kt-visualize-studio__field">
              <label for="VisualizeStudioEmail-{{ section.id }}" class="visually-hidden">
                {{ 'kt.contact.form.email' | t | default: 'Email' }}
              </label>
              <input
                type="email"
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
                id="VisualizeStudioEmail-{{ section.id }}"
                name="contact[email]"
                placeholder="{{ 'kt.contact.form.email_placeholder' | t | default: 'Your Email' }}"
                inputmode="email"
                autocomplete="email"
                required
                aria-required="true"
                {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="VisualizeStudioEmail-{{ section.id }}-error"{% endif %}
              >
              {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'VisualizeStudioEmail-' | append: section.id | append: '-error' -%}
            </div>

            {%- comment -%}
              Honeypot — see base.css `.kt-form__honeypot` for positioning.
              Backend should reject any submission with a non-empty
              `contact[website]`. R296: ID suffixed with `section.id` so
              two instances of the section on the same template don't
              produce duplicate IDs (WCAG 4.1.1 fail).
            {%- endcomment -%}
            <p class="kt-form__honeypot" aria-hidden="true" inert>
              <label for="VisualizeStudioWebsiteTrap-{{ section.id }}">{{ 'kt.a11y.honeypot' | t | default: 'Leave this field empty' }}</label>
              <input type="text" id="VisualizeStudioWebsiteTrap-{{ section.id }}" name="contact[website]" tabindex="-1" autocomplete="off" aria-hidden="true">
            </p>

            {%- comment -%}
              `contact[body]` is the message field of Shopify's contact
              form. Without it, submissions deliver to the merchant
              inbox with an empty message — a lead with only name +
              email and no context. Hidden value carries the form
              intent (section heading) so merchants can route /
              auto-reply based on the source.
            {%- endcomment -%}
            {%- comment -%}
              Form context for merchant inbox triage — pulls from the
              section's existing heading_line1 setting (which is the
              actual visible section heading) rather than referencing
              an undefined `heading` setting that would silently
              resolve to nil.
            {%- endcomment -%}
            {%- assign visualize_subject_default = 'kt.section.visualize_studio.subject_default' | t -%}
            {%- capture visualize_body_message -%}
              Visualize Studio consultation request — section: {{ section.settings.heading_line1 | default: visualize_subject_default }}
            {%- endcapture -%}
            <input
              type="hidden"
              name="contact[body]"
              value="{{ visualize_body_message | strip | escape }}"
            >

            {%- assign visualize_submit_default = 'kt.section.visualize_studio.submit_default' | t -%}
            <button type="submit" class="kt-visualize-studio__submit">
              {{ section.settings.submit_text | default: visualize_submit_default }}
            </button>
            {%- endif -%}{%- comment -%} R151 close form posted_successfully? swap branch {%- endcomment -%}
          {%- endform -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.visualize-studio.name",
  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ],
    "templates": [
      "cart",
      "search",
      "password",
      "gift_card",
      "404"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.visualize-studio.settings.background_image.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.visualize-studio.settings.eyebrow.label",
      "default": "Visualize"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.visualize-studio.settings.heading_line1.label",
      "default": "Heading"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.visualize-studio.settings.heading_line2.label",
      "default": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.visualize-studio.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.visualize-studio.settings.heading_tag.options__1.label"
        },
        {
          "value": "h3",
          "label": "t:sections.visualize-studio.settings.heading_tag.options__2.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.visualize-studio.settings.description.label",
      "default": "Add a description for this section."
    },
    {
      "type": "header",
      "content": "t:sections.visualize-studio.settings.header__form.content"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "t:sections.visualize-studio.settings.form_heading.label",
      "default": "Form heading"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "t:sections.visualize-studio.settings.form_subheading.label",
      "default": "Subheading"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "t:sections.visualize-studio.settings.submit_text.label",
      "default": "Submit"
    }
  ],
  "presets": [
    {
      "name": "t:sections.visualize-studio.presets.name"
    }
  ]
}
{% endschema %}
