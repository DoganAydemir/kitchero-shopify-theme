{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}
{{ 'kt-section-customer-account.css' | asset_url | stylesheet_tag }}

<section class="kt-customer kt-customer--wide" data-section-id="{{ section.id }}" data-section-type="main-addresses">
  <div class="kt-customer__container kt-customer__container--wide">
    <header class="kt-account__header">
      <h1 class="kt-customer__title">{{ 'kt.customer.addresses.title' | t }}</h1>
    </header>

    <div class="kt-account__layout">
      {%- render 'account-nav', current: 'addresses' -%}

      <div class="kt-account__content">
        <div class="kt-addresses__actions">
          <h2 class="kt-account__section-title">{{ 'kt.customer.addresses.title' | t }}</h2>
          <button type="button" class="kt-addresses__btn" data-addresses-toggle-new aria-expanded="false" aria-controls="AddressNewForm">
            {{ 'kt.customer.addresses.add_new' | t }}
          </button>
        </div>

        {%- comment -%} New address form {%- endcomment -%}
        <div id="AddressNewForm" class="kt-addresses__form" hidden data-new-form>
          <h3 class="kt-addresses__form-title">{{ 'kt.customer.addresses.form_add_title' | t }}</h3>
          {%- form 'customer_address', customer.new_address -%}
            {%- if form.errors -%}
              <div class="kt-customer__errors" role="alert" tabindex="-1">
                <h2 class="kt-customer__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h2>
                <ul class="kt-customer__errors-list">
                  {%- for field in form.errors -%}
                    <li>
                      {%- if field == 'form' -%}
                        {{ form.errors.translated_messages[field] }}
                      {%- else -%}
                        {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            <div class="kt-addresses__row">
              <div class="kt-addresses__field">
                <label for="AddressFirstNameNew" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.first_name' | t }}</label>
                <input type="text" id="AddressFirstNameNew" name="address[first_name]" required aria-required="true" class="kt-customer__input" value="{{ form.first_name | escape }}" autocomplete="given-name" {% if form.errors contains 'first_name' %}aria-invalid="true" aria-describedby="AddressFirstNameNew-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'first_name', describedby_id: 'AddressFirstNameNew-error' -%}
              </div>
              <div class="kt-addresses__field">
                <label for="AddressLastNameNew" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.last_name' | t }}</label>
                <input type="text" id="AddressLastNameNew" name="address[last_name]" required aria-required="true" class="kt-customer__input" value="{{ form.last_name | escape }}" autocomplete="family-name" {% if form.errors contains 'last_name' %}aria-invalid="true" aria-describedby="AddressLastNameNew-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'last_name', describedby_id: 'AddressLastNameNew-error' -%}
              </div>
            </div>

            <div class="kt-addresses__field">
              <label for="AddressCompanyNew" class="kt-addresses__label">{{ 'kt.customer.addresses.company' | t }}</label>
              <input type="text" id="AddressCompanyNew" name="address[company]" class="kt-customer__input" value="{{ form.company | escape }}" autocomplete="organization" {% if form.errors contains 'company' %}aria-invalid="true" aria-describedby="AddressCompanyNew-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'company', describedby_id: 'AddressCompanyNew-error' -%}
            </div>

            <div class="kt-addresses__field">
              <label for="AddressAddress1New" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.address1' | t }}</label>
              <input type="text" id="AddressAddress1New" name="address[address1]" required aria-required="true" class="kt-customer__input" value="{{ form.address1 | escape }}" autocomplete="address-line1" {% if form.errors contains 'address1' %}aria-invalid="true" aria-describedby="AddressAddress1New-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'address1', describedby_id: 'AddressAddress1New-error' -%}
            </div>

            <div class="kt-addresses__field">
              <label for="AddressAddress2New" class="kt-addresses__label">{{ 'kt.customer.addresses.address2' | t }}</label>
              <input type="text" id="AddressAddress2New" name="address[address2]" class="kt-customer__input" value="{{ form.address2 | escape }}" autocomplete="address-line2" {% if form.errors contains 'address2' %}aria-invalid="true" aria-describedby="AddressAddress2New-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'address2', describedby_id: 'AddressAddress2New-error' -%}
            </div>

            <div class="kt-addresses__row">
              <div class="kt-addresses__field">
                <label for="AddressCityNew" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.city' | t }}</label>
                <input type="text" id="AddressCityNew" name="address[city]" required aria-required="true" class="kt-customer__input" value="{{ form.city | escape }}" autocomplete="address-level2" {% if form.errors contains 'city' %}aria-invalid="true" aria-describedby="AddressCityNew-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'city', describedby_id: 'AddressCityNew-error' -%}
              </div>
              <div class="kt-addresses__field">
                <label for="AddressZipNew" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.zip' | t }}</label>
                <input type="text" id="AddressZipNew" name="address[zip]" required aria-required="true" class="kt-customer__input" value="{{ form.zip | escape }}" autocomplete="postal-code" {% if form.errors contains 'zip' %}aria-invalid="true" aria-describedby="AddressZipNew-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'zip', describedby_id: 'AddressZipNew-error' -%}
              </div>
            </div>

            <div class="kt-addresses__row">
              <div class="kt-addresses__field">
                <label for="AddressCountryNew" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.country' | t }}</label>
                <select id="AddressCountryNew" name="address[country]" required aria-required="true" class="kt-customer__input" data-default="{{ form.country | escape }}" autocomplete="country-name" {% if form.errors contains 'country' %}aria-invalid="true" aria-describedby="AddressCountryNew-error"{% endif %}>
                  {{ country_option_tags }}
                </select>
                {%- render 'form-field-error', form: form, field: 'country', describedby_id: 'AddressCountryNew-error' -%}
              </div>
              <div class="kt-addresses__field" data-province-field>
                <label for="AddressProvinceNew" class="kt-addresses__label">{{ 'kt.customer.addresses.province' | t }}</label>
                <select id="AddressProvinceNew" name="address[province]" class="kt-customer__input" data-default="{{ form.province | escape }}" autocomplete="address-level1" {% if form.errors contains 'province' %}aria-invalid="true" aria-describedby="AddressProvinceNew-error"{% endif %}>

                </select>
                {%- render 'form-field-error', form: form, field: 'province', describedby_id: 'AddressProvinceNew-error' -%}
              </div>
            </div>

            <div class="kt-addresses__field">
              <label for="AddressPhoneNew" class="kt-addresses__label">{{ 'kt.customer.addresses.phone' | t }}</label>
              <input type="tel" id="AddressPhoneNew" name="address[phone]" class="kt-customer__input" value="{{ form.phone | escape }}" inputmode="tel" autocomplete="tel" {% if form.errors contains 'phone' %}aria-invalid="true" aria-describedby="AddressPhoneNew-error"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'phone', describedby_id: 'AddressPhoneNew-error' -%}
            </div>

            <div class="kt-addresses__checkbox-row">
              <input type="checkbox" id="AddressDefaultNew" name="address[default]" value="1">
              <label for="AddressDefaultNew">{{ 'kt.customer.addresses.set_default' | t }}</label>
            </div>

            <div class="kt-addresses__form-actions">
              <button type="submit" class="kt-customer__submit">{{ 'kt.customer.addresses.save' | t }}</button>
              <button type="button" class="kt-addresses__btn" data-addresses-cancel-new>{{ 'kt.customer.addresses.cancel' | t }}</button>
            </div>
          {%- endform -%}
        </div>

        {%- comment -%} Existing addresses {%- endcomment -%}
        {%- paginate customer.addresses by 6 -%}
          {%- if customer.addresses.size > 0 -%}
            <div class="kt-addresses__list">
              {%- for address in customer.addresses -%}
                <div class="kt-addresses__card" id="AddressCard{{ address.id }}">
                  {%- if address == customer.default_address -%}
                    <span class="kt-addresses__default">{{ 'kt.customer.addresses.default' | t }}</span>
                  {%- endif -%}
                  <address class="kt-addresses__address">{{ address | format_address }}</address>
                  <div class="kt-addresses__card-actions">
                    <button type="button" class="kt-addresses__btn" data-addresses-toggle-edit="{{ address.id }}" aria-expanded="false" aria-controls="AddressEditForm{{ address.id }}">
                      {{ 'kt.customer.addresses.edit' | t }}
                    </button>
                    {%- comment -%}
                      Delete button wrapped in a native form so it
                      works without JS. Shopify routes POST to an
                      address URL with hidden `_method=delete` as
                      an actual DELETE. JS intercepts the submit
                      event for a confirm() dialog and an AJAX
                      DELETE (see assets/customer-addresses.js) so
                      JS-on users still get the polished UX.
                    {%- endcomment -%}
                    {%- comment -%}
                      Wrap in {% form 'customer_address', address %} so
                      Shopify auto-injects the authenticity_token (CSRF).
                      Without it, JS-off users posting the delete get a
                      422 on stores with strict CSRF middleware.
                    {%- endcomment -%}
                    {%- form 'customer_address', address, class: 'kt-addresses__delete-form' -%}
                      <input type="hidden" name="_method" value="delete">
                      <button type="submit" class="kt-addresses__btn kt-addresses__btn--danger" data-addresses-delete="{{ address.url }}" data-confirm-message="{{ 'kt.customer.addresses.delete_confirm' | t }}">
                        {{ 'kt.customer.addresses.delete' | t }}
                      </button>
                    {%- endform -%}
                  </div>

                  <div id="AddressEditForm{{ address.id }}" class="kt-addresses__form" hidden data-edit-form="{{ address.id }}">
                    <h3 class="kt-addresses__form-title">{{ 'kt.customer.addresses.form_edit_title' | t }}</h3>
                    {%- form 'customer_address', address -%}
                      {%- if form.errors -%}
                        <div class="kt-customer__errors" role="alert" tabindex="-1">
                          <ul class="kt-customer__errors-list">
                            {%- for field in form.errors -%}
                              <li>
                                {%- if field == 'form' -%}
                                  {{ form.errors.translated_messages[field] }}
                                {%- else -%}
                                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      {%- endif -%}

                      {%- comment -%}
                        Per-address error-id anchors. Building these up front
                        (via | append so address.id is resolved at the Liquid
                        layer) lets each {% render 'form-field-error' %} call
                        pass a real interpolated string. A literal
                        'AddressFirstName{{ address.id }}-error' on the render
                        line would be passed verbatim — Liquid does NOT
                        interpolate {{ }} inside render-tag string arguments —
                        which would emit duplicate <p id="...{{ address.id }}..."
                        errors on every address card and break
                        aria-describedby linkage.
                      {%- endcomment -%}
                      {%- assign err_fname    = 'AddressFirstName' | append: address.id | append: '-error' -%}
                      {%- assign err_lname    = 'AddressLastName' | append: address.id | append: '-error' -%}
                      {%- assign err_company  = 'AddressCompany' | append: address.id | append: '-error' -%}
                      {%- assign err_addr1    = 'AddressAddress1' | append: address.id | append: '-error' -%}
                      {%- assign err_addr2    = 'AddressAddress2' | append: address.id | append: '-error' -%}
                      {%- assign err_city     = 'AddressCity' | append: address.id | append: '-error' -%}
                      {%- assign err_zip      = 'AddressZip' | append: address.id | append: '-error' -%}
                      {%- assign err_country  = 'AddressCountry' | append: address.id | append: '-error' -%}
                      {%- assign err_province = 'AddressProvince' | append: address.id | append: '-error' -%}
                      {%- assign err_phone    = 'AddressPhone' | append: address.id | append: '-error' -%}

                      <div class="kt-addresses__row">
                        <div class="kt-addresses__field">
                          <label for="AddressFirstName{{ address.id }}" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.first_name' | t }}</label>
                          <input type="text" id="AddressFirstName{{ address.id }}" name="address[first_name]" required aria-required="true" class="kt-customer__input" value="{{ form.first_name | default: address.first_name | escape }}" autocomplete="given-name" {% if form.errors contains 'first_name' %}aria-invalid="true" aria-describedby="{{ err_fname }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'first_name', describedby_id: err_fname -%}
                        </div>
                        <div class="kt-addresses__field">
                          <label for="AddressLastName{{ address.id }}" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.last_name' | t }}</label>
                          <input type="text" id="AddressLastName{{ address.id }}" name="address[last_name]" required aria-required="true" class="kt-customer__input" value="{{ form.last_name | default: address.last_name | escape }}" autocomplete="family-name" {% if form.errors contains 'last_name' %}aria-invalid="true" aria-describedby="{{ err_lname }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'last_name', describedby_id: err_lname -%}
                        </div>
                      </div>

                      <div class="kt-addresses__field">
                        <label for="AddressCompany{{ address.id }}" class="kt-addresses__label">{{ 'kt.customer.addresses.company' | t }}</label>
                        <input type="text" id="AddressCompany{{ address.id }}" name="address[company]" class="kt-customer__input" value="{{ form.company | default: address.company | escape }}" autocomplete="organization" {% if form.errors contains 'company' %}aria-invalid="true" aria-describedby="{{ err_company }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'company', describedby_id: err_company -%}
                      </div>

                      <div class="kt-addresses__field">
                        <label for="AddressAddress1{{ address.id }}" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.address1' | t }}</label>
                        <input type="text" id="AddressAddress1{{ address.id }}" name="address[address1]" required aria-required="true" class="kt-customer__input" value="{{ form.address1 | default: address.address1 | escape }}" autocomplete="address-line1" {% if form.errors contains 'address1' %}aria-invalid="true" aria-describedby="{{ err_addr1 }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'address1', describedby_id: err_addr1 -%}
                      </div>

                      <div class="kt-addresses__field">
                        <label for="AddressAddress2{{ address.id }}" class="kt-addresses__label">{{ 'kt.customer.addresses.address2' | t }}</label>
                        <input type="text" id="AddressAddress2{{ address.id }}" name="address[address2]" class="kt-customer__input" value="{{ form.address2 | default: address.address2 | escape }}" autocomplete="address-line2" {% if form.errors contains 'address2' %}aria-invalid="true" aria-describedby="{{ err_addr2 }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'address2', describedby_id: err_addr2 -%}
                      </div>

                      <div class="kt-addresses__row">
                        <div class="kt-addresses__field">
                          <label for="AddressCity{{ address.id }}" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.city' | t }}</label>
                          <input type="text" id="AddressCity{{ address.id }}" name="address[city]" required aria-required="true" class="kt-customer__input" value="{{ form.city | default: address.city | escape }}" autocomplete="address-level2" {% if form.errors contains 'city' %}aria-invalid="true" aria-describedby="{{ err_city }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'city', describedby_id: err_city -%}
                        </div>
                        <div class="kt-addresses__field">
                          <label for="AddressZip{{ address.id }}" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.zip' | t }}</label>
                          <input type="text" id="AddressZip{{ address.id }}" name="address[zip]" required aria-required="true" class="kt-customer__input" value="{{ form.zip | default: address.zip | escape }}" autocomplete="postal-code" {% if form.errors contains 'zip' %}aria-invalid="true" aria-describedby="{{ err_zip }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'zip', describedby_id: err_zip -%}
                        </div>
                      </div>

                      <div class="kt-addresses__row">
                        <div class="kt-addresses__field">
                          <label for="AddressCountry{{ address.id }}" class="kt-addresses__label kt-form__label--required">{{ 'kt.customer.addresses.country' | t }}</label>
                          <select id="AddressCountry{{ address.id }}" name="address[country]" required aria-required="true" class="kt-customer__input" data-default="{{ form.country | default: address.country | escape }}" autocomplete="country-name" {% if form.errors contains 'country' %}aria-invalid="true" aria-describedby="{{ err_country }}"{% endif %}>
                  {{ country_option_tags }}
                </select>
                {%- render 'form-field-error', form: form, field: 'country', describedby_id: err_country -%}
                        </div>
                        <div class="kt-addresses__field" data-province-field>
                          <label for="AddressProvince{{ address.id }}" class="kt-addresses__label">{{ 'kt.customer.addresses.province' | t }}</label>
                          <select id="AddressProvince{{ address.id }}" name="address[province]" class="kt-customer__input" data-default="{{ form.province | default: address.province | escape }}" autocomplete="address-level1" {% if form.errors contains 'province' %}aria-invalid="true" aria-describedby="{{ err_province }}"{% endif %}>

                </select>
                {%- render 'form-field-error', form: form, field: 'province', describedby_id: err_province -%}
                        </div>
                      </div>

                      <div class="kt-addresses__field">
                        <label for="AddressPhone{{ address.id }}" class="kt-addresses__label">{{ 'kt.customer.addresses.phone' | t }}</label>
                        <input type="tel" id="AddressPhone{{ address.id }}" name="address[phone]" class="kt-customer__input" value="{{ form.phone | default: address.phone | escape }}" inputmode="tel" autocomplete="tel" {% if form.errors contains 'phone' %}aria-invalid="true" aria-describedby="{{ err_phone }}"{% endif %}>
              {%- render 'form-field-error', form: form, field: 'phone', describedby_id: err_phone -%}
                      </div>

                      <div class="kt-addresses__checkbox-row">
                        <input type="checkbox" id="AddressDefault{{ address.id }}" name="address[default]" value="1"{% if address.default %} checked{% endif %}>
                        <label for="AddressDefault{{ address.id }}">{{ 'kt.customer.addresses.set_default' | t }}</label>
                      </div>

                      <div class="kt-addresses__form-actions">
                        <button type="submit" class="kt-customer__submit">{{ 'kt.customer.addresses.save' | t }}</button>
                        <button type="button" class="kt-addresses__btn" data-addresses-cancel-edit="{{ address.id }}">{{ 'kt.customer.addresses.cancel' | t }}</button>
                      </div>
                    {%- endform -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              {%- render 'pagination', paginate: paginate -%}
            {%- endif -%}
          {%- else -%}
            <div class="kt-account__empty">
              <p>{{ 'kt.customer.addresses.no_addresses' | t }}</p>
              {%- comment -%}
                Give brand-new customers a direct CTA instead of a
                flat paragraph. The data-addresses-toggle-new hook
                is the same handler that the "+ Add new address"
                header button uses, so clicking this reveals the
                inline new-address form below.
              {%- endcomment -%}
              <button
                type="button"
                class="kt-account__cta"
                data-addresses-toggle-new
                aria-expanded="false"
                aria-controls="AddressNewForm"
              >
                {{ 'kt.customer.addresses.add_new' | t }}
              </button>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'customer-addresses.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-addresses.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/addresses"]
  }
}
{% endschema %}
