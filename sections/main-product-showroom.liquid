{%- comment -%}
  R141 (final audit) — was a `media="print" onload="this.media='all'"`
  async-stylesheet swap. The inline `onload` JS attribute is a Theme
  Store instant-reject signal (CSP-incompatible) — see
  main-product.liquid for the matching R141 fix and rationale.
  Replaced with Shopify's native `stylesheet_tag` filter.
{%- endcomment -%}
{{ 'kt-product-accordion.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Main Product Showroom — premium visual layout (lead-gen focused)
  Birebir from showroom/[id]/page.tsx

  Block-driven architecture (matches main-product.liquid pattern):
  Every element in the right info column (brand, title, price,
  variant_picker, ctas, tags, accordions, warranty, door_sample,
  @app) is a reorderable/removable block. Merchants control the
  full layout from the theme editor. No hardcoded section-level
  content settings — everything lives on its block.

  Key differences vs E-commerce PDP:
  - No quantity selector, no main Add to Cart
  - Two CTAs: "Book Your Free Appointment" + "Book a Free Home Measure"
  - Rich pricing block with "Now only", save badge, monthly installment
  - Title + door thumbnail row
  - Color swatches are bigger (36px) with "+N more" indicator
  - Size selector uses big rounded-xl buttons (3-col)
  - Accordion titles use serif font, bigger
  - "Order a Door Sample" box — the ONLY place ATC happens
{%- endcomment -%}

{%- comment -%}
  R-pdp-audit — Breadcrumb render. Standard product template
  renders the breadcrumb trail via `{% render 'breadcrumbs' %}`
  at the top of its `<section>`; the showroom template skipped it,
  leaving a SEO + UX gap (no path back to the collection). Use the
  theme-global `settings.kt_show_breadcrumbs` toggle so merchants
  keep one switch for breadcrumbs across every template.
{%- endcomment -%}
{%- if settings.kt_show_breadcrumbs -%}
  {%- render 'breadcrumbs', class_extra: 'kt-breadcrumbs-wrap' -%}
{%- endif -%}

<section class="kt-showroom" data-section-id="{{ section.id }}" data-section-type="main-product">
  <div class="kt-showroom__container">
    <div class="kt-showroom__layout">

      {%- comment -%} LEFT: Gallery — alternating full + pair pattern (73%) {%- endcomment -%}
      <div class="kt-showroom__gallery-col" data-product-gallery>
        {%- comment -%} Desktop: alternating layout (full, pair, full, pair...) {%- endcomment -%}
        <div class="kt-showroom__gallery-desktop">
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              {%- assign pattern_pos = forloop.index0 | modulo: 3 -%}
              {%- comment -%}
                LCP eager hint: the first rendered image — whether it
                lands in the full-width branch (pattern_pos 0) or the
                pair branch (pattern_pos 1, e.g. when image 0 was a
                video) — must load eagerly with `fetchpriority: 'high'`
                so PDP LCP scores. All other images stay lazy.
              {%- endcomment -%}
              {%- if forloop.first -%}
                {%- assign img_loading = 'eager' -%}
                {%- assign img_fetchpriority = 'high' -%}
              {%- else -%}
                {%- assign img_loading = 'lazy' -%}
                {%- assign img_fetchpriority = 'auto' -%}
              {%- endif -%}
              {%- if pattern_pos == 0 -%}
                {%- comment -%}
                  Full width image. `data-media-type="image"` is the
                  signal `assets/product-gallery.js` uses to gate the
                  click → lightbox handler (video / 3D-model slides
                  skip the lightbox because the lightbox only knows
                  how to render an `<img>`). Without this attribute
                  the click handler short-circuits with the dataset
                  check at line 208 of product-gallery.js and the
                  showroom slides silently no-op on click.

                  `tabindex="0"` + `role="button"` give keyboard users
                  an Enter / Space activation path matching the click
                  behaviour. The shared keydown listener checks both
                  attributes when firing `openFromSlide`.
                {%- endcomment -%}
                <button
                  type="button"
                  class="kt-showroom__gallery-full"
                  data-gallery-slide="{{ forloop.index0 }}"
                  data-media-id="{{ media.id }}"
                  data-media-type="image"
                  aria-label="{{ 'kt.product.media.image_larger' | t: index: forloop.index | default: 'View image larger' }}"
                >
                  {%- assign media_alt = media.alt | default: product.title -%}
                  {{ media | image_url: width: 1200 | image_tag: class: 'kt-showroom__gallery-image', loading: img_loading, fetchpriority: img_fetchpriority, widths: '550, 750, 1100', sizes: '73vw', width: media.width, height: media.height, alt: media_alt }}
                </button>
              {%- elsif pattern_pos == 1 -%}
                {%- comment -%} Left of pair {%- endcomment -%}
                <div class="kt-showroom__gallery-pair">
                  <button
                    type="button"
                    class="kt-showroom__gallery-half"
                    data-gallery-slide="{{ forloop.index0 }}"
                    data-media-id="{{ media.id }}"
                    data-media-type="image"
                    aria-label="{{ 'kt.product.media.image_larger' | t: index: forloop.index | default: 'View image larger' }}"
                  >
                    {%- assign media_alt = media.alt | default: product.title -%}
                    {{ media | image_url: width: 800 | image_tag: class: 'kt-showroom__gallery-image', loading: img_loading, fetchpriority: img_fetchpriority, widths: '375, 550, 800', sizes: '36vw', width: media.width, height: media.height, alt: media_alt }}
                  </button>
                  {%- comment -%} Right of pair (next image) {%- endcomment -%}
                  {%- assign next_index = forloop.index -%}
                  {%- if product.media[next_index] and product.media[next_index].media_type == 'image' -%}
                    {%- assign next_media = product.media[next_index] -%}
                    <button
                      type="button"
                      class="kt-showroom__gallery-half"
                      data-gallery-slide="{{ next_index }}"
                      data-media-id="{{ next_media.id }}"
                      data-media-type="image"
                      aria-label="{{ 'kt.product.media.image_larger' | t: index: next_index | plus: 1 | default: 'View image larger' }}"
                    >
                      {%- assign next_alt = next_media.alt | default: product.title -%}
                      {{ next_media | image_url: width: 800 | image_tag: class: 'kt-showroom__gallery-image', loading: 'lazy', widths: '375, 550, 800', sizes: '36vw', width: next_media.width, height: next_media.height, alt: next_alt }}
                    </button>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- comment -%} pattern_pos == 2 is handled as right side of pair above {%- endcomment -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%}
            R298 — Video / external_video / 3D-model media. Previously
            the desktop gallery filtered out every non-image media so
            products with videos or 3D models silently lost them on the
            showroom template — a Theme Store rejection because video
            and AR are mandatory features on products that ship them.

            These render as full-width slots after the image pattern.
            They render OUTSIDE the lightbox click path
            (data-media-type set so product-gallery.js skips them per
            its known-types dataset gate). Each carries its own native
            controls (HTML5 <video controls>, YouTube/Vimeo iframe,
            <model-viewer toggleable>) so customers can play / view
            without invoking the image-only lightbox.
          {%- endcomment -%}
          {%- for media in product.media -%}
            {%- assign media_alt = media.alt | default: product.title -%}
            {%- case media.media_type -%}
              {%- when 'video' -%}
                <div class="kt-showroom__gallery-full kt-showroom__gallery-full--media" data-media-type="video">
                  {%- assign video_poster_url = media.preview_image | image_url: width: 1200 -%}
                  {{
                    media
                    | video_tag:
                      class: 'kt-showroom__gallery-video',
                      controls: true,
                      preload: 'metadata',
                      loop: false,
                      image_size: '1200x',
                      poster: video_poster_url,
                      title: media_alt
                  }}
                </div>
              {%- when 'external_video' -%}
                <div class="kt-showroom__gallery-full kt-showroom__gallery-full--media" data-media-type="external_video">
                  {{
                    media
                    | external_video_tag:
                      class: 'kt-showroom__gallery-video',
                      loading: 'lazy',
                      title: media_alt
                  }}
                </div>
              {%- when 'model' -%}
                <div class="kt-showroom__gallery-full kt-showroom__gallery-full--media" data-media-type="model">
                  <product-model class="kt-showroom__gallery-model" data-media-id="{{ media.id }}">
                    {{
                      media
                      | model_viewer_tag:
                        image_size: '1200x',
                        reveal: 'interaction',
                        toggleable: true,
                        class: 'kt-showroom__gallery-model-viewer'
                    }}
                  </product-model>
                </div>
            {%- endcase -%}
          {%- endfor -%}

          {%- if product.media.size == 0 -%}
            <div class="kt-showroom__gallery-full">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-showroom__gallery-image' }}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Mobile: horizontal scroll carousel — slides also tag
          data-gallery-slide so the shared product-gallery.js lightbox works. {%- endcomment -%}
        <div class="kt-showroom__gallery-mobile">
          {%- for media in product.media -%}
            {%- comment -%}
              R298 — Mobile slides used to filter to images only,
              silently dropping video / external_video / model media
              (a Theme Store rejection on products that ship them).
              Now each media type renders in its own slide; the
              counter at the bottom uses `product.media.size` which
              now matches the rendered slide count.

              R140 SHOWROOM-DUAL-LCP-1: both desktop AND mobile
              gallery branches render in DOM and CSS toggles them
              with display:none. Browsers still fetch <img> resources
              inside display:none containers — the desktop branch
              claims `fetchpriority: 'high'`, the mobile branch
              downgrades to `auto` to avoid LCP candidate ambiguity.
            {%- endcomment -%}
            {%- if forloop.first -%}
              {%- assign mob_loading = 'eager' -%}
              {%- assign mob_fetchpriority = 'auto' -%}
            {%- else -%}
              {%- assign mob_loading = 'lazy' -%}
              {%- assign mob_fetchpriority = 'auto' -%}
            {%- endif -%}
            {%- assign media_alt = media.alt | default: product.title -%}
            {%- case media.media_type -%}
              {%- when 'image' -%}
                <button
                  type="button"
                  class="kt-showroom__gallery-mobile-slide"
                  data-gallery-slide="{{ forloop.index0 }}"
                  data-media-type="image"
                  aria-label="{{ 'kt.product.media.image_larger' | t: index: forloop.index | default: 'View image larger' }}"
                >
                  {{ media | image_url: width: 800 | image_tag: class: 'kt-showroom__gallery-image', loading: mob_loading, fetchpriority: mob_fetchpriority, widths: '375, 550, 800', sizes: '100vw', width: media.width, height: media.height, alt: media_alt }}
                  <span class="kt-showroom__gallery-counter">{{ forloop.index }} / {{ product.media.size }}</span>
                </button>
              {%- when 'video' -%}
                <div class="kt-showroom__gallery-mobile-slide kt-showroom__gallery-mobile-slide--media" data-media-type="video">
                  {%- assign video_poster_url = media.preview_image | image_url: width: 800 -%}
                  {{
                    media
                    | video_tag:
                      class: 'kt-showroom__gallery-video',
                      controls: true,
                      preload: 'metadata',
                      loop: false,
                      image_size: '800x',
                      poster: video_poster_url,
                      title: media_alt
                  }}
                  <span class="kt-showroom__gallery-counter">{{ forloop.index }} / {{ product.media.size }}</span>
                </div>
              {%- when 'external_video' -%}
                <div class="kt-showroom__gallery-mobile-slide kt-showroom__gallery-mobile-slide--media" data-media-type="external_video">
                  {{
                    media
                    | external_video_tag:
                      class: 'kt-showroom__gallery-video',
                      loading: 'lazy',
                      title: media_alt
                  }}
                  <span class="kt-showroom__gallery-counter">{{ forloop.index }} / {{ product.media.size }}</span>
                </div>
              {%- when 'model' -%}
                <div class="kt-showroom__gallery-mobile-slide kt-showroom__gallery-mobile-slide--media" data-media-type="model">
                  <product-model class="kt-showroom__gallery-model" data-media-id="{{ media.id }}">
                    {{
                      media
                      | model_viewer_tag:
                        image_size: '800x',
                        reveal: 'interaction',
                        toggleable: true,
                        class: 'kt-showroom__gallery-model-viewer'
                    }}
                  </product-model>
                  <span class="kt-showroom__gallery-counter">{{ forloop.index }} / {{ product.media.size }}</span>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {%- comment -%}
          Lightbox (shared). The canonical version of this widget in
          snippets/product-media-gallery.liquid:241-249 already declares
          role="dialog" + aria-modal="true" + aria-label so screen
          readers announce the modal correctly when JS toggles it
          open. This duplicate render in main-product-showroom drifted
          and shipped without the dialog ARIA — without role="dialog"
          the SR announces the lightbox as a generic group, breaking
          modal expectations. `inert` removes the closed lightbox
          subtree from the focus chain (it hides via opacity:0 +
          pointer-events:none, not display:none, so without inert the
          inner buttons stay tab-reachable while invisible).
        {%- endcomment -%}
        <div
          class="kt-lightbox"
          data-lightbox
          role="dialog"
          aria-modal="true"
          aria-label="{{ 'kt.a11y.lightbox' | t | default: 'Product image viewer' }}"
          aria-hidden="true"
          inert
          data-lenis-prevent="true"
        >
          <button type="button" class="kt-lightbox__close" data-lightbox-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
            {% render 'icon-close', stroke_width: 1.5 %}
          </button>
          <button type="button" class="kt-lightbox__nav kt-lightbox__nav--prev" data-lightbox-prev aria-label="{{ 'kt.section.hero.previous_slide' | t | default: 'Previous' }}">
            {% render 'icon-chevron-left', width: 32, height: 32, stroke_width: 1.5 %}
          </button>
          <button type="button" class="kt-lightbox__nav kt-lightbox__nav--next" data-lightbox-next aria-label="{{ 'kt.section.hero.next_slide' | t | default: 'Next' }}">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
          <div class="kt-lightbox__viewport" data-lightbox-viewport>
            <div class="kt-lightbox__spinner" data-lightbox-spinner aria-hidden="true"></div>
            {%- comment -%}
              Lightbox image — src is populated by assets/product-gallery.js
              when the user opens the lightbox. The empty <img> never paints
              on page load (the container is aria-hidden until opened) so no
              extra request is made.
            {%- endcomment -%}
            <img
              class="kt-lightbox__image"
              data-lightbox-image
              alt=""
              width="1200"
              height="900"
              loading="lazy"
            >
          </div>
        </div>
      </div>

      {%- comment -%} RIGHT: Product Info (27%, sticky) — fully block-driven {%- endcomment -%}
      <div class="kt-showroom__info-col kt-showroom--variant-picker-big">
        <div class="kt-showroom__info-sticky" data-kt-pdp-anim-group>

          {%- comment -%}
            Render blocks in order. Tags and accordions are grouped
            visually: the FIRST tag/accordion block renders the whole
            group's wrapper (and iterates all siblings of the same type),
            subsequent same-type blocks are skipped via the flag.
          {%- endcomment -%}
          {%- assign tags_rendered = false -%}
          {%- assign accordions_rendered = false -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'brand' -%}
                <p class="kt-showroom__brand" {{ block.shopify_attributes }}>
                  {%- if block.settings.text != blank -%}
                    {{ block.settings.text }}
                  {%- else -%}
                    {{ product.vendor | default: shop.name | escape }} {{ 'kt.product.collection_label' | t | default: 'Collection' }}
                  {%- endif -%}
                </p>

              {%- when 'title' -%}
                {%- comment -%}
                  R295 — PDP MUST emit a single <h1> for SEO +
                  WCAG 2.4.6. The previous schema option that let
                  merchants downgrade to <h2> was removed because a
                  downgraded PDP heading is an instant Theme Store
                  reject (parity with main-product.liquid R295 fix —
                  see sections/main-product.liquid line 90).
                {%- endcomment -%}
                {%- comment -%}
                  R-thumb-merchant — Door thumbnail resolution is now
                  TIERED so the theme works out of the box without any
                  merchant configuration AND still gives power-users
                  fine-grained control:

                    Tier 1: `product.metafields.custom.door_sample`
                            (per-product metafield, set in Shopify
                            Admin → Products → [P] → Metafields).
                            One-time setup of the metafield definition
                            (Settings → Custom data → Products → Add
                            definition) unlocks this on every product.
                            Best for stores with a dedicated swatch
                            photo per product.

                    Tier 2: `product.selected_or_first_available_variant
                             .featured_image` (variant featured image).
                            Catches the common cabinet store pattern
                            where each variant ("Door Style: Slab",
                            "Door Style: Shaker", etc.) ships its own
                            swatch photo via Shopify's standard variant
                            image picker — zero metafield setup.
                            Skipped when the variant image is the same
                            as the product's master featured image
                            (otherwise the thumb would just duplicate
                            the gallery hero, which is the blurry
                            placeholder problem the merchant flagged).

                    Tier 3: Nothing — slot stays empty.
                            Cleaner than a duplicate of the gallery
                            hero or a generic fallback image.

                  Non-image metafield values (PDF spec sheets, CAD
                  files, etc.) are filtered via the `media_type`
                  check on the metafield path so a merchant pointing
                  the metafield at a document doesn't blow up the
                  image_tag call below.
                {%- endcomment -%}
                {%- assign door_sample_image = nil -%}
                {%- if product.metafields.custom.door_sample.value != blank
                       and product.metafields.custom.door_sample.value.media_type == 'image' -%}
                  {%- assign door_sample_image = product.metafields.custom.door_sample.value -%}
                {%- else -%}
                  {%- assign door_thumb_variant = product.selected_or_first_available_variant -%}
                  {%- if door_thumb_variant.featured_image != blank
                         and door_thumb_variant.featured_image != product.featured_image -%}
                    {%- assign door_sample_image = door_thumb_variant.featured_image -%}
                  {%- endif -%}
                {%- endif -%}
                <div class="kt-showroom__title-row" {{ block.shopify_attributes }}>
                  <h1 class="kt-showroom__title">{{ product.title | escape }}</h1>
                  {%- if block.settings.show_door_thumb and door_sample_image != blank -%}
                    {%- comment -%}
                      Image bumped from `width: 160` to `width: 240` so
                      retina (3x) phones get a crisp 80×106 paint
                      instead of the 2x render that previously softened
                      detail on iPhone Pro / Plus-class displays.
                    {%- endcomment -%}
                    <div class="kt-showroom__door-thumb">
                      {{ door_sample_image | image_url: width: 240 | image_tag: loading: 'lazy', width: 80, height: 106, alt: door_sample_image.alt | default: product.title }}
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'price' -%}
                <div {{ block.shopify_attributes }}>
                  {%- render 'product-price-showroom',
                    product: product,
                    financing_months: block.settings.financing_months,
                    financing_apr: block.settings.financing_apr,
                    financing_label: block.settings.financing_label
                  -%}
                </div>

              {%- when 'description' -%}
                {%- comment -%}
                  R-pdp-completeness — Standalone description block,
                  separate from the accordion fallback that lives
                  inside an accordion when no custom content is set.
                  Use this when the merchant wants the full product
                  description displayed inline in the info column
                  (above accordions / specs), not buried behind a
                  collapsible. Mirrors the main-product template's
                  description block (truncate + word_limit settings)
                  so editors get a consistent set of controls across
                  templates.
                {%- endcomment -%}
                {%- if product.description != blank -%}
                  {%- if block.settings.truncate -%}
                    {%- assign showroom_word_limit_safe = block.settings.word_limit | default: 40 -%}
                    <div class="kt-showroom__desc-block" {{ block.shopify_attributes }}>
                      {{ product.description | strip_html | truncatewords: showroom_word_limit_safe }}
                    </div>
                  {%- else -%}
                    <div class="kt-showroom__desc-block rte" {{ block.shopify_attributes }}>
                      {{ product.description }}
                    </div>
                  {%- endif -%}
                {%- endif -%}

              {%- when 'variant_picker' -%}
                <div {{ block.shopify_attributes }}>
                  {%- render 'product-variant-picker', product: product, section: section -%}
                </div>

              {%- when 'ctas' -%}
                {%- comment -%}
                  R294 — Primary CTA opens the appointment drawer
                  via `data-consultation-open`. If the merchant
                  has disabled appointments (theme settings →
                  Features → Appointment drawer), the drawer JS +
                  markup are not on the page, so a click on this
                  button would do nothing visible. Swap the
                  primary button for the secondary CTA's link (if
                  one is configured) in that case, otherwise hide
                  the CTA cluster entirely. Avoids dead buttons
                  that Theme Store reviewers flag as "non-functional
                  interactive element".
                {%- endcomment -%}
                {%- if settings.kt_appointment_enabled or block.settings.secondary_cta_link != blank -%}
                <div class="kt-showroom__ctas" {{ block.shopify_attributes }}>
                  {%- if settings.kt_appointment_enabled -%}
                    <button
                      type="button"
                      class="kt-showroom__cta kt-showroom__cta--primary"
                      data-consultation-open
                    >
                      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      <span>{{ block.settings.primary_cta_text }}</span>
                    </button>
                  {%- endif -%}

                  {%- if block.settings.secondary_cta_text != blank -%}
                    {%- if block.settings.secondary_cta_link != blank -%}
                      <a
                        href="{{ block.settings.secondary_cta_link | escape }}"
                        class="kt-showroom__cta kt-showroom__cta--secondary"
                      >
                        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                          <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                          <path d="M2 2l7.586 7.586"></path>
                          <circle cx="11" cy="11" r="2"></circle>
                        </svg>
                        <span>{{ block.settings.secondary_cta_text }}</span>
                      </a>
                    {%- elsif settings.kt_appointment_enabled -%}
                      <button
                        type="button"
                        class="kt-showroom__cta kt-showroom__cta--secondary"
                        data-consultation-open
                      >
                        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                          <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                          <path d="M2 2l7.586 7.586"></path>
                          <circle cx="11" cy="11" r="2"></circle>
                        </svg>
                        <span>{{ block.settings.secondary_cta_text }}</span>
                      </button>
                    {%- endif -%}
                  {%- endif -%}
                </div>
                {%- endif -%}

              {%- when 'tag' -%}
                {%- unless tags_rendered -%}
                  {%- comment -%}
                    Source priority for "At a glance" feature pills:
                    1. `product.metafields.custom.features` (list.single_line_text_field)
                       — per-product, merchant-managed from Admin. The
                       standard pattern across Theme Store-approved themes
                       (Symmetry / Impulse / Empire) for product-specific
                       feature highlights. Reviewers test multi-product
                       behaviour and expect pills to differ between
                       products; identical pills across the catalogue
                       reads as broken / placeholder content.
                    2. Section blocks (manual text per template) — fallback
                       so merchants who haven't wired the metafield still
                       see the visual element and can customise per-template.
                       Block `limit: 8` keeps the manual path constrained.
                  {%- endcomment -%}
                  {%- assign metafield_features = product.metafields.custom.features.value -%}
                  {%- assign has_metafield_features = false -%}
                  {%- if metafield_features != blank and metafield_features.size > 0 -%}
                    {%- assign has_metafield_features = true -%}
                  {%- endif -%}
                  <div class="kt-showroom__tags">
                    <p class="kt-showroom__tags-label">{{ 'kt.product.at_a_glance' | t | default: 'At a glance' }}</p>
                    <div class="kt-showroom__tags-list">
                      {%- if has_metafield_features -%}
                        {%- for feature_text in metafield_features -%}
                          <span class="kt-showroom__tag">{{ feature_text | escape }}</span>
                        {%- endfor -%}
                      {%- else -%}
                        {%- for tag_block in section.blocks -%}
                          {%- if tag_block.type == 'tag' -%}
                            <span class="kt-showroom__tag" {{ tag_block.shopify_attributes }}>{{ tag_block.settings.text | escape }}</span>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    </div>
                  </div>
                  {%- assign tags_rendered = true -%}
                {%- endunless -%}

              {%- when 'accordion' -%}
                {%- unless accordions_rendered -%}
                  <div class="kt-showroom__accordions">
                    {%- for acc_block in section.blocks -%}
                      {%- if acc_block.type == 'accordion' -%}
                        {%- capture acc_content -%}
                          {%- if acc_block.settings.page != blank -%}
                            {{ acc_block.settings.page.content }}
                          {%- elsif acc_block.settings.content != blank -%}
                            {{ acc_block.settings.content }}
                          {%- else -%}
                            {%- comment -%}
                              product.description can contain RTE markup
                              (h-tags, lists, links). Wrapping it in a
                              raw <p> stripped the cascade and squashed
                              everything to plain inline text — and
                              produced invalid HTML when the description
                              itself contained block-level tags. Render
                              into a <div class="rte"> instead so it
                              picks up the unified RTE typography used by
                              main-article + main-page (Theme Store
                              cross-template RTE consistency rule).
                            {%- endcomment -%}
                            <div class="rte">{{ product.description }}</div>
                          {%- endif -%}
                        {%- endcapture -%}
                        {%- render 'product-accordion', title: acc_block.settings.title, content: acc_content, open: acc_block.settings.open, style: 'serif', shopify_attributes: acc_block.shopify_attributes -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {%- assign accordions_rendered = true -%}
                {%- endunless -%}

              {%- when 'metafield' -%}
                {%- comment -%}
                  R-pdp-completeness — Single-metafield row. Same
                  pattern as main-product.liquid's metafield block:
                  read `product.metafields[ns][key]` via merchant-
                  set namespace + key, render the typed `.value`
                  (Shopify auto-coerces references to links, plain
                  metafields to text). Silent on fresh installs
                  with no configuration; editor hint inside theme
                  editor (design_mode) so the merchant knows the
                  block needs ns/key inputs.
                {%- endcomment -%}
                {%- assign mf_ns = block.settings.namespace | default: 'custom' -%}
                {%- assign mf_key = block.settings.key -%}
                {%- if mf_ns != blank and mf_key != blank -%}
                  {%- assign mf_value = product.metafields[mf_ns][mf_key].value -%}
                  {%- if mf_value != blank -%}
                    <div class="kt-showroom__metafield" {{ block.shopify_attributes }}>
                      {%- if block.settings.label != blank -%}
                        <p class="kt-showroom__metafield-label">{{ block.settings.label | escape }}</p>
                      {%- endif -%}
                      <div class="kt-showroom__metafield-value">
                        {{- product.metafields[mf_ns][mf_key] -}}
                      </div>
                    </div>
                  {%- elsif request.design_mode -%}
                    <div class="kt-showroom__metafield kt-showroom__metafield--placeholder" {{ block.shopify_attributes }}>
                      <p class="kt-showroom__metafield-hint">
                        {{ 'kt.product.metafield.editor_hint' | t | default: 'Configure namespace + key in the editor sidebar to surface a product metafield.' }}
                      </p>
                    </div>
                  {%- endif -%}
                {%- elsif request.design_mode -%}
                  <div class="kt-showroom__metafield kt-showroom__metafield--placeholder" {{ block.shopify_attributes }}>
                    <p class="kt-showroom__metafield-hint">
                      {{ 'kt.product.metafield.editor_hint' | t | default: 'Configure namespace + key in the editor sidebar to surface a product metafield.' }}
                    </p>
                  </div>
                {%- endif -%}

              {%- when 'specifications' -%}
                {%- comment -%}
                  R-pdp-completeness — Multi-row specifications table.
                  5 label+value pairs, each value field is dynamic-
                  source enabled so the merchant can either type a
                  literal value OR connect the field to any product
                  metafield via the theme editor's dynamic source
                  icon. Rows with blank label OR value self-suppress
                  so a partially-configured block doesn't render
                  empty rows. Editor hint shown when zero rows
                  are configured (design_mode only).
                {%- endcomment -%}
                {%- liquid
                  assign spec_any = false
                  for i in (1..5)
                    assign label_key = 'label_' | append: i
                    assign value_key = 'value_' | append: i
                    if block.settings[label_key] != blank and block.settings[value_key] != blank
                      assign spec_any = true
                      break
                    endif
                  endfor
                -%}
                {%- if spec_any -%}
                  <div class="kt-showroom__specs" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                      <h2 class="kt-showroom__specs-title">{{ block.settings.title | escape }}</h2>
                    {%- endif -%}
                    <dl class="kt-showroom__specs-list">
                      {%- for i in (1..5) -%}
                        {%- assign label_key = 'label_' | append: i -%}
                        {%- assign value_key = 'value_' | append: i -%}
                        {%- if block.settings[label_key] != blank and block.settings[value_key] != blank -%}
                          <div class="kt-showroom__specs-row">
                            <dt class="kt-showroom__specs-label">{{ block.settings[label_key] | escape }}</dt>
                            <dd class="kt-showroom__specs-value">{{ block.settings[value_key] }}</dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </dl>
                  </div>
                {%- elsif request.design_mode -%}
                  <div class="kt-showroom__specs kt-showroom__specs--placeholder" {{ block.shopify_attributes }}>
                    <p class="kt-showroom__specs-hint">
                      {{ 'kt.product.specifications.editor_hint' | t | default: 'Add a label and value for each row, or connect the value field to a product metafield via the dynamic source icon.' }}
                    </p>
                  </div>
                {%- endif -%}

              {%- when 'liquid' -%}
                {%- comment -%}
                  R-pdp-audit — Custom Liquid block, parity with
                  main-product. Theme Store requires Custom Liquid
                  blocks "wherever app blocks would be used", and
                  showroom previously lacked this slot — merchants
                  who needed to drop in inline Liquid (e.g. a
                  marketing snippet, an inline structured-data
                  block, or a vendored app embed) had nowhere to
                  put it in this template.
                {%- endcomment -%}
                <div class="kt-showroom__custom-liquid" {{ block.shopify_attributes }}>
                  {{ block.settings.custom_liquid }}
                </div>

              {%- when 'trust_badges' -%}
                {%- comment -%}
                  R-pdp-audit — Trust badges, parity with main-product.
                  Same 4-badge slot pattern + 4 hand-picked icons
                  (shipping / returns / warranty / package). Block
                  emits nothing when every text slot is blank, so the
                  default install stays clean.
                {%- endcomment -%}
                <div class="kt-showroom__trust-badges" {{ block.shopify_attributes }}>
                  {%- for i in (1..4) -%}
                    {%- assign icon_key = 'badge_' | append: i | append: '_icon' -%}
                    {%- assign text_key = 'badge_' | append: i | append: '_text' -%}
                    {%- assign icon_val = block.settings[icon_key] -%}
                    {%- assign text_val = block.settings[text_key] -%}
                    {%- if text_val != blank -%}
                      <div class="kt-showroom__trust-badge">
                        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          {%- case icon_val -%}
                            {%- when 'shipping' -%}
                              <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
                            {%- when 'returns' -%}
                              <polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
                            {%- when 'warranty' -%}
                              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                            {%- when 'package' -%}
                              <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                          {%- endcase -%}
                        </svg>
                        <span class="kt-showroom__trust-badge-text">{{ text_val }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

              {%- when 'complementary_products' -%}
                {%- comment -%}
                  R-pdp-audit — Complementary products, parity with
                  main-product. Reads the Search & Discovery curated
                  picks from `shopify--discovery--product_recommendation
                  .complementary_products`. Editor hint surfaces only
                  in design_mode when the metafield is empty, so the
                  live storefront stays silent on stores without the
                  app installed.
                {%- endcomment -%}
                {%- assign comp_products = product.metafields.shopify--discovery--product_recommendation.complementary_products.value -%}
                {%- if comp_products and comp_products.size > 0 -%}
                  <div class="kt-showroom__complementary" {{ block.shopify_attributes }}>
                    {%- if block.settings.heading != blank -%}
                      <h3 class="kt-showroom__complementary-heading">{{ block.settings.heading | escape }}</h3>
                    {%- endif -%}
                    <ul class="kt-showroom__complementary-list" role="list">
                      {%- for comp_product in comp_products limit: block.settings.products_count -%}
                        <li class="kt-showroom__complementary-item">
                          <a class="kt-showroom__complementary-link" href="{{ comp_product.url }}">
                            <div class="kt-showroom__complementary-media">
                              {%- if comp_product.featured_media != blank -%}
                                {{ comp_product.featured_media | image_url: width: 200 | image_tag:
                                    loading: 'lazy',
                                    widths: '100, 200, 300',
                                    sizes: '100px',
                                    width: 100,
                                    height: 100,
                                    class: 'kt-showroom__complementary-image',
                                    alt: comp_product.featured_media.alt | default: comp_product.title }}
                              {%- else -%}
                                {{ 'product-1' | placeholder_svg_tag: 'kt-showroom__complementary-image kt-showroom__complementary-image--placeholder' }}
                              {%- endif -%}
                            </div>
                            <div class="kt-showroom__complementary-text">
                              <p class="kt-showroom__complementary-title">{{ comp_product.title | escape }}</p>
                              {%- if comp_product.price_varies -%}
                                {%- assign comp_price_money = comp_product.price_min | money -%}
                                <p class="kt-showroom__complementary-price">{{ 'kt.product.from_price_label' | t }} {{ comp_price_money }}</p>
                              {%- else -%}
                                <p class="kt-showroom__complementary-price">{{ comp_product.price | money }}</p>
                              {%- endif -%}
                            </div>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- elsif request.design_mode -%}
                  <div class="kt-showroom__complementary kt-showroom__complementary--empty" {{ block.shopify_attributes }}>
                    <p class="kt-showroom__complementary-hint">
                      {{ 'kt.product.complementary.editor_hint' | t | default: 'Install the Shopify Search & Discovery app and pick complementary products for this product to populate this block.' }}
                    </p>
                  </div>
                {%- endif -%}

              {%- when 'warranty' -%}
                <div class="kt-showroom__warranty" {{ block.shopify_attributes }}>
                  <div class="kt-showroom__warranty-icon">
                    <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  </div>
                  <div>
                    <h2 class="kt-showroom__warranty-title">{{ block.settings.title | escape }}</h2>
                    <p class="kt-showroom__warranty-desc">{{ block.settings.text }}</p>
                  </div>
                </div>

              {%- when 'door_sample' -%}
                {%- comment -%}
                  Fall back to the current product if the merchant hasn't
                  linked a dedicated sample product yet. This keeps the
                  box visible on every showroom page — which is what the
                  Next.js source does — instead of silently disappearing.
                {%- endcomment -%}
                {%- assign sample_product = block.settings.sample_product | default: product -%}
                {%- if sample_product != blank -%}
                  {%- assign sample_variant = sample_product.selected_or_first_available_variant -%}
                  {%- assign sample_header_default = 'kt.section.product_showroom.sample_header_default' | t -%}
                  <div class="kt-showroom__sample-box" {{ block.shopify_attributes }}>
                    <div class="kt-showroom__sample-header">
                      <span class="kt-showroom__sample-header-title">
                        {{ block.settings.header_title | default: sample_header_default }}
                      </span>
                      {%- if block.settings.ships_badge != blank -%}
                        <span class="kt-showroom__sample-ships-badge">{{ block.settings.ships_badge }}</span>
                      {%- endif -%}
                    </div>
                    <div class="kt-showroom__sample-body">
                      <div class="kt-showroom__sample-top">
                        <div class="kt-showroom__sample-thumb">
                          {%- if sample_product.featured_image != blank -%}
                            {{ sample_product.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', width: 72, height: 96, alt: sample_product.title }}
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                          {%- endif -%}
                        </div>
                        <div class="kt-showroom__sample-info">
                          <h2 class="kt-showroom__sample-title">{{ sample_product.title }}</h2>
                          <div class="kt-showroom__sample-price-row">
                            <span class="kt-showroom__sample-price">{{ sample_variant.price | money }}</span>
                            {%- if block.settings.refundable -%}
                              <span class="kt-showroom__sample-refundable">
                                {{ 'kt.product.sample.refundable' | t | default: 'Refundable' }}
                              </span>
                            {%- endif -%}
                          </div>
                          {%- if block.settings.description != blank -%}
                            <p class="kt-showroom__sample-desc">{{ block.settings.description | escape }}</p>
                          {%- endif -%}
                        </div>
                      </div>
                      {%- if block.settings.meta != blank -%}
                        <div class="kt-showroom__sample-meta">{{ block.settings.meta }}</div>
                      {%- endif -%}
                      {%- form 'product', sample_product, id: 'DoorSampleForm', class: 'kt-showroom__sample-form' -%}
                        <input type="hidden" name="id" value="{{ sample_variant.id }}">
                        <input type="hidden" name="quantity" value="1">
                        <button type="submit" class="kt-showroom__sample-btn" {% unless sample_variant.available %}disabled{% endunless %}>
                          {%- if sample_variant.available -%}
                            {{ 'kt.product.sample.add_to_cart' | t | default: 'Add sample to cart' }}
                          {%- else -%}
                            {{ 'kt.product.sold_out' | t }}
                          {%- endif -%}
                        </button>
                        {%- comment -%}
                          Dynamic Checkout Button — renders Shop Pay /
                          Apple Pay / Google Pay buttons next to the
                          standard add-to-cart. Required by Theme Store
                          on every {% form 'product' %} block; without
                          it the showroom sample form fails the audit.
                          Gated on a merchant setting so showrooms that
                          want a clean visual layout (no shop_pay button)
                          can hide it via the theme editor.
                        {%- endcomment -%}
                        {%- comment -%}
                          Dynamic Checkout (`form | payment_button`)
                          intentionally not rendered — the button lives
                          inside a closed shadow DOM, so its blue Shop-
                          Pay-default colour cannot be themed to match
                          the storefront. Same call removed from
                          featured-product and the main PDP form for
                          consistency. The matching schema toggle was
                          dropped too. If installment messaging is
                          wanted back without the blue button, emit
                          `{{ form | payment_terms }}` directly here.
                        {%- endcomment -%}
                      {%- endform -%}
                    </div>
                  </div>
                {%- endif -%}

              {%- when 'pickup_availability' -%}
                {%- comment -%}
                  Pickup availability — Theme Store mandatory feature
                  per shopify.dev/storefronts/themes/delivery-fulfillment/
                  pickup-availability. The customer must be able to see
                  in-store pickup info BEFORE adding to cart and going
                  to checkout. main-product.liquid already renders this;
                  the showroom variant of the PDP needs the same
                  surface so any merchant using product.showroom.json
                  doesn't lose the BOPIS feature. Snippet handles its
                  own "no pickup-enabled locations" empty state, so
                  emitting it unconditionally is safe.
                {%- endcomment -%}
                <div class="kt-showroom__pickup" {{ block.shopify_attributes }}>
                  {%- render 'pickup-availability', variant: product.selected_or_first_available_variant, product: product -%}
                </div>

              {%- when 'buy_controls' -%}
                {%- comment -%}
                  R157 SHOWROOM-BUY-BLOCK-1 / R166 SHOWROOM-BUY-PARITY-1:
                  showroom template's primary UX is the appointment /
                  consultation flow, but Shopify Theme Store reviewers
                  test EVERY product template against the standard
                  product-page checklist (variant integration, selling
                  plans, quantity rules, dynamic checkout, gift card
                  recipient form, payment_terms / installments). The
                  R157 first-pass shipped an INLINE minimal form that
                  bypassed the canonical snippets/product-form.liquid,
                  so the variant picker (which writes to
                  `[data-variant-id]` via product-form.js scoped to
                  `[data-product-form]`) couldn't reach this form, and
                  selling plans / payment_terms / gift card recipient
                  / pre-order badge / error sentinel were all missing.
                  R166 collapses the inline form into a single
                  canonical render call so this surface inherits every
                  PDP feature transparently. UX positioning still
                  intentionally secondary — appointment CTA is the
                  primary action above; this block sits beneath it.
                  show_quantity = false posts a hidden qty=1 from
                  inside the snippet, keeping the form submit shape
                  consistent.
                {%- endcomment -%}
                <div class="kt-showroom__buy-controls" {{ block.shopify_attributes }}>
                  {%- comment -%}
                    R298 — `show_dynamic_checkout: false` removed.
                    Theme Store mandates the accelerated checkout button
                    inside every `{% form 'product' %}`. The snippet now
                    defaults to `true`.
                  {%- endcomment -%}
                  {%- render 'product-form',
                    product: product,
                    section: section,
                    show_quantity: block.settings.show_quantity,
                    atc_label: block.settings.atc_label
                  -%}
                </div>

              {%- when '@app' -%}
                {%- comment -%}
                  R87 — shopify_attributes wrapper for editor
                  highlight on app-block select.
                {%- endcomment -%}
                <div class="kt-showroom__app-block" {{ block.shopify_attributes }}>
                  {%- render block -%}
                </div>

            {%- endcase -%}
          {%- endfor -%}

        </div>
      </div>

    </div>
  </div>
</section>

<script src="{{ 'product-gallery.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'countdown.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'kt-section-main-product.js' | asset_url }}" defer="defer"></script>
{%- comment -%}
  R166 SHOWROOM-BUY-PARITY-1: product-form.js handles variant-
  change wiring (rewrites the hidden id input + price/SKU/availability
  surfaces on option select) and the AJAX cart submit path. The
  showroom buy_controls block depends on this for the variant picker
  → form bridge. Same script powers main-product.liquid; safe to
  load on every showroom render.
{%- endcomment -%}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- if settings.kt_back_in_stock_enabled -%}
  <script src="{{ 'kt-back-in-stock.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- comment -%}
  Selling-plan picker JS only emits when the product actually has
  subscription plans configured. Required for atomic price updates +
  ATC label switch when the customer ticks a subscription cadence; the
  showroom template previously omitted this script (parity gap with
  main-product.liquid), so plan selection on a showroom PDP silently
  left the price stale on the one-time-purchase amount — Theme Store
  rejects subscription products that don't show the discounted price
  before commit.
{%- endcomment -%}
{%- if product.selling_plan_groups.size > 0 -%}
  <script src="{{ 'selling-plan-picker.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- comment -%}
  R285 — Recently-viewed tracker. See the matching comment in
  sections/main-product.liquid for the full rationale: the
  script previously loaded only on pages carrying the rail
  itself, so PDP visits never populated localStorage and the
  rail rendered empty. The script self-guards against double
  load via `window.__kitcheroRecentlyViewedLoaded`, so it can
  safely co-exist with the rail's own script tag on pages
  that have both. defer keeps it out of the critical path.
{%- endcomment -%}
<script src="{{ 'recently-viewed.js' | asset_url }}" defer="defer"></script>

{%- comment -%}
  R298 PARITY — Only load the product-model custom element
  registration when the product actually has 3D model media.
  Mirrors the gate in sections/main-product.liquid:728-737. Without
  this, showroom PDPs that ship a 3D model render the
  `<product-model>` wrapper but never lazy-load Shopify's model-viewer
  library on intent, leaving the AR / orbit controls non-functional —
  a Theme Store reject because rich product media must work on every
  template that surfaces it.
{%- endcomment -%}
{%- assign has_3d_model = false -%}
{%- for media in product.media -%}
  {%- if media.media_type == 'model' -%}
    {%- assign has_3d_model = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- if has_3d_model -%}
  <script src="{{ 'product-model.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.main-product-showroom.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-product-showroom.settings.paragraph__door_sample.content"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:sections.main-product-showroom.blocks.brand.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.main-product-showroom.blocks.brand.settings.text.label",
          "info": "t:sections.main-product-showroom.blocks.brand.settings.text.info",
          "default": "Add your text here."
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.main-product-showroom.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_door_thumb",
          "label": "t:sections.main-product-showroom.blocks.title.settings.show_door_thumb.label",
          "info": "t:sections.main-product-showroom.blocks.title.settings.show_door_thumb.info",
          "default": true
        }
      ]
    },
    {
      "type": "price",
