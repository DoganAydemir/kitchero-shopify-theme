{{ 'kt-section-main-product-showroom.css' | asset_url | stylesheet_tag }}
{{ 'kt-product-gallery.css' | asset_url | stylesheet_tag }}
{{ 'kt-product-variant-picker.css' | asset_url | stylesheet_tag }}
{{ 'kt-product-accordion.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Main Product Showroom — premium visual layout (lead-gen focused)
  Birebir from showroom/[id]/page.tsx

  Block-driven architecture (matches main-product.liquid pattern):
  Every element in the right info column (brand, title, price,
  variant_picker, ctas, tags, accordions, warranty, door_sample,
  @app) is a reorderable/removable block. Merchants control the
  full layout from the theme editor. No hardcoded section-level
  content settings — everything lives on its block.

  Key differences vs E-commerce PDP:
  - No quantity selector, no main Add to Cart
  - Two CTAs: "Book Your Free Appointment" + "Book a Free Home Measure"
  - Rich pricing block with "Now only", save badge, monthly installment
  - Title + door thumbnail row
  - Color swatches are bigger (36px) with "+N more" indicator
  - Size selector uses big rounded-xl buttons (3-col)
  - Accordion titles use serif font, bigger
  - "Order a Door Sample" box — the ONLY place ATC happens
{%- endcomment -%}

<section class="kt-showroom" data-section-id="{{ section.id }}" data-section-type="main-product">
  <div class="kt-showroom__container">
    <div class="kt-showroom__layout">

      {%- comment -%} LEFT: Gallery — alternating full + pair pattern (73%) {%- endcomment -%}
      <div class="kt-showroom__gallery-col" data-product-gallery>
        {%- comment -%} Desktop: alternating layout (full, pair, full, pair...) {%- endcomment -%}
        <div class="kt-showroom__gallery-desktop">
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              {%- assign pattern_pos = forloop.index0 | modulo: 3 -%}
              {%- if pattern_pos == 0 -%}
                {%- comment -%} Full width image {%- endcomment -%}
                <div class="kt-showroom__gallery-full" data-gallery-slide="{{ forloop.index0 }}">
                  {%- assign media_alt = media.alt | default: product.title -%}
                  {{ media | image_url: width: 1200 | image_tag: class: 'kt-showroom__gallery-image', loading: 'lazy', widths: '550, 750, 1100', sizes: '73vw', width: media.width, height: media.height, alt: media_alt }}
                </div>
              {%- elsif pattern_pos == 1 -%}
                {%- comment -%} Left of pair {%- endcomment -%}
                <div class="kt-showroom__gallery-pair">
                  <div class="kt-showroom__gallery-half" data-gallery-slide="{{ forloop.index0 }}">
                    {%- assign media_alt = media.alt | default: product.title -%}
                    {{ media | image_url: width: 800 | image_tag: class: 'kt-showroom__gallery-image', loading: 'lazy', widths: '375, 550, 800', sizes: '36vw', width: media.width, height: media.height, alt: media_alt }}
                  </div>
                  {%- comment -%} Right of pair (next image) {%- endcomment -%}
                  {%- assign next_index = forloop.index -%}
                  {%- if product.media[next_index] and product.media[next_index].media_type == 'image' -%}
                    <div class="kt-showroom__gallery-half" data-gallery-slide="{{ next_index }}">
                      {%- assign next_media = product.media[next_index] -%}
                      {%- assign next_alt = next_media.alt | default: product.title -%}
                      {{ next_media | image_url: width: 800 | image_tag: class: 'kt-showroom__gallery-image', loading: 'lazy', widths: '375, 550, 800', sizes: '36vw', width: next_media.width, height: next_media.height, alt: next_alt }}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- comment -%} pattern_pos == 2 is handled as right side of pair above {%- endcomment -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if product.media.size == 0 -%}
            <div class="kt-showroom__gallery-full">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-showroom__gallery-image' }}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Mobile: horizontal scroll carousel — slides also tag
          data-gallery-slide so the shared product-gallery.js lightbox works. {%- endcomment -%}
        <div class="kt-showroom__gallery-mobile">
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              <div class="kt-showroom__gallery-mobile-slide" data-gallery-slide="{{ forloop.index0 }}">
                {%- assign media_alt = media.alt | default: product.title -%}
                {{ media | image_url: width: 800 | image_tag: class: 'kt-showroom__gallery-image', loading: 'lazy', widths: '375, 550, 800', sizes: '100vw', width: media.width, height: media.height, alt: media_alt }}
                <span class="kt-showroom__gallery-counter">{{ forloop.index }} / {{ product.media.size }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Lightbox (shared) {%- endcomment -%}
        <div class="kt-lightbox" data-lightbox aria-hidden="true" data-lenis-prevent="true">
          <button type="button" class="kt-lightbox__close" data-lightbox-close aria-label="{{ 'accessibility.close' | t | default: 'Close' }}">
            <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
          <button type="button" class="kt-lightbox__nav kt-lightbox__nav--prev" data-lightbox-prev aria-label="{{ 'sections.hero.previous_slide' | t | default: 'Previous' }}">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button type="button" class="kt-lightbox__nav kt-lightbox__nav--next" data-lightbox-next aria-label="{{ 'sections.hero.next_slide' | t | default: 'Next' }}">
            <svg aria-hidden="true" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
          <div class="kt-lightbox__viewport" data-lightbox-viewport>
            <div class="kt-lightbox__spinner" data-lightbox-spinner aria-hidden="true"></div>
            {%- comment -%} theme-check-disable RemoteAsset {%- endcomment -%}
            <img class="kt-lightbox__image" data-lightbox-image src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" alt="" width="1200" height="900" />
            {%- comment -%} theme-check-enable RemoteAsset {%- endcomment -%}
          </div>
        </div>
      </div>

      {%- comment -%} RIGHT: Product Info (27%, sticky) — fully block-driven {%- endcomment -%}
      <div class="kt-showroom__info-col kt-showroom--variant-picker-big">
        <div class="kt-showroom__info-sticky">

          {%- comment -%}
            Render blocks in order. Tags and accordions are grouped
            visually: the FIRST tag/accordion block renders the whole
            group's wrapper (and iterates all siblings of the same type),
            subsequent same-type blocks are skipped via the flag.
          {%- endcomment -%}
          {%- assign tags_rendered = false -%}
          {%- assign accordions_rendered = false -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'brand' -%}
                <p class="kt-showroom__brand" {{ block.shopify_attributes }}>
                  {%- if block.settings.text != blank -%}
                    {{ block.settings.text }}
                  {%- else -%}
                    {{ product.vendor | default: shop.name }} {{ 'products.product.collection_label' | t | default: 'Collection' }}
                  {%- endif -%}
                </p>

              {%- when 'title' -%}
                {%- assign heading_tag_value = block.settings.heading_tag | default: 'h1' -%}
                {%- assign door_sample_image = product.metafields.custom.door_sample.value -%}
                <div class="kt-showroom__title-row" {{ block.shopify_attributes }}>
                  <{{ heading_tag_value }} class="kt-showroom__title">{{ product.title }}</{{ heading_tag_value }}>
                  {%- if block.settings.show_door_thumb -%}
                    {%- if door_sample_image != blank -%}
                      <div class="kt-showroom__door-thumb">
                        {{ door_sample_image | image_url: width: 160 | image_tag: loading: 'lazy', width: 80, height: 106, alt: product.title }}
                      </div>
                    {%- elsif product.featured_image != blank -%}
                      <div class="kt-showroom__door-thumb">
                        {{ product.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', width: 80, height: 106, alt: product.title }}
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- when 'price' -%}
                <div {{ block.shopify_attributes }}>
                  {%- render 'product-price-showroom',
                    product: product,
                    financing_months: block.settings.financing_months,
                    financing_apr: block.settings.financing_apr,
                    financing_label: block.settings.financing_label
                  -%}
                </div>

              {%- when 'variant_picker' -%}
                <div {{ block.shopify_attributes }}>
                  {%- render 'product-variant-picker', product: product -%}
                </div>

              {%- when 'ctas' -%}
                <div class="kt-showroom__ctas" {{ block.shopify_attributes }}>
                  <button
                    type="button"
                    class="kt-showroom__cta kt-showroom__cta--primary"
                    data-appointment-open
                  >
                    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    <span>{{ block.settings.primary_cta_text | default: 'Book Your Free Appointment' }}</span>
                  </button>

                  {%- if block.settings.secondary_cta_text != blank -%}
                    {%- if block.settings.secondary_cta_link != blank -%}
                      <a
                        href="{{ block.settings.secondary_cta_link }}"
                        class="kt-showroom__cta kt-showroom__cta--secondary"
                      >
                        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                          <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                          <path d="M2 2l7.586 7.586"></path>
                          <circle cx="11" cy="11" r="2"></circle>
                        </svg>
                        <span>{{ block.settings.secondary_cta_text }}</span>
                      </a>
                    {%- else -%}
                      <button
                        type="button"
                        class="kt-showroom__cta kt-showroom__cta--secondary"
                        data-appointment-open
                      >
                        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                          <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                          <path d="M2 2l7.586 7.586"></path>
                          <circle cx="11" cy="11" r="2"></circle>
                        </svg>
                        <span>{{ block.settings.secondary_cta_text }}</span>
                      </button>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- when 'tag' -%}
                {%- unless tags_rendered -%}
                  <div class="kt-showroom__tags">
                    <p class="kt-showroom__tags-label">{{ 'products.product.at_a_glance' | t | default: 'At a glance' }}</p>
                    <div class="kt-showroom__tags-list">
                      {%- for tag_block in section.blocks -%}
                        {%- if tag_block.type == 'tag' -%}
                          <span class="kt-showroom__tag" {{ tag_block.shopify_attributes }}>{{ tag_block.settings.text }}</span>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                  {%- assign tags_rendered = true -%}
                {%- endunless -%}

              {%- when 'accordion' -%}
                {%- unless accordions_rendered -%}
                  <div class="kt-showroom__accordions">
                    {%- for acc_block in section.blocks -%}
                      {%- if acc_block.type == 'accordion' -%}
                        {%- capture acc_content -%}
                          {%- if acc_block.settings.page != blank -%}
                            {{ acc_block.settings.page.content }}
                          {%- elsif acc_block.settings.content != blank -%}
                            {{ acc_block.settings.content }}
                          {%- else -%}
                            <p>{{ product.description }}</p>
                          {%- endif -%}
                        {%- endcapture -%}
                        {%- render 'product-accordion', title: acc_block.settings.title, content: acc_content, open: acc_block.settings.open, style: 'serif', shopify_attributes: acc_block.shopify_attributes -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {%- assign accordions_rendered = true -%}
                {%- endunless -%}

              {%- when 'warranty' -%}
                <div class="kt-showroom__warranty" {{ block.shopify_attributes }}>
                  <div class="kt-showroom__warranty-icon">
                    <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  </div>
                  <div>
                    <h4 class="kt-showroom__warranty-title">{{ block.settings.title | default: 'Limited Lifetime Warranty' }}</h4>
                    <p class="kt-showroom__warranty-desc">{{ block.settings.text | default: 'Enjoy long-lasting confidence with our limited lifetime warranty on kitchen cabinets.' }}</p>
                  </div>
                </div>

              {%- when 'door_sample' -%}
                {%- comment -%}
                  Fall back to the current product if the merchant hasn't
                  linked a dedicated sample product yet. This keeps the
                  box visible on every showroom page — which is what the
                  Next.js source does — instead of silently disappearing.
                {%- endcomment -%}
                {%- assign sample_product = block.settings.sample_product | default: product -%}
                {%- if sample_product != blank -%}
                  {%- assign sample_variant = sample_product.selected_or_first_available_variant -%}
                  <div class="kt-showroom__sample-box" {{ block.shopify_attributes }}>
                    <div class="kt-showroom__sample-header">
                      <span class="kt-showroom__sample-header-title">
                        {{ block.settings.header_title | default: 'Order a Door Sample' }}
                      </span>
                      {%- if block.settings.ships_badge != blank -%}
                        <span class="kt-showroom__sample-ships-badge">{{ block.settings.ships_badge }}</span>
                      {%- endif -%}
                    </div>
                    <div class="kt-showroom__sample-body">
                      <div class="kt-showroom__sample-top">
                        <div class="kt-showroom__sample-thumb">
                          {%- if sample_product.featured_image != blank -%}
                            {{ sample_product.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', width: 72, height: 96, alt: sample_product.title }}
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                          {%- endif -%}
                        </div>
                        <div class="kt-showroom__sample-info">
                          <h4 class="kt-showroom__sample-title">{{ sample_product.title }}</h4>
                          <div class="kt-showroom__sample-price-row">
                            <span class="kt-showroom__sample-price">{{ sample_variant.price | money }}</span>
                            {%- if block.settings.refundable -%}
                              <span class="kt-showroom__sample-refundable">
                                {{ 'products.product.sample.refundable' | t | default: 'Refundable' }}
                              </span>
                            {%- endif -%}
                          </div>
                          {%- if block.settings.description != blank -%}
                            <p class="kt-showroom__sample-desc">{{ block.settings.description }}</p>
                          {%- endif -%}
                        </div>
                      </div>
                      {%- if block.settings.meta != blank -%}
                        <div class="kt-showroom__sample-meta">{{ block.settings.meta }}</div>
                      {%- endif -%}
                      {%- form 'product', sample_product, id: 'DoorSampleForm', class: 'kt-showroom__sample-form' -%}
                        <input type="hidden" name="id" value="{{ sample_variant.id }}">
                        <input type="hidden" name="quantity" value="1">
                        <button type="submit" class="kt-showroom__sample-btn" {% unless sample_variant.available %}disabled{% endunless %}>
                          {%- if sample_variant.available -%}
                            {{ 'products.product.sample.add_to_cart' | t | default: 'Add Sample to Cart' }}
                          {%- else -%}
                            {{ 'products.product.sold_out' | t }}
                          {%- endif -%}
                        </button>
                      {%- endform -%}
                    </div>
                  </div>
                {%- endif -%}

              {%- when '@app' -%}
                {%- render block -%}

            {%- endcase -%}
          {%- endfor -%}

        </div>
      </div>

    </div>
  </div>
</section>

<script src="{{ 'product-gallery.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'countdown.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-product-showroom.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-product-showroom.settings.paragraph__door_sample.content"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:sections.main-product-showroom.blocks.brand.name",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "t:sections.main-product-showroom.blocks.brand.settings.text.label", "info": "t:sections.main-product-showroom.blocks.brand.settings.text.info" }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.main-product-showroom.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "heading_tag",
          "label": "t:sections.main-product-showroom.blocks.title.settings.heading_tag.label",
          "options": [
            { "value": "h1", "label": "t:sections.main-product-showroom.blocks.title.settings.heading_tag.options__1.label" },
            { "value": "h2", "label": "t:sections.main-product-showroom.blocks.title.settings.heading_tag.options__2.label" }
          ],
          "default": "h1"
        },
        { "type": "checkbox", "id": "show_door_thumb", "label": "t:sections.main-product-showroom.blocks.title.settings.show_door_thumb.label", "default": true }
      ]
    },
    {
      "type": "price",
      "name": "t:sections.main-product-showroom.blocks.price.name",
      "limit": 1,
      "settings": [
        { "type": "number", "id": "financing_months", "label": "t:sections.main-product-showroom.blocks.price.settings.financing_months.label", "default": 60 },
        { "type": "number", "id": "financing_apr", "label": "t:sections.main-product-showroom.blocks.price.settings.financing_apr.label", "default": 0 },
        { "type": "text", "id": "financing_label", "label": "t:sections.main-product-showroom.blocks.price.settings.financing_label.label", "info": "t:sections.main-product-showroom.blocks.price.settings.financing_label.info" }
      ]
    },
    {
      "type": "variant_picker",
      "name": "t:sections.main-product-showroom.blocks.variant_picker.name",
      "limit": 1,
      "settings": []
    },
    {
      "type": "ctas",
      "name": "t:sections.main-product-showroom.blocks.ctas.name",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "primary_cta_text", "label": "t:sections.main-product-showroom.blocks.ctas.settings.primary_cta_text.label", "default": "Book Your Free Appointment" },
        { "type": "text", "id": "secondary_cta_text", "label": "t:sections.main-product-showroom.blocks.ctas.settings.secondary_cta_text.label", "default": "Book a Free Home Measure" },
        { "type": "url", "id": "secondary_cta_link", "label": "t:sections.main-product-showroom.blocks.ctas.settings.secondary_cta_link.label", "info": "t:sections.main-product-showroom.blocks.ctas.settings.secondary_cta_link.info" }
      ]
    },
    {
      "type": "tag",
      "name": "t:sections.main-product-showroom.blocks.tag.name",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "text", "label": "t:sections.main-product-showroom.blocks.tag.settings.text.label", "default": "5-Piece Shaker" }
      ]
    },
    {
      "type": "accordion",
      "name": "t:sections.main-product-showroom.blocks.accordion.name",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "t:sections.main-product-showroom.blocks.accordion.settings.title.label", "default": "About This Kitchen" },
        { "type": "richtext", "id": "content", "label": "t:sections.main-product-showroom.blocks.accordion.settings.content.label" },
        { "type": "page", "id": "page", "label": "t:sections.main-product-showroom.blocks.accordion.settings.page.label" },
        { "type": "checkbox", "id": "open", "label": "t:sections.main-product-showroom.blocks.accordion.settings.open.label", "default": false }
      ]
    },
    {
      "type": "warranty",
      "name": "t:sections.main-product-showroom.blocks.warranty.name",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "t:sections.main-product-showroom.blocks.warranty.settings.title.label", "default": "Limited Lifetime Warranty" },
        { "type": "textarea", "id": "text", "label": "t:sections.main-product-showroom.blocks.warranty.settings.text.label", "default": "Enjoy long-lasting confidence with our limited lifetime warranty on kitchen cabinets." }
      ]
    },
    {
      "type": "door_sample",
      "name": "t:sections.main-product-showroom.blocks.door_sample.name",
      "limit": 1,
      "settings": [
        { "type": "product", "id": "sample_product", "label": "t:sections.main-product-showroom.blocks.door_sample.settings.sample_product.label", "info": "t:sections.main-product-showroom.blocks.door_sample.settings.sample_product.info" },
        { "type": "text", "id": "header_title", "label": "t:sections.main-product-showroom.blocks.door_sample.settings.header_title.label", "default": "Order a Door Sample" },
        { "type": "text", "id": "ships_badge", "label": "t:sections.main-product-showroom.blocks.door_sample.settings.ships_badge.label", "default": "Ships in 48h" },
        { "type": "text", "id": "description", "label": "t:sections.main-product-showroom.blocks.door_sample.settings.description.label", "default": "Sample cost applied to your full order" },
        { "type": "checkbox", "id": "refundable", "label": "t:sections.main-product-showroom.blocks.door_sample.settings.refundable.label", "default": true },
        { "type": "text", "id": "meta", "label": "t:sections.main-product-showroom.blocks.door_sample.settings.meta.label", "default": "5″ × 7″ door front · Actual finish & texture" }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-product-showroom.presets.name",
      "blocks": [
        { "type": "brand" },
        { "type": "title" },
        { "type": "price" },
        { "type": "variant_picker" },
        { "type": "ctas" },
        { "type": "tag", "settings": { "text": "5-Piece Shaker" } },
        { "type": "tag", "settings": { "text": "Solid Maple" } },
        { "type": "tag", "settings": { "text": "Dovetail Drawer" } },
        { "type": "tag", "settings": { "text": "Soft-Close" } },
        { "type": "accordion", "settings": { "title": "About This Kitchen", "open": true } },
        { "type": "accordion", "settings": { "title": "Specifications" } },
        { "type": "accordion", "settings": { "title": "Installation" } },
        { "type": "accordion", "settings": { "title": "Delivery" } },
        { "type": "warranty" },
        { "type": "door_sample" }
      ]
    }
  ]
}
{% endschema %}
