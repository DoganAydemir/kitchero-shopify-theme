{{ 'section-main-search.css' | asset_url | stylesheet_tag }}
{{ 'component-card-product.css' | asset_url | stylesheet_tag }}

<section class="kt-search-page" data-section-id="{{ section.id }}">
  <div class="page-width">
    <h1 class="kt-search-page__title">{{ 'general.search.search' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="kt-search-page__form">
      <label for="search-page-input" class="visually-hidden">{{ 'general.search.search' | t }}</label>
      <input type="search" id="search-page-input" name="q" value="{{ search.terms | escape }}" class="kt-search-page__input" placeholder="{{ 'general.search.placeholder' | t }}" autocomplete="off">
      <input type="hidden" name="type" value="product,article,page">
      <button type="submit" class="kt-search-page__submit">{{ 'general.search.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="kt-search-page__results-count">
          {{ 'general.search.results_count' | t: count: search.results_count, terms: search.terms }}
        </p>
        <div class="kt-search-page__grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'card-product', product: item, show_vendor: false, show_secondary_image: false, show_quote_button: false -%}
            {%- elsif item.object_type == 'article' -%}
              {%- render 'article-card', article: item, show_author: false, show_date: true, show_excerpt: true -%}
            {%- else -%}
              <a href="{{ item.url }}" class="kt-search-page__page-result">
                <h3>{{ item.title }}</h3>
                <p>{{ item.content | strip_html | truncatewords: 20 }}</p>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="kt-search-page__no-results">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-search.name",
  "tag": "section",
  "class": "section"
}
{% endschema %}
