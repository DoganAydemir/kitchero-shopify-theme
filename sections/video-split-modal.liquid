{%- comment -%}
  Video Split + Modal (Variant B)
  ----------------------------------
  Two-column layout:
    LEFT  — Shopify-hosted looping muted background video (or poster).
    RIGHT — copy block + "Watch Film" play button that opens the
            shared video-modal snippet (YouTube / Vimeo embed).

  The modal opens via `[data-modal-video-open="{url}"]` on the play
  button. assets/video-modal.js handles the open/close lifecycle —
  it's a shared controller used by this section and video-poster-modal.
{%- endcomment -%}

{{ 'kt-section-video-split-modal.css' | asset_url | stylesheet_tag }}
{{ 'kt-video-modal.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign video_position = section.settings.video_position | default: 'left'
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign modal_id = 'VideoModal-' | append: section.id
-%}

<section
  class="kt-video-split kt-video-split--video-{{ video_position }}"
  data-section-id="{{ section.id }}"
  data-section-type="video-split-modal"
>
  <div class="page-width">
    <div class="kt-video-split__inner">

      {%- comment -%} LEFT (or right): looping background video pane.
        WCAG 2.2.2 — auto-playing motion content > 5s requires user-
        controllable pause. We render a small pause toggle on top of
        the media; data-video-split-pause-toggle is wired by the
        section JS to play/pause the underlying <video> element.
      {%- endcomment -%}
      <div class="kt-video-split__media">
        {%- if section.settings.loop_video != blank -%}
          <button
            type="button"
            class="kt-video-split__pause-toggle"
            data-video-split-pause-toggle
            aria-pressed="true"
            aria-label="{{ 'kt.section.video_split_modal.toggle_loop' | t | default: 'Pause or play background video' }}"
          >
            <svg class="kt-video-split__icon kt-video-split__icon--pause" aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="4" width="4" height="16"></rect>
              <rect x="14" y="4" width="4" height="16"></rect>
            </svg>
            <svg class="kt-video-split__icon kt-video-split__icon--play" aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
          </button>
          {%- if section.settings.loop_poster != blank -%}
            {%- assign poster_url = section.settings.loop_poster | image_url: width: 1200 -%}
            {{
              section.settings.loop_video
              | video_tag:
                image_size: '1200x',
                loop: true,
                autoplay: true,
                muted: true,
                playsinline: true,
                controls: false,
                preload: 'metadata',
                class: 'kt-video-split__video',
                poster: poster_url
            }}
          {%- else -%}
            {{
              section.settings.loop_video
              | video_tag:
                image_size: '1200x',
                loop: true,
                autoplay: true,
                muted: true,
                playsinline: true,
                controls: false,
                preload: 'metadata',
                class: 'kt-video-split__video'
            }}
          {%- endif -%}
        {%- elsif section.settings.loop_poster != blank -%}
          {{
            section.settings.loop_poster
            | image_url: width: 1200
            | image_tag:
              class: 'kt-video-split__poster',
              loading: 'lazy',
              widths: '450, 600, 900, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw',
              width: section.settings.loop_poster.width,
              height: section.settings.loop_poster.height,
              alt: ''
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-video-split__poster' }}
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT (or left): content pane with play button {%- endcomment -%}
      <div class="kt-video-split__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kt-video-split__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="kt-video-split__heading">
            {{ section.settings.heading }}
          </{{ heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="kt-video-split__description">{{ section.settings.description }}</p>
        {%- endif -%}

        {%- if section.settings.modal_video_url != blank -%}
          <button
            type="button"
            class="kt-video-split__play"
            data-modal-video-open="{{ section.settings.modal_video_url | escape }}"
            data-modal-target="{{ modal_id }}"
            aria-label="{{ 'kt.section.video_split_modal.play_aria' | t | default: 'Play video' }}"
          >
            <span class="kt-video-split__play-icon" aria-hidden="true">
              <svg aria-hidden="true" focusable="false" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </span>
            <span class="kt-video-split__play-label">
              {{ section.settings.play_button_text | default: 'Watch Film' }}
            </span>
          </button>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- if section.settings.modal_video_url != blank -%}
  {%- render 'video-modal', modal_id: modal_id -%}
  <script src="{{ 'video-modal.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script src="{{ 'kt-section-video-split-modal.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.video_split_modal.name",
  "tag": "div",
  "class": "section-video-split-modal",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.video_split_modal.settings.header__media.content"
    },
    {
      "type": "video",
      "id": "loop_video",
      "label": "t:sections.video_split_modal.settings.loop_video.label",
      "info": "t:sections.video_split_modal.settings.loop_video.info"
    },
    {
      "type": "image_picker",
      "id": "loop_poster",
      "label": "t:sections.video_split_modal.settings.loop_poster.label",
      "info": "t:sections.video_split_modal.settings.loop_poster.info"
    },
    {
      "type": "select",
      "id": "video_position",
      "label": "t:sections.video_split_modal.settings.video_position.label",
      "options": [
        { "value": "left", "label": "t:sections.video_split_modal.settings.video_position.options__left.label" },
        { "value": "right", "label": "t:sections.video_split_modal.settings.video_position.options__right.label" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:sections.video_split_modal.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.video_split_modal.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.video_split_modal.settings.heading.label",
      "default": "Watch the film."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.video_split_modal.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.video_split_modal.settings.description.label"
    },
    {
      "type": "text",
      "id": "play_button_text",
      "label": "t:sections.video_split_modal.settings.play_button_text.label",
      "default": "Watch Film"
    },
    {
      "type": "header",
      "content": "t:sections.video_split_modal.settings.header__modal.content"
    },
    {
      "type": "video_url",
      "id": "modal_video_url",
      "label": "t:sections.video_split_modal.settings.modal_video_url.label",
      "info": "t:sections.video_split_modal.settings.modal_video_url.info",
      "accept": ["youtube", "vimeo"]
    }
  ],
  "presets": [
    {
      "name": "t:sections.video_split_modal.presets.name",
      "settings": {
        "eyebrow": "Eyebrow",
        "heading": "Watch the film.",
        "description": "",
        "play_button_text": "Watch Film",
        "video_position": "left"
      }
    }
  ]
}
{% endschema %}
