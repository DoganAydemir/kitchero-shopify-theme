{%- comment -%}
  Banner Cover — full-bleed cover-photo hero with dark gradient overlay and
  centered content (eyebrow + big serif title + lead paragraph). Ported
  from the About page hero in the Next.js kitchen theme ("Style 2" variant
  of banner-hero). Used for editorial page headers where the imagery is
  the star.
{%- endcomment -%}

{{ 'kt-section-banner-cover.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h1'
  assign min_h_mobile = section.settings.min_height_mobile | default: 480
  assign min_h_desktop = section.settings.min_height_desktop | default: 640
  assign overlay_opacity = section.settings.overlay_opacity | default: 60 | divided_by: 100.0
  assign padding_top = section.settings.padding_top | default: 0
  assign padding_bottom = section.settings.padding_bottom | default: 0
-%}

{%- comment -%}
  R145 REGION-NAME-1: <section> landmark needs an accessible name.
  Prefer aria-labelledby pointing at the visible heading (so SR
  announces the actual banner copy as the region name). Fall back
  to a generic aria-label when heading is blank — banner-cover is
  often used with image-only / no heading, so a stable label is
  needed for the empty-heading case.
{%- endcomment -%}
{%- assign banner_cover_heading_id = 'BannerCoverHeading-' | append: section.id -%}
<section
  class="kt-banner-cover color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
  data-section-id="{{ section.id }}"
  data-section-type="banner-cover"
  data-allows-transparent-header="true"
  {% if section.settings.heading != blank %}aria-labelledby="{{ banner_cover_heading_id }}"{% else %}aria-label="{{ 'kt.banner_cover.region_label' | t | default: 'Banner' }}"{% endif %}
  style="--kt-banner-cover-min-height-mobile: {{ min_h_mobile }}px; --kt-banner-cover-min-height-desktop: {{ min_h_desktop }}px; --kt-banner-cover-overlay-opacity: {{ overlay_opacity }}; --kt-banner-cover-pad-top: {{ padding_top }}px; --kt-banner-cover-pad-bottom: {{ padding_bottom }}px;"
>
  <div class="kt-banner-cover__media" aria-hidden="true">
    {%- comment -%}
      `fetchpriority: 'high'` was unconditionally attached here in
      earlier rounds, but banner-cover sections aren't guaranteed to be
      the page's LCP — merchants often place them mid-page behind a
      true hero. Multiple high-priority images on the same page hurts
      Lighthouse (Avoid multiple critical resources) and can shift
      which image the browser actually rushes. `loading: 'eager'` still
      skips the lazy queue so the image loads early if the section is
      on-screen, while `fetchpriority: 'auto'` lets the browser decide.
    {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      {%- assign cover_focal = section.settings.image.presentation.focal_point | default: 'center center' -%}
      {%- comment -%}
        Pre-assign style — inline `style: 'object-position: ' | append:
        cover_focal, alt: ...` triggers Liquid's parser to interpret
        the comma after `cover_focal` as a second argument to `append`,
        producing "wrong number of arguments (given 3, expected 2)".
      {%- endcomment -%}
      {%- assign cover_image_style = 'object-position: ' | append: cover_focal -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'auto',
          class: 'kt-banner-cover__image',
          widths: '800, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          width: section.settings.image.width,
          height: section.settings.image.height,
          style: cover_image_style,
          alt: section.settings.image.alt | default: section.settings.heading
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-banner-cover__image' }}
    {%- endif -%}
    <div class="kt-banner-cover__gradient"></div>
  </div>

  <div class="kt-banner-cover__inner page-width">
    {%- if section.settings.eyebrow != blank -%}
      <span class="kt-banner-cover__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- comment -%}
      R87 — gate the heading element on a non-blank value. Previous
      code emitted an empty `<h1></h1>` when the merchant cleared
      the heading setting — a Lighthouse a11y warning ("page
      contains an empty heading"). Now we only emit the heading
      tag when there's content for it.
    {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <{{ heading_tag }} id="{{ banner_cover_heading_id }}" class="kt-banner-cover__title">
        {{- section.settings.heading -}}
      </{{ heading_tag }}>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="kt-banner-cover__desc">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>
</section>

{%- comment -%}
  Breadcrumb trail rendered immediately after the cover banner
  closes — sits between the full-bleed intro hero and the rest
  of the template body. Mirrors the placement used by every
  other intro component (page-header-dotted snippet, collection
  banner, article header, search hero) so the trail always sits
  in the same slot regardless of which intro the merchant picks.
  Gated by the theme-global toggle. Breadcrumb snippet self-
  skips on `index` / `cart` / `404` page types, so dropping the
  banner-cover on the homepage doesn't accidentally render a
  stray trail.
{%- endcomment -%}
{%- if settings.kt_show_breadcrumbs -%}
  {%- render 'breadcrumbs', class_extra: 'kt-breadcrumbs-wrap' -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.banner-cover.name",
  "tag": "div",
  "class": "section section--flush",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.banner-cover.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.banner-cover.settings.eyebrow.label",
      "default": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.banner-cover.settings.heading.label",
      "default": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.banner-cover.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.banner-cover.settings.description.label",
      "default": "Add a description for this section."
    },
    {
      "type": "header",
      "content": "t:sections.banner-cover.settings.header__media.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.banner-cover.settings.image.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.banner-cover.settings.overlay_opacity.label",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.banner-cover.settings.header__layout.content"
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "t:sections.banner-cover.settings.min_height_mobile.label",
      "min": 320,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 480
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "t:sections.banner-cover.settings.min_height_desktop.label",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__appearance.content"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_bottom.label",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:sections.banner-cover.presets.name"
    }
  ]
}
{% endschema %}
