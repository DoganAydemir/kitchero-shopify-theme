{{ 'kt-section-related-products.css' | asset_url | stylesheet_tag }}
{{ 'kt-card-product.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Related Products — "You may also like"

  Uses Shopify's `product.recommendations` object fed by the Section
  Rendering API. The `recommendations` object only populates when
  this section is rendered via `/recommendations/products?section_id=
  {section}&product_id={id}&intent=related` — on the initial product
  page server-render, `recommendations.performed` is `false` and
  `recommendations.products` is empty.

  Strategy:
    1. Server-render emits a wrapper with `data-product-recommendations`
       + `data-section-id` + `data-url` + `data-product-id`.
       When `recommendations.performed == false` we still emit the
       wrapper + a skeleton so the section reserves vertical space
       (reduces CLS) and the client JS has a target to swap into.
    2. `section-related-products.js` fires on DOMContentLoaded (and on
       `shopify:section:load` for editor compatibility), fetches the
       section HTML with the recommendations populated, and swaps the
       inner content in.
    3. On fetch failure the skeleton stays (acceptable degraded state);
       on `recommendations.products_count == 0` the client JS hides
       the whole section so the PDP doesn't end with an empty block.
{%- endcomment -%}

{%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}

<section
  class="kt-related"
  data-section-id="{{ section.id }}"
  data-section-type="related-products"
  data-product-recommendations
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_count }}&intent={{ section.settings.intent | default: 'related' }}"
  {% if recommendations.performed and recommendations.products_count == 0 %}hidden{% endif %}
>
  <div class="page-width">
    <div class="kt-related__header">
      <{{ heading_tag }} class="kt-related__title">{{ section.settings.heading | default: 'You may also like' }}</{{ heading_tag }}>
    </div>

    {%- comment -%}
      Per Shopify's complementary-products docs (COM-02), the
      complementary intent should default to 2-3 products visible
      (paginate the rest), while related stays generous (4-6).
      Resolve the right cap based on the active intent:
      `complementary_count` for complementary, `products_count`
      for related.
    {%- endcomment -%}
    {%- if section.settings.intent == 'complementary' -%}
      {%- assign related_limit = section.settings.complementary_count | default: 3 -%}
    {%- else -%}
      {%- assign related_limit = section.settings.products_count | default: 4 -%}
    {%- endif -%}

    <div class="kt-related__grid" role="list">
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- for recommended_product in recommendations.products limit: related_limit -%}
          {%- render 'card-product', product: recommended_product, show_vendor: true, show_secondary_image: true, show_quote_button: false -%}
        {%- endfor -%}
      {%- elsif recommendations.performed == false -%}
        {%- comment -%}
          Skeleton placeholders while the async fetch is in flight. The
          wrapper count matches `products_count` so the grid reserves
          the same space the real cards will occupy.
        {%- endcomment -%}
        {%- for i in (1..section.settings.products_count) -%}
          <div class="kt-related__skeleton" aria-hidden="true">
            <div class="kt-related__skeleton-image"></div>
            <div class="kt-related__skeleton-line kt-related__skeleton-line--title"></div>
            <div class="kt-related__skeleton-line kt-related__skeleton-line--price"></div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%}
  Only emit the fetch script when we actually need the async swap —
  i.e. we're on the initial PDP render where recommendations hasn't
  been performed yet. When the section is rendered inside the
  Section Rendering API response (the fetch's target), the server
  has already populated recommendations and the script is redundant.
{%- endcomment -%}
{%- if recommendations.performed == false -%}
  <script src="{{ 'section-related-products.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.related-products.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.related-products.settings.heading.label",
      "default": "You may also like"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.related-products.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "t:sections.related-products.settings.heading_tag.options__1.label" },
        { "value": "h3", "label": "t:sections.related-products.settings.heading_tag.options__2.label" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "t:sections.related-products.settings.products_count.label"
    },
    {
      "type": "range",
      "id": "complementary_count",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.related-products.settings.complementary_count.label",
      "info": "t:sections.related-products.settings.complementary_count.info"
    },
    {
      "type": "select",
      "id": "intent",
      "label": "t:sections.related-products.settings.intent.label",
      "info": "t:sections.related-products.settings.intent.info",
      "options": [
        { "value": "related", "label": "t:sections.related-products.settings.intent.options__related.label" },
        { "value": "complementary", "label": "t:sections.related-products.settings.intent.options__complementary.label" }
      ],
      "default": "related"
    }
  ],
  "presets": [
    {
      "name": "t:sections.related-products.presets.name"
    }
  ]
}
{% endschema %}
