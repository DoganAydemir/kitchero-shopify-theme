{{ 'section-how-it-works.css' | asset_url | stylesheet_tag }}

<section class="kt-how-it-works" data-section-id="{{ section.id }}" data-section-type="how-it-works">
  <div class="page-width">
    {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
    <{{ heading_tag }} class="kt-how-it-works__title">{{ section.settings.heading | default: 'How It Works' }}</{{ heading_tag }}>
    <p class="kt-how-it-works__subtitle">{{ section.settings.subtitle | default: 'From vision to reality in four steps' }}</p>

    <div class="kt-how-it-works__cards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="kt-how-it-works__card" {{ block.shopify_attributes }}>
            <div class="kt-how-it-works__card-image-wrap">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'kt-how-it-works__card-image', loading: 'lazy', widths: '375, 550, 750, 1000', sizes: '(min-width: 750px) 50vw, 100vw', width: block.settings.image.width, height: block.settings.image.height, alt: block.settings.title | default: '' }}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg kt-how-it-works__card-image' }}
              {%- endif -%}
            </div>
            <div class="kt-how-it-works__card-content">
              <span class="kt-how-it-works__card-number">{{ block.settings.number | default: forloop.index }}</span>
              <h3 class="kt-how-it-works__card-title">{{ block.settings.title }}</h3>
              <p class="kt-how-it-works__card-desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script src="{{ 'section-how-it-works.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Multicolumn steps",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "From vision to reality in four steps"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Consultation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Schedule a free consultation with our design experts."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multicolumn steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Consultation",
            "description": "Schedule a free consultation with our design experts to discuss your vision and budget."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Engineering",
            "description": "Our team creates precise 3D renders and technical drawings for your approval."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Craftsmanship",
            "description": "Premium materials are handcrafted by our master artisans with meticulous attention to detail."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "4",
            "title": "Installation",
            "description": "Professional installation with white-glove service and a comprehensive warranty."
          }
        }
      ]
    }
  ]
}
{% endschema %}
