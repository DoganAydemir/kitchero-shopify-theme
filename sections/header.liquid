{{ 'kt-section-header.css' | asset_url | stylesheet_tag }}

{%- liquid
  comment
    Header style is fully merchant-controlled. Pick "transparent" on
    templates whose first section is a full-bleed hero that wants the
    header to float over it (home, /about banner-cover, landing pages).
    Pick "solid" everywhere else. We do NOT force a value based on
    request.page_type — merchants own the call.
  endcomment
  assign header_style = section.settings.header_style | default: 'solid'
-%}

{%- unless header_style == 'transparent' -%}
  <div class="kt-header-spacer" aria-hidden="true"></div>
{%- endunless -%}

<header
  class="kt-header{% if header_style == 'transparent' %} kt-header--transparent{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="header"
  data-header-style="{{ header_style }}"
>
  <div class="kt-header__inner">
    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="kt-header__logo" aria-label="{{ shop.name }}">
      {%- if settings.kt_logo != blank -%}
        {{
          settings.kt_logo
          | image_url: width: 300
          | image_tag:
            class: 'kt-header__logo-image',
            widths: '100, 150, 200, 300',
            width: settings.kt_logo_width,
            height: settings.kt_logo_width | divided_by: settings.kt_logo.aspect_ratio,
            alt: shop.name
        }}
      {%- else -%}
        <span class="kt-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="kt-header__nav" aria-label="{{ 'kt.a11y.navigation' | t }}">
      {%- if section.settings.main_menu != blank -%}
        <ul class="kt-header__menu list-unstyled" role="list">
          {%- for link in section.settings.main_menu.links -%}
            <li class="kt-header__menu-item">
              {%- comment -%}
                Determine menu type:
                - has_grandchildren = at least one child has its own children → MEGA MENU
                - link.links.size > 0 but no grandchildren → FLYOUT DROPDOWN
                - no children → SIMPLE LINK
              {%- endcomment -%}
              {%- liquid
                assign has_grandchildren = false
                for child in link.links
                  if child.links.size > 0
                    assign has_grandchildren = true
                    break
                  endif
                endfor
              -%}

              {%- if has_grandchildren -%}
                {%- comment -%} ===== MEGA MENU (3-level: By Style > Contemporary) ===== {%- endcomment -%}
                <a
                  href="{{ link.url }}"
                  class="kt-header__menu-link"
                  aria-haspopup="true"
                  aria-expanded="false"
                  {% if link.current %}aria-current="page"{% endif %}
                >
                  {{ link.title }}
                  <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </a>
                <div class="kt-header__mega-menu" role="menu">
                  <div class="kt-header__mega-grid">
                    {%- for child_link in link.links -%}
                      <div class="kt-header__mega-column">
                        <h3 class="kt-header__mega-column-title">{{ child_link.title }}</h3>
                        {%- if child_link.links.size > 0 -%}
                          <ul class="kt-header__mega-list list-unstyled" role="list">
                            {%- for grandchild_link in child_link.links -%}
                              <li>
                                <a href="{{ grandchild_link.url }}" class="kt-header__mega-link" role="menuitem">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- else -%}
                          <a href="{{ child_link.url }}" class="kt-header__mega-link" role="menuitem">
                            {{ child_link.title }}
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}

                    {%- comment -%} Featured card block (optional) {%- endcomment -%}
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'mega_menu_featured' and block.settings.menu_title == link.title -%}
                        <div class="kt-header__mega-featured" {{ block.shopify_attributes }}>
                          {%- if block.settings.image != blank -%}
                            {{
                              block.settings.image
                              | image_url: width: 400
                              | image_tag:
                                class: 'kt-header__mega-featured-image',
                                loading: 'lazy',
                                width: 400,
                                height: 300,
                                alt: block.settings.heading | default: ''
                            }}
                          {%- else -%}
                            {{ 'collection-1' | placeholder_svg_tag: 'kt-header__mega-featured-image placeholder-svg' }}
                          {%- endif -%}
                          <div class="kt-header__mega-featured-overlay">
                            {%- if block.settings.heading != blank -%}
                              <p class="kt-header__mega-featured-title">{{ block.settings.heading }}</p>
                            {%- endif -%}
                            {%- if block.settings.description != blank -%}
                              <p class="kt-header__mega-featured-desc">{{ block.settings.description }}</p>
                            {%- endif -%}
                            {%- if block.settings.link != blank -%}
                              <a href="{{ block.settings.link }}" class="kt-header__mega-featured-cta">
                                {{ block.settings.link_text | default: 'Shop now' }}
                                <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                  <polyline points="9 6 15 12 9 18"></polyline>
                                </svg>
                              </a>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>

              {%- elsif link.links.size > 0 -%}
                {%- comment -%} ===== FLYOUT DROPDOWN (2-level: parent > children list) ===== {%- endcomment -%}
                <a
                  href="{{ link.url }}"
                  class="kt-header__menu-link"
                  aria-haspopup="true"
                  aria-expanded="false"
                  {% if link.current %}aria-current="page"{% endif %}
                >
                  {{ link.title }}
                  <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </a>
                <div class="kt-header__flyout" role="menu">
                  {%- for child_link in link.links -%}
                    <a href="{{ child_link.url }}" class="kt-header__flyout-link" role="menuitem">
                      {{ child_link.title }}
                    </a>
                  {%- endfor -%}
                </div>

              {%- else -%}
                {%- comment -%} ===== SIMPLE LINK ===== {%- endcomment -%}
                <a
                  href="{{ link.url }}"
                  class="kt-header__menu-link"
                  {% if link.current %}aria-current="page"{% endif %}
                >
                  {{ link.title }}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    {%- comment -%} Action Icons {%- endcomment -%}
    <div class="kt-header__icons">
      {%- comment -%}
        Search — opens the full-screen overlay modal. Fallback to the
        /search page when JS is disabled via the <noscript> below.
      {%- endcomment -%}
      <button
        type="button"
        class="kt-header__icon"
        data-search-open
        aria-label="{{ 'kt.search.search' | t }}"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="search-overlay"
      >
        <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
      <noscript>
        <a href="{{ routes.search_url }}" class="kt-header__icon" aria-label="{{ 'kt.search.search' | t }}">
          <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </a>
      </noscript>

      {%- comment -%}
        Account — when the visitor isn't logged in, route explicitly to
        /account/login so our `main-login.liquid` template renders.
        Logged-in visitors land on the account dashboard.

        Note: Shopify's newer "New customer accounts" setting (Settings →
        Customer accounts) bypasses theme templates entirely and
        redirects to Shopify's hosted account UI regardless of which
        route we link to. For this link to use the theme's login page,
        the store must be on "Classic customer accounts".
      {%- endcomment -%}
      {%- liquid
        if customer
          assign account_href = routes.account_url
          assign account_label = 'kt.a11y.account' | t
        else
          assign account_href = routes.account_login_url
          assign account_label = 'kt.customer.login.title' | t | default: 'Log in'
        endif
      -%}
      <a href="{{ account_href }}" class="kt-header__icon" aria-label="{{ account_label }}">
        <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>

      {%- comment -%} Cart {%- endcomment -%}
      <a href="{{ routes.cart_url }}" class="kt-header__icon kt-header__cart-icon" aria-label="{{ 'kt.cart.title' | t }}">
        <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        {%- comment -%}
          Cart count pill — rendered on every paint so the aria-live
          region is in the DOM from first load. If we only rendered it
          when cart.item_count > 0, screen readers would miss the
          initial add-to-cart announcement on an empty cart: SRs need
          the live region to pre-exist to notice its textContent
          changing. Hidden visually + from SR when count is 0.
        {%- endcomment -%}
        <span
          class="kt-header__cart-count"
          aria-live="polite"
          aria-atomic="true"
          {% if cart.item_count == 0 %}style="display: none;"{% endif %}
        >
          {{ cart.item_count }}
        </span>
      </a>

      {%- comment -%}
        Mobile menu toggle — only visible below 990px. The open/close
        logic lives in assets/kt-section-header-mobile-nav.js via a
        document-level delegated click handler.
      {%- endcomment -%}
      <button
        type="button"
        class="kt-header__menu-toggle"
        aria-label="{{ 'kt.a11y.navigation' | t }}"
        aria-expanded="false"
        aria-controls="kt-mobile-panel-{{ section.id }}"
      >
        <svg class="kt-header__menu-toggle-open" aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="kt-header__menu-toggle-close hidden" aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  {%- comment -%} App block slot (required for Theme Store) {%- endcomment -%}
  {%- assign header_app_blocks = section.blocks | where: 'type', '@app' -%}
  {%- if header_app_blocks.size > 0 -%}
    <div class="kt-header__app-blocks">
      {%- for block in header_app_blocks -%}
        {% render block %}
      {%- endfor -%}
    </div>
  {%- endif -%}
</header>

{%- comment -%}
  Mobile Panel — rendered OUTSIDE the <header> element on purpose.
  .kt-header has `backdrop-filter: blur(12px)`, which per the CSS spec
  creates a containing block for `position: fixed` descendants. If the
  panel stayed inside the header, its `inset: 0` would be computed
  against the header's ~60px bounding box instead of the viewport, so
  the panel appeared to "open inside the header" — short, stuck.
  Keeping it as a sibling of <header> keeps the viewport as the
  containing block, so `inset: 0` reaches the full 100vh.
{%- endcomment -%}
<div
  id="kt-mobile-panel-{{ section.id }}"
  class="kt-header__mobile-panel"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'kt.a11y.navigation' | t }}"
>
  <div class="kt-header__mobile-panel-header">
    <a href="{{ routes.root_url }}" class="kt-header__logo" aria-label="{{ shop.name }}">
      <span class="kt-header__logo-text">{{ shop.name }}</span>
    </a>
    <button
      type="button"
      class="kt-header__mobile-panel-close"
      aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}"
    >
      <svg aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  {%- comment -%}
    Mobile menu — multi-panel slide navigation, ported birebir from
    Navbar.tsx. Each menu level is its own full-viewport panel. The
    main panel lists top-level items; tapping a parent slides in the
    corresponding sub-panel from the right. Sub-panels have a "Back"
    button that reverses the slide.

    Panel identity: `main` for the top level, `p-{i}` for the i-th
    top-level item's sub-panel, `p-{i}-{j}` for the j-th child's
    sub-sub-panel. Up to 3 levels deep (Shopify's menu max).
  {%- endcomment -%}
  <div class="kt-header__mobile-slider" data-mobile-slider>
    {%- if section.settings.main_menu != blank -%}
      {%- comment -%} ============ LEVEL 1: Main panel ============ {%- endcomment -%}
      <div class="kt-header__mobile-view" data-panel="main" data-state="current">
        <div class="kt-header__mobile-view-inner">
          {%- for link in section.settings.main_menu.links -%}
            {%- if link.links.size > 0 -%}
              <button
                type="button"
                class="kt-header__mobile-link kt-header__mobile-link--parent"
                data-mobile-forward="p-{{ forloop.index0 }}"
                aria-expanded="false"
                aria-controls="mobile-panel-p-{{ forloop.index0 }}"
              >
                <span class="kt-header__mobile-link-label">{{ link.title }}</span>
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            {%- else -%}
              <a href="{{ link.url }}" class="kt-header__mobile-link">
                <span class="kt-header__mobile-link-label">{{ link.title }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}

          {%- if section.settings.mobile_cta_text != blank -%}
            <a
              href="{{ section.settings.mobile_cta_link | default: routes.root_url }}"
              class="kt-header__mobile-cta"
            >
              {{ section.settings.mobile_cta_text }}
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ============ LEVEL 2: Sub-panels ============ {%- endcomment -%}
      {%- for link in section.settings.main_menu.links -%}
        {%- if link.links.size > 0 -%}
          {%- assign l1_id = 'p-' | append: forloop.index0 -%}
          {%- assign l1_index = forloop.index0 -%}
          <div class="kt-header__mobile-view" data-panel="{{ l1_id }}" data-state="ahead" id="mobile-panel-{{ l1_id }}">
            <div class="kt-header__mobile-view-inner">
              <button
                type="button"
                class="kt-header__mobile-back"
                data-mobile-back
              >
                <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="19" y1="12" x2="5" y2="12"></line>
                  <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                <span class="kt-header__mobile-back-label">{{ 'kt.general.back' | t | default: 'Back' }}</span>
              </button>
              <h3 class="kt-header__mobile-view-title">{{ link.title }}</h3>

              {%- if link.url != blank and link.url != '#' -%}
                <a href="{{ link.url }}" class="kt-header__mobile-link kt-header__mobile-link--all">
                  <span class="kt-header__mobile-link-label">
                    {{ 'kt.general.view_all' | t | default: 'View all' }} {{ link.title }}
                  </span>
                </a>
              {%- endif -%}

              {%- for child in link.links -%}
                {%- if child.links.size > 0 -%}
                  <button
                    type="button"
                    class="kt-header__mobile-link kt-header__mobile-link--parent"
                    data-mobile-forward="p-{{ l1_index }}-{{ forloop.index0 }}"
                    aria-expanded="false"
                    aria-controls="mobile-panel-p-{{ l1_index }}-{{ forloop.index0 }}"
                  >
                    <span class="kt-header__mobile-link-label">{{ child.title }}</span>
                    <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                  </button>
                {%- else -%}
                  <a href="{{ child.url }}" class="kt-header__mobile-link">
                    <span class="kt-header__mobile-link-label">{{ child.title }}</span>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} ============ LEVEL 3: Sub-sub-panels ============ {%- endcomment -%}
          {%- for child in link.links -%}
            {%- if child.links.size > 0 -%}
              {%- assign l2_id = 'p-' | append: l1_index | append: '-' | append: forloop.index0 -%}
              <div class="kt-header__mobile-view" data-panel="{{ l2_id }}" data-state="ahead" id="mobile-panel-{{ l2_id }}">
                <div class="kt-header__mobile-view-inner">
                  <button
                    type="button"
                    class="kt-header__mobile-back"
                    data-mobile-back
                  >
                    <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="19" y1="12" x2="5" y2="12"></line>
                      <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    <span class="kt-header__mobile-back-label">{{ 'kt.general.back' | t | default: 'Back' }}</span>
                  </button>
                  <h3 class="kt-header__mobile-view-title">{{ child.title }}</h3>

                  {%- if child.url != blank and child.url != '#' -%}
                    <a href="{{ child.url }}" class="kt-header__mobile-link kt-header__mobile-link--all">
                      <span class="kt-header__mobile-link-label">
                        {{ 'kt.general.view_all' | t | default: 'View all' }} {{ child.title }}
                      </span>
                    </a>
                  {%- endif -%}

                  {%- for grandchild in child.links -%}
                    <a href="{{ grandchild.url }}" class="kt-header__mobile-link">
                      <span class="kt-header__mobile-link-label">{{ grandchild.title }}</span>
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script src="{{ 'kt-section-header.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'kt-section-header-mobile-nav.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "settings": [
    {
      "type": "select",
      "id": "header_style",
      "label": "t:sections.header.settings.header_style.label",
      "options": [
        { "value": "transparent", "label": "t:sections.header.settings.header_style.options__1.label" },
        { "value": "solid", "label": "t:sections.header.settings.header_style.options__2.label" }
      ],
      "default": "solid",
      "info": "t:sections.header.settings.header_style.info"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__navigation.content"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.main_menu.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__mobile.content"
    },
    {
      "type": "text",
      "id": "mobile_cta_text",
      "label": "t:sections.header.settings.mobile_cta_text.label",
      "default": "Estimate Project"
    },
    {
      "type": "url",
      "id": "mobile_cta_link",
      "label": "t:sections.header.settings.mobile_cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_featured",
      "name": "t:sections.header.blocks.mega_menu_featured.name",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "t:sections.header.blocks.mega_menu_featured.settings.menu_title.label",
          "info": "t:sections.header.blocks.mega_menu_featured.settings.menu_title.info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.header.blocks.mega_menu_featured.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.header.blocks.mega_menu_featured.settings.heading.label",
          "default": "The Heritage Collection"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.header.blocks.mega_menu_featured.settings.description.label",
          "default": "Top tier 5-piece solid wood doors engineered for lifetime performance."
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.header.blocks.mega_menu_featured.settings.link.label"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "t:sections.header.blocks.mega_menu_featured.settings.link_text.label",
          "default": "Explore"
        }
      ]
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
