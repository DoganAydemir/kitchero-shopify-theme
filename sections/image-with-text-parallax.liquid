    },
    {
      "type": "header",
      "content": "t:sections.image-with-text-parallax.settings.header__cta.content"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.image-with-text-parallax.settings.cta_text.label",
