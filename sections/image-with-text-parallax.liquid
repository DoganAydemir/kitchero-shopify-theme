    },
    {
      "type": "header",
      "content": "t:sections.image-with-text-parallax.settings.header__media.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-with-text-parallax.settings.image.label"
    },
    {
      "type": "select",
      "id": "image_position",
