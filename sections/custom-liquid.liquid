{%- comment -%}
  Custom Liquid section — Theme Store requirement.

  Lets a merchant drop arbitrary Liquid into any page that supports
  sections. The section is intentionally minimalist — the merchant is
  responsible for the markup; we only provide spacing tokens and a
  section wrapper so the editor can reorder/resize it like any other
  section.

  Why this section is mandatory:
  Theme Store requires a custom-liquid section that "must include
  setting type `liquid` and be available on all section-supporting
  templates" (see shopify.dev/docs/storefronts/themes/store/requirements).
  Without it, merchants cannot embed app snippets or one-off Liquid
  experiments without editing theme code, and the submission is
  rejected on technical-requirements grounds.

  No JS — pure Liquid passthrough. No assets/section-custom-liquid.css
  is loaded; the section root only owns layout padding tokens.
{%- endcomment -%}

{{ 'section-custom-liquid.css' | asset_url | stylesheet_tag }}

<div
  class="kt-custom-liquid color-{{ section.settings.color_scheme | default: 'scheme-1' }}"
  style="
    --kt-section-padding-top: {{ section.settings.padding_top }}px;
    --kt-section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="kt-custom-liquid__inner page-width">
    {{ section.settings.custom_liquid }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.custom-liquid.name",
  "tag": "section",
  "class": "kt-section--custom-liquid",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:sections.custom-liquid.settings.custom_liquid.label",
      "info": "t:sections.custom-liquid.settings.custom_liquid.info"
    },
    {
      "type": "header",
      "content": "t:sections.custom-liquid.settings.header__appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.custom-liquid.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.custom-liquid.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-liquid.settings.padding_top.label",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-liquid.settings.padding_bottom.label",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-liquid.presets.name"
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
