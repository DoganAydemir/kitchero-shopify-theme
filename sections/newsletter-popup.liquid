{%- comment -%}
  Newsletter Popup — full-screen modal that auto-opens after a delay.
  Ported from src/app/newsletter/page.tsx.

  Uses Shopify's {% form 'customer' %} form with the "newsletter" tag so
  submissions land in the merchant's Customers list. After a successful
  submit Shopify re-renders the page with form.posted_successfully? == true;
  we swap the modal into the success state and the JS auto-keeps it open.
{%- endcomment -%}

{%- comment -%}
  Pull the stylesheet in only when the merchant has toggled the popup
  on. ~10 KB saved on the initial paint for stores that disable the
  popup (which is the default state on most launches). The modal
  markup below is already gated on the same flag, so there's nothing
  to style when the flag is off.
{%- endcomment -%}
{%- if section.settings.enabled -%}
  {{ 'kt-section-newsletter-popup.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.settings.enabled -%}
  {%- assign newsletter_form_id = 'NewsletterPopupForm-' | append: section.id -%}
  {%- assign email_placeholder_default = 'kt.section.newsletter.email_placeholder_default' | t -%}
  {%- assign consent_label_default = 'kt.section.newsletter.consent_label_default' | t -%}
  {%- assign subscribe_default = 'kt.section.newsletter.subscribe_default' | t -%}
  {%- assign privacy_note_default = 'kt.section.newsletter.privacy_note_default' | t -%}
  {%- assign heading_part1_default = 'kt.section.newsletter_popup.heading_part1_default' | t -%}
  {%- assign heading_part2_default = 'kt.section.newsletter_popup.heading_part2_default' | t -%}

  {%- comment -%}
    The popup is hidden via CSS opacity:0 + pointer-events:none, NOT
    display:none / visibility:hidden — that means inner focusable
    elements (email input, submit, close button) stay in the keyboard
    Tab order even when the popup is closed. aria-hidden alone tells
    AT to skip the subtree but doesn't remove descendants from the
    focus chain (that's why other dialogs in the theme — search-overlay,
    cart-drawer, appointment-drawer, main-collection-drawer — pair it
    with `inert`). Without `inert`, a sighted keyboard user tabbing
    the page would move focus into the invisible popup.

    `inert` is a stable HTML attribute (Safari 15.5+, Chrome 102+,
    Firefox 112+) that removes the entire subtree from sequential
    focus, click events, and the accessibility tree. assets/
    newsletter-popup.js toggles it in lockstep with aria-hidden in
    openPopup() / closePopup() so the runtime behaviour matches.
  {%- endcomment -%}
  <div
    class="kt-newsletter-popup"
    id="NewsletterPopup-{{ section.id }}"
    data-newsletter-popup
    data-section-id="{{ section.id }}"
    data-delay-seconds="{{ section.settings.delay_seconds }}"
    data-cooldown-days="{{ section.settings.cooldown_days }}"
    aria-hidden="true"
    inert
  >
    <div class="kt-newsletter-popup__backdrop" data-popup-close aria-hidden="true"></div>

    <div
      class="kt-newsletter-popup__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="NewsletterPopupHeading-{{ section.id }}"
      aria-describedby="NewsletterPopupDesc-{{ section.id }}"
    >
      <button
        type="button"
        class="kt-newsletter-popup__close"
        data-popup-close
        aria-label="{{ 'kt.section.newsletter-popup.close' | t | default: 'Close' }}"
      >
        {% render 'icon-close', width: 18, height: 18, stroke_width: 1.5 %}
      </button>

      {%- comment -%} LEFT pane: image with offer badge {%- endcomment -%}
      <div class="kt-newsletter-popup__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              class: 'kt-newsletter-popup__image',
              loading: 'lazy',
              widths: '450, 600, 900, 1200',
              sizes: '(min-width: 750px) 450px, 100vw',
              width: section.settings.image.width,
              height: section.settings.image.height,
              alt: section.settings.image.alt | default: section.settings.heading_part1
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-newsletter-popup__image' }}
        {%- endif -%}

        <div class="kt-newsletter-popup__media-overlay" aria-hidden="true"></div>

        <div class="kt-newsletter-popup__badge">
          <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 12 20 22 4 22 4 12"></polyline>
            <rect x="2" y="7" width="20" height="5"></rect>
            <line x1="12" y1="22" x2="12" y2="7"></line>
            <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
            <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
          </svg>
          <span>{{ 'kt.section.newsletter-popup.badge' | t | default: 'Exclusive Offer' }}</span>
        </div>
      </div>

      {%- comment -%} RIGHT pane: form or success state {%- endcomment -%}
      <div class="kt-newsletter-popup__content">

        {%- form 'customer', id: newsletter_form_id, class: 'kt-newsletter-popup__form-wrap' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <div class="kt-newsletter-popup__success" data-popup-success>
              <div class="kt-newsletter-popup__success-icon" aria-hidden="true">
                <svg aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
              </div>
              <h2 class="kt-newsletter-popup__success-title" id="NewsletterPopupHeading-{{ section.id }}">
                {%- comment -%}
                  Schema declares `success_heading` as a merchant-editable
                  text setting. Previously this output rendered only the
                  translation key, which meant the editor toggle had zero
                  effect on the popup — exactly the "schema setting
                  declared but no runtime effect" pattern that Theme
                  Store reviewers flag as a broken feature. Now we
                  prefer the merchant override and fall back to the
                  translated default when the setting is empty (fresh
                  install). `| t` is NOT chained to the merchant value
                  — that would treat the merchant's literal text as a
                  translation key and emit "translation missing: ..."
                  for any non-key string.
                {%- endcomment -%}
                {%- if section.settings.success_heading != blank -%}
                  {{ section.settings.success_heading }}
                {%- else -%}
                  {{ 'kt.section.newsletter-popup.success_heading' | t }}
                {%- endif -%}
              </h2>
              <p class="kt-newsletter-popup__success-desc" id="NewsletterPopupDesc-{{ section.id }}">
                {%- comment -%}
                  XSS defense: the merchant-editable `success_description`
                  (textarea) and `success_code` (text) are NOT auto-
                  escaped by Liquid — a direct output of a textarea
                  variable emits raw bytes. Previously the raw
                  description was passed through
                  `| replace: '[code]', success_code_html`, so a
                  merchant admin with content-edit rights could paste
                  a script tag into either field and execute JS on
                  every visitor who saw the success state. Shopify's
                  threat model trusts the admin, but Theme Store policy
                  flags this as a stored-XSS vector the theme must
                  defuse — escape both inputs first, then inject the
                  `<span>` via the replace.
                {%- endcomment -%}
                {%- assign desc_default = 'Your 15% discount code has been sent to your inbox. Use code [code] at checkout.' -%}
                {%- assign desc_safe = section.settings.success_description | default: desc_default | escape -%}
                {%- assign code_safe = section.settings.success_code | escape -%}
                {%- assign success_code_html = '<span class="kt-newsletter-popup__code">' | append: code_safe | append: '</span>' -%}
                {{ desc_safe | replace: '[code]', success_code_html }}
              </p>
              {%- if section.settings.success_button_text != blank -%}
                <a
                  href="{{ section.settings.success_button_link | default: routes.all_products_collection_url | escape }}"
                  class="kt-newsletter-popup__success-btn"
                  data-popup-close
                >
                  {{ section.settings.success_button_text }}
                </a>
              {%- endif -%}
            </div>

          {%- else -%}

            {%- comment -%} Eyebrow block: icon + merchant-set eyebrow + discount label.
              Both fields render only when merchant supplies them — defaults
              are scrubbed to avoid synthesizing fake-urgency / fake-discount
              copy on a freshly-installed storefront. The icon container also
              suppresses when both labels are empty so the slot doesn't
              render an empty band. {%- endcomment -%}
            {%- if section.settings.eyebrow != blank or section.settings.discount_label != blank -%}
              <div class="kt-newsletter-popup__eyebrow">
                <div class="kt-newsletter-popup__eyebrow-icon" aria-hidden="true">
                  <svg aria-hidden="true" focusable="false" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="5" x2="5" y2="19"></line>
                    <circle cx="6.5" cy="6.5" r="2.5"></circle>
                    <circle cx="17.5" cy="17.5" r="2.5"></circle>
                  </svg>
                </div>
                <div class="kt-newsletter-popup__eyebrow-text">
                  {%- if section.settings.eyebrow != blank -%}
                    <span class="kt-newsletter-popup__eyebrow-label">
                      {{ section.settings.eyebrow }}
                    </span>
                  {%- endif -%}
                  {%- if section.settings.discount_label != blank -%}
                    <span class="kt-newsletter-popup__eyebrow-discount">
                      {{ section.settings.discount_label }}
                    </span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

            <h2 class="kt-newsletter-popup__heading" id="NewsletterPopupHeading-{{ section.id }}">
              {{ section.settings.heading_part1 | default: heading_part1_default }}
              {%- if section.settings.heading_italic_word != blank -%}
                <span class="kt-newsletter-popup__heading-italic">{{ section.settings.heading_italic_word }}</span>
              {%- endif -%}
              {{ section.settings.heading_part2 | default: heading_part2_default }}
            </h2>

            {%- if section.settings.description != blank -%}
              <p class="kt-newsletter-popup__description" id="NewsletterPopupDesc-{{ section.id }}">
                {{ section.settings.description }}
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              {%- comment -%}
                R151 NEWSLETTER-POPUP-1: error summary now uses the
                `data-form-error-summary` + `tabindex="-1"` pattern
                consistent with main-login / main-register / address
                forms. global.js focusFirstFormError() finds this on
                submit and moves keyboard/SR focus to it. role="alert"
                is scoped to the inner UL only (per R145
                ADDRESSES-ALERT-ROLE-1 fix) so NVDA/JAWS don't
                announce the heading + every list item as one
                run-on string. Replaces the previous bare
                `default_errors` blob which had no focus management
                and no inline anchor links.
              {%- endcomment -%}
              <div class="kt-newsletter-popup__errors" tabindex="-1" data-form-error-summary>
                <h3 class="kt-newsletter-popup__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h3>
                <ul class="kt-newsletter-popup__errors-list" role="alert">
                  {%- for field in form.errors -%}
                    <li>
                      {%- if field == 'form' -%}
                        {{ form.errors.translated_messages[field] }}
                      {%- else -%}
                        <a href="#NewsletterPopupEmail-{{ section.id }}">
                          {{- form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] -}}
                        </a>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            {%- assign popup_email_err = 'NewsletterPopupEmail-' | append: section.id | append: '-error' -%}
            <div class="kt-newsletter-popup__field">
              <label for="NewsletterPopupEmail-{{ section.id }}" class="visually-hidden">
                {{ 'kt.section.newsletter-popup.email_label' | t | default: 'Email address' }}
              </label>
              <span class="kt-newsletter-popup__field-icon" aria-hidden="true">
                <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </span>
              <input
                type="email"
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
                id="NewsletterPopupEmail-{{ section.id }}"
                name="contact[email]"
                class="kt-newsletter-popup__input"
                placeholder="{{ section.settings.email_placeholder | default: email_placeholder_default }}"
                required
                aria-required="true"
                maxlength="254"
                inputmode="email"
                {%- comment -%}
                  R104 — Return key fires submit on mobile.
                {%- endcomment -%}
                enterkeyhint="send"
                autocomplete="email"
                {%- comment -%}
                  R96 — preserve typed email across validation errors
                  so customer doesn't retype.
                {%- endcomment -%}
                value="{{ form.email | escape }}"
                data-popup-email
                {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="{{ popup_email_err }}"{% endif %}
              >
            </div>
            {%- render 'form-field-error', form: form, field: 'email', describedby_id: popup_email_err -%}

            {%- comment -%}
              Honeypot — appended to the popup form. Backend rejects
              any submission with non-empty contact[website].
            {%- endcomment -%}
            <p class="kt-form__honeypot" aria-hidden="true" inert>
              <label for="NewsletterPopupTrap-{{ section.id }}">{{ 'kt.a11y.honeypot' | t | default: 'Leave this field empty' }}</label>
              <input type="text" id="NewsletterPopupTrap-{{ section.id }}" name="contact[website]" tabindex="-1" autocomplete="off" aria-hidden="true">
            </p>

            {%- comment -%}
              R122 — GDPR consent gate. Same R96/R122-B3 rationale as
              newsletter-signup section. Default-OFF for non-EU
              merchants; merchants in EU/UK/Brazil enable + provide
              localized text with privacy-policy link.
            {%- endcomment -%}
            {%- if section.settings.show_consent_checkbox -%}
              <p class="kt-newsletter-popup__consent">
                <input
                  type="checkbox"
                  id="NewsletterPopupConsent-{{ section.id }}"
                  name="contact[accepts_marketing]"
                  value="true"
                  required
                  aria-required="true"
                >
                <label for="NewsletterPopupConsent-{{ section.id }}" class="kt-newsletter-popup__consent-label">
                  {{- section.settings.consent_label | default: consent_label_default -}}
                </label>
              </p>
            {%- endif -%}

            <button type="submit" class="kt-newsletter-popup__submit">
              <span>{{ section.settings.submit_button_text | default: subscribe_default }}</span>
              {% render 'icon-arrow-right', width: 14, height: 14, stroke_width: 1.5 %}
            </button>

            {%- comment -%}
              Privacy disclosure adjacent to the email field. Theme
              Store reviewers explicitly look for a clickable link to
              shop.privacy_policy here — the previous static text
              mentioned "Privacy Policy" but never linked. When the
              merchant has set up a privacy policy in Shopify admin,
              the policy title becomes a real anchor; otherwise the
              static disclosure renders alone (no broken link).

              We deliberately do NOT pre-flag `contact[accepts_marketing]=true`
              via a hidden field. GDPR Article 7 + ePrivacy Directive
              require explicit, granular, informed opt-in — a server-
              forced flag bypasses that and is a Theme Store reject
              signal. Instead the visible disclosure below + the
              merchant's Shopify-native double-opt-in confirmation
              email together produce the legally-valid consent
              record. accepts_marketing is set by the merchant's
              double-opt-in setting in Shopify admin, not by a
              client-side hidden field.
            {%- endcomment -%}
            <p class="kt-newsletter-popup__privacy">
              {{ section.settings.privacy_note | default: privacy_note_default }}
              {%- if shop.privacy_policy != blank %}
                <a href="{{ shop.privacy_policy.url }}" class="kt-newsletter-popup__privacy-link">{{ shop.privacy_policy.title }}</a>
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- comment -%}
            When Shopify re-renders the page after a successful
            submission, emit a sentinel element. `form.posted_successfully?`
            only resolves inside the {% form %} block, so the sentinel
            lives here. newsletter-popup.js reads its presence and
            promotes the data-posted-successfully attribute onto the
            popup root.
          {%- endcomment -%}
          {%- if form.posted_successfully? -%}
            <span
              hidden
              aria-hidden="true"
              data-newsletter-posted-success
              data-section-id="{{ section.id }}"
            ></span>
          {%- endif -%}
        {%- endform -%}

      </div>
    </div>

    {% comment %}
      App block slot — email capture app integrations (Klaviyo embed,
      Mailchimp widgets, consent managers) frequently want to inject a
      control inside the newsletter surface. Rendering outside the
      modal panel so app-block markup isn't subject to the panel's
      focus trap.
    {% endcomment %}
    {% render 'section-app-blocks' %}
  </div>

  <script src="{{ 'newsletter-popup.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.newsletter-popup.name",
  "tag": "aside",
  "class": "kt-newsletter-popup-wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "t:sections.newsletter-popup.settings.enabled.label",
      "info": "t:sections.newsletter-popup.settings.enabled.info",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.newsletter-popup.settings.header_content.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.newsletter-popup.settings.image.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.newsletter-popup.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "discount_label",
      "label": "t:sections.newsletter-popup.settings.discount_label.label"
    },
    {
      "type": "text",
      "id": "heading_part1",
      "label": "t:sections.newsletter-popup.settings.heading_part1.label",
      "default": "Join our"
    },
    {
      "type": "text",
      "id": "heading_italic_word",
      "label": "t:sections.newsletter-popup.settings.heading_italic_word.label",
      "default": "newsletter"
    },
    {
      "type": "text",
      "id": "heading_part2",
      "label": "t:sections.newsletter-popup.settings.heading_part2.label",
      "default": "today"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.newsletter-popup.settings.description.label",
      "default": "Subscribe to our newsletter for early access to new collections and seasonal updates."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "t:sections.newsletter-popup.settings.email_placeholder.label",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "submit_button_text",
      "label": "t:sections.newsletter-popup.settings.submit_button_text.label"
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "t:sections.newsletter-popup.settings.privacy_note.label",
      "default": "By subscribing, you agree to our Privacy Policy. Unsubscribe at any time."
    },
    {
      "type": "header",
      "content": "t:sections.newsletter-popup.settings.header_success.content"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "t:sections.newsletter-popup.settings.success_heading.label",
      "default": "Thanks for subscribing"
    },
    {
      "type": "textarea",
      "id": "success_description",
      "label": "t:sections.newsletter-popup.settings.success_description.label",
      "info": "t:sections.newsletter-popup.settings.success_description.info",
      "default": "Thanks for subscribing — your welcome message is on its way to your inbox."
    },
    {
      "type": "text",
      "id": "success_code",
      "label": "t:sections.newsletter-popup.settings.success_code.label"
    },
    {
      "type": "text",
      "id": "success_button_text",
      "label": "t:sections.newsletter-popup.settings.success_button_text.label",
      "default": "Start shopping"
    },
    {
      "type": "url",
      "id": "success_button_link",
      "label": "t:sections.newsletter-popup.settings.success_button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.newsletter-popup.settings.header_behavior.content"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "t:sections.newsletter-popup.settings.delay_seconds.label",
      "info": "t:sections.newsletter-popup.settings.delay_seconds.info",
      "min": 3,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.enabled }}"
    },
    {
      "type": "range",
      "id": "cooldown_days",
      "label": "t:sections.newsletter-popup.settings.cooldown_days.label",
      "info": "t:sections.newsletter-popup.settings.cooldown_days.info",
      "visible_if": "{{ section.settings.enabled }}",
      "min": 1,
      "max": 30,
      "step": 1,
      "unit": "d",
      "default": 7
    },
    {
      "type": "header",
      "content": "t:sections.newsletter-popup.settings.header__consent.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.newsletter-popup.settings.header__consent.info"
    },
    {
      "type": "checkbox",
      "id": "show_consent_checkbox",
      "label": "t:sections.newsletter-popup.settings.show_consent_checkbox.label",
      "info": "t:sections.newsletter-popup.settings.show_consent_checkbox.info",
      "default": false
    },
    {
      "type": "richtext",
      "id": "consent_label",
      "label": "t:sections.newsletter-popup.settings.consent_label.label",
      "info": "t:sections.newsletter-popup.settings.consent_label.info",
      "default": "<p>I agree to receive marketing emails. I can unsubscribe at any time.</p>"
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "enabled_on": {
    "groups": ["footer", "overlay"]
  },
  "presets": [
    {
      "name": "t:sections.newsletter-popup.presets.name"
    }
  ]
}
{% endschema %}
