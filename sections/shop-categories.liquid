{{ 'kt-section-shop-categories.css' | asset_url | stylesheet_tag }}

{%- assign shop_categories_heading_default = 'kt.section.shop_categories.heading_default' | t -%}
{%- assign shop_categories_subtitle_default = 'kt.section.shop_categories.subtitle_default' | t -%}

<section class="kt-shop-categories{% if section.settings.bg_color and section.settings.bg_color != 'auto' %} kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}" data-section-id="{{ section.id }}" data-section-type="shop-categories">
  <div class="page-width">
    <div class="kt-shop-categories__header">
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-shop-categories__title">
        {{ section.settings.heading | default: shop_categories_heading_default }}
      </{{ heading_tag }}>
      <div class="kt-shop-categories__subtitle-row">
        <p class="kt-shop-categories__subtitle">{{ section.settings.subtitle | default: shop_categories_subtitle_default }}</p>
        {% render 'icon-arrow-right', width: 24, height: 24, stroke_width: 1.5 %}
      </div>
    </div>
  </div>

  {%- comment -%}
    R182 PLACEHOLDER-ROTATE-1: rotate Shopify's `collection-1`/`-2`/
    `-3` placeholder set across the visible category cards so a
    fresh-install demo storefront doesn't render three identical
    placeholder images side-by-side. `forloop.index0` modulo 3
    cycles through the trio; once the merchant configures real
    images this code path goes inactive.
  {%- endcomment -%}
  {%- assign shop_cat_placeholders = 'collection-1,collection-2,collection-3' | split: ',' -%}
  <div class="kt-shop-categories__scroll">
    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <a
          href="{{ block.settings.link | default: routes.collections_url | escape }}"
          class="kt-shop-categories__card"
          {{ block.shopify_attributes }}
        >
          <div class="kt-shop-categories__card-image-wrap">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'kt-shop-categories__card-image',
                  loading: 'lazy',
                  widths: '375, 550, 750, 1100',
                  sizes: '(min-width: 990px) 35vw, (min-width: 750px) 45vw, 85vw',
                  width: block.settings.image.width,
                  height: block.settings.image.height,
                  alt: block.settings.title | default: ''
              }}
            {%- else -%}
              {%- assign shop_cat_ph_index = forloop.index0 | modulo: 3 -%}
              {{ shop_cat_placeholders[shop_cat_ph_index] | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="kt-shop-categories__card-overlay" aria-hidden="true"></div>
          <div class="kt-shop-categories__card-content">
            <h3 class="kt-shop-categories__card-title">{{ block.settings.title | escape }}</h3>
            <div class="kt-shop-categories__card-arrow" aria-hidden="true">
              {% render 'icon-arrow-right', width: 20, height: 20, stroke_width: 1.5 %}
            </div>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script src="{{ 'kt-section-shop-categories.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.shop-categories.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shop-categories.settings.heading.label",
      "default": "Shop by Style"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.shop-categories.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.shop-categories.settings.subtitle.label",
      "default": "Discover your perfect aesthetic"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        { "value": "auto", "label": "t:sections.shared.bg_color.options__auto.label" },
        { "value": "white", "label": "t:sections.shared.bg_color.options__white.label" },
        { "value": "stone_50", "label": "t:sections.shared.bg_color.options__stone_50.label" },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.shop-categories.blocks.category.name",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.shop-categories.blocks.category.settings.title.label",
          "default": "Category"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.shop-categories.blocks.category.settings.image.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.shop-categories.blocks.category.settings.link.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.shop-categories.presets.name",
      "category": "t:sections.categories.image.label",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Minimalist Modern"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Classic Wood"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Category title"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Scandinavian"
          }
        }
      ]
    }
  ]
}
{% endschema %}
