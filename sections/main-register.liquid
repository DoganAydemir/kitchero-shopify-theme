{{ 'kt-section-customer-forms.css' | asset_url | stylesheet_tag }}

<section class="kt-customer" data-section-id="{{ section.id }}" data-section-type="main-register">
  <div class="kt-customer__container">
    <h1 class="kt-customer__title">{{ 'kt.customer.register.title' | t }}</h1>

    {%- form 'create_customer', id: 'CreateCustomerForm' -%}
      {%- comment -%}
        Email-verification success state. When the merchant has
        "customer accounts → email verification" enabled (Shopify's
        default for new stores as of 2024), create_customer returns
        form.posted_successfully? == true without logging the
        customer in — Shopify sends a confirmation email. Without
        this branch the register form just re-rendered with the
        customer's typed values still in the inputs, looking like
        the submit failed silently. Theme Store reviewers test
        account creation end-to-end and flag this as a broken flow.
      {%- endcomment -%}
      {%- if form.posted_successfully? -%}
        <div class="kt-customer__success" role="status" tabindex="-1" data-form-error-summary>
          <h2 class="kt-customer__success-title">
            {{ 'kt.customer.register.success_heading' | t | default: 'Check your email' }}
          </h2>
          <p class="kt-customer__success-desc">
            {{ 'kt.customer.register.success_description' | t | default: 'We just sent a confirmation link to your inbox. Click the link to activate your account and start shopping.' }}
          </p>
          <a href="{{ routes.account_login_url }}" class="kt-customer__submit kt-customer__success-cta">
            {{ 'kt.customer.login.sign_in' | t }}
          </a>
        </div>
      {%- else -%}
      {%- if form.errors -%}
        {%- comment -%}
          role="alert" scoped to the UL (dynamic content) not the
          outer div (static heading) — see main-login.liquid for the
          full rationale. Heading reads through normal focus flow;
          the error list alerts on submit.
        {%- endcomment -%}
        <div class="kt-customer__errors" data-form-error-summary tabindex="-1">
          <h2 class="kt-customer__errors-title">{{ 'kt.contact.form.error_heading' | t }}</h2>
          <ul class="kt-customer__errors-list" role="alert">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.translated_messages[field] }}
                {%- else -%}
                  {%- comment -%}
                    Shopify error-field names are snake_case (first_name,
                    password_confirmation). Inputs below use hyphen IDs
                    (register-first-name). Without the replace, the
                    anchor lands on a non-existent `#register-first_name`
                    and clicking an error does nothing for keyboard /
                    SR users. Replace underscores → hyphens to match.
                  {%- endcomment -%}
                  <a href="#register-{{ field | replace: '_', '-' }}">
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="kt-customer__form">
        {%- comment -%}
          All non-password inputs bind `value="{{ form.X | escape }}"`
          so a server-side validation failure preserves the user's
          typed data. Shopify redirects back with `form.*` populated
          on failure; without these bindings the user retypes every
          field. Passwords stay empty for security.
        {%- endcomment -%}
        <div class="kt-customer__row">
          <div class="kt-customer__field">
            <label for="register-first-name" class="kt-customer__label kt-form__label--required">{{ 'kt.customer.register.first_name' | t }}</label>
            <input
              type="text"
              id="register-first-name"
              name="customer[first_name]"
              class="kt-customer__input"
              placeholder="{{ 'kt.customer.register.first_name' | t }}"
              value="{{ form.first_name | escape }}"
              required
              aria-required="true"
              {%- comment -%}
                R104 — Return advances to next field on mobile.
              {%- endcomment -%}
              enterkeyhint="next"
              autocomplete="given-name"
              {% if form.errors contains 'first_name' %}aria-invalid="true" aria-describedby="register-first-name-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'first_name', describedby_id: 'register-first-name-error' -%}
          </div>
          <div class="kt-customer__field">
            <label for="register-last-name" class="kt-customer__label kt-form__label--required">{{ 'kt.customer.register.last_name' | t }}</label>
            <input
              type="text"
              id="register-last-name"
              name="customer[last_name]"
              class="kt-customer__input"
              placeholder="{{ 'kt.customer.register.last_name' | t }}"
              value="{{ form.last_name | escape }}"
              required
              aria-required="true"
              {%- comment -%}
                R104 — Return advances to next field on mobile.
              {%- endcomment -%}
              enterkeyhint="next"
              autocomplete="family-name"
              {% if form.errors contains 'last_name' %}aria-invalid="true" aria-describedby="register-last-name-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'last_name', describedby_id: 'register-last-name-error' -%}
          </div>
        </div>
        <div class="kt-customer__field">
          <label for="register-email" class="kt-customer__label kt-form__label--required">{{ 'kt.customer.register.email' | t }}</label>
          <input
            type="email"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            id="register-email"
            name="customer[email]"
            class="kt-customer__input"
            placeholder="{{ 'kt.customer.register.email' | t }}"
            value="{{ form.email | escape }}"
            required
            aria-required="true"
            inputmode="email"
            {%- comment -%}
              R104 — Return advances to password on mobile.
            {%- endcomment -%}
            enterkeyhint="next"
            autocomplete="email"
            {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="register-email-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'register-email-error' -%}
        </div>
        <div class="kt-customer__field">
          <label for="register-password" class="kt-customer__label kt-form__label--required">{{ 'kt.customer.register.password' | t }}</label>
          {%- comment -%}
            Drop hardcoded `minlength="5"` — Shopify's server-side
            validation owns the minimum password length. Shops on Plus
            plans with Customer Accounts New UI sometimes enforce a
            higher minimum (8 or 12) via a security policy; having the
            theme hardcode 5 would block submission and give no
            helpful error (the browser native "at least 5 characters"
            tooltip contradicts the real 12-char requirement).
            Shopify returns per-field errors for password_too_short
            which render via the form-field-error snippet below.
          {%- endcomment -%}
          <input
            type="password"
            id="register-password"
            name="customer[password]"
            class="kt-customer__input"
            placeholder="{{ 'kt.customer.register.password' | t }}"
            required
            aria-required="true"
            {%- comment -%}
              R104 — Return fires Create account on mobile.
            {%- endcomment -%}
            enterkeyhint="go"
            autocomplete="new-password"
            {% if form.errors contains 'password' %}aria-invalid="true" aria-describedby="register-password-error"{% endif %}
            aria-describedby="register-password-hint"
          >
          <p class="kt-customer__hint" id="register-password-hint">
            {{ 'kt.customer.register.password_hint' | t | default: 'At least 5 characters.' }}
          </p>
          {%- render 'form-field-error', form: form, field: 'password', describedby_id: 'register-password-error' -%}
        </div>

        {%- comment -%}
          Marketing consent checkbox. `customer[accepts_marketing]` is
          Shopify's form field for opt-in to promotional email / SMS.
          REQUIRED to be off by default and require an explicit opt-in
          under EU GDPR + CCPA + CASL (Canada) — any pre-checked
          default is a legal risk for merchants selling into those
          markets. Label is a full-sentence consent statement (not
          just "Subscribe") so merchants meet the "informed consent"
          bar. Gated on a merchant setting so stores that handle
          marketing via a dedicated marketing app can turn it off.
        {%- endcomment -%}
        {%- if section.settings.show_marketing_opt_in -%}
          <div class="kt-customer__consent">
            <label class="kt-customer__consent-label" for="register-accepts-marketing">
              {%- comment -%}
                GDPR/ePrivacy — link the consent checkbox via
                `aria-describedby` to a privacy-policy pointer so
                assistive tech reads the consent text AND the
                "see our privacy policy" disclosure together. Gated
                on `shop.privacy_policy.url` because new stores may
                not have one linked yet — don't emit a dangling
                "Read our privacy policy" without a destination.
              {%- endcomment -%}
              <input
                type="checkbox"
                id="register-accepts-marketing"
                name="customer[accepts_marketing]"
                value="1"
                class="kt-customer__consent-checkbox"
                {%- if shop.privacy_policy.url != blank %} aria-describedby="register-consent-privacy"{%- endif -%}
              >
              <span class="kt-customer__consent-text">
                {{ 'kt.customer.register.marketing_consent' | t | default: 'Yes, sign me up to hear about new arrivals, sales, and exclusive offers. I can unsubscribe at any time.' }}
              </span>
            </label>
            {%- if shop.privacy_policy.url != blank -%}
              <p id="register-consent-privacy" class="kt-customer__consent-privacy">
                {{ 'kt.customer.register.privacy_note_html' | t: link: shop.privacy_policy.url }}
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}

        <button type="submit" class="kt-customer__submit">{{ 'kt.customer.register.submit' | t }}</button>

        <div class="kt-customer__alt">
          {{ 'kt.customer.register.already_have' | t | default: 'Already have an account?' }}
          <a href="{{ routes.account_login_url }}">{{ 'kt.customer.login.sign_in' | t }}</a>
        </div>
      </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/register"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_marketing_opt_in",
      "label": "t:sections.main-register.settings.show_marketing_opt_in.label",
      "info": "t:sections.main-register.settings.show_marketing_opt_in.info",
      "default": true
    }
  ]
}
{% endschema %}
