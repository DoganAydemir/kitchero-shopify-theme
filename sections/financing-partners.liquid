{%- comment -%}
  Financing Partners — minimalist centered intro used on the /financing
  template. Two-line editorial headline + description + a row of partner
  name-marks (logo_image optional; falls back to text wordmark) with
  grayscale → color hover treatment. Ported from the "PARTNER INTRO"
  block in the Next.js financing page.
{%- endcomment -%}

{{ 'kt-section-financing-partners.css' | asset_url | stylesheet_tag }}

{%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}

<section
  class="kt-financing-partners {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="financing-partners"
>
  <div class="page-width">
    <div class="kt-financing-partners__inner">
      <{{ heading_tag }} class="kt-financing-partners__title">
        {{- section.settings.heading -}}
      </{{ heading_tag }}>

      {%- if section.settings.description != blank -%}
        <p class="kt-financing-partners__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="kt-financing-partners__list" role="list">
          {%- for block in section.blocks -%}
            {%- comment -%}
              R168 DEMO-PLACEHOLDER-COPY-2: skip partner blocks
              the merchant hasn't configured. Without this guard,
              an empty `<span class="…__wordmark">` (no name, no
              logo image) renders as a visible-but-empty list
              item — Theme Store reviewers see an unfinished
              partner row on the storefront preview. Schema
              defaults are now null (the previous "Lender name"
              instruction copy was a demo-content reject vector),
              so the merchant has to actively fill in either the
              name OR the logo image for the block to render at
              all. Both branches of the wordmark/logo conditional
              already exist below; this just gates the entire
              list-item render on at least one being supplied.
            {%- endcomment -%}
            {%- if block.type != 'partner' -%}{% continue %}{%- endif -%}
            {%- if block.settings.name == blank and block.settings.logo_image == blank -%}{% continue %}{%- endif -%}
              <li class="kt-financing-partners__item" {{ block.shopify_attributes }}>
                {%- if block.settings.logo_image != blank -%}
                  {%- comment -%}
                    Compute the width attr from the merchant upload's
                    aspect ratio at 24px render height so <img> ships
                    valid width+height (Theme Check `ImgWidthAndHeight`
                    + CLS prevention). Previously only `height: 24`
                    was emitted — no width → browser reserves 0px
                    until the image loads → partner row jumps in.
                  {%- endcomment -%}
                  {%- assign logo_width = block.settings.logo_image.width | times: 24 | divided_by: block.settings.logo_image.height -%}
                  {{
                    block.settings.logo_image
                    | image_url: height: 48
                    | image_tag:
                      class: 'kt-financing-partners__logo',
                      loading: 'lazy',
                      width: logo_width,
                      height: 24,
                      alt: block.settings.name
                  }}
                {%- else -%}
                  <span
                    class="kt-financing-partners__wordmark kt-financing-partners__wordmark--{{ block.settings.style | default: 'default' }}"
                  >
                    {%- if block.settings.style == 'icon_prefix' -%}
                      <span class="kt-financing-partners__wordmark-icon" aria-hidden="true"></span>
                    {%- endif -%}
                    {{ block.settings.name }}
                  </span>
                {%- endif -%}
              </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.financing-partners.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.financing-partners.settings.heading.label",
      "default": "Our financing partners"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.financing-partners.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.financing-partners.settings.description.label",
      "default": "Add a description for this section."
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "t:sections.financing-partners.blocks.partner.name",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.financing-partners.blocks.partner.settings.name.label"
        },
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "t:sections.financing-partners.blocks.partner.settings.logo_image.label",
          "info": "t:sections.financing-partners.blocks.partner.settings.logo_image.info"
        },
        {
          "type": "select",
          "id": "style",
          "label": "t:sections.financing-partners.blocks.partner.settings.style.label",
          "options": [
            {
              "value": "default",
              "label": "t:sections.financing-partners.blocks.partner.settings.style.options__default.label"
            },
            {
              "value": "icon_prefix",
              "label": "t:sections.financing-partners.blocks.partner.settings.style.options__icon_prefix.label"
            },
            {
              "value": "italic",
              "label": "t:sections.financing-partners.blocks.partner.settings.style.options__italic.label"
            }
          ],
          "default": "default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.financing-partners.presets.name",
      "blocks": [
        {
          "type": "partner",
          "settings": {
            "name": "affirm",
            "style": "default"
          }
        },
        {
          "type": "partner",
          "settings": {
            "name": "bread pay",
            "style": "icon_prefix"
          }
        },
        {
          "type": "partner",
          "settings": {
            "name": "KLARNA.",
            "style": "italic"
          }
        }
      ]
    }
  ]
}
{% endschema %}
