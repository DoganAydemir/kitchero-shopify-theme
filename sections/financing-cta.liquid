{%- comment -%}
  Financing CTA — closing call-to-action band with a two-line serif
  heading (second word italic stone-400), a muted description, and two
  pill buttons side-by-side ("Apply Now" filled, "Explore Collections"
  outlined). Ported from the bottom CTA in the Next.js /financing page.
  Sits on a stone-100 band with a hairline top border.
{%- endcomment -%}

{{ 'kt-section-financing-cta.css' | asset_url | stylesheet_tag }}

{%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}

<section
  class="kt-financing-cta {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="financing-cta"
>
  <div class="page-width kt-financing-cta__inner">
    <{{ heading_tag }} class="kt-financing-cta__title">
      {%- if section.settings.heading_line1 != blank -%}
        <span>{{ section.settings.heading_line1 }}</span>
      {%- endif -%}
      {%- if section.settings.heading_line2 != blank -%}
        <span class="kt-financing-cta__title-accent">{{ section.settings.heading_line2 }}</span>
      {%- endif -%}
    </{{ heading_tag }}>

    {%- if section.settings.description != blank -%}
      <p class="kt-financing-cta__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    <div class="kt-financing-cta__buttons">
      {%- comment -%}
        R162 EMPTY-HREF-1: each CTA emits ONLY when both label AND
        URL are configured. Theme Store flags `<a href="#">` as a
        broken link. Editor hint surfaces the gap to merchants.
      {%- endcomment -%}
      {%- if section.settings.primary_text != blank and section.settings.primary_link != blank -%}
        <a
          href="{{ section.settings.primary_link | escape }}"
          class="kt-financing-cta__btn kt-financing-cta__btn--primary"
        >
          {{ section.settings.primary_text }}
          {% render 'icon-arrow-right', width: 14, height: 14 %}
        </a>
      {%- elsif section.settings.primary_text != blank and request.design_mode -%}
        <p class="kt-financing-cta__btn-empty">
          {{ 'kt.editor.empty_link_notice' | t | default: 'Add a link URL to enable this CTA.' }}
        </p>
      {%- endif -%}

      {%- if section.settings.secondary_text != blank and section.settings.secondary_link != blank -%}
        <a
          href="{{ section.settings.secondary_link | escape }}"
          class="kt-financing-cta__btn kt-financing-cta__btn--secondary"
        >
          {{ section.settings.secondary_text }}
        </a>
      {%- elsif section.settings.secondary_text != blank and request.design_mode -%}
        <p class="kt-financing-cta__btn-empty">
          {{ 'kt.editor.empty_link_notice' | t | default: 'Add a link URL to enable this CTA.' }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.financing-cta.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "t:sections.financing-cta.settings.heading_line1.label",
      "default": "Start your project"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "t:sections.financing-cta.settings.heading_line2.label",
      "default": "today."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.financing-cta.settings.heading_tag.label",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.financing-cta.settings.description.label",
      "default": "Add a description for this section."
    },
    {
      "type": "header",
      "content": "t:sections.financing-cta.settings.header__buttons.content"
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "t:sections.financing-cta.settings.primary_text.label",
      "default": "Apply Now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "t:sections.financing-cta.settings.primary_link.label"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "t:sections.financing-cta.settings.secondary_text.label",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "t:sections.financing-cta.settings.secondary_link.label"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        }
      ],
      "default": "auto"
    }
  ],
  "presets": [
    {
      "name": "t:sections.financing-cta.presets.name"
    }
  ]
}
{% endschema %}
