{%- comment -%}
  Main Product — E-Commerce Style PDP
  Birebir from product/[id]/page.tsx
  Left 58%: gallery | Right 42%: product info (sticky)
{%- endcomment -%}

<section class="kt-pdp" data-section-id="{{ section.id }}" data-section-type="main-product">
  <div class="page-width">
    <div class="kt-pdp__layout">

      {%- comment -%} LEFT: Gallery (58%) {%- endcomment -%}
      <div class="kt-pdp__gallery-col">
        {%- render 'product-media-gallery', product: product -%}
      </div>

      {%- comment -%} RIGHT: Product Info (42%, sticky) {%- endcomment -%}
      <div class="kt-pdp__info-col">
        <div class="kt-pdp__info-sticky">

          {%- comment -%} Breadcrumb {%- endcomment -%}
          <nav class="kt-pdp__breadcrumb" aria-label="{{ 'accessibility.breadcrumb' | t }}">
            <ol class="kt-pdp__breadcrumb-list" role="list">
              <li><a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a></li>
              {%- if product.collections.first -%}
                <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
              {%- endif -%}
              <li><span aria-current="page">{{ product.title }}</span></li>
            </ol>
          </nav>

          {%- comment -%} Title {%- endcomment -%}
          <h1 class="kt-pdp__title">{{ product.title }}</h1>

          {%- comment -%} Meta row: rating + "X reviews" + separator + In Stock {%- endcomment -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          <div class="kt-pdp__meta">
            {%- render 'product-rating', product: product -%}
            {%- assign review_count = product.metafields.reviews.rating_count.value -%}
            {%- if review_count -%}
              <span class="kt-pdp__meta-sep" aria-hidden="true">|</span>
            {%- endif -%}
            {%- if current_variant.available -%}
              <span class="kt-pdp__stock kt-pdp__stock--in">{{ 'products.product.in_stock' | t | default: 'In Stock' }}</span>
            {%- else -%}
              <span class="kt-pdp__stock kt-pdp__stock--out">{{ 'products.product.sold_out' | t }}</span>
            {%- endif -%}
          </div>

          {%- comment -%} Premium Countdown Block (if limited offer metafield set) {%- endcomment -%}
          {%- assign deal_ends_at = product.metafields.custom.deal_ends_at.value -%}
          {%- if deal_ends_at != blank -%}
            <div class="kt-pdp__countdown-block">
              <div class="kt-pdp__countdown-glow" aria-hidden="true"></div>
              <div class="kt-pdp__countdown-top">
                <div class="kt-pdp__countdown-label">
                  <span class="kt-pdp__countdown-dot" aria-hidden="true"></span>
                  <span>{{ 'sections.countdown.limited_offer' | t | default: 'Limited Time Offer' }}</span>
                </div>
                <span class="kt-pdp__countdown-badge">{{ 'sections.countdown.promo_active' | t | default: 'Promo Active' }}</span>
              </div>
              <div class="kt-pdp__countdown-bottom">
                <div
                  class="kt-pdp__countdown-timer"
                  data-countdown
                  data-ends-at="{{ deal_ends_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
                  aria-label="{{ 'sections.countdown.label' | t | default: 'Limited time offer' }}"
                >
                  <div class="kt-pdp__countdown-unit">
                    <span class="kt-pdp__countdown-num" data-countdown-days>00</span>
                    <span class="kt-pdp__countdown-key">{{ 'sections.countdown.days' | t | default: 'D' }}</span>
                  </div>
                  <span class="kt-pdp__countdown-colon">:</span>
                  <div class="kt-pdp__countdown-unit">
                    <span class="kt-pdp__countdown-num" data-countdown-hours>00</span>
                    <span class="kt-pdp__countdown-key">{{ 'sections.countdown.hours' | t | default: 'H' }}</span>
                  </div>
                  <span class="kt-pdp__countdown-colon">:</span>
                  <div class="kt-pdp__countdown-unit">
                    <span class="kt-pdp__countdown-num" data-countdown-minutes>00</span>
                    <span class="kt-pdp__countdown-key">{{ 'sections.countdown.minutes' | t | default: 'M' }}</span>
                  </div>
                  <span class="kt-pdp__countdown-colon">:</span>
                  <div class="kt-pdp__countdown-unit">
                    <span class="kt-pdp__countdown-num" data-countdown-seconds>00</span>
                    <span class="kt-pdp__countdown-key">{{ 'sections.countdown.seconds' | t | default: 'S' }}</span>
                  </div>
                </div>
                <div class="kt-pdp__countdown-ends">
                  <div class="kt-pdp__countdown-ends-label">{{ 'sections.countdown.ends_soon' | t | default: 'Ends soon' }}</div>
                  <div class="kt-pdp__countdown-progress"><div class="kt-pdp__countdown-progress-fill"></div></div>
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Price {%- endcomment -%}
          {%- render 'product-price', product: product -%}

          {%- comment -%} Description (short) {%- endcomment -%}
          {%- if product.description != blank -%}
            <div class="kt-pdp__short-desc">
              {{ product.description | strip_html | truncatewords: 40 }}
            </div>
          {%- endif -%}

          {%- comment -%} Variant Picker {%- endcomment -%}
          {%- render 'product-variant-picker', product: product -%}

          {%- comment -%} Product Form (qty + ATC + payment + actions) {%- endcomment -%}
          {%- render 'product-form', product: product, show_dynamic_checkout: section.settings.show_dynamic_checkout -%}

          {%- comment -%} Trust Badges {%- endcomment -%}
          <div class="kt-pdp__trust-badges">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_badge' -%}
                <div class="kt-pdp__trust-badge" {{ block.shopify_attributes }}>
                  <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    {%- case block.settings.icon -%}
                      {%- when 'shipping' -%}
                        <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
                      {%- when 'returns' -%}
                        <polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
                      {%- when 'warranty' -%}
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      {%- when 'package' -%}
                        <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    {%- endcase -%}
                  </svg>
                  <span class="kt-pdp__trust-badge-text">{{ block.settings.text }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- comment -%} Accordions {%- endcomment -%}
          <div class="kt-pdp__accordions">
            {%- for block in section.blocks -%}
              {%- if block.type == 'accordion' -%}
                {%- capture accordion_content -%}
                  {%- if block.settings.page != blank -%}
                    {{ block.settings.page.content }}
                  {%- else -%}
                    {{ block.settings.content }}
                  {%- endif -%}
                {%- endcapture -%}
                {%- render 'product-accordion', title: block.settings.title, content: accordion_content, open: block.settings.open -%}
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} Default accordions if no blocks {%- endcomment -%}
            {%- if section.blocks.size == 0 -%}
              {%- capture desc_content -%}
                <p>{{ product.description }}</p>
              {%- endcapture -%}
              {%- render 'product-accordion', title: 'Description', content: desc_content, open: true -%}
            {%- endif -%}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script src="{{ 'product-gallery.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'countdown.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-product.settings.header__layout.content"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-product.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "t:sections.main-product.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.main-product.settings.heading_tag.options__2.label" }
      ],
      "default": "h1"
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "t:sections.main-product.settings.show_dynamic_checkout.label",
      "info": "t:sections.main-product.settings.show_dynamic_checkout.info",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "t:sections.main-product.blocks.trust_badge.name",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.main-product.blocks.trust_badge.settings.icon.label",
          "options": [
            { "value": "shipping", "label": "t:sections.main-product.blocks.trust_badge.settings.icon.options__1.label" },
            { "value": "returns", "label": "t:sections.main-product.blocks.trust_badge.settings.icon.options__2.label" },
            { "value": "warranty", "label": "t:sections.main-product.blocks.trust_badge.settings.icon.options__3.label" },
            { "value": "package", "label": "t:sections.main-product.blocks.trust_badge.settings.icon.options__4.label" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.main-product.blocks.trust_badge.settings.text.label",
          "default": "Free Shipping"
        }
      ]
    },
    {
      "type": "accordion",
      "name": "t:sections.main-product.blocks.accordion.name",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.main-product.blocks.accordion.settings.title.label",
          "default": "Description"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.main-product.blocks.accordion.settings.content.label"
        },
        {
          "type": "page",
          "id": "page",
          "label": "t:sections.main-product.blocks.accordion.settings.page.label"
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "t:sections.main-product.blocks.accordion.settings.open.label",
          "default": false
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-product.presets.name",
      "blocks": [
        { "type": "trust_badge", "settings": { "icon": "shipping", "text": "Free Shipping" } },
        { "type": "trust_badge", "settings": { "icon": "returns", "text": "30-Day Returns" } },
        { "type": "trust_badge", "settings": { "icon": "warranty", "text": "Lifetime Warranty" } },
        { "type": "accordion", "settings": { "title": "Description", "open": true } },
        { "type": "accordion", "settings": { "title": "Specifications" } },
        { "type": "accordion", "settings": { "title": "Shipping & Returns" } }
      ]
    }
  ]
}
{% endschema %}
