{{ 'section-shop-color.css' | asset_url | stylesheet_tag }}

<section class="kt-shop-color" data-section-id="{{ section.id }}" data-section-type="shop-color">
  <div class="page-width">
    <div class="kt-shop-color__intro">
      <p class="kt-shop-color__label">{{ section.settings.label | default: 'Material Library' }}</p>
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-shop-color__title">{{ section.settings.heading | default: 'Shop by colors.' }}</{{ heading_tag }}>
    </div>

    <div class="kt-shop-color__layout">
      {%- comment -%} Left: Sticky image canvas (desktop only) {%- endcomment -%}
      <div class="kt-shop-color__image-col">
        <div class="kt-shop-color__image-sticky">
          <div class="kt-shop-color__image-wrap">
            {%- comment -%} All finish images stacked, only active one visible {%- endcomment -%}
            {%- assign placeholder_names = 'collection-1,collection-2,collection-3,collection-4,collection-5,collection-6' | split: ',' -%}
            {%- assign img_counter = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'category' -%}
                {%- for i in (1..3) -%}
                  {%- assign img_id = 'finish_' | append: i | append: '_image' -%}
                  {%- assign name_id = 'finish_' | append: i | append: '_name' -%}
                  {%- assign finish_img = block.settings[img_id] -%}
                  {%- assign finish_name = block.settings[name_id] -%}
                  {%- if finish_name != blank -%}
                    {%- if finish_img != blank -%}
                      {{ finish_img | image_url: width: 1000 | image_tag: class: 'kt-shop-color__image', loading: 'lazy', widths: '375, 550, 750, 1000', sizes: '42vw', width: finish_img.width, height: finish_img.height, alt: finish_name, data-finish-image: block.id | append: '-' | append: i, style: 'opacity:0;' }}
                    {%- else -%}
                      {%- assign ph_index = img_counter | modulo: 6 -%}
                      <div class="kt-shop-color__image kt-shop-color__placeholder" data-finish-image="{{ block.id }}-{{ i }}" style="opacity:0;">
                        {{ placeholder_names[ph_index] | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                    {%- assign img_counter = img_counter | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
            <div class="kt-shop-color__image-gradient"></div>

            <div class="kt-shop-color__image-info">
              <p class="kt-shop-color__image-code" data-finish-code></p>
              <div class="kt-shop-color__image-line"></div>
              <p class="kt-shop-color__image-name" data-finish-label></p>
            </div>

            <div class="kt-shop-color__palette">
              <div class="kt-shop-color__palette-top" data-palette-top></div>
              <div class="kt-shop-color__palette-bottom" data-palette-bottom></div>
            </div>
          </div>

          <p class="kt-shop-color__image-desc">
            {{ section.settings.description | default: 'Explore our curated material palettes. Select a category to see its characteristic finishes and textures.' }}
          </p>
        </div>
      </div>

      {%- comment -%} Right: Category accordion {%- endcomment -%}
      <div class="kt-shop-color__categories-col">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            <div
              class="kt-shop-color__category{% if forloop.first %} kt-shop-color__category--active{% endif %}"
              data-category-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="kt-shop-color__category-header">
                <h3 class="kt-shop-color__category-title">{{ block.settings.title }}</h3>
                <div class="kt-shop-color__category-swatch">
                  <div class="kt-shop-color__category-swatch-half" style="background-color: {{ block.settings.finish_1_color1 | default: '#F5F0EB' }};"></div>
                  <div class="kt-shop-color__category-swatch-half" style="background-color: {{ block.settings.finish_1_color2 | default: '#E8E6DF' }};"></div>
                </div>
              </div>

              <div class="kt-shop-color__category-content">
                {%- comment -%} Mobile inline image {%- endcomment -%}
                <div class="kt-shop-color__mobile-image">
                  {%- if block.settings.finish_1_image != blank -%}
                    {{ block.settings.finish_1_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '375, 550, 800', sizes: '100vw', width: block.settings.finish_1_image.width, height: block.settings.finish_1_image.height, alt: block.settings.finish_1_name }}
                  {%- else -%}
                    {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                  <div class="kt-shop-color__mobile-image-overlay"></div>
                  <div class="kt-shop-color__mobile-image-info">
                    <p class="kt-shop-color__mobile-image-code">{{ block.settings.finish_1_code }}</p>
                    <p class="kt-shop-color__mobile-image-name">{{ block.settings.finish_1_name }}</p>
                  </div>
                  <div class="kt-shop-color__mobile-swatch">
                    <div class="kt-shop-color__palette-top" style="background-color: {{ block.settings.finish_1_color1 | default: '#F5F0EB' }};"></div>
                    <div class="kt-shop-color__palette-bottom" style="background-color: {{ block.settings.finish_1_color2 | default: '#E8E6DF' }};"></div>
                  </div>
                </div>

                {%- comment -%} Finish buttons — each has its own image/colors {%- endcomment -%}
                <div class="kt-shop-color__finishes">
                  {%- if block.settings.finish_1_name != blank -%}
                    <button
                      type="button"
                      class="kt-shop-color__finish-btn kt-shop-color__finish-btn--active"
                      data-finish-select
                      data-finish-image-id="{{ block.id }}-1"
                      data-finish-code="{{ block.settings.finish_1_code }}"
                      data-finish-name="{{ block.settings.finish_1_name }}"
                      data-finish-cat="{{ block.settings.title }}"
                      data-finish-color1="{{ block.settings.finish_1_color1 | default: '#F5F0EB' }}"
                      data-finish-color2="{{ block.settings.finish_1_color2 | default: '#E8E6DF' }}"
                    >
                      {{ block.settings.finish_1_name }}
                    </button>
                  {%- endif -%}
                  {%- if block.settings.finish_2_name != blank -%}
                    <button
                      type="button"
                      class="kt-shop-color__finish-btn"
                      data-finish-select
                      data-finish-image-id="{{ block.id }}-2"
                      data-finish-code="{{ block.settings.finish_2_code }}"
                      data-finish-name="{{ block.settings.finish_2_name }}"
                      data-finish-cat="{{ block.settings.title }}"
                      data-finish-color1="{{ block.settings.finish_2_color1 | default: '#F5F0EB' }}"
                      data-finish-color2="{{ block.settings.finish_2_color2 | default: '#E8E6DF' }}"
                    >
                      {{ block.settings.finish_2_name }}
                    </button>
                  {%- endif -%}
                  {%- if block.settings.finish_3_name != blank -%}
                    <button
                      type="button"
                      class="kt-shop-color__finish-btn"
                      data-finish-select
                      data-finish-image-id="{{ block.id }}-3"
                      data-finish-code="{{ block.settings.finish_3_code }}"
                      data-finish-name="{{ block.settings.finish_3_name }}"
                      data-finish-cat="{{ block.settings.title }}"
                      data-finish-color1="{{ block.settings.finish_3_color1 | default: '#F5F0EB' }}"
                      data-finish-color2="{{ block.settings.finish_3_color2 | default: '#E8E6DF' }}"
                    >
                      {{ block.settings.finish_3_name }}
                    </button>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.cta_text != blank -%}
          <div class="kt-shop-color__cta">
            <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="kt-shop-color__cta-btn">
              {{ section.settings.cta_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'section-shop-color.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Collection tabs",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Material Library" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by colors." },
    { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"},{"value":"h4","label":"H4"},{"value":"h5","label":"H5"},{"value":"h6","label":"H6"}], "default": "h2" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Explore our curated material palettes. Select a category to see its characteristic finishes and textures." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Request Free Samples" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Color category",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "Category title", "default": "Luminous Light" },
        { "type": "header", "content": "Finish 1" },
        { "type": "text", "id": "finish_1_name", "label": "Name", "default": "Alabaster Base" },
        { "type": "text", "id": "finish_1_code", "label": "Code", "default": "B-200" },
        { "type": "image_picker", "id": "finish_1_image", "label": "Image" },
        { "type": "color", "id": "finish_1_color1", "label": "Swatch top", "default": "#faf9f6" },
        { "type": "color", "id": "finish_1_color2", "label": "Swatch bottom", "default": "#e8e6df" },
        { "type": "url", "id": "finish_1_link", "label": "Product link" },
        { "type": "header", "content": "Finish 2" },
        { "type": "text", "id": "finish_2_name", "label": "Name", "default": "Arctic White" },
        { "type": "text", "id": "finish_2_code", "label": "Code", "default": "W-100" },
        { "type": "image_picker", "id": "finish_2_image", "label": "Image" },
        { "type": "color", "id": "finish_2_color1", "label": "Swatch top", "default": "#ffffff" },
        { "type": "color", "id": "finish_2_color2", "label": "Swatch bottom", "default": "#f0f0f0" },
        { "type": "url", "id": "finish_2_link", "label": "Product link" },
        { "type": "header", "content": "Finish 3 (optional)" },
        { "type": "text", "id": "finish_3_name", "label": "Name" },
        { "type": "text", "id": "finish_3_code", "label": "Code" },
        { "type": "image_picker", "id": "finish_3_image", "label": "Image" },
        { "type": "color", "id": "finish_3_color1", "label": "Swatch top" },
        { "type": "color", "id": "finish_3_color2", "label": "Swatch bottom" },
        { "type": "url", "id": "finish_3_link", "label": "Product link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection tabs",
      "blocks": [
        { "type": "category", "settings": { "title": "Luminous Light", "finish_1_name": "Alabaster Base", "finish_1_code": "B-200", "finish_1_color1": "#faf9f6", "finish_1_color2": "#e8e6df", "finish_2_name": "Arctic White", "finish_2_code": "W-100", "finish_2_color1": "#ffffff", "finish_2_color2": "#f0f0f0" } },
        { "type": "category", "settings": { "title": "Balanced Medium", "finish_1_name": "Walnut Grain", "finish_1_code": "W-400", "finish_1_color1": "#3e2a1e", "finish_1_color2": "#2a1c14", "finish_2_name": "Natural Oak", "finish_2_code": "O-300", "finish_2_color1": "#d2b48c", "finish_2_color2": "#c19a6b" } },
        { "type": "category", "settings": { "title": "Dramatic Dark", "finish_1_name": "Obsidian Mat", "finish_1_code": "MAT-900", "finish_1_color1": "#1a1a1a", "finish_1_color2": "#2d2d2d", "finish_2_name": "Midnight Navy", "finish_2_code": "N-800", "finish_2_color1": "#1e2b3c", "finish_2_color2": "#0f172a" } }
      ]
    }
  ]
}
{% endschema %}
