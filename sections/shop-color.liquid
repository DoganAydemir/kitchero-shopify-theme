{{ 'section-shop-color.css' | asset_url | stylesheet_tag }}

<section class="kt-shop-color" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="kt-shop-color__layout">
      {%- comment -%} Image Column {%- endcomment -%}
      <div class="kt-shop-color__image-col">
        <div class="kt-shop-color__image-wrap">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1200
              | image_tag:
                class: 'kt-shop-color__image',
                loading: 'lazy',
                widths: '375, 550, 750, 1100',
                sizes: '(min-width: 990px) 58vw, 100vw',
                width: section.settings.image.width,
                height: section.settings.image.height,
                alt: section.settings.heading | default: shop.name
            }}
          {%- else -%}
            {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg kt-shop-color__image' }}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Content Column {%- endcomment -%}
      <div class="kt-shop-color__content-col">
        <h2 class="kt-shop-color__title">{{ section.settings.heading | default: 'Shop by Color' }}</h2>
        <p class="kt-shop-color__subtitle">{{ section.settings.subtitle | default: 'Find your perfect finish' }}</p>

        <div class="kt-shop-color__finishes">
          {%- for block in section.blocks -%}
            {%- if block.type == 'finish' -%}
              <a
                href="{{ block.settings.link | default: routes.collections_url }}"
                class="kt-shop-color__finish"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.swatch_color != blank -%}
                  <span class="kt-shop-color__swatch" style="background-color: {{ block.settings.swatch_color }};"></span>
                {%- endif -%}
                <div>
                  <p class="kt-shop-color__finish-name">{{ block.settings.title }}</p>
                  {%- if block.settings.code != blank -%}
                    <p class="kt-shop-color__finish-code">{{ block.settings.code }}</p>
                  {%- endif -%}
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.cta_text != blank -%}
          <div class="kt-shop-color__cta">
            <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="button">
              {{ section.settings.cta_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by color",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Color" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Find your perfect finish" },
    { "type": "image_picker", "id": "image", "label": "Featured image" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Request Free Samples" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "finish",
      "name": "Finish",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "title", "label": "Name", "default": "Ivory Mist" },
        { "type": "text", "id": "code", "label": "Code", "default": "LT-001" },
        { "type": "color", "id": "swatch_color", "label": "Swatch color", "default": "#F5F0EB" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by color",
      "blocks": [
        { "type": "finish", "settings": { "title": "Ivory Mist", "code": "LT-001", "swatch_color": "#F5F0EB" } },
        { "type": "finish", "settings": { "title": "Warm Almond", "code": "LT-002", "swatch_color": "#D4C4A8" } },
        { "type": "finish", "settings": { "title": "Classic Walnut", "code": "MD-001", "swatch_color": "#6B4E37" } },
        { "type": "finish", "settings": { "title": "Midnight Charcoal", "code": "DK-001", "swatch_color": "#2C2C2C" } }
      ]
    }
  ]
}
{% endschema %}
