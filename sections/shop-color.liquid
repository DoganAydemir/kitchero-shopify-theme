{{ 'kt-section-shop-color.css' | asset_url | stylesheet_tag }}

{%- assign shop_color_label_default = 'kt.section.shop_color.label_default' | t -%}
{%- assign shop_color_heading_default = 'kt.section.shop_color.heading_default' | t -%}
{%- assign shop_color_description_default = 'kt.section.shop_color.description_default' | t -%}

<section class="kt-shop-color{% if section.settings.bg_color and section.settings.bg_color != 'auto' %} kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}" data-section-id="{{ section.id }}" data-section-type="shop-color">
  <div class="page-width">
    <div class="kt-shop-color__intro">
      <p class="kt-shop-color__label">{{ section.settings.label | default: shop_color_label_default }}</p>
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-shop-color__title">{{ section.settings.heading | default: shop_color_heading_default }}</{{ heading_tag }}>
    </div>

    <div class="kt-shop-color__layout">
      {%- comment -%} Left: Sticky image canvas (desktop only) {%- endcomment -%}
      <div class="kt-shop-color__image-col">
        <div class="kt-shop-color__image-sticky">
          <div class="kt-shop-color__image-wrap">
            {%- comment -%} All finish images stacked, only active one visible {%- endcomment -%}
            {%- assign placeholder_names = 'collection-1,collection-2,collection-3,collection-4,collection-5,collection-6' | split: ',' -%}
            {%- assign img_counter = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'category' -%}
                {%- for i in (1..3) -%}
                  {%- assign img_id = 'finish_' | append: i | append: '_image' -%}
                  {%- assign name_id = 'finish_' | append: i | append: '_name' -%}
                  {%- assign finish_img = block.settings[img_id] -%}
                  {%- assign finish_name = block.settings[name_id] -%}
                  {%- if finish_name != blank -%}
                    {%- assign finish_data_id = block.id | append: '-' | append: i -%}
                    {%- if finish_img != blank -%}
                      {{ finish_img | image_url: width: 1000 | image_tag: class: 'kt-shop-color__image', loading: 'lazy', widths: '375, 550, 750, 1000', sizes: '42vw', width: finish_img.width, height: finish_img.height, alt: finish_name, data-finish-image: finish_data_id, style: 'opacity:0;' }}
                    {%- else -%}
                      {%- assign ph_index = img_counter | modulo: 6 -%}
                      <div class="kt-shop-color__image kt-shop-color__placeholder" data-finish-image="{{ finish_data_id }}" style="opacity:0;">
                        {{ placeholder_names[ph_index] | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                    {%- assign img_counter = img_counter | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
            <div class="kt-shop-color__image-gradient"></div>

            <div class="kt-shop-color__image-info">
              <p class="kt-shop-color__image-code" data-finish-code></p>
              <div class="kt-shop-color__image-line"></div>
              <p class="kt-shop-color__image-name" data-finish-label></p>
            </div>

            <div class="kt-shop-color__palette">
              <div class="kt-shop-color__palette-top" data-palette-top></div>
              <div class="kt-shop-color__palette-bottom" data-palette-bottom></div>
            </div>
          </div>

          <p class="kt-shop-color__image-desc">
            {{ section.settings.description | default: shop_color_description_default }}
          </p>
        </div>
      </div>

      {%- comment -%} Right: Category accordion {%- endcomment -%}
      <div class="kt-shop-color__categories-col">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            <div
              class="kt-shop-color__category{% if forloop.first %} kt-shop-color__category--active{% endif %}"
              data-category-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="kt-shop-color__category-header">
                <h3 class="kt-shop-color__category-title">{{ block.settings.title }}</h3>
                <div class="kt-shop-color__category-swatch">
                  <div class="kt-shop-color__category-swatch-half" style="background-color: {{ block.settings.finish_1_color1 | default: '#F5F0EB' }};"></div>
                  <div class="kt-shop-color__category-swatch-half" style="background-color: {{ block.settings.finish_1_color2 | default: '#E8E6DF' }};"></div>
                </div>
              </div>

              <div class="kt-shop-color__category-content">
                <div class="kt-shop-color__category-content-inner">
                {%- comment -%} Mobile inline images — one per finish, JS toggles visibility {%- endcomment -%}
                {%- assign mobile_placeholders = 'collection-1,collection-2,collection-3,collection-4,collection-5,collection-6' | split: ',' -%}
                <div class="kt-shop-color__mobile-image">
                  {%- for i in (1..3) -%}
                    {%- assign m_img_id = 'finish_' | append: i | append: '_image' -%}
                    {%- assign m_name_id = 'finish_' | append: i | append: '_name' -%}
                    {%- assign m_img = block.settings[m_img_id] -%}
                    {%- assign m_name = block.settings[m_name_id] -%}
                    {%- if m_name != blank -%}
                      <div class="kt-shop-color__mobile-image-slide{% if i == 1 %} kt-shop-color__mobile-image-slide--active{% endif %}" data-mobile-finish-image="{{ block.id }}-{{ i }}">
                        {%- if m_img != blank -%}
                          {{ m_img | image_url: width: 800 | image_tag: loading: 'lazy', widths: '375, 550, 800', sizes: '100vw', width: m_img.width, height: m_img.height, alt: m_name }}
                        {%- else -%}
                          {%- assign m_ph_index = forloop.index0 | plus: forloop.parentloop.index0 | times: 2 | modulo: 6 -%}
                          {{ mobile_placeholders[m_ph_index] | placeholder_svg_tag: 'placeholder-svg' }}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                  <div class="kt-shop-color__mobile-image-overlay"></div>
                  <div class="kt-shop-color__mobile-image-info">
                    <p class="kt-shop-color__mobile-image-code">{{ block.settings.finish_1_code }}</p>
                    <p class="kt-shop-color__mobile-image-name">{{ block.settings.finish_1_name }}</p>
                  </div>
                  <div class="kt-shop-color__mobile-swatch">
                    <div class="kt-shop-color__palette-top" style="background-color: {{ block.settings.finish_1_color1 | default: '#F5F0EB' }};"></div>
                    <div class="kt-shop-color__palette-bottom" style="background-color: {{ block.settings.finish_1_color2 | default: '#E8E6DF' }};"></div>
                  </div>
                </div>

                {%- comment -%} Finish buttons — each has its own image/colors {%- endcomment -%}
                <div class="kt-shop-color__finishes">
                  {%- if block.settings.finish_1_name != blank -%}
                    <button
                      type="button"
                      class="kt-shop-color__finish-btn kt-shop-color__finish-btn--active"
                      data-finish-select
                      data-finish-image-id="{{ block.id }}-1"
                      data-finish-code="{{ block.settings.finish_1_code | escape }}"
                      data-finish-name="{{ block.settings.finish_1_name | escape }}"
                      data-finish-cat="{{ block.settings.title | escape }}"
                      data-finish-color1="{{ block.settings.finish_1_color1 | default: '#F5F0EB' }}"
                      data-finish-color2="{{ block.settings.finish_1_color2 | default: '#E8E6DF' }}"
                    >
                      {{ block.settings.finish_1_name }}
                    </button>
                  {%- endif -%}
                  {%- if block.settings.finish_2_name != blank -%}
                    <button
                      type="button"
                      class="kt-shop-color__finish-btn"
                      data-finish-select
                      data-finish-image-id="{{ block.id }}-2"
                      data-finish-code="{{ block.settings.finish_2_code | escape }}"
                      data-finish-name="{{ block.settings.finish_2_name | escape }}"
                      data-finish-cat="{{ block.settings.title | escape }}"
                      data-finish-color1="{{ block.settings.finish_2_color1 | default: '#F5F0EB' }}"
                      data-finish-color2="{{ block.settings.finish_2_color2 | default: '#E8E6DF' }}"
                    >
                      {{ block.settings.finish_2_name }}
                    </button>
                  {%- endif -%}
                  {%- if block.settings.finish_3_name != blank -%}
                    <button
                      type="button"
                      class="kt-shop-color__finish-btn"
                      data-finish-select
                      data-finish-image-id="{{ block.id }}-3"
                      data-finish-code="{{ block.settings.finish_3_code | escape }}"
                      data-finish-name="{{ block.settings.finish_3_name | escape }}"
                      data-finish-cat="{{ block.settings.title | escape }}"
                      data-finish-color1="{{ block.settings.finish_3_color1 | default: '#F5F0EB' }}"
                      data-finish-color2="{{ block.settings.finish_3_color2 | default: '#E8E6DF' }}"
                    >
                      {{ block.settings.finish_3_name }}
                    </button>
                  {%- endif -%}
                </div>
                </div>{%- comment -%} .kt-shop-color__category-content-inner {%- endcomment -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.cta_text != blank -%}
          <div class="kt-shop-color__cta">
            <a href="{{ section.settings.cta_link | default: routes.root_url | escape }}" class="kt-shop-color__cta-btn">
              {{ section.settings.cta_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-shop-color.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.shop-color.name",
  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ],
    "templates": [
      "cart",
      "search",
      "password",
      "gift_card",
      "404"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.shop-color.settings.label.label",
      "default": "Label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.shop-color.settings.heading.label",
      "default": "Shop by color"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.shop-color.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.shop-color.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.shop-color.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.shop-color.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.shop-color.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.shop-color.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.shop-color.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.shop-color.settings.description.label",
      "default": "Add a description for this section."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.shop-color.settings.cta_text.label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.shop-color.settings.cta_link.label"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        { "value": "auto", "label": "t:sections.shared.bg_color.options__auto.label" },
        { "value": "white", "label": "t:sections.shared.bg_color.options__white.label" },
        { "value": "stone_50", "label": "t:sections.shared.bg_color.options__stone_50.label" }
      ],
      "default": "auto"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.shop-color.blocks.category.name",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.shop-color.blocks.category.settings.title.label",
          "default": "Category title"
        },
        {
          "type": "header",
          "content": "t:sections.shop-color.blocks.category.settings.header__finish_1.content"
        },
        {
          "type": "text",
          "id": "finish_1_name",
          "label": "t:sections.shop-color.blocks.category.settings.finish_1_name.label",
          "default": "Finish name"
        },
        {
          "type": "text",
          "id": "finish_1_code",
          "label": "t:sections.shop-color.blocks.category.settings.finish_1_code.label",
          "default": "B-200"
        },
        {
          "type": "image_picker",
          "id": "finish_1_image",
          "label": "t:sections.shop-color.blocks.category.settings.finish_1_image.label"
        },
        {
          "type": "color",
          "id": "finish_1_color1",
          "label": "t:sections.shop-color.blocks.category.settings.finish_1_color1.label",
          "default": "#faf9f6"
        },
        {
          "type": "color",
          "id": "finish_1_color2",
          "label": "t:sections.shop-color.blocks.category.settings.finish_1_color2.label",
          "default": "#e8e6df"
        },
        {
          "type": "url",
          "id": "finish_1_link",
          "label": "t:sections.shop-color.blocks.category.settings.finish_1_link.label"
        },
        {
          "type": "header",
          "content": "t:sections.shop-color.blocks.category.settings.header__finish_2.content"
        },
        {
          "type": "text",
          "id": "finish_2_name",
          "label": "t:sections.shop-color.blocks.category.settings.finish_2_name.label",
          "default": "Finish name"
        },
        {
          "type": "text",
          "id": "finish_2_code",
          "label": "t:sections.shop-color.blocks.category.settings.finish_2_code.label",
          "default": "W-100"
        },
        {
          "type": "image_picker",
          "id": "finish_2_image",
          "label": "t:sections.shop-color.blocks.category.settings.finish_2_image.label"
        },
        {
          "type": "color",
          "id": "finish_2_color1",
          "label": "t:sections.shop-color.blocks.category.settings.finish_2_color1.label",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "finish_2_color2",
          "label": "t:sections.shop-color.blocks.category.settings.finish_2_color2.label",
          "default": "#f0f0f0"
        },
        {
          "type": "url",
          "id": "finish_2_link",
          "label": "t:sections.shop-color.blocks.category.settings.finish_2_link.label"
        },
        {
          "type": "header",
          "content": "t:sections.shop-color.blocks.category.settings.header__finish_3.content"
        },
        {
          "type": "text",
          "id": "finish_3_name",
          "label": "t:sections.shop-color.blocks.category.settings.finish_3_name.label",
          "default": "Finish 3 name"
        },
        {
          "type": "text",
          "id": "finish_3_code",
          "label": "t:sections.shop-color.blocks.category.settings.finish_3_code.label",
          "default": "Finish 3 code"
        },
        {
          "type": "image_picker",
          "id": "finish_3_image",
          "label": "t:sections.shop-color.blocks.category.settings.finish_3_image.label"
        },
        {
          "type": "color",
          "id": "finish_3_color1",
          "label": "t:sections.shop-color.blocks.category.settings.finish_3_color1.label"
        },
        {
          "type": "color",
          "id": "finish_3_color2",
          "label": "t:sections.shop-color.blocks.category.settings.finish_3_color2.label"
        },
        {
          "type": "url",
          "id": "finish_3_link",
          "label": "t:sections.shop-color.blocks.category.settings.finish_3_link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.shop-color.presets.name",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Light",
            "finish_1_name": "Finish name",
            "finish_1_code": "B-200",
            "finish_1_color1": "#faf9f6",
            "finish_1_color2": "#e8e6df",
            "finish_2_name": "Finish name",
            "finish_2_code": "W-100",
            "finish_2_color1": "#ffffff",
            "finish_2_color2": "#f0f0f0"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Medium",
            "finish_1_name": "Finish name",
            "finish_1_code": "W-400",
            "finish_1_color1": "#3e2a1e",
            "finish_1_color2": "#2a1c14",
            "finish_2_name": "Finish name",
            "finish_2_code": "O-300",
            "finish_2_color1": "#d2b48c",
            "finish_2_color2": "#c19a6b"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Dark",
            "finish_1_name": "Finish name",
            "finish_1_code": "MAT-900",
            "finish_1_color1": "#1a1a1a",
            "finish_1_color2": "#2d2d2d",
            "finish_2_name": "Finish name",
            "finish_2_code": "N-800",
            "finish_2_color1": "#1e2b3c",
            "finish_2_color2": "#0f172a"
          }
        }
      ]
    }
  ]
}
{% endschema %}
