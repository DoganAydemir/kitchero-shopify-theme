{{ 'kt-section-deals-grid.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Deals Grid — birebir from Next.js /deals page. Dotted header +
  premium package cards (tier badge, popular flag, price + includes
  overlay, strikethrough original, "Free Design" accent, fill-on-
  hover CTA) + bottom "Need a custom quote?" dual-CTA strip.

  Cards link to collections, NOT product detail (per the project
  roadmap — deal cards surface a curated collection, not a single SKU).
{%- endcomment -%}

{%- assign deals_cta_default = 'kt.section.deals_grid.cta_default' | t -%}
<section class="kt-deals {% if section.settings.bg_color and section.settings.bg_color != 'auto' %}kt-section-bg--{{ section.settings.bg_color | replace: '_', '-' }}{% endif %}" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="kt-deals__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'deal' -%}
          {%- assign includes_list = block.settings.includes | newline_to_br | split: '<br />' -%}
          {%- assign tier_text = block.settings.tier -%}
          {%- assign card_link = block.settings.link | default: routes.collections_url -%}
          {%- assign badge_bg = block.settings.badge_color | default: '#10b981' -%}

          <a href="{{ card_link | escape }}" class="kt-deals__card" {{ block.shopify_attributes }}>

            {%- comment -%} Image + overlays {%- endcomment -%}
            <div class="kt-deals__card-media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1600
                  | image_tag:
                    class: 'kt-deals__card-image',
                    loading: 'lazy',
                    widths: '550, 750, 1100, 1500',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    width: block.settings.image.width,
                    height: block.settings.image.height,
                    alt: tier_text
                }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg kt-deals__card-image' }}
              {%- endif -%}

              <div class="kt-deals__card-gradient" aria-hidden="true"></div>

              {%- comment -%}
                Tier badge (top-left). Background colour is rendered as
                an inline style fed from the merchant's color-picker
                setting so any hex is supported — previously the badge
                colour was a 4-option select (emerald/dark/amber/red)
                that fed into CSS `[data-color-theme]` attribute rules,
                which capped merchants at four brand tones. The badge
                text itself is now the verbatim `tier` field (no
                hardcoded "Package" suffix) so a merchant who wants
                "Premium", "Tier 1 Package", or just "Pro" gets exactly
                that — and no surprise word appended on render.
              {%- endcomment -%}
              {%- if tier_text != blank -%}
                <span
                  class="kt-deals__card-tier"
                  style="background-color: {{ badge_bg }};"
                >
                  {{- tier_text -}}
                </span>
              {%- endif -%}

              {%- comment -%} Popular badge (top-right) {%- endcomment -%}
              {%- if block.settings.is_popular -%}
                <span class="kt-deals__card-popular">
                  <svg aria-hidden="true" focusable="false" width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                  {{ 'kt.section.deals.most_popular' | t | default: 'Most Popular' }}
                </span>
              {%- endif -%}

              {%- comment -%} Price + includes overlay (bottom-left) {%- endcomment -%}
              <div class="kt-deals__card-overlay">
                {%- comment -%}
                  Price row — when both the current and original price
                  are set, render them on the same baseline (big current
                  + small struck-through original) so the discount reads
                  inline rather than floating in the card body. Earlier
                  the original price sat alone on a separate line under
                  the body padding, far from the price it was supposed
                  to qualify. The new <s> sits inline next to the big
                  figure, scaled down per the .kt-deals__card-price-
                  original CSS rule.
                {%- endcomment -%}
                {%- if block.settings.price != blank -%}
                  <p class="kt-deals__card-price-row">
                    <span class="kt-deals__card-price-big">{{ block.settings.price | escape }}</span>
                    {%- if block.settings.original_price != blank -%}
                      <s class="kt-deals__card-price-original">{{ block.settings.original_price | escape }}</s>
                    {%- endif -%}
                  </p>
                {%- endif -%}

                {%- if block.settings.includes != blank -%}
                  <ul class="kt-deals__card-includes" role="list">
                    {%- for line in includes_list limit: 3 -%}
                      {%- assign clean = line | strip_html | strip -%}
                      {%- if clean != blank -%}
                        <li>
                          <span class="kt-deals__card-include-bullet" aria-hidden="true">+</span>
                          {{ clean }}
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            </div>

            {%- comment -%}
              Info block (below image). The card body now starts with
              accent text → description → CTA — every price detail
              (current + struck-through original) is already on the
              image overlay above, so there is nothing price-related
              to repeat here.
            {%- endcomment -%}
            <div class="kt-deals__card-body">
              {%- if block.settings.accent_text != blank -%}
                <div class="kt-deals__card-accent">
                  <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2l1.88 5.62L19.5 9.5l-5.62 1.88L12 17l-1.88-5.62L4.5 9.5l5.62-1.88z"/>
                  </svg>
                  <span>{{ block.settings.accent_text }}</span>
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="kt-deals__card-desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}

              <div class="kt-deals__card-cta-wrap">
                <span class="kt-deals__card-cta">
                  {{ block.settings.cta_text | default: deals_cta_default }}
                  {% render 'icon-arrow-right', width: 14, height: 14 %}
                </span>
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} Bottom CTA section {%- endcomment -%}
{%- if section.settings.show_bottom_cta -%}
  <section class="kt-deals-cta">
    <div class="page-width">
      <div class="kt-deals-cta__inner">
        {%- if section.settings.bottom_heading != blank -%}
          <h2 class="kt-deals-cta__title">{{ section.settings.bottom_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.bottom_description != blank -%}
          <p class="kt-deals-cta__desc">{{ section.settings.bottom_description }}</p>
        {%- endif -%}
        <div class="kt-deals-cta__buttons">
          {%- if section.settings.bottom_cta_primary_text != blank -%}
            <a href="{{ section.settings.bottom_cta_primary_link | default: routes.root_url | escape }}" class="kt-deals-cta__btn kt-deals-cta__btn--primary">
              {{ section.settings.bottom_cta_primary_text }}
              {% render 'icon-arrow-right', width: 14, height: 14 %}
            </a>
          {%- endif -%}
          {%- if section.settings.bottom_cta_secondary_text != blank -%}
            <a href="{{ section.settings.bottom_cta_secondary_link | default: routes.root_url | escape }}" class="kt-deals-cta__btn kt-deals-cta__btn--secondary">
              {{ section.settings.bottom_cta_secondary_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{%- comment -%}
  Render any @app blocks the merchant has dragged into this section.
  Schema declares "@app"; without this render path, app blocks are
  silently dropped — their UI never paints on the storefront even
  though the editor accepts them.
{%- endcomment -%}
{% render 'section-app-blocks' %}

{% schema %}
{
  "name": "t:sections.deals-grid.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.deals-grid.settings.header__bottom.content"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_cta",
      "label": "t:sections.deals-grid.settings.show_bottom_cta.label",
      "default": true
    },
    {
      "type": "text",
      "id": "bottom_heading",
      "label": "t:sections.deals-grid.settings.bottom_heading.label",
      "default": "Need a Custom Quote?",
      "visible_if": "{{ section.settings.show_bottom_cta }}"
    },
    {
      "type": "textarea",
      "id": "bottom_description",
      "label": "t:sections.deals-grid.settings.bottom_description.label",
      "visible_if": "{{ section.settings.show_bottom_cta }}",
      "default": "Add a description for this section."
    },
    {
      "type": "text",
      "id": "bottom_cta_primary_text",
      "label": "t:sections.deals-grid.settings.bottom_cta_primary_text.label",
      "default": "Get Custom Quote",
      "visible_if": "{{ section.settings.show_bottom_cta }}"
    },
    {
      "type": "url",
      "id": "bottom_cta_primary_link",
      "label": "t:sections.deals-grid.settings.bottom_cta_primary_link.label",
      "visible_if": "{{ section.settings.show_bottom_cta }}"
    },
    {
      "type": "text",
      "id": "bottom_cta_secondary_text",
      "label": "t:sections.deals-grid.settings.bottom_cta_secondary_text.label",
      "default": "Explore Financing",
      "visible_if": "{{ section.settings.show_bottom_cta }}"
    },
    {
      "type": "url",
      "id": "bottom_cta_secondary_link",
      "label": "t:sections.deals-grid.settings.bottom_cta_secondary_link.label",
      "visible_if": "{{ section.settings.show_bottom_cta }}"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "t:sections.shared.bg_color.label",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.shared.bg_color.options__auto.label"
        },
        {
          "value": "white",
          "label": "t:sections.shared.bg_color.options__white.label"
        },
        {
          "value": "stone_50",
          "label": "t:sections.shared.bg_color.options__stone_50.label"
        },
        { "value": "stone_100", "label": "t:sections.shared.bg_color.options__stone_100.label" }
      ],
      "default": "auto"
    }
  ],
  "blocks": [
    {
      "type": "deal",
      "name": "t:sections.deals-grid.blocks.deal.name",
      "limit": 8,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.deals-grid.blocks.deal.settings.header__badges.content"
        },
        {
          "type": "text",
          "id": "tier",
          "label": "t:sections.deals-grid.blocks.deal.settings.tier.label",
          "info": "t:sections.deals-grid.blocks.deal.settings.tier.info",
          "default": "Tier 1"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "t:sections.deals-grid.blocks.deal.settings.badge_color.label",
          "default": "#10b981"
        },
        {
          "type": "checkbox",
          "id": "is_popular",
          "label": "t:sections.deals-grid.blocks.deal.settings.is_popular.label",
          "info": "t:sections.deals-grid.blocks.deal.settings.is_popular.info",
          "default": false
        },
        {
          "type": "header",
          "content": "t:sections.deals-grid.blocks.deal.settings.header__price.content"
        },
        {
          "type": "text",
          "id": "price",
          "label": "t:sections.deals-grid.blocks.deal.settings.price.label",
          "info": "t:sections.deals-grid.blocks.deal.settings.price.info",
          "default": "Price"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "t:sections.deals-grid.blocks.deal.settings.original_price.label",
          "info": "t:sections.deals-grid.blocks.deal.settings.original_price.info",
          "default": "Original price"
        },
        {
          "type": "header",
          "content": "t:sections.deals-grid.blocks.deal.settings.header__content.content"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.deals-grid.blocks.deal.settings.description.label",
          "default": "Add a description for this section."
        },
        {
          "type": "textarea",
          "id": "includes",
          "label": "t:sections.deals-grid.blocks.deal.settings.includes.label",
          "info": "t:sections.deals-grid.blocks.deal.settings.includes.info",
          "default": "Feature one\nFeature two\nFeature three"
        },
        {
          "type": "text",
          "id": "accent_text",
          "label": "t:sections.deals-grid.blocks.deal.settings.accent_text.label",
          "default": "Accent text"
        },
        {
          "type": "header",
          "content": "t:sections.deals-grid.blocks.deal.settings.header__media.content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.deals-grid.blocks.deal.settings.image.label"
        },
        {
          "type": "header",
          "content": "t:sections.deals-grid.blocks.deal.settings.header__cta.content"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "t:sections.deals-grid.blocks.deal.settings.cta_text.label",
          "default": "See Details"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.deals-grid.blocks.deal.settings.link.label"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.deals-grid.presets.name",
      "blocks": [
        {
          "type": "deal",
          "settings": {
            "tier": "Tier 1",
            "badge_color": "#10b981",
            "is_popular": true,
            "includes": "Feature one\nFeature two\nFeature three",
            "accent_text": "Accent text"
          }
        },
        {
          "type": "deal",
          "settings": {
            "tier": "Tier 2",
            "badge_color": "#1c1917",
            "is_popular": false,
            "includes": "Feature one\nFeature two\nFeature three",
            "accent_text": "Accent text"
          }
        }
      ]
    }
  ]
}
{% endschema %}
