{%- comment -%}
  Financing Calculator — interactive "pay monthly" calculator ported from
  the Next.js financing page. A large centered card on a stone-50 bg.
  Contains: loan-amount input with a huge serif $ prefix, a 3-column grid
  of term buttons (each showing the computed monthly payment, APR, and
  the "MONTHS" label), a primary CTA, and a trust line. All math runs
  client-side in plain JS. Term blocks are merchant-editable.
{%- endcomment -%}

{{ 'kt-section-financing-calculator.css' | asset_url | stylesheet_tag }}

{%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}

<section
  class="kt-financing-calculator"
  data-section-id="{{ section.id }}"
  data-section-type="financing-calculator"
  data-default-amount="{{ section.settings.default_amount | default: 8000 }}"
>
  <div class="page-width">
    <div class="kt-financing-calculator__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kt-financing-calculator__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <{{ heading_tag }} class="kt-financing-calculator__title">
        {{- section.settings.heading -}}
      </{{ heading_tag }}>

      {%- if section.settings.description != blank -%}
        <p class="kt-financing-calculator__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="kt-financing-calculator__card">
        <div class="kt-financing-calculator__card-body">
          <div class="kt-financing-calculator__amount-wrap">
            <label
              class="kt-financing-calculator__amount-label"
              for="FinancingCalcAmount-{{ section.id }}"
            >
              {{ section.settings.amount_label | default: 'Estimated Loan Amount' }}
            </label>
            <div class="kt-financing-calculator__amount-field">
              {%- comment -%}
                Currency symbol pulled from the shop's active currency via
                `cart.currency.symbol` so EU / TR / other-market merchants
                don't see a hardcoded USD "$". `cart` is always available
                in Liquid (even when empty), so this is safe anywhere the
                section renders. aria-hidden because the symbol is already
                implied in the input's inputmode/numeric context and the
                amount label describes the field for AT.
              {%- endcomment -%}
              <span class="kt-financing-calculator__amount-prefix" aria-hidden="true">{{ cart.currency.symbol }}</span>
              <input
                type="number"
                id="FinancingCalcAmount-{{ section.id }}"
                class="kt-financing-calculator__amount-input"
                data-calc-amount
                value="{{ section.settings.default_amount | default: 8000 }}"
                min="{{ section.settings.min_amount | default: 500 }}"
                max="{{ section.settings.max_amount | default: 200000 }}"
                step="100"
                inputmode="numeric"
                aria-label="{{ section.settings.amount_label | default: 'Estimated Loan Amount' | escape }}"
              >
            </div>
          </div>

          {%- if section.blocks.size > 0 -%}
            <div
              class="kt-financing-calculator__terms"
              role="radiogroup"
              aria-label="{{ 'kt.section.financing-calculator.terms_label' | t }}"
            >
              {%- for block in section.blocks -%}
                {%- if block.type == 'term' -%}
                  {%- assign is_default = false -%}
                  {%- if forloop.first -%}
                    {%- assign is_default = true -%}
                  {%- endif -%}
                  <button
                    type="button"
                    class="kt-financing-calculator__term{% if is_default %} kt-financing-calculator__term--active{% endif %}"
                    data-calc-term
                    data-months="{{ block.settings.months }}"
                    data-apr="{{ block.settings.apr }}"
                    data-accent="{{ block.settings.accent_color | default: 'neutral' }}"
                    aria-pressed="{% if is_default %}true{% else %}false{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    <span class="kt-financing-calculator__term-months">
                      {{- block.settings.months }} {{ section.settings.months_label | default: 'Months' -}}
                    </span>
                    <span class="kt-financing-calculator__term-price">
                      {%- comment -%}
                        R108 — `<output>` is the HTML5 element for
                        "the result of a calculation"
                        (html.spec.whatwg.org/multipage/form-elements.html#the-output-element).
                        Each term button shows the JS-computed
                        monthly payment for that term. SR users on
                        modern AT (NVDA, JAWS, VoiceOver) hear
                        "output" rather than the generic "text" they
                        would for a `<span>`. We don't add aria-live
                        because the customer types in the amount
                        input rapidly; announcing every keystroke
                        would be noise — the user navigates to each
                        term to read it.
                      {%- endcomment -%}
                      <output class="kt-financing-calculator__term-amount" data-calc-price for="FinancingCalcAmount-{{ section.id }}">0</output>
                      <span class="kt-financing-calculator__term-per">{{ 'kt.product.price.per_month_short' | t }}</span>
                    </span>
                    <span
                      class="kt-financing-calculator__term-apr kt-financing-calculator__term-apr--{{ block.settings.accent_color | default: 'neutral' }}"
                    >
                      {%- comment -%}
                        When the merchant fills `apr_label`, display it verbatim
                        so they can put "0,00% TAEG" / "0 % Zinsen" / etc. When
                        they leave it blank, fall back to a localized suffix so
                        shoppers never see an untranslated "% APR" string.
                      {%- endcomment -%}
                      {%- assign apr_fallback = 'kt.product.price.apr_suffix_html' | t: rate: block.settings.apr -%}
                      {{- block.settings.apr_label | default: apr_fallback -}}
                    </span>
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if section.settings.cta_text != blank -%}
            <a
              href="{{ section.settings.cta_link | default: routes.root_url | escape }}"
              class="kt-financing-calculator__cta"
            >
              {{ section.settings.cta_text }}
            </a>
          {%- endif -%}

          {%- if section.settings.trust_text != blank -%}
            <div class="kt-financing-calculator__trust">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>
              <span>{{ section.settings.trust_text }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-financing-calculator.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.financing-calculator.name",
  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.financing-calculator.settings.header__content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.financing-calculator.settings.eyebrow.label",
      "default": "Calculator"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.financing-calculator.settings.heading.label",
      "default": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.financing-calculator.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.financing-calculator.settings.description.label",
      "default": "Add a short description for this section."
    },
    {
      "type": "header",
      "content": "t:sections.financing-calculator.settings.header__input.content"
    },
    {
      "type": "text",
      "id": "amount_label",
      "label": "t:sections.financing-calculator.settings.amount_label.label",
      "default": "Estimated Loan Amount"
    },
    {
      "type": "text",
      "id": "months_label",
      "label": "t:sections.financing-calculator.settings.months_label.label",
      "default": "Months"
    },
    {
      "type": "number",
      "id": "default_amount",
      "label": "t:sections.financing-calculator.settings.default_amount.label",
      "default": 8000
    },
    {
      "type": "number",
      "id": "min_amount",
      "label": "t:sections.financing-calculator.settings.min_amount.label",
      "default": 500
    },
    {
      "type": "number",
      "id": "max_amount",
      "label": "t:sections.financing-calculator.settings.max_amount.label",
      "default": 200000
    },
    {
      "type": "header",
      "content": "t:sections.financing-calculator.settings.header__cta.content"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.financing-calculator.settings.cta_text.label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.financing-calculator.settings.cta_link.label"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "t:sections.financing-calculator.settings.trust_text.label"
    }
  ],
  "blocks": [
    {
      "type": "term",
      "name": "t:sections.financing-calculator.blocks.term.name",
      "limit": 6,
      "settings": [
        {
          "type": "number",
          "id": "months",
          "label": "t:sections.financing-calculator.blocks.term.settings.months.label",
          "default": 12
        },
        {
          "type": "number",
          "id": "apr",
          "label": "t:sections.financing-calculator.blocks.term.settings.apr.label",
          "info": "t:sections.financing-calculator.blocks.term.settings.apr.info",
          "default": 0
        },
        {
          "type": "text",
          "id": "apr_label",
          "label": "t:sections.financing-calculator.blocks.term.settings.apr_label.label"
        },
        {
          "type": "select",
          "id": "accent_color",
          "label": "t:sections.financing-calculator.blocks.term.settings.accent_color.label",
          "options": [
            { "value": "emerald", "label": "t:sections.financing-calculator.blocks.term.settings.accent_color.options__emerald.label" },
            { "value": "neutral", "label": "t:sections.financing-calculator.blocks.term.settings.accent_color.options__neutral.label" }
          ],
          "default": "emerald"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.financing-calculator.presets.name",
      "blocks": [
        {
          "type": "term",
          "settings": { "months": 12, "apr": 0, "accent_color": "emerald" }
        },
        {
          "type": "term",
          "settings": { "months": 24, "apr": 0, "accent_color": "neutral" }
        },
        {
          "type": "term",
          "settings": { "months": 36, "apr": 0, "accent_color": "neutral" }
        }
      ]
    }
  ]
}
{% endschema %}
