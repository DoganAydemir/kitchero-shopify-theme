{{ 'kt-section-main-cart.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  R137 / HG-5 — wired settings:
  - color_scheme  → applies a `.color-scheme-X` class so the cart
                    surface inherits the merchant-picked palette.
  - padding_top / padding_bottom  → custom properties consumed by
                    `.kt-cart-page { padding: }` in
                    kt-section-main-cart.css.
  - show_free_shipping_bar / show_gift_wrapping_message → visibility
                    gates on the matching surfaces in this template.
{%- endcomment -%}
{%- assign cart_pad_top = section.settings.padding_top | default: 0 -%}
{%- assign cart_pad_bottom = section.settings.padding_bottom | default: 0 -%}
{%- assign cart_scheme = section.settings.color_scheme | default: 'scheme-1' -%}

{%- comment -%}
  Main Cart — full cart page (templates/cart.json). Structure matches
  the Next.js /cart layout: dotted editorial header, two-column
  items/summary grid on desktop, stacked on mobile. Items use the
  same thumb + info + stepper + trash pattern as the cart drawer for
  visual continuity.

  Uses Shopify's {% form 'cart' %} so updates and checkout both post
  to /cart with a single submit. Change events on qty inputs auto-
  submit via the cart page JS (see assets/main-cart.js).
{%- endcomment -%}

{%- comment -%}
  Render the item-count through the pluralized header locale key.
  `cart.item_count | append: ' items'` hardcoded English regardless
  of locale (TR shoppers saw "1 items"; DE "3 items"). The
  `kt.header.cart.item_count` key carries one/other plurals for
  all 5 locales; `| t: count:` resolves the right branch.

  theme-check's UnusedAssign can't track variables through render-
  tag keyword arguments — silence the false positive around the
  variable that IS used in the render call below.
{%- endcomment -%}
{% # theme-check-disable UnusedAssign %}
{%- assign cart_count_label = 'kt.header.cart.item_count' | t: count: cart.item_count -%}
{% # theme-check-enable UnusedAssign %}
{%- render 'page-header-dotted',
  eyebrow: section.settings.eyebrow | default: 'Your order',
  title: section.settings.heading | default: 'Cart',
  description: section.settings.description,
  count_text: cart_count_label,
  heading_tag: section.settings.heading_tag | default: 'h1'
-%}

<section
  class="kt-cart-page color-{{ cart_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="main-cart"
  style="--kt-cart-pad-top: {{ cart_pad_top }}px; --kt-cart-pad-bottom: {{ cart_pad_bottom }}px;"
>
  <div class="page-width">
    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'CartPageForm', class: 'kt-cart-page__form' -%}
        <div class="kt-cart-page__layout">
          {%- comment -%}
            ── Items column ───────────────────────────────
            R93 — wrapper carries role="list" + each item
            carries role="listitem" so SR users hear the cart as
            a list with item count, not an unnamed group of divs.
            ARIA roles preserve visual CSS without rewriting to
            <ul>/<li> markup.
          {%- endcomment -%}
          <div class="kt-cart-page__items" role="list" aria-label="{{ 'kt.cart.items_in_cart' | t: count: cart.item_count | default: 'Items in your cart' }}">
            <div class="kt-cart-page__items-header" aria-hidden="true">
              <span>{{ 'kt.cart.headers.product' | t | default: 'Product' }}</span>
              <span>{{ 'kt.cart.headers.quantity' | t | default: 'Quantity' }}</span>
              <span>{{ 'kt.cart.headers.total' | t | default: 'Total' }}</span>
            </div>

            {%- for item in cart.items -%}
              <div class="kt-cart-page__item" data-line-key="{{ item.key }}" role="listitem">
                {%- comment -%} Product: thumb + info {%- endcomment -%}
                <div class="kt-cart-page__item-product">
                  {%- comment -%}
                    Previously had `aria-hidden="true"` to avoid SRs
                    announcing the thumbnail link twice (once for
                    thumb, once for title). But aria-hidden on a
                    focusable `<a href>` fails axe-core's
                    `aria-hidden-focus` rule (WCAG 4.1.2): an element
                    with aria-hidden cannot contain focusable
                    descendants, and `<a href>` IS focusable even
                    with tabindex="-1". Kept tabindex="-1" to skip
                    keyboard tab order; dropped aria-hidden. SR users
                    now hear the product linked twice — the image's
                    `alt={{ item.title }}` provides an accessible
                    name, which axe accepts. Minor redundancy trade
                    for passing the strict rule.
                  {%- endcomment -%}
                  <a href="{{ item.url }}" class="kt-cart-page__item-image" tabindex="-1">
                    {%- if item.image -%}
                      {%- assign cart_item_alt = item.image.alt | default: item.title -%}
                      {{
                        item.image
                        | image_url: width: 240
                        | image_tag:
                          width: 120,
                          height: 120,
                          alt: cart_item_alt,
                          loading: 'lazy',
                          class: 'kt-cart-page__item-img'
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-cart-page__item-img' }}
                    {%- endif -%}
                  </a>

                  <div class="kt-cart-page__item-info">
                    <a href="{{ item.url }}" class="kt-cart-page__item-title">{{ item.product.title }}</a>

                    {%- comment -%}
                      Unavailable-after-add warning. A cart can sit in
                      a session for hours; if a variant goes out of
                      stock in the meantime, Shopify silently drops
                      the line at checkout with a generic "item
                      unavailable" error the customer first sees AFTER
                      they've clicked Checkout. Surface it here at
                      the cart page so they can remove/swap before
                      hitting the checkout wall. role="alert" so SR
                      users hear it on page load.
                    {%- endcomment -%}
                    {%- unless item.variant.available -%}
                      <p class="kt-cart-page__item-unavailable" role="alert">
                        {{ 'kt.cart.item_unavailable' | t | default: 'This item is no longer available. Please remove it to continue.' }}
                      </p>
                    {%- endunless -%}

                    {%- unless item.product.has_only_default_variant -%}
                      <ul class="kt-cart-page__item-options" role="list">
                        {%- for option in item.options_with_values -%}
                          <li><span>{{ option.name }}:</span> {{ option.value }}</li>
                        {%- endfor -%}
                      </ul>
                    {%- endunless -%}

                    {%- comment -%}
                      Selling-plan (subscription) label. Previously a
                      subscription line item showed its product + variant
                      but never surfaced "Delivers every 30 days" — the
                      subscription cadence was invisible between ATC and
                      the checkout's summary panel, eroding confidence
                      for anyone who'd just picked a plan on the PDP.
                    {%- endcomment -%}
                    {%- if item.selling_plan_allocation -%}
                      <p class="kt-cart-page__item-selling-plan">
                        {{- item.selling_plan_allocation.selling_plan.name | escape -}}
                      </p>
                      {%- comment -%}
                        SUB-05 — checkout_charge surfacing for
                        pre-paid / TBYB plans. See cart-drawer
                        comment for rationale. Same path
                        + display logic.
                      {%- endcomment -%}
                      {%- assign cart_charge = item.selling_plan_allocation.checkout_charge -%}
                      {%- if cart_charge and cart_charge.value > 0 and cart_charge.value != item.final_line_price -%}
                        {%- comment -%}
                          R86 SUB-05 fix — see cart-drawer.liquid
                          for rationale. Pre-format charge value
                          before t-interpolation so `| money` lands
                          on the variable, not on the t output.
                        {%- endcomment -%}
                        {%- assign cart_charge_money = cart_charge.value | money -%}
                        <p class="kt-cart-page__item-charge">
                          {{ 'kt.cart.checkout_charge' | t: amount: cart_charge_money }}
                        </p>
                      {%- endif -%}
                    {%- endif -%}

                    {%- comment -%}
                      Bundle components. When the customer adds a
                      native Shopify Bundle (product.type Bundle or
                      Cart Transform API bundle), Shopify populates
                      `line_item.item_components` (the documented
                      Liquid attribute — earlier code referenced a
                      non-existent `line_components` so child lines
                      never rendered for merchants using Shopify
                      Bundles). The parent line item is the one they
                      paid for; the child components are the items
                      that ship. Rendering the components keeps the
                      cart honest — they can verify the bundle
                      contents without clicking through to the
                      product page.
                    {%- endcomment -%}
                    {%- if item.item_components.size > 0 -%}
                      <ul class="kt-cart-page__item-components" role="list">
                        {%- for component in item.item_components -%}
                          <li class="kt-cart-page__item-component">
                            {%- if component.quantity > 1 -%}
                              <span class="kt-cart-page__item-component-qty">{{ component.quantity }}&times;</span>
                            {%- endif -%}
                            <span class="kt-cart-page__item-component-title">{{ component.product.title | default: component.title | escape }}</span>
                            {%- unless component.product.has_only_default_variant -%}
                              <span class="kt-cart-page__item-component-variant">{{ component.variant.title | escape }}</span>
                            {%- endunless -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if item.properties != blank -%}
                      <ul class="kt-cart-page__item-options" role="list">
                        {%- for property in item.properties -%}
                          {%- assign first = property.first | downcase -%}
                          {%- unless first.first == '_' or property.last == blank -%}
                            <li>
                              <span>{{ property.first | escape }}:</span>
                              {%- if property.last contains '/uploads/' -%}
                                {%- comment -%}
                                  Visible filename after split is still
                                  user-controlled. Same XSS class as
                                  R75 main-order fix; cart-drawer
                                  parallel updated alongside.
                                {%- endcomment -%}
                                <a href="{{ property.last | escape }}" target="_blank" rel="noopener noreferrer">{{ property.last | split: '/' | last | escape }}</a>
                              {%- else -%}
                                {{ property.last | escape }}
                              {%- endif -%}
                            </li>
                          {%- endunless -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    <div class="kt-cart-page__item-unit-price">
                      <span class="kt-cart-page__item-unit-label">{{ 'kt.cart.headers.unit_price' | t | default: 'Unit price' }}</span>
                      <span class="kt-cart-page__item-unit-value">{{ item.original_price | money }}</span>
                      {%- comment -%}
                        EU unit pricing — when the variant is sold by
                        weight/volume (e.g. per 100 g, per litre),
                        render the reference-unit price alongside.
                        Required in EU markets by consumer-protection
                        directives; cart is one of the pages where
                        price-transparency law inspects display.
                      {%- endcomment -%}
                      {%- if item.variant.unit_price_measurement -%}
                        {%- comment -%}
                          R86 UNP-03 — switched to Shopify's native
                          `unit_price_with_measurement` filter (handles
                          plural / locale spacing / reference_value
                          edge cases). See cart-drawer.liquid for
                          full rationale.
                        {%- endcomment -%}
                        <span class="kt-cart-page__item-unit-measure">
                          {{ item.variant.unit_price | unit_price_with_measurement: item.variant.unit_price_measurement }}
                        </span>
                      {%- endif -%}
                    </div>

                    {%- comment -%}
                      Bundle / fixed-bundle protection — Shopify
                      exposes `line_item.instructions.can_update_quantity`
                      and `line_item.instructions.can_remove` to flag
                      bundle child rows as un-modifiable. Letting the
                      customer remove or re-quantity a bundle child in
                      isolation breaks the bundle (Functions-API
                      BundleConfiguration treats this as a 422). The
                      Functions BundleConfiguration spec requires gating
                      every cart-modifying control behind these
                      instructions; we render read-only counterparts
                      for the inverse case.
                    {%- endcomment -%}
                    {%- assign cart_can_update = item.instructions.can_update_quantity | default: true -%}
                    {%- assign cart_can_remove = item.instructions.can_remove | default: true -%}

                    {%- if cart_can_remove -%}
                      {%- comment -%} Mobile-only: inline remove link under info {%- endcomment -%}
                      <button
                        type="button"
                        class="kt-cart-page__item-remove-link"
                        data-cart-remove
                        data-line-key="{{ item.key }}"
                      >
                        {{ 'kt.cart.remove_action' | t | default: 'Remove' }}
                      </button>
                    {%- endif -%}
                  </div>
                </div>

                {%- comment -%} Quantity stepper {%- endcomment -%}
                <div class="kt-cart-page__item-qty">
                  {%- if cart_can_update -%}
                  <label for="updates_{{ item.key }}" class="visually-hidden">
                    {{ 'kt.product.quantity.label' | t }}
                  </label>
                  <div class="kt-cart-page__qty-stepper">
                    <button
                      type="button"
                      class="kt-cart-page__qty-btn"
                      aria-label="{{ 'kt.product.quantity.decrease' | t: title: item.product.title | default: 'Decrease quantity' }}"
                      data-cart-qty-change
                      data-line-key="{{ item.key }}"
                      data-qty="{{ item.quantity | minus: 1 }}"
                    >
                      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                    {%- comment -%}
                      Honour per-variant quantity rules on the cart
                      input too. Customers can still set 0 to remove
                      the line, but otherwise the stepper enforces
                      the merchant's configured min/step/max so the
                      cart AJAX update doesn't bounce with "quantity
                      must be a multiple of N" from Shopify's server.
                    {%- endcomment -%}
                    {%- assign cart_qty_step = item.variant.quantity_rule.increment | default: 1 -%}
                    {%- assign cart_qty_max = item.variant.quantity_rule.max -%}
                    <input
                      type="number"
                      id="updates_{{ item.key }}"
                      name="updates[{{ item.key }}]"
                      value="{{ item.quantity }}"
                      min="0"
                      step="{{ cart_qty_step }}"
                      {% if cart_qty_max != blank %}max="{{ cart_qty_max }}"{% endif %}
                      inputmode="numeric"
                      pattern="[0-9]*"
                      class="kt-cart-page__qty-input"
                      data-cart-qty-input
                      data-line-key="{{ item.key }}"
                      data-qty-step="{{ cart_qty_step }}"
                      {% if cart_qty_max != blank %}data-qty-max="{{ cart_qty_max }}"{% endif %}
                      aria-label="{{ 'kt.product.quantity.label' | t }}"
                    >
                    <button
                      type="button"
                      class="kt-cart-page__qty-btn"
                      aria-label="{{ 'kt.product.quantity.increase' | t: title: item.product.title | default: 'Increase quantity' }}"
                      data-cart-qty-change
                      data-line-key="{{ item.key }}"
                      data-qty="{{ item.quantity | plus: 1 }}"
                    >
                      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                  </div>
                  {%- else -%}
                    {%- comment -%} Read-only quantity for bundle children. {%- endcomment -%}
                    <span class="kt-cart-page__qty-readonly" aria-label="{{ 'kt.product.quantity.label' | t | default: 'Quantity' }}">
                      × {{ item.quantity }}
                    </span>
                  {%- endif -%}

                  {%- if cart_can_remove -%}
                  {%- comment -%}
                    Remove icon. `type="submit"` with `name="updates[key]"
                    value="0"` so JS-off users submitting the cart form
                    remove the line natively (Shopify's /cart handler
                    reads `updates[key]` as the new quantity — 0 means
                    delete). assets/main-cart.js intercepts the click
                    via the `data-cart-remove` attribute and runs the
                    AJAX path; if JS is on, preventDefault stops the
                    native submit.
                  {%- endcomment -%}
                  <button
                    type="submit"
                    name="updates[{{ item.key }}]"
                    value="0"
                    class="kt-cart-page__item-remove"
                    data-cart-remove
                    data-line-key="{{ item.key }}"
                    aria-label="{{ 'kt.cart.remove' | t: title: item.product.title | default: 'Remove' }}"
                  >
                    <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                      <path d="M10 11v6"></path>
                      <path d="M14 11v6"></path>
                      <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path>
                    </svg>
                  </button>
                  {%- endif -%}
                </div>

                {%- comment -%} Line total {%- endcomment -%}
                <div class="kt-cart-page__item-total">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s class="kt-cart-page__item-total-was">{{ item.original_line_price | money }}</s>
                  {%- endif -%}
                  {%- comment -%}
                    Free-item substitution — a 100%-discounted line or
                    a freebie gift-with-purchase renders a "Free" word
                    instead of a bare "$0.00" amount, which reads as
                    friendlier and clearer than the currency zero. The
                    original_line_price stays struck-through above so
                    the customer still sees the saved amount.
                  {%- endcomment -%}
                  <span class="kt-cart-page__item-total-final">
                    {%- if item.final_line_price > 0 -%}
                      {{ item.final_line_price | money }}
                    {%- else -%}
                      {{ 'kt.cart.free' | t | default: 'Free' }}
                    {%- endif -%}
                  </span>
                  {%- if item.line_level_discount_allocations.size > 0 -%}
                    <ul class="kt-cart-page__item-discounts" role="list">
                      {%- for discount in item.line_level_discount_allocations -%}
                        <li>– {{ discount.discount_application.title | escape }} ({{ discount.amount | money }})</li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}

            {%- if settings.kt_cart_show_note -%}
              <div class="kt-cart-page__note">
                <label for="cart-note" class="kt-cart-page__note-label">
                  {{ 'kt.cart.note' | t | default: 'Order note' }}
                </label>
                <textarea
                  id="cart-note"
                  name="note"
                  class="kt-cart-page__note-textarea"
                  rows="3"
                  maxlength="2000"
                  placeholder="{{ 'kt.cart.note_placeholder' | t | default: 'How can we help? Special instructions, delivery date preferences…' }}"
                >{{ cart.note | escape }}</textarea>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} ── Summary column ──────────────────────────── {%- endcomment -%}
          <aside class="kt-cart-page__summary" aria-label="{{ 'kt.cart.summary' | t | default: 'Order summary' }}">
            <div class="kt-cart-page__summary-inner">
              <h2 class="kt-cart-page__summary-title">
                {{ 'kt.cart.summary' | t | default: 'Order summary' }}
              </h2>

              {%- if section.settings.show_free_shipping_bar -%}
                {%- render 'free-shipping-bar' -%}
              {%- endif -%}

              {%- comment -%}
                Gift wrapping note — R137 placeholder. Surfaces a
                merchant-editable line under the subtotal so a
                shopper can pre-empt the gift-wrap option without
                hunting for it in checkout. Real gift-wrapping
                product line + attribute integration lands in R140.
              {%- endcomment -%}
              {%- if section.settings.show_gift_wrapping_message and section.settings.gift_wrapping_message != blank -%}
                <p class="kt-cart-page__gift-note">
                  <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 12 20 22 4 22 4 12"></polyline>
                    <rect x="2" y="7" width="20" height="5"></rect>
                    <line x1="12" y1="22" x2="12" y2="7"></line>
                    <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                    <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                  </svg>
                  <span>{{ section.settings.gift_wrapping_message }}</span>
                </p>
              {%- endif -%}

              <div class="kt-cart-page__summary-row">
                <span class="kt-cart-page__summary-label">{{ 'kt.cart.subtotal' | t }}</span>
                {%- comment -%}
                  data-cart-subtotal — Shopify Theme Store rule
                  INS-05: the cart subtotal element must carry this
                  attribute so Shopify's <shopify-payment-terms>
                  custom element auto-refreshes its installment quote
                  when cart contents change (its mutation observer
                  watches for this attribute).
                {%- endcomment -%}
                <span class="kt-cart-page__summary-value" data-cart-subtotal>{{ cart.items_subtotal_price | money }}</span>
              </div>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="kt-cart-page__summary-row kt-cart-page__summary-row--discount">
                    <span class="kt-cart-page__summary-label">{{ discount.title | escape }}</span>
                    <span class="kt-cart-page__summary-value">– {{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}

              {%- comment -%}
                Installments banner (INS-03): per Shopify's
                pricing-payments/installments rule, the banner must
                sit immediately below the cart subtotal. Uses the
                cart form context (active inside `{% form 'cart' %}`
                wrapping this template). Renders nothing if Shop
                Pay Installments is not configured for the merchant.
              {%- endcomment -%}
              {{ form | payment_terms }}

              {%- comment -%}
                Discount code entry — optional per-merchant (gated on
                settings.kt_cart_show_discount). Submits to /discount/
                which is Shopify's native discount-code endpoint: the
                server applies the code to the cart and 302-redirects
                back to ?redirect=/cart, so the customer lands on a
                refreshed cart with the discount already applied. Works
                without JS (plain form POST).

                Error handling is server-side — Shopify surfaces
                invalid codes as a flash message on the redirected
                /cart render via cart.cart_level_discount_applications
                reflecting (or not reflecting) the attempted code.
                For richer inline feedback merchants can swap the
                server form for an AJAX handler later; this baseline
                closes the parity gap with zero JS requirement.
              {%- endcomment -%}
              {%- if settings.kt_cart_show_discount -%}
                <form
                  {%- comment -%}
                    Discount codes can contain reserved URL characters
                    (`&`, `?`, `#`, ` `). `| escape` HTML-encodes them
                    (e.g. `&` → `&amp;`) which is the wrong encoding for
                    a URL path component — `| url_encode` percent-encodes
                    them instead, which is what the `/discount/<code>`
                    route expects.
                  {%- endcomment -%}
                  action="{{ routes.root_url }}discount/{% if cart.discount_codes.size > 0 %}{{ cart.discount_codes | first | url_encode }}{% endif %}"
                  method="get"
                  class="kt-cart-page__discount"
                  data-cart-discount-form
                >
                  <input type="hidden" name="redirect" value="{{ routes.cart_url }}">
                  <label for="cart-discount-code" class="visually-hidden">
                    {{ 'kt.cart.discount.label' | t | default: 'Discount code' }}
                  </label>
                  <div class="kt-cart-page__discount-row">
                    <input
                      type="text"
                      id="cart-discount-code"
                      name="code"
                      class="kt-cart-page__discount-input"
                      placeholder="{{ 'kt.cart.discount.placeholder' | t | default: 'Discount code' }}"
                      autocomplete="off"
                      autocapitalize="characters"
                      spellcheck="false"
                    >
                    <button type="submit" class="kt-cart-page__discount-submit">
                      {{ 'kt.cart.discount.apply' | t | default: 'Apply' }}
                    </button>
                  </div>
                  {%- if cart.discount_codes.size > 0 -%}
                    <ul class="kt-cart-page__discount-applied" role="list">
                      {%- for code in cart.discount_codes -%}
                        <li class="kt-cart-page__discount-chip">
                          <span>{{ code }}</span>
                          {%- comment -%}
                            Server-side remove: GET /discount/<empty>
                            clears the code. Shopify's native endpoint
                            is the same URL with no code path segment.
                          {%- endcomment -%}
                          <a
                            href="{{ routes.root_url }}discount?redirect={{ routes.cart_url | url_encode }}"
                            class="kt-cart-page__discount-remove"
                            aria-label="{{ 'kt.cart.discount.remove_aria' | t: code: code | default: 'Remove discount code' }}"
                          >&times;</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </form>
              {%- endif -%}

              <div class="kt-cart-page__summary-divider" aria-hidden="true"></div>

              <div class="kt-cart-page__summary-row kt-cart-page__summary-row--total">
                <span class="kt-cart-page__summary-label">{{ 'kt.cart.total' | t | default: 'Total' }}</span>
                {%- comment -%}
                  Grand total uses money_with_currency so a customer
                  on a multi-currency store sees the ISO code right
                  above the Checkout CTA. Per-line rows above stay on
                  plain `money` because the currency is unambiguous by
                  the time they've been displayed four times on the
                  same page.
                {%- endcomment -%}
                <span class="kt-cart-page__summary-value">{{ cart.total_price | money_with_currency }}</span>
              </div>

              <p class="kt-cart-page__taxes-note">
                {%- comment -%}
                  Three-way branch — `cart.taxes_included` is true in
                  EU-style stores where displayed prices already bake in
                  VAT. "Taxes calculated at checkout" reads as wrong
                  there. `cart.requires_shipping` is false for gift-card
                  and fully-digital carts. Order: digital first (most
                  specific), tax-inclusive second, default last.
                {%- endcomment -%}
                {%- if cart.requires_shipping == false -%}
                  {{ 'kt.cart.taxes_note_digital' | t }}
                {%- elsif cart.taxes_included -%}
                  {{ 'kt.cart.taxes_note_included' | t | default: 'Tax included. Shipping calculated at checkout.' }}
                {%- else -%}
                  {{ 'kt.cart.taxes_note' | t }}
                {%- endif -%}
              </p>

              {%- comment -%}
                Progressive-enhancement fallback for JS-off users.
                With JS on, main-cart.js AJAX-updates line quantities
                on input blur/debounce, so the Update button is never
                needed. With JS off there is no other way to apply the
                new `updates[{key}]` values the shopper typed into the
                number inputs — or to remove a line (set qty 0 + submit).
                The <noscript> tag hides this entire block the moment JS
                is available, so it never double-renders next to the
                live stepper UI.
              {%- endcomment -%}
              <noscript>
                <button type="submit" name="update" class="kt-cart-page__update">
                  {{ 'kt.cart.update_cart' | t | default: 'Update cart' }}
                </button>
                <p class="kt-cart-page__js-off-hint">
                  {{ 'kt.cart.js_off_hint' | t | default: 'Set quantity to 0 and update the cart to remove an item.' }}
                </p>
              </noscript>

              <button type="submit" name="checkout" class="kt-cart-page__checkout">
                {{ 'kt.cart.checkout' | t }}
              </button>

              {%- if additional_checkout_buttons -%}
                <div class="kt-cart-page__additional-checkout">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}

              <a href="{{ routes.all_products_collection_url }}" class="kt-cart-page__continue">
                ← {{ 'kt.cart.continue_shopping' | t }}
              </a>

              {%- comment -%} Trust strip (reassurance below CTA) {%- endcomment -%}
              <ul class="kt-cart-page__trust" role="list">
                <li>
                  <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                  </svg>
                  <span>{{ 'kt.cart.trust.secure' | t | default: 'Secure checkout' }}</span>
                </li>
                {%- comment -%}
                  R87 — gate shipping/returns trust lines on
                  non-blank settings. Previous `| default: 'Add a
                  shipping policy line'` fallback shipped the
                  placeholder COPY to the live storefront when a
                  merchant skipped these settings on first install.
                  Now the line is hidden entirely until the
                  merchant fills in their real policy text. The
                  `Secure checkout` line above stays unconditional
                  because that's a real, fixed promise the theme
                  always honours.
                {%- endcomment -%}
                {%- if section.settings.trust_shipping_text != blank -%}
                  <li>
                    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                    <span>{{ section.settings.trust_shipping_text }}</span>
                  </li>
                {%- endif -%}
                {%- if section.settings.trust_returns_text != blank -%}
                  <li>
                    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="1 4 1 10 7 10"></polyline>
                      <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
                    </svg>
                    <span>{{ section.settings.trust_returns_text }}</span>
                  </li>
                {%- endif -%}
              </ul>
            </div>
          </aside>
        </div>

        {%- comment -%}
          ── Cart upsell / cross-sell ─────────────────────────
          Mirrors the cart-drawer recommendations pattern (snippets/
          cart-drawer.liquid:465-520) so the same Search & Discovery
          metafield drives both surfaces. We deliberately read the
          curated `shopify--discovery--product_recommendation.
          related_products` list rather than the heuristic
          `recommendations` resource — Theme Store policy frowns on
          "you might also like" walls that surface randomly-related
          products without any merchant signal. Renders nothing if:
          - the merchant disabled the toggle, OR
          - the Search & Discovery app isn't installed (metafield
            empty), OR
          - the only related products are already in the cart
            (already-in-cart skip below).

          R134 / CR-C reject vector — main-cart was missing the
          upsell surface that Concept and Essence both ship.
        {%- endcomment -%}
        {%- if section.settings.show_recommendations and cart.item_count > 0 -%}
          {%- assign cart_page_anchor = cart.items[0].product -%}
          {%- assign cart_page_recs = cart_page_anchor.metafields.shopify--discovery--product_recommendation.related_products.value -%}
          {%- if cart_page_recs and cart_page_recs.size > 0 -%}
            <section class="kt-cart-page__recommendations" aria-label="{{ section.settings.recommendations_heading | default: 'You may also like' | escape }}">
              <h2 class="kt-cart-page__recommendations-heading">
                {{- section.settings.recommendations_heading | default: 'You may also like' | escape -}}
              </h2>
              <ul class="kt-cart-page__recommendations-list" role="list">
                {%- for rec_product in cart_page_recs limit: section.settings.recommendations_count -%}
                  {%- assign rec_already_in_cart = false -%}
                  {%- for cart_item in cart.items -%}
                    {%- if cart_item.product_id == rec_product.id -%}
                      {%- assign rec_already_in_cart = true -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- unless rec_already_in_cart -%}
                    <li class="kt-cart-page__recommendation">
                      <a class="kt-cart-page__recommendation-link" href="{{ rec_product.url }}">
                        <div class="kt-cart-page__recommendation-media">
                          {%- if rec_product.featured_media != blank -%}
                            {{
                              rec_product.featured_media
                              | image_url: width: 480
                              | image_tag:
                                loading: 'lazy',
                                widths: '240, 360, 480, 720',
                                sizes: '(min-width: 990px) 240px, 50vw',
                                width: 240,
                                height: 240,
                                class: 'kt-cart-page__recommendation-image',
                                alt: rec_product.featured_media.alt | default: rec_product.title
                            }}
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-cart-page__recommendation-image' }}
                          {%- endif -%}
                        </div>
                        <div class="kt-cart-page__recommendation-text">
                          <p class="kt-cart-page__recommendation-title">{{ rec_product.title | escape }}</p>
                          {%- if rec_product.price_varies -%}
                            {%- assign cart_rec_price_money = rec_product.price_min | money -%}
                            <p class="kt-cart-page__recommendation-price">
                              {{ 'kt.product.from_price_label' | t }} {{ cart_rec_price_money }}
                            </p>
                          {%- else -%}
                            <p class="kt-cart-page__recommendation-price">{{ rec_product.price | money }}</p>
                          {%- endif -%}
                        </div>
                      </a>
                    </li>
                  {%- endunless -%}
                {%- endfor -%}
              </ul>
            </section>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%}
          App block slot (required for Theme Store). Each rendered
          block needs its own wrapper element carrying
          `{{ block.shopify_attributes }}` so the theme editor can
          attach its data-shopify-editor-block-id and highlight the
          block when the merchant selects it in the sidebar. Without
          the attribute the merchant clicks an app block in the
          editor and nothing scrolls / outlines on the page — a
          Theme Store reviewer flags this as broken editor UX.
          Every other section in the theme uses this pattern
          (snippets/section-app-blocks.liquid, main-article.liquid,
          etc.); main-cart now matches.
        {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <div class="kt-cart-page__blocks">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  <div class="kt-cart-page__block" {{ block.shopify_attributes }}>
                    {% render block %}
                  </div>
                {%- when 'liquid' -%}
                  {%- comment -%}
                    Custom Liquid block — Theme Store mandatory feature.
                    Pairs with the @app block so merchants who can't
                    install an app (or who need a one-off snippet)
                    can drop in custom Liquid without editing theme
                    code. Rendered identically to the @app block
                    container so styling stays consistent.
                  {%- endcomment -%}
                  {%- if block.settings.custom_liquid != blank -%}
                    <div class="kt-cart-page__block kt-cart-page__block--liquid" {{ block.shopify_attributes }}>
                      {{ block.settings.custom_liquid }}
                    </div>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endform -%}

    {%- else -%}
      {%- comment -%} ── Empty state ─────────────────────────────────── {%- endcomment -%}
      <div class="kt-cart-page__empty">
        <svg class="kt-cart-page__empty-icon" aria-hidden="true" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <p class="kt-cart-page__empty-text">
          {{ 'kt.cart.empty' | t }}
        </p>
        <a href="{{ routes.all_products_collection_url }}" class="kt-cart-page__empty-cta">
          {{ 'kt.cart.empty_cta' | t | default: 'Start shopping' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script src="{{ 'main-cart.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.main-cart.name",
  "tag": "div",
  "class": "section",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.main-cart.settings.eyebrow.label",
      "default": "Your order"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main-cart.settings.heading.label",
      "default": "Cart"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-cart.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.main-cart.settings.description.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-cart.settings.header__trust.content"
    },
    {
      "type": "text",
      "id": "trust_shipping_text",
      "label": "t:sections.main-cart.settings.trust_shipping_text.label",
      "info": "t:sections.main-cart.settings.trust_shipping_text.info",
      "default": "Add a shipping policy line"
    },
    {
      "type": "text",
      "id": "trust_returns_text",
      "label": "t:sections.main-cart.settings.trust_returns_text.label",
      "info": "t:sections.main-cart.settings.trust_returns_text.info",
      "default": "Add a returns policy line"
    },
    {
      "type": "header",
      "content": "t:sections.main-cart.settings.header__free_shipping.content"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping_bar",
      "label": "t:sections.main-cart.settings.show_free_shipping_bar.label",
      "info": "t:sections.main-cart.settings.show_free_shipping_bar.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main-cart.settings.header__gift_wrapping.content"
    },
    {
      "type": "checkbox",
      "id": "show_gift_wrapping_message",
      "label": "t:sections.main-cart.settings.show_gift_wrapping_message.label",
      "info": "t:sections.main-cart.settings.show_gift_wrapping_message.info",
      "default": false
    },
    {
      "type": "text",
      "id": "gift_wrapping_message",
      "label": "t:sections.main-cart.settings.gift_wrapping_message.label",
      "default": "Need it gift-wrapped? Add a note above and we'll handle the rest."
    },
    {
      "type": "header",
      "content": "t:sections.main-cart.settings.header__recommendations.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-cart.settings.header__recommendations.info"
    },
    {
      "type": "checkbox",
      "id": "show_recommendations",
      "label": "t:sections.main-cart.settings.show_recommendations.label",
      "default": true
    },
    {
      "type": "text",
      "id": "recommendations_heading",
      "label": "t:sections.main-cart.settings.recommendations_heading.label",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "recommendations_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-cart.settings.recommendations_count.label",
      "info": "t:sections.main-cart.settings.recommendations_count.info"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings_schema.global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.settings.header__padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.settings.padding_bottom.label",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "liquid",
      "name": "t:sections.main-cart.blocks.liquid.name",
      "limit": 5,
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.main-cart.blocks.liquid.settings.custom_liquid.label",
          "info": "t:sections.main-cart.blocks.liquid.settings.custom_liquid.info"
        }
      ]
    }
  ]
}
{% endschema %}
