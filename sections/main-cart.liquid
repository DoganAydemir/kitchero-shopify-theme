{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}

<section class="kt-cart-page" data-section-id="{{ section.id }}">
  <div class="page-width">
    <h1 class="kt-cart-page__title">{{ 'sections.cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="CartPageForm">
        <div class="kt-cart-page__layout">
          {%- comment -%} Cart Items {%- endcomment -%}
          <div class="kt-cart-page__items">
            {%- for item in cart.items -%}
              <div class="kt-cart-page__item">
                <div class="kt-cart-page__item-image">
                  {%- if item.image -%}
                    <a href="{{ item.url }}">
                      {{ item.image | image_url: width: 200 | image_tag: width: 100, height: 100, alt: item.title, loading: 'lazy', class: 'kt-cart-page__item-img' }}
                    </a>
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-cart-page__item-img' }}
                  {%- endif -%}
                </div>
                <div class="kt-cart-page__item-info">
                  <a href="{{ item.url }}" class="kt-cart-page__item-title">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="kt-cart-page__item-variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="kt-cart-page__item-price">{{ item.final_line_price | money }}</p>
                </div>
                <div class="kt-cart-page__item-qty">
                  <label for="updates_{{ item.key }}" class="visually-hidden">{{ 'products.product.quantity.label' | t }}</label>
                  <input type="number" id="updates_{{ item.key }}" name="updates[]" value="{{ item.quantity }}" min="0" class="kt-cart-page__qty-input" aria-label="{{ 'products.product.quantity.label' | t }}">
                </div>
                <div class="kt-cart-page__item-total">
                  {{ item.final_line_price | money }}
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- comment -%} Cart Summary {%- endcomment -%}
          <div class="kt-cart-page__summary">
            {%- if settings.show_cart_note -%}
              <div class="kt-cart-page__note">
                <label for="cart-note" class="kt-cart-page__note-label">{{ 'sections.cart.note' | t | default: 'Order note' }}</label>
                <textarea id="cart-note" name="note" class="kt-cart-page__note-textarea" rows="3">{{ cart.note }}</textarea>
              </div>
            {%- endif -%}

            <div class="kt-cart-page__subtotal">
              <span>{{ 'sections.cart.subtotal' | t | default: 'Subtotal' }}</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <p class="kt-cart-page__taxes-note">{{ 'sections.cart.taxes_note' | t | default: 'Taxes and shipping calculated at checkout' }}</p>

            <button type="submit" name="checkout" class="kt-cart-page__checkout">
              {{ 'sections.cart.checkout' | t | default: 'Checkout' }}
            </button>

            <a href="{{ routes.collections_url }}" class="kt-cart-page__continue">
              {{ 'sections.cart.continue_shopping' | t | default: 'Continue shopping' }}
            </a>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="kt-cart-page__empty">
        <p>{{ 'sections.cart.empty' | t | default: 'Your cart is empty' }}</p>
        <a href="{{ routes.collections_url }}" class="button">{{ 'sections.cart.continue_shopping' | t | default: 'Continue shopping' }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-cart.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
