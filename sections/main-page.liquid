{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_header = section.settings.show_header
  assign header_eyebrow = section.settings.header_eyebrow
  assign header_description = section.settings.header_description
  assign header_count_text = section.settings.header_count_text
  assign heading_tag = section.settings.heading_tag | default: 'h1'
  assign content_max_width = section.settings.content_max_width | default: 800

  # `| default:` fires when the value is falsy (and 0 is falsy in Liquid)
  # so we read the setting first and only fall back when it's truly nil.
  # This keeps a merchant-chosen 0 respected.
  assign pt_desktop = section.settings.padding_top
  if pt_desktop == nil
    assign pt_desktop = 64
  endif
  assign pb_desktop = section.settings.padding_bottom
  if pb_desktop == nil
    assign pb_desktop = 96
  endif
  assign pt_mobile = pt_desktop | times: 0.7 | round | at_least: 0
  assign pb_mobile = pb_desktop | times: 0.7 | round | at_least: 0
-%}

<article
  class="kt-main-page"
  data-section-id="{{ section.id }}"
  data-section-type="main-page"
  style="--kt-main-page-padding-top-mobile: {{ pt_mobile }}px; --kt-main-page-padding-bottom-mobile: {{ pb_mobile }}px; --kt-main-page-padding-top-desktop: {{ pt_desktop }}px; --kt-main-page-padding-bottom-desktop: {{ pb_desktop }}px;"
>
  {%- if show_header -%}
    {%- comment -%}
      If the page body has content below (raw CMS HTML), shrink the dotted
      header a notch so the overall page rhythm stays lean. When the page
      is pure header + app blocks, use the full-size variant.
    {%- endcomment -%}
    {%- assign is_compact = false -%}
    {%- if page.content != blank -%}
      {%- assign is_compact = true -%}
    {%- endif -%}
    {%- render 'page-header-dotted',
      eyebrow: header_eyebrow,
      title: page.title,
      description: header_description,
      count_text: header_count_text,
      heading_tag: heading_tag,
      compact: is_compact
    -%}
  {%- else -%}
    {%- comment -%}
      Compact fallback header used when the dotted hero is disabled —
      preserves the semantic h1 so the page still has a proper outline.
    {%- endcomment -%}
    <header class="kt-main-page__compact-header">
      <div class="page-width">
        <{{ heading_tag }} class="kt-main-page__compact-title">{{ page.title }}</{{ heading_tag }}>
      </div>
    </header>
  {%- endif -%}

  {%- if page.content != blank -%}
    <div class="kt-main-page__body">
      <div class="page-width">
        <div class="kt-main-page__content rte" style="--kt-page-content-max-width: {{ content_max_width }}px;">
          {{ page.content }}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} App-block render slot — sits BELOW the CMS content so
     merchants can append review widgets, FAQs, custom galleries, etc. {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="kt-main-page__app-blocks">
      <div class="page-width">
        {%- for block in section.blocks -%}
          {%- if block.type == '@app' -%}
            {% render block %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</article>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-page.settings.header__dotted.content"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "t:sections.main-page.settings.show_header.label",
      "info": "t:sections.main-page.settings.show_header.info",
      "default": true
    },
    {
      "type": "text",
      "id": "header_eyebrow",
      "label": "t:sections.main-page.settings.header_eyebrow.label",
      "info": "t:sections.main-page.settings.header_eyebrow.info"
    },
    {
      "type": "textarea",
      "id": "header_description",
      "label": "t:sections.main-page.settings.header_description.label",
      "info": "t:sections.main-page.settings.header_description.info"
    },
    {
      "type": "text",
      "id": "header_count_text",
      "label": "t:sections.main-page.settings.header_count_text.label",
      "info": "t:sections.main-page.settings.header_count_text.info"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-page.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "t:sections.main-page.settings.header__content.content"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "t:sections.main-page.settings.content_max_width.label",
      "info": "t:sections.main-page.settings.content_max_width.info",
      "min": 560,
      "max": 1200,
      "step": 40,
      "unit": "px",
      "default": 800
    },
    {
      "type": "header",
      "content": "t:sections.main-page.settings.header__spacing.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.main-page.settings.padding_top.label",
      "info": "t:sections.main-page.settings.padding_top.info",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.main-page.settings.padding_bottom.label",
      "info": "t:sections.main-page.settings.padding_bottom.info",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
