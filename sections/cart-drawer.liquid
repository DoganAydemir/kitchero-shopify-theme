{%- comment -%}
  Cart Drawer — slide-in from right. Registered as a SECTION (not a
  snippet) so it can be refreshed via Shopify's Section Rendering API
  from cart-drawer.js: `fetch('/?sections=cart-drawer')`.

  Works without JS: the cart icon falls back to {{ routes.cart_url }}.

  All markup lives in snippets/cart-drawer.liquid so the schema-free
  snippet form is still renderable from templates/other layouts if
  ever needed.

  TSB-001 internal gate: layout/theme.liquid renders this section
  unconditionally (Theme Store rule forbids conditional `{% section %}`
  calls). When the merchant has chosen `kt_cart_type == 'page'`
  (full-page cart), this section emits NOTHING so the drawer markup
  doesn't ship to the page. The wrapper still exists in the SRA
  response shape so AJAX refresh stays consistent.
{%- endcomment -%}

{%- if settings.kt_cart_type == 'drawer' -%}
  {%- comment -%}
    R97 — pass section_id so the snippet can stamp data-section-id
    on its host custom element. Lets shopify:section:load /
    :section:unload editor lifecycle hooks scope to the right node.
  {%- endcomment -%}
  {%- render 'cart-drawer', section: section, section_id: section.id -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.cart-drawer.name",
  "tag": "aside",
  "class": "kt-cart-drawer-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.cart-drawer.settings.header__recommendations.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.cart-drawer.settings.header__recommendations.info"
    },
    {
      "type": "checkbox",
      "id": "show_recommendations",
      "label": "t:sections.cart-drawer.settings.show_recommendations.label",
      "default": true
    },
    {
      "type": "text",
      "id": "recommendations_heading",
      "label": "t:sections.cart-drawer.settings.recommendations_heading.label",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "recommendations_count",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.cart-drawer.settings.recommendations_count.label",
      "info": "t:sections.cart-drawer.settings.recommendations_count.info"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "max_blocks": 6
}
{% endschema %}
