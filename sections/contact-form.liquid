{{ 'kt-section-contact-form.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Contact Form Section — showrooms grid + inquiry form.
  Birebir from contact/page.tsx.
  Uses {% form 'contact' %} for Shopify form submission.
{%- endcomment -%}

<section class="kt-contact" data-section-id="{{ section.id }}">
  {%- comment -%} Showrooms Grid {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="kt-contact__showrooms">
      <div class="page-width">
        <div class="kt-contact__showrooms-header">
          <span class="kt-contact__label">{{ section.settings.showrooms_label | default: 'Our Locations' }}</span>
          <h2 class="kt-contact__showrooms-title">{{ section.settings.showrooms_heading | default: 'Visit A Studio' }}</h2>
        </div>

        <div class="kt-contact__showrooms-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'showroom' -%}
              <div class="kt-contact__showroom" {{ block.shopify_attributes }}>
                <div class="kt-contact__showroom-image-wrap">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 800 | image_tag: class: 'kt-contact__showroom-image', loading: 'lazy', widths: '375, 550, 800', sizes: '(min-width: 750px) 50vw, 100vw', width: block.settings.image.width, height: block.settings.image.height, alt: block.settings.title }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-contact__showroom-image' }}
                  {%- endif -%}
                  <span class="kt-contact__showroom-pin" aria-hidden="true">
                    <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  </span>
                </div>
                <h3 class="kt-contact__showroom-name">{{ block.settings.title }}</h3>
                <div class="kt-contact__showroom-details">
                  {%- if block.settings.address != blank -%}
                    <p class="kt-contact__showroom-address">{{ block.settings.address }}</p>
                  {%- endif -%}
                  <div class="kt-contact__showroom-divider"></div>
                  {%- if block.settings.phone != blank -%}
                    <p class="kt-contact__showroom-meta">
                      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                      {{ block.settings.phone }}
                    </p>
                  {%- endif -%}
                  {%- if block.settings.email != blank -%}
                    <p class="kt-contact__showroom-meta">
                      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                      {{ block.settings.email }}
                    </p>
                  {%- endif -%}
                </div>
                {%- if block.settings.directions_url != blank -%}
                  <a href="{{ block.settings.directions_url }}" class="kt-contact__showroom-link" target="_blank" rel="noopener">
                    {{ 'sections.contact.directions' | t | default: 'Get Directions' }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Contact Form {%- endcomment -%}
  <div class="kt-contact__form-section">
    <div class="page-width">
      <div class="kt-contact__form-layout">
        <div class="kt-contact__form-intro">
          <span class="kt-contact__label">{{ section.settings.form_label | default: 'Direct Inquiry' }}</span>
          <h2 class="kt-contact__form-heading">{{ section.settings.form_heading_line1 | default: 'Begin Your' }}<br>{{ section.settings.form_heading_line2 | default: 'Journey.' }}</h2>
          <p class="kt-contact__form-desc">{{ section.settings.form_description | default: 'Whether requesting a 3D plan, a material sample kit, or a trade collaboration, our global team is ready to serve.' }}</p>

          <div class="kt-contact__form-social">
            <span class="kt-contact__label">{{ 'sections.contact.follow_us' | t | default: 'Follow Us' }}</span>
            {%- render 'social-icons' -%}
          </div>
        </div>

        <div class="kt-contact__form-wrap">
          {%- form 'contact', id: 'ContactForm' -%}
            {%- if form.posted_successfully? -%}
              <div class="kt-contact__form-success" role="status">
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4 4 10-10"/></svg>
                <div>
                  <strong>{{ 'sections.contact.success_heading' | t | default: 'Message sent' }}</strong>
                  <p>{{ 'sections.contact.success_body' | t | default: 'Thanks — our concierge team will reply within one business day.' }}</p>
                </div>
              </div>
            {%- else -%}
              {%- if form.errors -%}
                <div class="kt-contact__form-errors" role="alert">
                  <strong>{{ 'templates.contact.form.error_heading' | t | default: 'Please fix the following:' }}</strong>
                  <ul>
                    {%- for field in form.errors -%}
                      <li>{{ form.errors.messages[field] }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

              <div class="kt-contact__form-row">
                <div class="kt-contact__form-field">
                  <label for="contact-first-name" class="kt-contact__form-label">{{ 'sections.contact.first_name' | t | default: 'First Name' }}</label>
                  <input type="text" id="contact-first-name" name="contact[first_name]" class="kt-contact__form-input" required autocomplete="given-name" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}">
                </div>
                <div class="kt-contact__form-field">
                  <label for="contact-last-name" class="kt-contact__form-label">{{ 'sections.contact.last_name' | t | default: 'Last Name' }}</label>
                  <input type="text" id="contact-last-name" name="contact[last_name]" class="kt-contact__form-input" required autocomplete="family-name" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}">
                </div>
              </div>
              <div class="kt-contact__form-row">
                <div class="kt-contact__form-field">
                  <label for="contact-email" class="kt-contact__form-label">{{ 'sections.contact.email' | t | default: 'Email Address' }}</label>
                  <input type="email" id="contact-email" name="contact[email]" class="kt-contact__form-input" required autocomplete="email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
                </div>
                <div class="kt-contact__form-field">
                  <label for="contact-phone" class="kt-contact__form-label">{{ 'sections.contact.phone' | t | default: 'Phone Number' }}</label>
                  <input type="tel" id="contact-phone" name="contact[phone]" class="kt-contact__form-input" autocomplete="tel" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
                </div>
              </div>
              <div class="kt-contact__form-field">
                <label for="contact-message" class="kt-contact__form-label">{{ 'sections.contact.message' | t | default: 'How can we assist you?' }}</label>
                <textarea id="contact-message" name="contact[body]" class="kt-contact__form-textarea" rows="4" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
              </div>
              <button type="submit" class="kt-contact__form-submit">
                {{ 'sections.contact.submit' | t | default: 'Submit Inquiry' }}
              </button>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "t:sections.contact-form.settings.header__showrooms.content" },
    { "type": "text", "id": "showrooms_label", "label": "t:sections.contact-form.settings.showrooms_label.label", "default": "Our Locations" },
    { "type": "text", "id": "showrooms_heading", "label": "t:sections.contact-form.settings.showrooms_heading.label", "default": "Visit A Studio" },
    { "type": "header", "content": "t:sections.contact-form.settings.header__contact_form.content" },
    { "type": "text", "id": "form_label", "label": "t:sections.contact-form.settings.form_label.label", "default": "Direct Inquiry" },
    { "type": "text", "id": "form_heading_line1", "label": "t:sections.contact-form.settings.form_heading_line1.label", "default": "Begin Your" },
    { "type": "text", "id": "form_heading_line2", "label": "t:sections.contact-form.settings.form_heading_line2.label", "default": "Journey." },
    { "type": "textarea", "id": "form_description", "label": "t:sections.contact-form.settings.form_description.label", "default": "Whether requesting a 3D plan, a material sample kit, or a trade collaboration, our global team is ready to serve." }
  ],
  "blocks": [
    {
      "type": "showroom",
      "name": "t:sections.contact-form.blocks.showroom.name",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "t:sections.contact-form.blocks.showroom.settings.title.label", "default": "New York Flagship" },
        { "type": "image_picker", "id": "image", "label": "t:sections.contact-form.blocks.showroom.settings.image.label" },
        { "type": "textarea", "id": "address", "label": "t:sections.contact-form.blocks.showroom.settings.address.label", "default": "125 5th Avenue, Suite 300\nNew York, NY 10003" },
        { "type": "text", "id": "phone", "label": "t:sections.contact-form.blocks.showroom.settings.phone.label", "default": "+1 (212) 555-0198" },
        { "type": "text", "id": "email", "label": "t:sections.contact-form.blocks.showroom.settings.email.label", "default": "ny@kitchero.com" },
        { "type": "url", "id": "directions_url", "label": "t:sections.contact-form.blocks.showroom.settings.directions_url.label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name",
      "blocks": [
        { "type": "showroom", "settings": { "title": "New York Flagship", "address": "125 5th Avenue, Suite 300\nNew York, NY 10003", "phone": "+1 (212) 555-0198", "email": "ny@kitchero.com" } },
        { "type": "showroom", "settings": { "title": "Los Angeles Studio", "address": "8440 Melrose Avenue\nWest Hollywood, CA 90069", "phone": "+1 (323) 555-1044", "email": "la@kitchero.com" } }
      ]
    }
  ]
}
{% endschema %}
