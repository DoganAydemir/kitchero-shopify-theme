{{ 'kt-section-contact-form.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Contact Form Section — showrooms grid + inquiry form.
  Birebir from contact/page.tsx.
  Uses {% form 'contact' %} for Shopify form submission.
{%- endcomment -%}

<section class="kt-contact" data-section-id="{{ section.id }}">
  {%- comment -%} Showrooms Grid {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="kt-contact__showrooms">
      <div class="page-width">
        <div class="kt-contact__showrooms-header">
          <span class="kt-contact__label">{{ section.settings.showrooms_label | default: 'Our Locations' }}</span>
          <h2 class="kt-contact__showrooms-title">{{ section.settings.showrooms_heading | default: 'Visit our locations' }}</h2>
        </div>

        <div class="kt-contact__showrooms-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'showroom' -%}
              <div class="kt-contact__showroom" {{ block.shopify_attributes }}>
                <div class="kt-contact__showroom-image-wrap">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 800 | image_tag: class: 'kt-contact__showroom-image', loading: 'lazy', widths: '375, 550, 800', sizes: '(min-width: 750px) 50vw, 100vw', width: block.settings.image.width, height: block.settings.image.height, alt: block.settings.title }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-contact__showroom-image' }}
                  {%- endif -%}
                  <span class="kt-contact__showroom-pin" aria-hidden="true">
                    <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  </span>
                </div>
                <h3 class="kt-contact__showroom-name">{{ block.settings.title }}</h3>
                <div class="kt-contact__showroom-details">
                  {%- if block.settings.address != blank -%}
                    <address class="kt-contact__showroom-address">{{ block.settings.address }}</address>
                  {%- endif -%}
                  <div class="kt-contact__showroom-divider"></div>
                  {%- if block.settings.phone != blank -%}
                    <p class="kt-contact__showroom-meta">
                      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                      {{ block.settings.phone }}
                    </p>
                  {%- endif -%}
                  {%- if block.settings.email != blank -%}
                    <p class="kt-contact__showroom-meta">
                      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                      {{ block.settings.email }}
                    </p>
                  {%- endif -%}
                </div>
                {%- if block.settings.directions_url != blank -%}
                  <a href="{{ block.settings.directions_url | escape }}" class="kt-contact__showroom-link" target="_blank" rel="noopener noreferrer">
                    {{ 'kt.section.contact.directions' | t | default: 'Get Directions' }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Contact Form {%- endcomment -%}
  <div class="kt-contact__form-section">
    <div class="page-width">
      <div class="kt-contact__form-layout">
        <div class="kt-contact__form-intro">
          <span class="kt-contact__label">{{ section.settings.form_label | default: 'Direct Inquiry' }}</span>
          <h2 class="kt-contact__form-heading">{{ section.settings.form_heading_line1 | default: 'Begin Your' }}<br>{{ section.settings.form_heading_line2 | default: 'Journey.' }}</h2>
          <p class="kt-contact__form-desc">{{ section.settings.form_description | default: 'Add a description that invites visitors to reach out.' }}</p>

          <div class="kt-contact__form-social">
            <span class="kt-contact__label">{{ 'kt.section.contact.follow_us' | t | default: 'Follow Us' }}</span>
            {%- render 'social-icons' -%}
          </div>
        </div>

        <div class="kt-contact__form-wrap">
          {%- form 'contact', id: 'ContactForm' -%}
            {%- if form.posted_successfully? -%}
              <div class="kt-contact__form-success" role="status">
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4 4 10-10"/></svg>
                <div>
                  <strong>{{ 'kt.section.contact.success_heading' | t | default: 'Message sent' }}</strong>
                  <p>{{ 'kt.section.contact.success_body' | t | default: 'Thanks — we will reply within one business day.' }}</p>
                </div>
              </div>
            {%- else -%}
              {%- if form.errors -%}
                {%- comment -%}
                  tabindex="-1" + data-form-error-summary makes this
                  container a programmatic-only focus target. assets/
                  global.js's `focusFirstFormError()` picks it up after
                  any submit-with-errors so keyboard users land on the
                  error list instead of being stranded on document.body
                  (WCAG 2.4.3 Focus Order + 3.3.1 Error Identification).
                {%- endcomment -%}
                <div class="kt-contact__form-errors" role="alert" tabindex="-1" data-form-error-summary>
                  <strong>{{ 'kt.contact.form.error_heading' | t | default: 'Please fix the following:' }}</strong>
                  <ul>
                    {%- for field in form.errors -%}
                      <li>{{ form.errors.messages[field] }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

              <div class="kt-contact__form-row">
                <div class="kt-contact__form-field">
                  <label for="contact-first-name" class="kt-contact__form-label kt-form__label--required">{{ 'kt.section.contact.first_name' | t | default: 'First Name' }}</label>
                  <input
                    type="text"
                    id="contact-first-name"
                    name="contact[first_name]"
                    class="kt-contact__form-input"
                    required
                    aria-required="true"
                    autocomplete="given-name"
                    value="{% if form.first_name %}{{ form.first_name | escape }}{% elsif customer %}{{ customer.first_name | escape }}{% endif %}"
                    {% if form.errors contains 'first_name' %}aria-invalid="true" aria-describedby="contact-first-name-error"{% endif %}
                  >
                  {%- render 'form-field-error', form: form, field: 'first_name', describedby_id: 'contact-first-name-error' -%}
                </div>
                <div class="kt-contact__form-field">
                  <label for="contact-last-name" class="kt-contact__form-label kt-form__label--required">{{ 'kt.section.contact.last_name' | t | default: 'Last Name' }}</label>
                  <input
                    type="text"
                    id="contact-last-name"
                    name="contact[last_name]"
                    class="kt-contact__form-input"
                    required
                    aria-required="true"
                    autocomplete="family-name"
                    value="{% if form.last_name %}{{ form.last_name | escape }}{% elsif customer %}{{ customer.last_name | escape }}{% endif %}"
                    {% if form.errors contains 'last_name' %}aria-invalid="true" aria-describedby="contact-last-name-error"{% endif %}
                  >
                  {%- render 'form-field-error', form: form, field: 'last_name', describedby_id: 'contact-last-name-error' -%}
                </div>
              </div>
              <div class="kt-contact__form-row">
                <div class="kt-contact__form-field">
                  <label for="contact-email" class="kt-contact__form-label kt-form__label--required">{{ 'kt.section.contact.email' | t | default: 'Email Address' }}</label>
                  <input
                    type="email"
                    id="contact-email"
                    name="contact[email]"
                    class="kt-contact__form-input"
                    required
                    aria-required="true"
                    inputmode="email"
                    autocomplete="email"
                    value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
                    {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="contact-email-error"{% endif %}
                  >
                  {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'contact-email-error' -%}
                </div>
                <div class="kt-contact__form-field">
                  <label for="contact-phone" class="kt-contact__form-label">{{ 'kt.section.contact.phone' | t | default: 'Phone Number' }}</label>
                  <input
                    type="tel"
                    id="contact-phone"
                    name="contact[phone]"
                    class="kt-contact__form-input"
                    inputmode="tel"
                    autocomplete="tel"
                    value="{% if form.phone %}{{ form.phone | escape }}{% elsif customer %}{{ customer.phone | escape }}{% endif %}"
                    {% if form.errors contains 'phone' %}aria-invalid="true" aria-describedby="contact-phone-error"{% endif %}
                  >
                  {%- render 'form-field-error', form: form, field: 'phone', describedby_id: 'contact-phone-error' -%}
                </div>
              </div>
              <div class="kt-contact__form-field">
                <label for="contact-message" class="kt-contact__form-label kt-form__label--required">{{ 'kt.section.contact.message' | t | default: 'How can we assist you?' }}</label>
                <textarea
                  id="contact-message"
                  name="contact[body]"
                  class="kt-contact__form-textarea"
                  rows="4"
                  required
                  aria-required="true"
                  {% if form.errors contains 'body' %}aria-invalid="true" aria-describedby="contact-message-error"{% endif %}
                >{% if form.body %}{{ form.body | escape }}{% endif %}</textarea>
                {%- render 'form-field-error', form: form, field: 'body', describedby_id: 'contact-message-error' -%}
              </div>

              {%- comment -%}
                Honeypot — bots fill every input; humans skip the
                hidden one. Backend should reject any submission with
                a non-empty `contact[website]`. Position via CSS, not
                `display:none`/`visibility:hidden` (some bots skip
                hidden fields by inspecting computed style).
              {%- endcomment -%}
              <p class="kt-form__honeypot" aria-hidden="true" inert>
                <label for="contact-website-trap">{{ 'kt.a11y.honeypot' | t | default: 'Leave this field empty' }}</label>
                <input type="text" id="contact-website-trap" name="contact[website]" tabindex="-1" autocomplete="off" aria-hidden="true">
              </p>
              <button type="submit" class="kt-contact__form-submit">
                {{ 'kt.section.contact.submit' | t | default: 'Submit Inquiry' }}
              </button>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "div",
  "class": "section",
  "settings": [
    { "type": "header", "content": "t:sections.contact-form.settings.header__showrooms.content" },
    { "type": "text", "id": "showrooms_label", "label": "t:sections.contact-form.settings.showrooms_label.label", "default": "Our Locations" },
    { "type": "text", "id": "showrooms_heading", "label": "t:sections.contact-form.settings.showrooms_heading.label", "default": "Visit our locations" },
    { "type": "header", "content": "t:sections.contact-form.settings.header__contact_form.content" },
    { "type": "text", "id": "form_label", "label": "t:sections.contact-form.settings.form_label.label", "default": "Eyebrow" },
    { "type": "text", "id": "form_heading_line1", "label": "t:sections.contact-form.settings.form_heading_line1.label", "default": "Heading" },
    { "type": "text", "id": "form_heading_line2", "label": "t:sections.contact-form.settings.form_heading_line2.label", "default": "Subheading" },
    { "type": "textarea", "id": "form_description", "label": "t:sections.contact-form.settings.form_description.label", "default": "Add a description that invites visitors to reach out." }
  ],
  "blocks": [
    {
      "type": "showroom",
      "name": "t:sections.contact-form.blocks.showroom.name",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "t:sections.contact-form.blocks.showroom.settings.title.label", "default": "Location name" },
        { "type": "image_picker", "id": "image", "label": "t:sections.contact-form.blocks.showroom.settings.image.label" },
        { "type": "textarea", "id": "address", "label": "t:sections.contact-form.blocks.showroom.settings.address.label" },
        { "type": "text", "id": "phone", "label": "t:sections.contact-form.blocks.showroom.settings.phone.label" },
        { "type": "text", "id": "email", "label": "t:sections.contact-form.blocks.showroom.settings.email.label" },
        { "type": "url", "id": "directions_url", "label": "t:sections.contact-form.blocks.showroom.settings.directions_url.label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name",
      "blocks": [
        { "type": "showroom", "settings": { "title": "Location 1" } },
        { "type": "showroom", "settings": { "title": "Location 2" } }
      ]
    }
  ]
}
{% endschema %}
