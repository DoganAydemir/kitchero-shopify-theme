{{ 'kt-section-before-after.css' | asset_url | stylesheet_tag }}

<section
  class="kt-before-after"
  data-section-id="{{ section.id }}"
  data-section-type="before-after"
  aria-labelledby="BeforeAfterTitle-{{ section.id }}"
>
  <div class="page-width">
    <div class="kt-before-after__header">
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      {%- assign heading_default = 'kt.section.before_after.heading_default' | t -%}
      {%- assign subtitle_default = 'kt.section.before_after.subtitle_default' | t -%}
      <{{ heading_tag }} id="BeforeAfterTitle-{{ section.id }}" class="kt-before-after__title">{{ section.settings.heading | default: heading_default }}</{{ heading_tag }}>
      <p class="kt-before-after__subtitle">{{ section.settings.subtitle | default: subtitle_default }}</p>
    </div>

    {%- comment -%}
      Pre-assign alt labels: Liquid parses inline pipe chains inside
      image_tag's `alt:` param greedily, so we build them first.
    {%- endcomment -%}
    {%- assign before_label = 'kt.section.before_after.before' | t | default: 'Before' -%}
    {%- assign after_label = 'kt.section.before_after.after' | t | default: 'After' -%}
    {%- assign heading_text = section.settings.heading | default: '' -%}
    {%- if heading_text != '' -%}
      {%- assign alt_before = heading_text | append: ' — ' | append: before_label -%}
      {%- assign alt_after = heading_text | append: ' — ' | append: after_label -%}
    {%- else -%}
      {%- assign alt_before = before_label -%}
      {%- assign alt_after = after_label -%}
    {%- endif -%}

    <div class="kt-before-after__slider" data-before-after>
      {%- comment -%} After image (full background) {%- endcomment -%}
      {%- if section.settings.after_image != blank -%}
        {{ section.settings.after_image | image_url: width: 2000 | image_tag: class: 'kt-before-after__image', loading: 'lazy', widths: '550, 750, 1100, 1600, 2000', sizes: '100vw', width: section.settings.after_image.width, height: section.settings.after_image.height, alt: alt_after }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-before-after__image' }}
      {%- endif -%}

      {%- comment -%} Before image (clipped left) {%- endcomment -%}
      <div class="kt-before-after__before-wrap" data-before-clip style="clip-path: inset(0 50% 0 0);">
        {%- if section.settings.before_image != blank -%}
          {{ section.settings.before_image | image_url: width: 2000 | image_tag: class: 'kt-before-after__image', loading: 'lazy', widths: '550, 750, 1100, 1600, 2000', sizes: '100vw', width: section.settings.before_image.width, height: section.settings.before_image.height, alt: alt_before }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg kt-before-after__image' }}
        {%- endif -%}
      </div>

      <div class="kt-before-after__line" data-before-line style="left: 50%;"></div>
      <div
        class="kt-before-after__handle"
        data-before-handle
        style="left: 50%;"
        role="slider"
        tabindex="0"
        aria-label="{{ 'kt.section.before_after.compare_label' | t | default: 'Drag to compare before and after' }}"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
      >
        {% render 'icon-chevron-left', stroke_width: 2 %}
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
      </div>

      <span class="kt-before-after__label kt-before-after__label--before">{{ 'kt.section.before_after.before' | t | default: 'Before' }}</span>
      <span class="kt-before-after__label kt-before-after__label--after">{{ 'kt.section.before_after.after' | t | default: 'After' }}</span>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-before-after.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.before-after.name",
  "tag": "div",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.before-after.settings.heading.label",
      "default": "See the Difference"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.before-after.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.before-after.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.before-after.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.before-after.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.before-after.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.before-after.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.before-after.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.before-after.settings.subtitle.label",
      "default": "Drag to compare before and after"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "t:sections.before-after.settings.before_image.label",
      "info": "t:sections.before-after.settings.before_image.info"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "t:sections.before-after.settings.after_image.label",
      "info": "t:sections.before-after.settings.after_image.info"
    }
  ],
  "presets": [
    {
      "name": "t:sections.before-after.presets.name"
    }
  ]
}
{% endschema %}
