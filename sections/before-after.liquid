{{ 'section-before-after.css' | asset_url | stylesheet_tag }}

<section class="kt-before-after color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}" data-section-type="before-after">
  <div class="page-width">
    <div class="kt-before-after__header">
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-before-after__title">{{ section.settings.heading | default: 'See the Difference' }}</{{ heading_tag }}>
      <p class="kt-before-after__subtitle">{{ section.settings.subtitle | default: 'Drag to compare before and after' }}</p>
    </div>

    <div class="kt-before-after__slider" data-before-after>
      {%- comment -%} After image (full background) {%- endcomment -%}
      {%- if section.settings.after_image != blank -%}
        {{ section.settings.after_image | image_url: width: 1600 | image_tag: class: 'kt-before-after__image', loading: 'lazy', widths: '750, 1100, 1600', sizes: '100vw', width: section.settings.after_image.width, height: section.settings.after_image.height, alt: 'After' }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-before-after__image' }}
      {%- endif -%}

      {%- comment -%} Before image (clipped left) {%- endcomment -%}
      <div class="kt-before-after__before-wrap" data-before-clip style="clip-path: inset(0 50% 0 0);">
        {%- if section.settings.before_image != blank -%}
          {{ section.settings.before_image | image_url: width: 1600 | image_tag: class: 'kt-before-after__image', loading: 'lazy', widths: '750, 1100, 1600', sizes: '100vw', width: section.settings.before_image.width, height: section.settings.before_image.height, alt: 'Before' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg kt-before-after__image' }}
        {%- endif -%}
      </div>

      <div class="kt-before-after__line" data-before-line style="left: 50%;"></div>
      <div class="kt-before-after__handle" data-before-handle style="left: 50%;">
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
      </div>

      <span class="kt-before-after__label kt-before-after__label--before">{{ 'sections.before_after.before' | t | default: 'Before' }}</span>
      <span class="kt-before-after__label kt-before-after__label--after">{{ 'sections.before_after.after' | t | default: 'After' }}</span>
    </div>
  </div>
</section>

<script src="{{ 'section-before-after.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Before/after image",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Difference"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Drag to compare before and after"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Before/after image"
    }
  ]
}
{% endschema %}
