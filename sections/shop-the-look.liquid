{{ 'kt-section-shop-the-look.css' | asset_url | stylesheet_tag }}

<section class="kt-shop-the-look" data-section-id="{{ section.id }}" data-section-type="shop-the-look">
  <div class="page-width">
    <div class="kt-shop-the-look__header">
      <span class="kt-shop-the-look__label">{{ section.settings.label | default: 'Visual Commerce' }}</span>
      {%- assign heading_tag = section.settings.heading_tag | default: 'h2' -%}
      <{{ heading_tag }} class="kt-shop-the-look__title">{{ section.settings.heading | default: 'Interactive <em>shopping</em> environments' }}</{{ heading_tag }}>
    </div>

    {%- comment -%} Wrapper is NOT overflow-hidden so popups escape {%- endcomment -%}
    <div class="kt-shop-the-look__wrapper">
      {%- comment -%} Image container: rounded & clipped {%- endcomment -%}
      <div class="kt-shop-the-look__image-container">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'kt-shop-the-look__image', loading: 'lazy', widths: '550, 750, 1100, 1600, 2000', sizes: '100vw', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.heading | default: '' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="kt-shop-the-look__image-overlay" aria-hidden="true"></div>
      </div>

      {%- comment -%} Hotspot layer — ABOVE clipped container {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'hotspot' -%}
          <div
            class="kt-shop-the-look__hotspot-wrap"
            style="top: {{ block.settings.vertical_position }}%; left: {{ block.settings.horizontal_position }}%;"
            data-hotspot-id="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <button
              type="button"
              class="kt-shop-the-look__hotspot"
              data-hotspot-toggle="{{ block.id }}"
              aria-label="{{ block.settings.product_title | default: 'Product' | escape }}"
            >
              {% render 'icon-plus', width: 18, height: 18 %}
            </button>

            {%- comment -%} Desktop popup {%- endcomment -%}
            <div
              class="kt-shop-the-look__popup{% if block.settings.vertical_position > 55 %} kt-shop-the-look__popup--above{% else %} kt-shop-the-look__popup--below{% endif %}{% if block.settings.horizontal_position > 70 %} kt-shop-the-look__popup--right{% elsif block.settings.horizontal_position < 30 %} kt-shop-the-look__popup--left{% else %} kt-shop-the-look__popup--center{% endif %}"
              data-hotspot-popup="{{ block.id }}"
              aria-hidden="true"
              inert
            >
              {%- comment -%}
                Empty-state placeholder rule: the popup card
                anchors visually around the product image; dropping
                the image-wrap entirely when blank leaves the meta +
                CTA floating without context. Fall through to
                Shopify's product-1 SVG placeholder so the popup
                composition stays intact on a fresh install where the
                merchant has added a hotspot but hasn't yet picked
                an image for the swatch / look detail.
              {%- endcomment -%}
              <div class="kt-shop-the-look__popup-image-wrap">
                {%- if block.settings.product_image != blank -%}
                  {{ block.settings.product_image | image_url: width: 400 | image_tag: class: 'kt-shop-the-look__popup-image', loading: 'lazy', width: 400, height: 400, alt: block.settings.product_title | default: '' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-shop-the-look__popup-image' }}
                {%- endif -%}
              </div>
              <div class="kt-shop-the-look__popup-meta">
                <h3 class="kt-shop-the-look__popup-name">{{ block.settings.product_title }}</h3>
                {%- comment -%}
                  R143 SHOP-THE-LOOK-1: hide the price element entirely
                  when blank rather than rendering an empty `<span>`.
                  Empty span on fresh install (no merchant value yet)
                  reads as a layout glitch — reviewer flag for "missing
                  data". Suppressing keeps the popup card clean until
                  merchant fills it in.
                {%- endcomment -%}
                {%- if block.settings.product_price != blank -%}
                  <span class="kt-shop-the-look__popup-price">{{ block.settings.product_price }}</span>
                {%- endif -%}
              </div>
              {%- comment -%}
                Only emit the CTA when the merchant actually supplied a
                product URL for this hotspot. Falling back to `href="#"`
                looks functional but scrolls to page top — misleading for
                shoppers and a Theme Store "broken link" red flag. In the
                theme editor we surface a hint so merchants notice the
                gap; on the live storefront we render nothing.
              {%- endcomment -%}
              {%- if block.settings.product_link != blank -%}
                <a href="{{ block.settings.product_link | escape }}" class="kt-shop-the-look__popup-link">
                  {{ 'kt.section.shop_the_look.view_details' | t | default: 'View Details' }}
                  {% render 'icon-arrow-right', width: 12, height: 12 %}
                </a>
              {%- elsif request.design_mode -%}
                <p class="kt-shop-the-look__popup-empty">
                  {{ 'kt.section.shop_the_look.empty_link_notice' | t }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile bottom sheet {%- endcomment -%}
    <div class="kt-shop-the-look__mobile-sheet" data-mobile-sheet aria-hidden="true" inert>
      <div class="kt-shop-the-look__mobile-sheet-inner">
        <button type="button" class="kt-shop-the-look__mobile-sheet-close" data-mobile-sheet-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
          {% render 'icon-close', width: 20, height: 20, stroke_width: 1.5 %}
        </button>
        <div class="kt-shop-the-look__mobile-sheet-content">
          <div class="kt-shop-the-look__mobile-sheet-img" data-mobile-sheet-img></div>
          <div>
            {%- comment -%}
              Mobile sheet is a dynamic bottom-sheet that reveals on
              hotspot tap — not a heading in the page outline. Was h4
              which jumped the heading order. <p> + strong styling
              keeps the visual weight without polluting the outline.
            {%- endcomment -%}
            <p class="kt-shop-the-look__mobile-sheet-name" data-mobile-sheet-name></p>
            <p class="kt-shop-the-look__mobile-sheet-price" data-mobile-sheet-price></p>
            {%- comment -%}
              Mobile sheet "View Product" link is a JS-populated template:
              kt-section-shop-the-look.js copies the active hotspot's
              product URL onto this anchor each time the sheet opens.
              Default href points at the shop root so a premature click
              (JS still loading, or a hotspot without product_link) lands
              on a real page instead of scrolling to the top. JS also
              hides this link outright when the active hotspot has no
              product link configured.
            {%- endcomment -%}
            <a href="{{ routes.root_url }}" class="kt-shop-the-look__mobile-sheet-link" data-mobile-sheet-link>
              {{ 'kt.section.shop_the_look.view_product' | t | default: 'View Product' }}
              {% render 'icon-arrow-right', width: 14, height: 14 %}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'kt-section-shop-the-look.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.shop-the-look.name",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.shop-the-look.settings.label.label",
      "default": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.shop-the-look.settings.heading.label",
      "default": "Interactive <em>shopping</em> environments"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.shop-the-look.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.shop-the-look.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.shop-the-look.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.shop-the-look.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.shop-the-look.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.shop-the-look.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.shop-the-look.settings.heading_tag.options__6.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.shop-the-look.settings.image.label"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "t:sections.shop-the-look.blocks.hotspot.name",
      "limit": 6,
      "settings": [
        {
          "type": "range",
          "id": "horizontal_position",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "t:sections.shop-the-look.blocks.hotspot.settings.horizontal_position.label",
          "default": 35
        },
        {
          "type": "range",
          "id": "vertical_position",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "t:sections.shop-the-look.blocks.hotspot.settings.vertical_position.label",
          "default": 25
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "t:sections.shop-the-look.blocks.hotspot.settings.product_title.label",
          "default": "Product name"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "t:sections.shop-the-look.blocks.hotspot.settings.product_price.label",
          "info": "t:sections.shop-the-look.blocks.hotspot.settings.product_price.info"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "t:sections.shop-the-look.blocks.hotspot.settings.product_image.label"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "t:sections.shop-the-look.blocks.hotspot.settings.product_link.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["cart", "search", "password", "gift_card", "404"]
  },
  "presets": [
    {
      "name": "t:sections.shop-the-look.presets.name",
      "category": "t:sections.categories.image.label",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "horizontal_position": 35,
            "vertical_position": 25,
            "product_title": "Product name"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "horizontal_position": 55,
            "vertical_position": 65,
            "product_title": "Product name"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "horizontal_position": 75,
            "vertical_position": 45,
            "product_title": "Product name"
          }
        }
      ]
    }
  ]
}
{% endschema %}
