{{ 'section-shop-the-look.css' | asset_url | stylesheet_tag }}

<section class="kt-shop-the-look" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="kt-shop-the-look__header">
      <h2 class="kt-shop-the-look__title">{{ section.settings.heading | default: 'Shop the Look' }}</h2>
      <p class="kt-shop-the-look__subtitle">{{ section.settings.subtitle | default: 'Click hotspots to discover featured products' }}</p>
    </div>

    <div class="kt-shop-the-look__container">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'kt-shop-the-look__image', loading: 'lazy', widths: '750, 1100, 1600', sizes: '100vw', width: section.settings.image.width, height: section.settings.image.height, alt: section.settings.heading | default: '' }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg kt-shop-the-look__image' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'hotspot' -%}
          <a
            href="{{ block.settings.product_link | default: '#' }}"
            class="kt-shop-the-look__hotspot"
            style="top: {{ block.settings.vertical_position }}%; left: {{ block.settings.horizontal_position }}%;"
            {{ block.shopify_attributes }}
            aria-label="{{ block.settings.product_title | default: 'Product' }}"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            <span class="kt-shop-the-look__tooltip">
              <span class="kt-shop-the-look__tooltip-title">{{ block.settings.product_title }}</span>
              {%- if block.settings.product_price != blank -%}
                <span class="kt-shop-the-look__tooltip-price">{{ block.settings.product_price }}</span>
              {%- endif -%}
            </span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop the look",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the Look" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Click hotspots to discover featured products" },
    { "type": "image_picker", "id": "image", "label": "Room image" }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "limit": 8,
      "settings": [
        { "type": "range", "id": "horizontal_position", "min": 5, "max": 95, "step": 1, "unit": "%", "label": "Horizontal position", "default": 50 },
        { "type": "range", "id": "vertical_position", "min": 5, "max": 95, "step": 1, "unit": "%", "label": "Vertical position", "default": 50 },
        { "type": "text", "id": "product_title", "label": "Product name", "default": "Heritage Cabinet" },
        { "type": "text", "id": "product_price", "label": "Price", "default": "$1,200" },
        { "type": "url", "id": "product_link", "label": "Product link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the look",
      "blocks": [
        { "type": "hotspot", "settings": { "horizontal_position": 30, "vertical_position": 45, "product_title": "Heritage Base Cabinet", "product_price": "$1,450" } },
        { "type": "hotspot", "settings": { "horizontal_position": 65, "vertical_position": 35, "product_title": "Brass Pull Handle", "product_price": "$24" } }
      ]
    }
  ]
}
{% endschema %}
