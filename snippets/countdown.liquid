{%- comment -%}
  Countdown Pill — shows remaining time for limited offers.
  Reads product.metafields.custom.deal_ends_at (date_time type).
  If metafield is blank or past → nothing renders.
  JS ticks every second, hides when expired.

  Accepts:
  - product: {Object} Shopify product
{%- endcomment -%}

{%- assign deal_ends_at = product.metafields.custom.deal_ends_at.value -%}

{%- if deal_ends_at != blank -%}
  <div
    class="kt-countdown"
    data-countdown
    data-ends-at="{{ deal_ends_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
    aria-label="{{ 'sections.countdown.label' | t | default: 'Limited time offer' }}"
  >
    <svg class="kt-countdown__icon" aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"></circle>
      <polyline points="12 6 12 12 16 14"></polyline>
    </svg>
    <span class="kt-countdown__time" data-countdown-display>
      <span data-countdown-days>00</span>{{ 'sections.countdown.days' | t | default: 'D' }}
      <span class="kt-countdown__sep">:</span>
      <span data-countdown-hours>00</span>{{ 'sections.countdown.hours' | t | default: 'H' }}
      <span class="kt-countdown__sep">:</span>
      <span data-countdown-minutes>00</span>{{ 'sections.countdown.minutes' | t | default: 'M' }}
      <span class="kt-countdown__sep">:</span>
      <span data-countdown-seconds>00</span>{{ 'sections.countdown.seconds' | t | default: 'S' }}
    </span>
  </div>
{%- endif -%}
