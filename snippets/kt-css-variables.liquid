{%- doc -%}
  Kitchero inline CSS variables.

  Emits @font-face declarations, per-scheme design tokens, and global tokens
  (typography, layout, spacing, buttons, inputs, cards, media, drawer, badge)
  as a single `{% style %}` block rendered from `layout/theme.liquid`.

  Token naming convention: all custom properties use the `--kt-*` prefix
  and are grouped by concern (`--kt-c-*` color, `--kt-f-*` font,
  `--kt-btn-*`, `--kt-pcard-*`, etc.). Scheme selectors use the attribute
  form `[data-kt-scheme="<id>"]` applied on `<body>`.

  Consumers: `assets/base.css`, `assets/component-*.css`, and every
  `assets/section-*.css` file. When renaming a token, update every
  `var(--kt-*)` consumer in lockstep.
{%- enddoc -%}
{%- liquid
  assign body_font = settings.kt_body_font
  assign body_font_bold = body_font | font_modify: 'weight', 'bold'
  assign body_font_italic = body_font | font_modify: 'style', 'italic'
  assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
  assign heading_font = settings.kt_heading_font
  assign accent_font = settings.kt_accent_font
  assign accent_font_italic = accent_font | font_modify: 'style', 'italic'
  assign accent_font_bold = accent_font | font_modify: 'weight', 'bold'
-%}
{% style %}
  {{ body_font | font_face: font_display: 'swap' }}
  {{ body_font_bold | font_face: font_display: 'swap' }}
  {{ body_font_italic | font_face: font_display: 'swap' }}
  {{ body_font_bold_italic | font_face: font_display: 'swap' }}
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ accent_font | font_face: font_display: 'swap' }}
  {{ accent_font_italic | font_face: font_display: 'swap' }}
  {{ accent_font_bold | font_face: font_display: 'swap' }}

  {%- for scheme in settings.kt_schemes -%}
    {%- liquid
      assign bg = scheme.settings.surface
      assign bg_brightness = bg | color_brightness
      if bg_brightness <= 26
        assign bg_contrast = bg | color_lighten: 50
      elsif bg_brightness <= 65
        assign bg_contrast = bg | color_lighten: 5
      else
        assign bg_contrast = bg | color_darken: 25
      endif
    -%}
    {%- if forloop.first -%}
      :root,
      body,
    {%- endif -%}
    [data-kt-scheme="{{ scheme.id }}"] {
      --kt-c-bg: {{ bg.red }},{{ bg.green }},{{ bg.blue }};
      --kt-c-bg-gradient: {% if scheme.settings.surface_gradient != empty %}{{ scheme.settings.surface_gradient }}{% else %}{{ bg }}{% endif %};
      --kt-c-bg-contrast: {{ bg_contrast.red }},{{ bg_contrast.green }},{{ bg_contrast.blue }};
      --kt-c-fg: {{ scheme.settings.text_primary.red }},{{ scheme.settings.text_primary.green }},{{ scheme.settings.text_primary.blue }};
      --kt-c-shadow: {{ scheme.settings.shadow_color.red }},{{ scheme.settings.shadow_color.green }},{{ scheme.settings.shadow_color.blue }};
      --kt-c-action: {{ scheme.settings.action.red }},{{ scheme.settings.action.green }},{{ scheme.settings.action.blue }};
      --kt-c-action-text: {{ scheme.settings.action_text.red }},{{ scheme.settings.action_text.green }},{{ scheme.settings.action_text.blue }};
      --kt-c-action-alt: {{ bg.red }},{{ bg.green }},{{ bg.blue }};
      --kt-c-action-alt-text: {{ scheme.settings.link_text.red }},{{ scheme.settings.link_text.green }},{{ scheme.settings.link_text.blue }};
      --kt-c-link: {{ scheme.settings.link_text.red }},{{ scheme.settings.link_text.green }},{{ scheme.settings.link_text.blue }};
      --kt-c-badge-text: {{ scheme.settings.text_primary.red }},{{ scheme.settings.text_primary.green }},{{ scheme.settings.text_primary.blue }};
      --kt-c-badge-bg: {{ bg.red }},{{ bg.green }},{{ bg.blue }};
      --kt-c-badge-border: {{ scheme.settings.text_primary.red }},{{ scheme.settings.text_primary.green }},{{ scheme.settings.text_primary.blue }};
      --kt-c-payment-terms-bg: rgb({{ bg.rgb }});
    }
  {%- endfor -%}

  body {
    color: rgba(var(--kt-c-fg), 0.75);
    background-color: rgb(var(--kt-c-bg));
  }

  :root {
    --kt-f-body-family: {{ body_font.family }}, {{ body_font.fallback_families }};
    --kt-f-body-style: {{ body_font.style }};
    --kt-f-body-weight: {{ body_font.weight }};
    --kt-f-body-weight-bold: {{ body_font.weight | plus: 300 | at_most: 1000 }};
    --kt-f-heading-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --kt-f-heading-style: {{ heading_font.style }};
    --kt-f-heading-weight: {{ heading_font.weight }};
    --kt-f-accent-family: {{ accent_font.family }}, {{ accent_font.fallback_families }};
    --kt-f-body-scale: {{ settings.kt_body_scale | divided_by: 100.0 }};
    --kt-f-heading-scale: {{ settings.kt_heading_scale | times: 1.0 | divided_by: settings.kt_body_scale }};

    --kt-page-max: {{ settings.kt_page_width | divided_by: 10 }}rem;

    --kt-gap-sections-d: {{ settings.kt_section_spacing }}px;
    --kt-gap-sections-m: {% if settings.kt_section_spacing < 24 %}{{ settings.kt_section_spacing }}{% else %}{{ settings.kt_section_spacing | times: 0.7 | round | at_least: 20 }}{% endif %}px;
    --kt-gap-grid-y-d: {{ settings.kt_grid_spacing_y }}px;
    --kt-gap-grid-x-d: {{ settings.kt_grid_spacing_x }}px;
    --kt-gap-grid-y-m: {{ settings.kt_grid_spacing_y | divided_by: 2 }}px;
    --kt-gap-grid-x-m: {{ settings.kt_grid_spacing_x | divided_by: 2 }}px;

    --kt-btn-radius: {{ settings.kt_btn_radius }}px;
    --kt-btn-border-w: {% if settings.kt_btn_border_op > 0 %}{{ settings.kt_btn_border_w }}{% else %}0{% endif %}px;
    --kt-btn-border-op: {{ settings.kt_btn_border_op | divided_by: 100.0 }};
    --kt-btn-shadow-op: {{ settings.kt_btn_shadow_op | divided_by: 100.0 }};
    --kt-btn-shadow-x: {{ settings.kt_btn_shadow_x }}px;
    --kt-btn-shadow-y: {{ settings.kt_btn_shadow_y }}px;
    --kt-btn-shadow-blur: {{ settings.kt_btn_shadow_blur }}px;

    --kt-input-radius: {{ settings.kt_input_radius }}px;
    --kt-input-border-w: {{ settings.kt_input_border_w }}px;
    --kt-input-border-op: {{ settings.kt_input_border_op | divided_by: 100.0 }};

    --kt-badge-radius: {{ settings.kt_badge_radius | divided_by: 10.0 }}rem;

    --kt-pcard-img-pad: {{ settings.kt_pcard_img_pad | divided_by: 10.0 }}rem;
    --kt-pcard-radius: {{ settings.kt_pcard_radius | divided_by: 10.0 }}rem;
    --kt-pcard-text-align: {{ settings.kt_pcard_text_align }};
    --kt-pcard-border-w: {{ settings.kt_pcard_border_w | divided_by: 10.0 }}rem;
    --kt-pcard-border-op: {{ settings.kt_pcard_border_op | divided_by: 100.0 }};
    --kt-pcard-shadow-op: {{ settings.kt_pcard_shadow_op | divided_by: 100.0 }};

    --kt-ccard-img-pad: {{ settings.kt_ccard_img_pad | divided_by: 10.0 }}rem;
    --kt-ccard-radius: {{ settings.kt_ccard_radius | divided_by: 10.0 }}rem;

    --kt-media-pad: {{ settings.kt_media_pad }}px;
    --kt-media-border-op: {{ settings.kt_media_border_op | divided_by: 100.0 }};
    --kt-media-border-w: {{ settings.kt_media_border_w }}px;
    --kt-media-radius: {{ settings.kt_media_radius }}px;

    --kt-drawer-border-w: {{ settings.kt_drawer_border_w }}px;
    --kt-drawer-border-op: {{ settings.kt_drawer_border_op | divided_by: 100.0 }};
  }

  *,
  *::before,
  *::after {
    box-sizing: inherit;
  }

  html {
    box-sizing: border-box;
    font-size: calc(var(--kt-f-body-scale) * 100%);
    height: 100%;
  }

  body {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    grid-template-columns: 100%;
    min-height: 100%;
    margin: 0;
    font-size: 0.9375rem;
    letter-spacing: 0.02rem;
    line-height: 1.6;
    font-family: var(--kt-f-body-family);
    font-style: var(--kt-f-body-style);
    font-weight: var(--kt-f-body-weight);
  }

  @media screen and (min-width: 750px) {
    body {
      font-size: 1rem;
    }
  }
{% endstyle %}
{%- comment -%} Expose the active scheme id for the body tag in theme.liquid. {%- endcomment -%}
