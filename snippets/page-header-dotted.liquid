{%- comment -%}
  Page Header — Dotted
  Shared "architectural" page header with layered dotted grid + parallax
  markers. Ported from PageHeader.tsx (used across the Next.js theme on
  feature showcase pages).

  Accepts:
  - eyebrow: {String} tiny uppercase category label (optional; hides if blank)
  - title: {String} main heading (required)
  - description: {String} supporting paragraph (optional)
  - count_text: {String} small pill badge on the right (optional, e.g. "4 Variants")
  - heading_tag: {String} semantic tag — 'h1' (default) or 'h2'
  - meta_html: {String} pre-built HTML row rendered between title and description
                (optional, e.g. article date + author from main-article.liquid)

  Visual layers:
    1. Base matrix grid (static 24px radial-gradient dots, opacity 0.18)
    2. Major parallax dots (80px dots, opacity 0.22, drift 20%)
    3. Scanlines (1px horizontal lines, opacity 0.05)
    4. Technical `+` markers (opacity 0.3, drift 35%)

  Animations: GSAP reveals the content (y:50 → 0, opacity 0 → 1) and
  scrolls layers 2 + 4 on `window` scroll. Respects
  `prefers-reduced-motion`. CSS on its own renders the static layout so
  the header looks right even before JS runs.
{%- endcomment -%}

{{ 'kt-page-header-dotted.css' | asset_url | stylesheet_tag }}

{%- assign heading_tag = heading_tag | default: 'h1' -%}
{%- assign compact_class = '' -%}
{%- if compact -%}
  {%- assign compact_class = ' kt-page-header-dotted--compact' -%}
{%- endif -%}

<section
  class="kt-page-header-dotted{{ compact_class }}"
  data-section-id="{{ section.id }}"
  data-dotted-header
  aria-labelledby="DottedHeaderTitle-{{ section.id | default: 'static' }}"
>
  {%- comment -%} Layer 1: Base matrix grid (static) {%- endcomment -%}
  <div class="kt-page-header-dotted__dots-base" aria-hidden="true"></div>

  {%- comment -%} Layer 2: Major parallax dots (JS drifts on scroll) {%- endcomment -%}
  <div class="kt-page-header-dotted__dots-parallax" data-parallax-dots aria-hidden="true"></div>

  {%- comment -%} Layer 3: Scanlines (static) {%- endcomment -%}
  <div class="kt-page-header-dotted__scanlines" aria-hidden="true"></div>

  {%- comment -%} Layer 4: Technical plus markers (parallax) {%- endcomment -%}
  <div class="kt-page-header-dotted__markers" data-parallax-markers aria-hidden="true">
    <span class="kt-page-header-dotted__marker kt-page-header-dotted__marker--1" aria-hidden="true">+</span>
    <span class="kt-page-header-dotted__marker kt-page-header-dotted__marker--2" aria-hidden="true">+</span>
    <span class="kt-page-header-dotted__marker kt-page-header-dotted__marker--3" aria-hidden="true">+</span>
    <span class="kt-page-header-dotted__marker kt-page-header-dotted__marker--4" aria-hidden="true">+</span>
  </div>

  <div class="page-width">
    <div class="kt-page-header-dotted__inner">
      <div class="kt-page-header-dotted__text">
        {%- if eyebrow != blank -%}
          <div class="kt-page-header-dotted__eyebrow-wrap">
            <span class="kt-page-header-dotted__eyebrow" data-dotted-anim>{{ eyebrow }}</span>
          </div>
        {%- endif -%}

        {%- comment -%}
          Gate the heading on `title != blank`. Without this guard the
          template emits an empty `<h1></h1>` when a merchant has not
          filled in the title setting yet — empty headings fail axe /
          Lighthouse a11y checks AND give Theme Store reviewers a
          visible "ghost row" above the page content. Decorative dot
          layers + section markers still render, so the visual rhythm
          is preserved; only the heading element is dropped when blank.
        {%- endcomment -%}
        {%- if title != blank -%}
          <div class="kt-page-header-dotted__title-wrap">
            <{{ heading_tag }}
              id="DottedHeaderTitle-{{ section.id | default: 'static' }}"
              class="kt-page-header-dotted__title"
              data-dotted-anim
            >{{ title }}</{{ heading_tag }}>
          </div>
        {%- endif -%}

        {%- comment -%}
          Optional inline meta row (article date + author, etc.).
          Callers pass pre-built HTML via the `meta_html` parameter
          using a `{%- capture -%}` block; renders right under the
          title and above the description, inside the dotted band
          itself so editorial pages keep one cohesive hero rather
          than splitting meta onto a separate strip below.
        {%- endcomment -%}
        {%- if meta_html != blank -%}
          <div class="kt-page-header-dotted__meta-wrap" data-dotted-anim>
            {{ meta_html }}
          </div>
        {%- endif -%}

        {%- if description != blank -%}
          <div class="kt-page-header-dotted__desc-wrap">
            <p class="kt-page-header-dotted__desc" data-dotted-anim>{{ description }}</p>
          </div>
        {%- endif -%}
      </div>

      {%- if count_text != blank -%}
        <div class="kt-page-header-dotted__count-wrap">
          <span class="kt-page-header-dotted__count" data-dotted-anim>{{ count_text }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%}
  Breadcrumb trail. The dotted header is the canonical intro
  component for page / blog / collection / cart / deals / news-
  letter templates, so rendering the breadcrumb HERE — right
  after the dotted `<section>` closes and before whatever body
  the template puts next — guarantees the trail always sits
  directly below the intro and above the body, on every template
  that uses this snippet. Gated by the theme-global toggle so
  merchants can hide all breadcrumbs from one switch.
{%- endcomment -%}
{%- if settings.kt_show_breadcrumbs -%}
  {%- render 'breadcrumbs', class_extra: 'kt-breadcrumbs-wrap' -%}
{%- endif -%}

<script src="{{ 'kt-page-header-dotted.js' | asset_url }}" defer="defer"></script>
