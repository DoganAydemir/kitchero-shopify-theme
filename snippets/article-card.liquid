{%- comment -%}
  Article Card — used in blog listing grid, search results, and
  related-articles. Birebir from Next.js /blog: portrait 3:4 thumb
  with floating category pill, meta row (date + rule), big serif
  title, 3-line clamped excerpt, and a "Read Article →" CTA with a
  slide-up reveal on hover.

  Accepts:
  - article: {Object} Shopify article (required)
  - show_author: {Boolean} (default: false) — rarely used in editorial grids
  - show_date: {Boolean} (default: true)
  - show_excerpt: {Boolean} (default: true)
  - index: {Number} Zero-based index; first 3 get eager loading for LCP (default: 99)
{%- endcomment -%}

{%- liquid
  assign show_author = show_author | default: false
  assign show_date = show_date | default: true
  assign show_excerpt = show_excerpt | default: true
  assign card_index = index | default: 99
  if card_index < 3
    assign img_loading = 'eager'
  else
    assign img_loading = 'lazy'
  endif
  if card_index == 0
    assign img_fetchpriority = 'high'
  else
    assign img_fetchpriority = 'auto'
  endif
-%}

<a href="{{ article.url }}" class="kt-article-card">
  <div class="kt-article-card__image-wrap">
    {%- if article.image -%}
      {{
        article.image
        | image_url: width: 1200
        | image_tag:
          class: 'kt-article-card__image',
          loading: img_loading,
          fetchpriority: img_fetchpriority,
          widths: '375, 550, 800, 1200',
          sizes: '(min-width: 750px) 50vw, 100vw',
          width: article.image.width,
          height: article.image.height,
          alt: article.title
      }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg kt-article-card__image' }}
    {%- endif -%}

    {%- comment -%}
      Filter out underscore-prefixed tags — Shopify convention flags
      these as hidden meta tags (_featured, _cover, _pinned) used for
      internal editorial curation. Walk the tag list until a public
      tag is found. Previously `article.tags.first` published
      "_featured" in the UI on merchants who used tag-based pinning.
    {%- endcomment -%}
    {%- assign article_card_primary_tag = blank -%}
    {%- for tag in article.tags -%}
      {%- assign tag_first_char = tag | slice: 0 -%}
      {%- unless tag_first_char == '_' -%}
        {%- assign article_card_primary_tag = tag -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
    {%- if article_card_primary_tag != blank -%}
      <span class="kt-article-card__category">{{ article_card_primary_tag }}</span>
    {%- endif -%}
  </div>

  <div class="kt-article-card__content">
    {%- if show_date or show_author -%}
      <div class="kt-article-card__meta">
        {%- if show_date -%}
          <time class="kt-article-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
            {{ article.published_at | date: format: 'abbreviated_date' }}
          </time>
        {%- endif -%}
        {%- if show_author -%}
          <span class="kt-article-card__author">{{ article.author }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <h2 class="kt-article-card__title">{{ article.title }}</h2>

    {%- if show_excerpt and article.excerpt_or_content != blank -%}
      <p class="kt-article-card__excerpt">
        {{ article.excerpt_or_content | strip_html | truncatewords: 28 }}
      </p>
    {%- endif -%}

    <span class="kt-article-card__cta">
      <span class="kt-article-card__cta-label">
        <span class="kt-article-card__cta-label-inner">
          {{ 'kt.section.blog.read_article' | t | default: 'Read Article' }}
        </span>
        <span class="kt-article-card__cta-label-inner--ghost" aria-hidden="true">
          {{ 'kt.section.blog.read_article' | t | default: 'Read Article' }}
        </span>
      </span>
      <svg class="kt-article-card__cta-arrow" aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
</a>
