{%- comment -%}
  Appointment / Free Estimate Drawer — slide-in from right.
  Ported from AppointmentDrawer.tsx.
  Uses Shopify {% form 'contact' %} for submission.
{%- endcomment -%}

<div class="kt-appointment-drawer" id="appointment-drawer" aria-hidden="true">
  <div class="kt-appointment-drawer__overlay" data-appointment-close></div>
  <div class="kt-appointment-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'kt.section.appointment.title' | t | default: 'Free Estimate' }}">

    {%- comment -%} Header {%- endcomment -%}
    <div class="kt-appointment-drawer__header">
      <h2 class="kt-appointment-drawer__title">{{ 'kt.section.appointment.title' | t | default: 'Free Estimate' }}</h2>
      <button type="button" class="kt-appointment-drawer__close" data-appointment-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
        <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    {%- comment -%} Form Body {%- endcomment -%}
    <div class="kt-appointment-drawer__body">
      {% form 'contact', id: 'appointment-form' %}
        {%- comment -%} Name Row {%- endcomment -%}
        <div class="kt-appointment-drawer__row kt-appointment-drawer__row--split">
          <div class="kt-appointment-drawer__field">
            <label for="appointment-first-name" class="field__label">
              {{ 'kt.section.appointment.first_name' | t | default: 'First Name' }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="appointment-first-name"
              name="contact[first_name]"
              class="field__input"
              required
              autocomplete="given-name"
            >
          </div>
          <div class="kt-appointment-drawer__field">
            <label for="appointment-last-name" class="field__label">
              {{ 'kt.section.appointment.last_name' | t | default: 'Last Name' }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="appointment-last-name"
              name="contact[last_name]"
              class="field__input"
              required
              autocomplete="family-name"
            >
          </div>
        </div>

        {%- comment -%} Email {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-email" class="field__label">
            {{ 'kt.section.appointment.email' | t | default: 'Email' }} <span aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="appointment-email"
            name="contact[email]"
            class="field__input"
            required
            autocomplete="email"
          >
        </div>

        {%- comment -%} Phone {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-phone" class="field__label">
            {{ 'kt.section.appointment.phone' | t | default: 'Phone' }} <span aria-hidden="true">*</span>
          </label>
          <input
            type="tel"
            id="appointment-phone"
            name="contact[phone]"
            class="field__input"
            required
            autocomplete="tel"
          >
        </div>

        {%- comment -%} Interested In {%- endcomment -%}
        <fieldset class="kt-appointment-drawer__fieldset">
          <legend class="field__label">{{ 'kt.section.appointment.interested_in' | t | default: 'Interested In' }} <span aria-hidden="true">*</span></legend>
          <div class="kt-appointment-drawer__radio-group">
            <label class="kt-appointment-drawer__radio-label">
              <input type="radio" name="contact[interest]" value="{{ 'kt.section.appointment.interest_cabinets' | t }}" checked class="kt-appointment-drawer__radio">
              <span>{{ 'kt.section.appointment.interest_cabinets' | t }}</span>
            </label>
            <label class="kt-appointment-drawer__radio-label">
              <input type="radio" name="contact[interest]" value="{{ 'kt.section.appointment.interest_countertops' | t }}" class="kt-appointment-drawer__radio">
              <span>{{ 'kt.section.appointment.interest_countertops' | t }}</span>
            </label>
            <label class="kt-appointment-drawer__radio-label">
              <input type="radio" name="contact[interest]" value="{{ 'kt.section.appointment.interest_both' | t }}" class="kt-appointment-drawer__radio">
              <span>{{ 'kt.section.appointment.interest_both' | t }}</span>
            </label>
          </div>
        </fieldset>

        {%- comment -%} Message {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-message" class="field__label">
            {{ 'kt.section.appointment.message' | t | default: 'Message' }}
          </label>
          <textarea
            id="appointment-message"
            name="contact[body]"
            class="field__textarea"
            rows="4"
          ></textarea>
        </div>

        {%- comment -%} Submit {%- endcomment -%}
        <div class="kt-appointment-drawer__footer">
          <button type="submit" class="button kt-appointment-drawer__submit">
            {{ 'kt.section.appointment.submit' | t | default: 'Submit Request' }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</div>
