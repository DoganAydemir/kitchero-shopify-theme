{%- comment -%}
  Appointment / Free Estimate Drawer — slide-in from right.
  Ported from AppointmentDrawer.tsx.
  Uses Shopify {% form 'contact' %} for submission.
{%- endcomment -%}

<div class="kt-appointment-drawer" id="appointment-drawer" aria-hidden="true" inert>
  <div class="kt-appointment-drawer__overlay" data-appointment-close></div>
  <div class="kt-appointment-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="AppointmentDrawerTitle" tabindex="-1">

    {%- comment -%} Header {%- endcomment -%}
    <div class="kt-appointment-drawer__header">
      <h2 class="kt-appointment-drawer__title" id="AppointmentDrawerTitle">{{ 'kt.section.appointment.title' | t }}</h2>
      <button type="button" class="kt-appointment-drawer__close" data-appointment-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
        {% render 'icon-close', width: 20, height: 20, stroke_width: 1.5 %}
      </button>
    </div>

    {%- comment -%} Form Body {%- endcomment -%}
    <div class="kt-appointment-drawer__body">
      {% form 'contact', id: 'appointment-form' %}
        {%- if form.posted_successfully? -%}
          {%- comment -%}
            Success sentinel — an empty `<span>` whose presence
            tells appointment-drawer.js "the form just submitted
            successfully, auto-open the drawer on load". Without
            this, Shopify redirects back to the current page, the
            success `<p>` below renders inside the aria-hidden
            drawer, and the user sees no feedback — they assume
            the submit failed and re-submit. The span carries no
            text so SR users don't hear a duplicate announcement
            (the `role="status"` paragraph below handles that).
          {%- endcomment -%}
          <span data-appointment-posted-successfully hidden></span>
          <p class="kt-form__success" role="status" data-contact-feedback="appointment-form">
            {{ 'kt.section.appointment.success' | t | default: 'Thanks — we will be in touch shortly.' }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          {%- comment -%}
            R297 — `data-form-error-summary` + anchor-wrapped list
            items match the login/contact pattern. Keyboard users tab
            from the summary into the failing field via the anchor;
            the global focus helper (`assets/global.js:444
            focusFirstFormError`) targets `[data-form-error-summary]`
            first then falls back to `[role="alert"][tabindex="-1"]`.
          {%- endcomment -%}
          <div class="kt-form__error-summary" data-form-error-summary tabindex="-1" data-contact-feedback="appointment-form">
            <p class="kt-form__error-title" role="alert">{{ 'kt.section.contact.error_title' | t | default: 'Please correct the following:' }}</p>
            <ul class="kt-form__error-list">
              {%- for field in form.errors -%}
                <li>
                  {%- if field == 'form' -%}
                    {{ form.errors.translated_messages[field] }}
                  {%- elsif field == 'first_name' or field == 'last_name' or field == 'email' or field == 'phone' or field == 'body' or field == 'message' -%}
                    {%- comment -%}
                      Map Shopify's contact-form field names to the
                      input IDs used in this drawer. `body` is the
                      Shopify field for the message textarea.
                    {%- endcomment -%}
                    {%- assign appt_anchor = 'appointment-' | append: field -%}
                    {%- if field == 'first_name' -%}{%- assign appt_anchor = 'appointment-first-name' -%}{%- endif -%}
                    {%- if field == 'last_name' -%}{%- assign appt_anchor = 'appointment-last-name' -%}{%- endif -%}
                    {%- if field == 'body' -%}{%- assign appt_anchor = 'appointment-message' -%}{%- endif -%}
                    <a href="#{{ appt_anchor }}">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}</a>
                  {%- else -%}
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.translated_messages[field] }}
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- comment -%} Name Row {%- endcomment -%}
        <div class="kt-appointment-drawer__row kt-appointment-drawer__row--split">
          <div class="kt-appointment-drawer__field">
            <label for="appointment-first-name" class="field__label kt-form__label--required">
              {{ 'kt.section.appointment.first_name' | t | default: 'First Name' }}
            </label>
            <input
              type="text"
              id="appointment-first-name"
              name="contact[first_name]"
              class="field__input"
              required
              aria-required="true"
              autocomplete="given-name"
              {% if form.errors contains 'first_name' %}aria-invalid="true" aria-describedby="appointment-first-name-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'first_name', describedby_id: 'appointment-first-name-error' -%}
          </div>
          <div class="kt-appointment-drawer__field">
            <label for="appointment-last-name" class="field__label kt-form__label--required">
              {{ 'kt.section.appointment.last_name' | t | default: 'Last Name' }}
            </label>
            <input
              type="text"
              id="appointment-last-name"
              name="contact[last_name]"
              class="field__input"
              required
              aria-required="true"
              autocomplete="family-name"
              {% if form.errors contains 'last_name' %}aria-invalid="true" aria-describedby="appointment-last-name-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'last_name', describedby_id: 'appointment-last-name-error' -%}
          </div>
        </div>

        {%- comment -%} Email {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-email" class="field__label kt-form__label--required">
            {{ 'kt.section.appointment.email' | t | default: 'Email' }}
          </label>
          <input
            type="email"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            id="appointment-email"
            name="contact[email]"
            class="field__input"
            required
            aria-required="true"
            inputmode="email"
            autocomplete="email"
            {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="appointment-email-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'appointment-email-error' -%}
        </div>

        {%- comment -%} Phone {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-phone" class="field__label kt-form__label--required">
            {{ 'kt.section.appointment.phone' | t | default: 'Phone' }}
          </label>
          <input
            type="tel"
            id="appointment-phone"
            name="contact[phone]"
            class="field__input"
            required
            aria-required="true"
            inputmode="tel"
            autocomplete="tel"
            {% if form.errors contains 'phone' %}aria-invalid="true" aria-describedby="appointment-phone-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'phone', describedby_id: 'appointment-phone-error' -%}
        </div>

        {%- comment -%}
          R-appt-interest-removed — The "Interested in" radio group
          (Option A / Option B) was hard-coded placeholder copy with no
          merchant-facing setting, so a store owner had no way to relabel
          or remove the options. Dropped from the consultation form to
          keep it a clean name/email/phone/message lead capture. If a
          merchant ever needs a category field, it should come back as a
          configurable block setting, not fixed placeholder labels.
        {%- endcomment -%}

        {%- comment -%} Message {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-message" class="field__label">
            {{ 'kt.section.appointment.message' | t | default: 'Message' }}
          </label>
          {%- comment -%}
            R297 — Bound the message length so spam bots cannot post
            multi-MB payloads. 2000 chars is plenty for a consultation
            request; matches the cart-note + contact-form caps.
          {%- endcomment -%}
          <textarea
            id="appointment-message"
            name="contact[body]"
            class="field__textarea"
            rows="4"
            maxlength="2000"
          ></textarea>
        </div>

        {%- comment -%}
          Honeypot — bots auto-fill every input including off-screen
          ones; humans skip it because they can't see it. Backend
          should reject any submission with non-empty contact[website].
        {%- endcomment -%}
        <p class="kt-form__honeypot" aria-hidden="true" inert>
          <label for="appointment-website-trap">{{ 'kt.a11y.honeypot' | t | default: 'Leave this field empty' }}</label>
          <input type="text" id="appointment-website-trap" name="contact[website]" tabindex="-1" autocomplete="off" aria-hidden="true">
        </p>

        {%- comment -%}
          R342 LEGAL-PRIVACY-APPOINTMENT: PII collection (name +
          email + phone + message) triggers GDPR Art. 13
          disclosure-at-collection. Link gated on
          shop.privacy_policy so stores without a published
          policy don't ship a dangling link.
        {%- endcomment -%}
        {%- if shop.privacy_policy != blank -%}
          <p class="kt-appointment-drawer__privacy">
            {{ 'kt.section.contact.privacy_note_html' | t: link: shop.privacy_policy.url }}
          </p>
        {%- endif -%}

        {%- comment -%} Submit {%- endcomment -%}
        <div class="kt-appointment-drawer__footer">
          <button type="submit" class="button kt-appointment-drawer__submit">
            {{ 'kt.section.appointment.submit' | t | default: 'Submit Request' }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</div>
