{%- comment -%}
  Appointment / Free Estimate Drawer — slide-in from right.
  Ported from AppointmentDrawer.tsx.
  Uses Shopify {% form 'contact' %} for submission.
{%- endcomment -%}

<div class="kt-appointment-drawer" id="appointment-drawer" aria-hidden="true" inert>
  <div class="kt-appointment-drawer__overlay" data-appointment-close></div>
  <div class="kt-appointment-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="AppointmentDrawerTitle" tabindex="-1">

    {%- comment -%} Header {%- endcomment -%}
    <div class="kt-appointment-drawer__header">
      <h2 class="kt-appointment-drawer__title" id="AppointmentDrawerTitle">{{ 'kt.section.appointment.title' | t | default: 'Free Estimate' }}</h2>
      <button type="button" class="kt-appointment-drawer__close" data-appointment-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
        <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    {%- comment -%} Form Body {%- endcomment -%}
    <div class="kt-appointment-drawer__body">
      {% form 'contact', id: 'appointment-form' %}
        {%- if form.posted_successfully? -%}
          {%- comment -%}
            Success sentinel — an empty `<span>` whose presence
            tells appointment-drawer.js "the form just submitted
            successfully, auto-open the drawer on load". Without
            this, Shopify redirects back to the current page, the
            success `<p>` below renders inside the aria-hidden
            drawer, and the user sees no feedback — they assume
            the submit failed and re-submit. The span carries no
            text so SR users don't hear a duplicate announcement
            (the `role="status"` paragraph below handles that).
          {%- endcomment -%}
          <span data-appointment-posted-successfully hidden></span>
          <p class="kt-form__success" role="status">
            {{ 'kt.section.appointment.success' | t | default: 'Thanks — we will be in touch shortly.' }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="kt-form__error-summary" role="alert" tabindex="-1">
            <p class="kt-form__error-title">{{ 'kt.section.contact.error_title' | t | default: 'Please correct the following:' }}</p>
            <ul class="kt-form__error-list">
              {%- for field in form.errors -%}
                <li>
                  {%- if field == 'form' -%}
                    {{ form.errors.messages[field] }}
                  {%- else -%}
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- comment -%} Name Row {%- endcomment -%}
        <div class="kt-appointment-drawer__row kt-appointment-drawer__row--split">
          <div class="kt-appointment-drawer__field">
            <label for="appointment-first-name" class="field__label">
              {{ 'kt.section.appointment.first_name' | t | default: 'First Name' }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="appointment-first-name"
              name="contact[first_name]"
              class="field__input"
              required
              aria-required="true"
              autocomplete="given-name"
              {% if form.errors contains 'first_name' %}aria-invalid="true" aria-describedby="appointment-first-name-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'first_name', describedby_id: 'appointment-first-name-error' -%}
          </div>
          <div class="kt-appointment-drawer__field">
            <label for="appointment-last-name" class="field__label">
              {{ 'kt.section.appointment.last_name' | t | default: 'Last Name' }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="appointment-last-name"
              name="contact[last_name]"
              class="field__input"
              required
              aria-required="true"
              autocomplete="family-name"
              {% if form.errors contains 'last_name' %}aria-invalid="true" aria-describedby="appointment-last-name-error"{% endif %}
            >
            {%- render 'form-field-error', form: form, field: 'last_name', describedby_id: 'appointment-last-name-error' -%}
          </div>
        </div>

        {%- comment -%} Email {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-email" class="field__label">
            {{ 'kt.section.appointment.email' | t | default: 'Email' }} <span aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="appointment-email"
            name="contact[email]"
            class="field__input"
            required
            aria-required="true"
            inputmode="email"
            autocomplete="email"
            {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="appointment-email-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'email', describedby_id: 'appointment-email-error' -%}
        </div>

        {%- comment -%} Phone {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-phone" class="field__label">
            {{ 'kt.section.appointment.phone' | t | default: 'Phone' }} <span aria-hidden="true">*</span>
          </label>
          <input
            type="tel"
            id="appointment-phone"
            name="contact[phone]"
            class="field__input"
            required
            aria-required="true"
            inputmode="tel"
            autocomplete="tel"
            {% if form.errors contains 'phone' %}aria-invalid="true" aria-describedby="appointment-phone-error"{% endif %}
          >
          {%- render 'form-field-error', form: form, field: 'phone', describedby_id: 'appointment-phone-error' -%}
        </div>

        {%- comment -%}
          Interested In — three radios sharing contact[interest].
          Unique `id` on each input + matching `<label for>` pairing
          so assistive tech can programmatically link label↔input
          (the wrapping-label pattern works visually but Theme Check
          LabelMissing may flag unreferenced inputs, and some SRs
          announce just the control without the wrapped span text).
        {%- endcomment -%}
        <fieldset class="kt-appointment-drawer__fieldset">
          <legend class="field__label">{{ 'kt.section.appointment.interested_in' | t | default: 'Interested In' }} <span aria-hidden="true">*</span></legend>
          <div class="kt-appointment-drawer__radio-group">
            <label class="kt-appointment-drawer__radio-label" for="appointment-interest-cabinets">
              <input type="radio" id="appointment-interest-cabinets" name="contact[interest]" value="{{ 'kt.section.appointment.interest_cabinets' | t }}" checked class="kt-appointment-drawer__radio">
              <span>{{ 'kt.section.appointment.interest_cabinets' | t }}</span>
            </label>
            <label class="kt-appointment-drawer__radio-label" for="appointment-interest-countertops">
              <input type="radio" id="appointment-interest-countertops" name="contact[interest]" value="{{ 'kt.section.appointment.interest_countertops' | t }}" class="kt-appointment-drawer__radio">
              <span>{{ 'kt.section.appointment.interest_countertops' | t }}</span>
            </label>
            <label class="kt-appointment-drawer__radio-label" for="appointment-interest-both">
              <input type="radio" id="appointment-interest-both" name="contact[interest]" value="{{ 'kt.section.appointment.interest_both' | t }}" class="kt-appointment-drawer__radio">
              <span>{{ 'kt.section.appointment.interest_both' | t }}</span>
            </label>
          </div>
        </fieldset>

        {%- comment -%} Message {%- endcomment -%}
        <div class="kt-appointment-drawer__field">
          <label for="appointment-message" class="field__label">
            {{ 'kt.section.appointment.message' | t | default: 'Message' }}
          </label>
          <textarea
            id="appointment-message"
            name="contact[body]"
            class="field__textarea"
            rows="4"
          ></textarea>
        </div>

        {%- comment -%}
          Honeypot — bots auto-fill every input including off-screen
          ones; humans skip it because they can't see it. Backend
          should reject any submission with non-empty contact[website].
        {%- endcomment -%}
        <p class="kt-form__honeypot" aria-hidden="true">
          <label for="appointment-website-trap">{{ 'kt.a11y.honeypot' | t | default: 'Leave this field empty' }}</label>
          <input type="text" id="appointment-website-trap" name="contact[website]" tabindex="-1" autocomplete="off">
        </p>

        {%- comment -%} Submit {%- endcomment -%}
        <div class="kt-appointment-drawer__footer">
          <button type="submit" class="button kt-appointment-drawer__submit">
            {{ 'kt.section.appointment.submit' | t | default: 'Submit Request' }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</div>
