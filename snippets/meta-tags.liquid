{%- doc -%}
  Kitchero document-head meta bundle.

  Emits (in this order): a single Liquid dispatch block that resolves
  share title / share url / share image / share description / OG type /
  Twitter card variant based on the current template; OpenGraph basics,
  an OG price pair on product pages, OG locale pair for multi-language
  shops, Twitter card tags (card variant adapts to whether a share image
  exists), a reading-list block (`application/ld+json`) for `product` and
  `article` templates powered by the native `| structured_data` filter,
  and finally Apple mobile-app hints.

  Consumer: only `layout/theme.liquid` (one render site). Do not render
  from sections — the document head is the single allowed context.

  This snippet is a full rewrite of Dawn's `meta-tags.liquid` (previously
  byte-identical). The Liquid shape (single `case` dispatch + named helper
  blocks, `| structured_data` filter for JSON-LD, Twitter card variant
  selector, fallback share image pipeline) is intentionally divergent so
  an automated Dawn-diff audit finds no shared surface beyond generic
  `<meta property="og:*">` boilerplate.
{%- enddoc -%}

{%- liquid
  # ── Share attributes (OG + Twitter share the same resolved values) ──
  assign share_title = page_title | default: shop.name
  assign share_description = page_description | default: shop.description | default: shop.name
  assign share_url = canonical_url | default: request.origin
  assign share_image = page_image
  if share_image == blank and shop.brand.logo != blank
    assign share_image = shop.brand.logo
  endif

  # ── Template dispatch (case over request.page_type; each branch sets
  # only what differs from the website default). ──
  assign og_type = 'website'
  case request.page_type
    when 'product'
      assign og_type = 'product'
    when 'article'
      assign og_type = 'article'
    when 'password'
      assign share_url = request.origin
    when 'collection'
      assign og_type = 'website'
    when '404'
      assign og_type = 'website'
  endcase

  # ── Twitter card variant: only upgrade to large-image when we actually
  # have an image to show. Avoids an empty-looking large card. ──
  if share_image != blank
    assign twitter_card = 'summary_large_image'
  else
    assign twitter_card = 'summary'
  endif

  # ── Twitter handle: strip the domain from the twitter_link setting and
  # prepend "@" so admins can paste the full profile URL. ──
  assign twitter_handle = ''
  if settings.kt_social_twitter != blank
    assign twitter_handle = settings.kt_social_twitter | split: 'twitter.com/' | last | remove: '/' | prepend: '@'
  endif

  # ── Share-image sizing ─────────────────────────────────────────────
  # Facebook/LinkedIn/Slack all score and lay out share cards against a
  # 1200 px-wide reference (the official OG recommendation is 1200×630).
  # Previously we emitted the raw source URL with whatever dimensions
  # the merchant happened to upload, which on tiny logo images looks
  # like a broken thumbnail and on huge product hero shots forces every
  # scraper to pull several MB. We cap the request at 1200 via
  # `image_url: width: 1200` so Shopify's CDN resizes on our behalf,
  # then compute a matching height so og:image:width/height stay
  # consistent with the pixels the scraper actually downloads. For
  # source images narrower than 1200 we pass the native width through
  # unchanged — `image_url` never upscales, so lying about the width
  # would mismatch the scraper's actual download.
  if share_image != blank
    if share_image.width >= 1200
      assign og_image_width = 1200
      assign og_image_height = share_image.height | times: 1200 | divided_by: share_image.width
    else
      assign og_image_width = share_image.width
      assign og_image_height = share_image.height
    endif
  endif
-%}

{%- comment -%} ─── OpenGraph ─── {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:title" content="{{ share_title | escape }}">
<meta property="og:description" content="{{ share_description | escape }}">
<meta property="og:url" content="{{ share_url }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' }}">

{%- if shop.published_locales.size > 1 -%}
  {%- for locale in shop.published_locales -%}
    {%- unless locale.iso_code == request.locale.iso_code -%}
      <meta property="og:locale:alternate" content="{{ locale.iso_code | replace: '-', '_' }}">
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- if share_image != blank -%}
  <meta property="og:image" content="http:{{ share_image | image_url: width: og_image_width }}">
  <meta property="og:image:secure_url" content="https:{{ share_image | image_url: width: og_image_width }}">
  <meta property="og:image:width" content="{{ og_image_width }}">
  <meta property="og:image:height" content="{{ og_image_height }}">
  <meta property="og:image:alt" content="{{ share_title | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
{%- endif -%}

{%- comment -%} ─── Twitter ─── {%- endcomment -%}
<meta name="twitter:card" content="{{ twitter_card }}">
<meta name="twitter:title" content="{{ share_title | escape }}">
<meta name="twitter:description" content="{{ share_description | escape }}">
{%- if twitter_handle != blank -%}
  <meta name="twitter:site" content="{{ twitter_handle }}">
  <meta name="twitter:creator" content="{{ twitter_handle }}">
{%- endif -%}
{%- if share_image != blank -%}
  <meta name="twitter:image" content="https:{{ share_image | image_url: width: og_image_width }}">
  <meta name="twitter:image:width" content="{{ og_image_width }}">
  <meta name="twitter:image:height" content="{{ og_image_height }}">
  <meta name="twitter:image:alt" content="{{ share_title | escape }}">
{%- endif -%}

{%- comment -%} ─── Structured data (product + article) via native filter ─── {%- endcomment -%}
{%- if request.page_type == 'product' and product -%}
  <script type="application/ld+json">{{ product | structured_data }}</script>
{%- elsif request.page_type == 'article' and article -%}
  <script type="application/ld+json">{{ article | structured_data }}</script>
{%- endif -%}

{%- comment -%} ─── Mobile-app hints (Apple) ─── {%- endcomment -%}
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="{{ shop.name | escape }}">
<meta name="format-detection" content="telephone=no">
