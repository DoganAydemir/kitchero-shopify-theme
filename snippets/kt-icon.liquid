{% doc %}
  Shared inline-SVG icon renderer (stroke style, currentColor).
  All glyphs inherit `currentColor`; unknown keys fall back to a right arrow.

  @param {string} icon - Icon key (calendar, clock, phone, mail, chat, arrow_right, check, sparkle, star, shield, map_pin, tag, truck).
  @param {number} [width] - Pixel width (default 16).
  @param {number} [height] - Pixel height (default 16).
  @param {number} [stroke_width] - SVG stroke width (default 1.75).

  Usage: {%- render 'kt-icon', icon: block.settings.primary_icon, width: 16, height: 16 -%}
{% enddoc %}
{%- liquid
  assign icon_w = width | default: 16
  assign icon_h = height | default: 16
  assign icon_sw = stroke_width | default: 1.75
-%}
{%- capture icon_attrs -%}aria-hidden="true" focusable="false" width="{{ icon_w }}" height="{{ icon_h }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ icon_sw }}" stroke-linecap="round" stroke-linejoin="round"{%- endcapture -%}
{%- case icon -%}
  {%- when 'calendar' -%}
    <svg {{ icon_attrs }}><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
  {%- when 'clock' -%}
    <svg {{ icon_attrs }}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
  {%- when 'phone' -%}
    <svg {{ icon_attrs }}><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
  {%- when 'mail' -%}
    <svg {{ icon_attrs }}><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
  {%- when 'chat' -%}
    <svg {{ icon_attrs }}><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
  {%- when 'arrow_right' -%}
    <svg {{ icon_attrs }}><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
  {%- when 'check' -%}
    <svg {{ icon_attrs }}><polyline points="20 6 9 17 4 12"/></svg>
  {%- when 'sparkle' -%}
    <svg {{ icon_attrs }}><path d="M12 3l1.9 5.8L20 11l-6.1 2.2L12 19l-1.9-5.8L4 11l6.1-2.2z"/></svg>
  {%- when 'star' -%}
    <svg {{ icon_attrs }}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
  {%- when 'shield' -%}
    <svg {{ icon_attrs }}><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
  {%- when 'map_pin' -%}
    <svg {{ icon_attrs }}><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
  {%- when 'tag' -%}
    <svg {{ icon_attrs }}><path d="M20.59 13.41 13.42 20.6a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
  {%- when 'truck' -%}
    <svg {{ icon_attrs }}><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
  {%- else -%}
    <svg {{ icon_attrs }}><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
{%- endcase -%}
