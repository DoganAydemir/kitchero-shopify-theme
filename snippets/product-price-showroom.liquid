{%- comment -%}
  Product Price — Showroom style.
  Birebir from showroom/[id]/page.tsx pricing block.

  Renders:
    "Now only" label (small, muted)
    Big red current price
    "Save $X" badge (red pill, only if on sale)
    "Was $X" strikethrough (only if on sale)
    Monthly installment pill (auto-calculated from financing_months + financing_apr
    section settings, if provided)

  Accepts:
  - product: {Object}          Shopify product
  - financing_months: {Number} number of months for the installment line
  - financing_apr: {Number}    APR percentage (0 for interest-free)
  - financing_label: {String}  text to render the monthly pill (optional override)
{%- endcomment -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign current_price = variant.price
  assign compare_price = variant.compare_at_price
  # Free-product guard — same pattern as product-price.liquid:21-29.
  # A 0-priced variant with compare > 0 would otherwise emit a "Save"
  # badge equal to the compare price and a "$0.00" current — both of
  # which read as broken merchandising. Substitute "Free" copy instead.
  assign is_free = false
  if current_price == 0
    assign is_free = true
  endif
  assign on_sale = false
  if compare_price > current_price and is_free == false
    assign on_sale = true
    assign savings = compare_price | minus: current_price
  endif

  unless financing_months
    assign financing_months = 60
  endunless
-%}

<div class="kt-showroom-price" data-product-price>
  <span class="kt-showroom-price__label">{{ 'kt.product.price.now_only' | t | default: 'Now only' }}</span>

  {%- comment -%}
    The `kt-product-price__current/compare/discount` aliases beside the
    showroom-specific class names are required for atomic price updates
    on variant + selling-plan change. `assets/product-form.js`'s
    `renderPriceForVariant()` queries `.kt-product-price__current` /
    `__compare` / `__discount` to swap the rendered price string; without
    these aliases the JS silently no-ops on the showroom template and
    the customer sees a stale price after picking a variant or
    subscription cadence — Theme Store rejects that as deceptive pricing.
  {%- endcomment -%}
  <div class="kt-showroom-price__row">
    <span class="kt-showroom-price__current kt-product-price__current">
      {%- if is_free -%}
        {{ 'kt.cart.free' | t | default: 'Free' }}
      {%- else -%}
        {{ current_price | money }}
      {%- endif -%}
    </span>
    {%- if on_sale -%}
      {%- comment -%}
        R89 — Liquid filter-chain fix: `| money` was landing on the t
        output (a string), not on `savings`/`compare_price`. Customer
        saw raw cents in the savings/was-price labels. `| default:
        'Save'/'Was'` after `| money` was also moot — money returns a
        truthy string, the default never fires. Pre-assign formatted
        money values; rely on locale keys present in en/tr/de/fr/es
        for translation.
      {%- endcomment -%}
      {%- assign savings_money = savings | money -%}
      <span class="kt-showroom-price__save kt-product-price__discount">
        {{ 'kt.product.price.save_html' | t: amount: savings_money }}
      </span>
    {%- endif -%}
  </div>

  {%- if on_sale -%}
    {%- assign compare_price_money = compare_price | money -%}
    <span class="kt-showroom-price__was kt-product-price__compare">
      {{ 'kt.product.price.was_html' | t: amount: compare_price_money }}
    </span>
  {%- endif -%}

  {%- comment -%}
    Tax-inclusive indicator — Theme Store mandate (Section 7) for any
    PDP path that displays a price. The default `product-price.liquid`
    renders this; the showroom variant was missing it, so EU-market
    merchants running `product.showroom.json` shipped a price with no
    tax disclosure. Mirrors the wording / class used on the default
    PDP for visual consistency. Suppressed for free products — no
    tax discussion makes sense at $0.
  {%- endcomment -%}
  {%- if cart.taxes_included and is_free == false -%}
    <span class="kt-showroom-price__tax-note">
      {{ 'kt.product.taxes_included' | t | default: 'Tax included.' }}
    </span>
  {%- endif -%}

  {%- comment -%}
    Monthly installment pill — calculated price / months. Suppressed
    for free products since "Free / 60 months" makes no sense.
  {%- endcomment -%}
  {%- if financing_months > 0 and is_free == false -%}
    {%- assign monthly = current_price | divided_by: financing_months -%}
    <p class="kt-showroom-price__financing">
      <span class="kt-showroom-price__financing-pill">
        {%- if financing_label != blank -%}
          {{ financing_label }}
        {%- else -%}
          {{ monthly | money }} {{ 'kt.product.price.per_month' | t | default: 'per month' }}
          {%- if financing_apr -%}
            &nbsp;· {{ 'kt.product.price.apr_suffix_html' | t: rate: financing_apr }}
          {%- endif -%}
          &nbsp;· {{ financing_months | divided_by: 12 }} {{ 'kt.product.price.years' | t | default: 'years' }}*
        {%- endif -%}
      </span>
    </p>
  {%- endif -%}
</div>
