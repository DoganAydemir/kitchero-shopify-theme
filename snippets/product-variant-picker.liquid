{%- comment -%}
  Product Variant Picker — renders option selectors.
  Birebir from source: finish selector (swatches) + cabinet type (grid buttons).
  Uses Shopify product.options_with_values.

  Accepts:
  - product: {Object} Shopify product
{%- endcomment -%}

{%- unless product.has_only_default_variant -%}
  <div class="kt-variant-picker" data-variant-picker>
    {%- for option in product.options_with_values -%}
      {%- assign option_name_lower = option.name | downcase -%}
      {%- assign is_color = false -%}
      {%- if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'renk' or option_name_lower == 'finish' -%}
        {%- assign is_color = true -%}
      {%- endif -%}

      <fieldset class="kt-variant-picker__group" data-option-index="{{ forloop.index0 }}">
        <legend class="kt-variant-picker__label">
          {{ option.name }}:
          <span class="kt-variant-picker__selected" data-option-selected="{{ forloop.index0 }}">
            {{ option.selected_value | default: option.values.first }}
          </span>
        </legend>

        {%- if is_color -%}
          {%- comment -%}
            Swatch resolution priority — matches the Shopify Online Store
            2.0 pattern used by Dawn / Impulse:
            1. Variant metafield `custom.swatch_color` (hex or CSS color)
               — merchant can override any swatch per variant.
            2. Variant metafield `custom.swatch_image` (image swatch) —
               rendered as the background of the swatch chip.
            3. CSS Named Colors on the option value (e.g. "Black" maps
               natively to rgb(0,0,0) via background-color: valueName).
            4. Hardcoded fallback palette below for brand-specific finish
               names the browser wouldn't understand.
          {%- endcomment -%}
          <div class="kt-variant-picker__swatches">
            {%- for value in option.values -%}
              {%- liquid
                assign matching_variant = nil
                for v in product.variants
                  if v.options contains value
                    assign matching_variant = v
                    break
                  endif
                endfor

                assign swatch_meta_color = nil
                assign swatch_meta_image = nil
                if matching_variant
                  assign swatch_meta_color = matching_variant.metafields.custom.swatch_color
                  assign swatch_meta_image = matching_variant.metafields.custom.swatch_image.value
                endif

                assign color_lower = value | downcase | strip
                assign swatch_hex = ''
                case color_lower
                  when 'black'
                    assign swatch_hex = '#1a1a1a'
                  when 'white', 'arctic white'
                    assign swatch_hex = '#faf9f6'
                  when 'gray', 'grey', 'pebble gray'
                    assign swatch_hex = '#a8a29e'
                  when 'charcoal'
                    assign swatch_hex = '#44403c'
                  when 'espresso'
                    assign swatch_hex = '#3C2415'
                  when 'navy', 'navy blue'
                    assign swatch_hex = '#1e3a5f'
                  when 'walnut'
                    assign swatch_hex = '#5D432C'
                  when 'oak', 'natural oak'
                    assign swatch_hex = '#d2b48c'
                  when 'brown'
                    assign swatch_hex = '#6b4e31'
                  when 'beige', 'ivory'
                    assign swatch_hex = '#e8dccc'
                  when 'ice'
                    assign swatch_hex = '#e6eef2'
                  when 'dark'
                    assign swatch_hex = '#1c1917'
                  else
                    assign swatch_hex = ''
                endcase

                assign swatch_style = ''
                if swatch_meta_image != blank
                  assign swatch_image_url = swatch_meta_image | image_url: width: 80
                  assign swatch_style = 'background-image: url(' | append: swatch_image_url | append: '); background-size: cover; background-position: center;'
                elsif swatch_meta_color != blank
                  assign swatch_style = 'background-color: ' | append: swatch_meta_color | append: ';'
                elsif swatch_hex != blank
                  assign swatch_style = 'background-color: ' | append: swatch_hex | append: ';'
                else
                  # Fall back to the CSS color name — modern browsers accept
                  # 140 named colors, which covers most generic palettes.
                  assign swatch_style = 'background-color: ' | append: color_lower | append: ';'
                endif
              -%}

              <label class="kt-variant-picker__swatch-label">
                <input
                  type="radio"
                  name="option-{{ option.name | handle }}"
                  value="{{ value | escape }}"
                  {% if forloop.first %}checked{% endif %}
                  class="kt-variant-picker__swatch-input visually-hidden"
                  data-option-value
                >
                <span
                  class="kt-variant-picker__swatch"
                  style="{{ swatch_style }}"
                  title="{{ value }}"
                ></span>
              </label>
            {%- endfor -%}
          </div>

        {%- else -%}
          {%- comment -%} Non-color: grid buttons {%- endcomment -%}
          <div class="kt-variant-picker__buttons">
            {%- for value in option.values -%}
              <label class="kt-variant-picker__btn-label">
                <input
                  type="radio"
                  name="option-{{ option.name | handle }}"
                  value="{{ value | escape }}"
                  {% if forloop.first %}checked{% endif %}
                  class="kt-variant-picker__btn-input visually-hidden"
                  data-option-value
                >
                <span class="kt-variant-picker__btn">{{ value }}</span>
              </label>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </fieldset>
    {%- endfor -%}

    {%- comment -%} Hidden select for variant ID (JS updates this) {%- endcomment -%}
    <select name="id" class="visually-hidden" data-variant-select aria-label="{{ 'products.product.variant' | t | default: 'Variant' }}">
      {%- for variant in product.variants -%}
        <option
          value="{{ variant.id }}"
          {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
          {% unless variant.available %}disabled{% endunless %}
          data-variant-json='{{ variant | json }}'
        >
          {{ variant.title }}
        </option>
      {%- endfor -%}
    </select>
  </div>
{%- endunless -%}
