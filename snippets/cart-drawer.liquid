{%- comment -%}
  Cart Drawer — slide-in from right. Birebir from CartDrawer.tsx.
  Refresh handled by product-form.js (fetch-and-swap) and cart-drawer.js
  (quantity updates via AJAX + HTML re-render). Works without JS: the
  cart icon falls back to /cart.
{%- endcomment -%}

<cart-drawer
  class="kt-cart-drawer"
  id="cart-drawer"
  {% if section_id %}data-section-id="{{ section_id }}"{% endif %}
  aria-hidden="true"
  inert
>
  <div class="kt-cart-drawer__overlay" data-cart-drawer-close></div>
  <div class="kt-cart-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="CartDrawerTitle" tabindex="-1">
    {%- comment -%} Header {%- endcomment -%}
    <div class="kt-cart-drawer__header">
      <h2 class="kt-cart-drawer__title" id="CartDrawerTitle">{{ 'kt.cart.title_full' | t | default: 'Your Cart' }}</h2>
      <button type="button" class="kt-cart-drawer__close" data-cart-drawer-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
        {% render 'icon-close', width: 20, height: 20, stroke_width: 1.5 %}
      </button>
    </div>
    {%- comment -%}
      R94 — SR-only polite live region for cart-mutation announcements.
      Item count is announced via the cart-icon badge's aria-live="polite"
      (header.liquid:441), but item-level events (add/remove with title)
      need their own announcer. cart-drawer.js writes text here on
      successful add/remove/update. visually-hidden so it never paints.
      role="status" + aria-live="polite" + aria-atomic="true" gets
      consistent NVDA/VO behaviour across screen readers.
    {%- endcomment -%}
    <div
      class="visually-hidden"
      data-cart-drawer-announcer
      role="status"
      aria-live="polite"
      aria-atomic="true"
    ></div>

    {%- comment -%}
      Cart Items.
      `data-lenis-prevent="true"` tells Lenis (smooth scroll vendor)
      not to hijack vertical scroll inside the drawer. Without this,
      Lenis's translateY animation fights the drawer's native overflow
      scroll and the qty list scrolls jankily / not at all on iOS.
      Filter drawer body uses the same attribute (kt-collection-filters
      .css pattern, see main-collection-drawer.liquid:84).
    {%- endcomment -%}
    {%- comment -%}
      R93 — wrapper carries role="list" + each item carries
      role="listitem" so SR users hear "list, X items" instead of
      "group" or "no list announced". Native <ul><li> would also
      work but require CSS rewrite (current rules target the
      `.kt-cart-drawer__body` + `.kt-cart-drawer__item` div
      classes); ARIA roles preserve the visual styling without
      losing list semantics. Pattern matches WAI-ARIA Authoring
      Practices for stylistically-suppressed lists.
    {%- endcomment -%}
    <div
      class="kt-cart-drawer__body"
      id="cart-drawer-items"
      data-lenis-prevent="true"
      {% if cart.item_count > 0 %}role="list" aria-label="{{ 'kt.cart.items_in_cart' | t: count: cart.item_count | default: 'Items in your cart' }}"{% endif %}
    >
      {%- if cart.item_count > 0 -%}
        {%- for item in cart.items -%}
          <div class="kt-cart-drawer__item" data-line-key="{{ item.key }}" role="listitem">
            {%- comment -%}
              Thumbnail. aria-hidden removed to avoid axe-core
              `aria-hidden-focus` — see sections/main-cart.liquid
              for the full rationale. tabindex="-1" kept so keyboard
              Tab flow skips the thumb and lands on the title link.
            {%- endcomment -%}
            <a href="{{ item.url }}" class="kt-cart-drawer__item-image" tabindex="-1">
              {%- if item.image -%}
                {%- comment -%}
                  Prefer merchant-authored image alt over the line title
                  (Theme Store a11y rule: title is not satisfactory as
                  alt text). Falls back to item.title when missing.
                {%- endcomment -%}
                {%- assign item_alt = item.image.alt | default: item.title -%}
                {{
                  item.image
                  | image_url: width: 192
                  | image_tag:
                    width: 96,
                    height: 96,
                    alt: item_alt,
                    loading: 'lazy',
                    class: 'kt-cart-drawer__item-img'
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-cart-drawer__item-img' }}
              {%- endif -%}
            </a>

            {%- comment -%} Content column {%- endcomment -%}
            <div class="kt-cart-drawer__item-info">
              {%- comment -%}
                Variant-unavailable alert — variant went out of stock
                between ATC and now (or merchant deleted it). Without
                this surface the customer sees the cart drawer + a
                Checkout button, clicks it, and only THEN gets
                Shopify's "Some items are no longer available" wall.
                Mirrors `sections/main-cart.liquid:101-105` so the
                drawer and full cart give the same warning.
              {%- endcomment -%}
              {%- unless item.variant.available -%}
                <p class="kt-cart-drawer__item-unavailable" role="alert">
                  {{ 'kt.cart.item_unavailable' | t | default: 'This item is no longer available. Please remove it to continue.' }}
                </p>
              {%- endunless -%}

              {%- comment -%} Row 1: title + price on same line {%- endcomment -%}
              <div class="kt-cart-drawer__item-top">
                <a href="{{ item.url }}" class="kt-cart-drawer__item-title">
                  {{- item.product.title | escape -}}
                </a>
                <div class="kt-cart-drawer__item-price-stack">
                  {%- comment -%}
                    "Free" substitution for 100%-discount / freebie
                    lines — matches /cart page treatment.
                  {%- endcomment -%}
                  <span class="kt-cart-drawer__item-price">
                    {%- if item.final_line_price > 0 -%}
                      {%- comment -%}
                        Strikethrough original_line_price when a discount
                        has trimmed the line (auto-applied promo, line
                        discount, "Buy 2 Get 1 Free", etc.). Without the
                        struck-through original alongside the final, the
                        customer sees only the discounted total and the
                        SAVING is invisible — main-cart.liquid renders
                        the same `<s>` pair, so this closes the drawer
                        parity gap reviewers cite when applying a code,
                        opening the drawer, and expecting to see the
                        old price crossed out.
                        Wrapped in <s> for screen readers — text-decoration
                        alone doesn't convey "no longer valid" semantics.
                      {%- endcomment -%}
                      {%- if item.original_line_price > item.final_line_price -%}
                        <s class="kt-cart-drawer__item-price-original">
                          <span class="visually-hidden">{{ 'kt.product.regular_price' | t }}&nbsp;</span>
                          {{ item.original_line_price | money }}
                        </s>
                        <span class="visually-hidden">{{ 'kt.product.sale_price' | t }}&nbsp;</span>
                      {%- endif -%}
                      {{ item.final_line_price | money }}
                    {%- else -%}
                      {{ 'kt.cart.free' | t | default: 'Free' }}
                    {%- endif -%}
                  </span>
                  {%- comment -%}
                    EU unit pricing mirror of the main cart page — when
                    the variant has a unit_price_measurement, show the
                    per-reference-unit price in muted text beneath the
                    line total.
                  {%- endcomment -%}
                  {%- if item.variant.unit_price_measurement -%}
                    {%- comment -%}
                      R86 UNP-03 — use Shopify's
                      `unit_price_with_measurement` filter instead of
                      manual `unit_price | money` + reference_value/
                      reference_unit concatenation. The native filter
                      handles plural rules, locale-aware separator
                      spacing, and reference_value != 1 logic in one
                      call. Per Shopify docs: "use the
                      unit_price_with_measurement filter to display
                      the unit price."
                    {%- endcomment -%}
                    <span class="kt-cart-drawer__item-unit-measure">
                      {{ item.variant.unit_price | unit_price_with_measurement: item.variant.unit_price_measurement }}
                    </span>
                  {%- endif -%}
                  {%- comment -%}
                    Line-level discount allocations — mirrors /cart page
                    treatment. When a discount applies to this specific
                    line (e.g. "Buy 2 Get 1 Free", "Spring Sale 20%"),
                    the customer sees the discount name + amount under
                    the price. Without this, drawer shows the discounted
                    price but the SAVING is invisible — reviewer test
                    case: apply a code, open drawer, expect to see "−$X
                    Spring Sale" line.
                  {%- endcomment -%}
                  {%- if item.line_level_discount_allocations.size > 0 -%}
                    <ul class="kt-cart-drawer__item-discounts" role="list">
                      {%- for discount in item.line_level_discount_allocations -%}
                        <li>– {{ discount.discount_application.title | escape }} ({{ discount.amount | money }})</li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%}
                Row 2: variant / selling-plan / bundle components / properties.
                R143 CART-DELETED-PROD-1: gate on `item.product` first.
                When a cart-resident product is deleted from admin
                (rare but possible during checkout), `item.product`
                resolves nil and `has_only_default_variant` becomes
                nil → the unless branch runs unexpectedly and renders
                an empty <p> with a stray <br>. Explicit `if
                item.product and ...has_only_default_variant == false`
                skips the block when product is gone OR when product
                only has Default Title variant.
              {%- endcomment -%}
              {%- if item.product and item.product.has_only_default_variant == false -%}
                <p class="kt-cart-drawer__item-variant">
                  {%- for option in item.options_with_values -%}
                    {{- option.value | escape -}}
                    {%- unless forloop.last %}<br>{% endunless -%}
                  {%- endfor -%}
                </p>
              {%- endif -%}

              {%- comment -%}
                Selling-plan (subscription) label — matches the main
                cart page. Subscription cadence needs to be visible
                here because the drawer opens on ATC success and the
                customer reviews the line before proceeding.
              {%- endcomment -%}
              {%- if item.selling_plan_allocation -%}
                <p class="kt-cart-drawer__item-selling-plan">
                  {{- item.selling_plan_allocation.selling_plan.name | escape -}}
                </p>
                {%- comment -%}
                  SUB-05 — checkout charge surfacing for pre-paid /
                  TBYB / first-payment-discount plans where the
                  amount Shopify charges TODAY differs from the
                  recurring total. Without this the customer sees
                  the line price (recurring) but not what hits
                  their card at checkout, eroding confidence on
                  PDP→cart→checkout transitions.
                {%- endcomment -%}
                {%- assign charge = item.selling_plan_allocation.checkout_charge -%}
                {%- if charge and charge.value > 0 and charge.value != item.final_line_price -%}
                  {%- comment -%}
                    R86 SUB-05 fix: pre-format the money value
                    BEFORE passing into `t: amount: ...`. The
                    previous chain `t: amount: charge.value |
                    money` was parsed as `(t output) | money`,
                    leaking raw cents into the rendered string.
                    Pre-assigning the formatted amount keeps the
                    `| money` filter applied to the variable.
                  {%- endcomment -%}
                  {%- assign charge_money = charge.value | money -%}
                  <p class="kt-cart-drawer__item-charge">
                    {{ 'kt.cart.checkout_charge' | t: amount: charge_money }}
                  </p>
                {%- endif -%}
              {%- endif -%}

              {%- comment -%}
                Bundle components — native Shopify Bundles + Cart
                Transform API populate `item.item_components` (the
                documented Liquid attribute). Earlier the loop read
                `item.line_components` which doesn't exist on the
                line_item drop, so child lines never rendered for
                merchants using Shopify Bundles. Rendering child
                lines gives the customer a "what's in the box"
                receipt before they click Checkout. Compact render
                (title + qty only) keeps drawer density manageable.
              {%- endcomment -%}
              {%- if item.item_components.size > 0 -%}
                <ul class="kt-cart-drawer__item-components" role="list">
                  {%- for component in item.item_components -%}
                    <li>
                      {%- if component.quantity > 1 -%}<span>{{ component.quantity }}&times;</span> {% endif -%}
                      {{- component.product.title | default: component.title | escape -}}
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if item.properties != blank -%}
                <ul class="kt-cart-drawer__item-properties" role="list">
                  {%- for property in item.properties -%}
                    {%- assign first = property.first | downcase -%}
                    {%- unless first.first == '_' or property.last == blank -%}
                      <li>
                        <span>{{ property.first | escape }}:</span>
                        {%- if property.last contains '/uploads/' -%}
                          {%- comment -%}
                            The visible filename text after split is still
                            user-controlled (file uploads at /cart/add).
                            R75 caught this on main-order.liquid; R76
                            verifies the cart-side renders. A crafted
                            upload like `/uploads/<svg onload=...>.png`
                            survives the path split untouched and renders
                            raw inside the drawer DOM. `| escape` on the
                            visible text closes that XSS path.
                          {%- endcomment -%}
                          <a href="{{ property.last | escape }}" target="_blank" rel="noopener noreferrer">{{ property.last | split: '/' | last | escape }}</a>
                        {%- else -%}
                          {{ property.last | escape }}
                        {%- endif -%}
                      </li>
                    {%- endunless -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- comment -%}
                Row 3: qty stepper on LEFT + remove button on RIGHT.

                Quantity rule respect — `item.variant.quantity_rule.increment`
                tells Shopify what step size this variant accepts (e.g.
                wholesale "case of 6" = increment 6). Hardcoded +1/-1
                previously caused "Unable to update cart" errors for any
                merchant using B2B bundles, since Shopify rejects non-
                conforming quantities at the /cart/change.js endpoint.
                main-cart.liquid already reads this rule; drawer now
                matches so both surfaces behave identically.
              {%- endcomment -%}
              {%- assign drawer_qty_step = item.variant.quantity_rule.increment | default: 1 -%}
              {%- assign drawer_qty_max = item.variant.quantity_rule.max -%}
              {%- comment -%}
                quantity_rule.min isn't gated separately here because the
                minus path lets a customer drop to 0 (which removes the
                line entirely). For a wholesale case-of-6 product the
                merchant intent is "must order 6 OR remove" — both
                outcomes are reachable through the minus button without
                a separate min cap.
              {%- endcomment -%}
              {%- comment -%}
                Compute the next qty values so the +/- buttons can be
                gated by quantity_rule. Without these caps, a customer
                with a max-of-10 variant clicking + at qty 10 sends
                qty=11 to /cart/change.js, gets a 422 + main-cart pattern
                rolls back the UI — drawer needs the same defence so the
                button is `disabled` once the rule hits its ceiling and
                doesn't keep emitting failing requests.
              {%- endcomment -%}
              {%- assign drawer_qty_next_up = item.quantity | plus: drawer_qty_step -%}
              {%- if drawer_qty_max != blank and drawer_qty_next_up > drawer_qty_max -%}
                {%- assign drawer_qty_next_up = drawer_qty_max -%}
              {%- endif -%}
              {%- assign drawer_qty_next_down = item.quantity | minus: drawer_qty_step -%}
              {%- if drawer_qty_next_down < 0 -%}
                {%- assign drawer_qty_next_down = 0 -%}
              {%- endif -%}
              {%- assign drawer_qty_at_max = false -%}
              {%- if drawer_qty_max != blank and item.quantity >= drawer_qty_max -%}
                {%- assign drawer_qty_at_max = true -%}
              {%- endif -%}
              {%- comment -%}
                Bundle / fixed-bundle protection — Shopify exposes
                `line_item.instructions.can_update_quantity` and
                `line_item.instructions.can_remove` to tell themes
                whether a given line item can be modified by the
                customer. For child components of a bundle (Shopify
                Functions BundleConfiguration / fixed bundles), both
                are FALSE — letting the customer change one component
                in isolation would break bundle integrity. The
                Shopify-documented pattern is to gate qty / remove
                controls behind these instructions so bundle children
                render as read-only rows in the drawer rather than
                silently failing on /cart/change.js with a 422.
              {%- endcomment -%}
              {%- assign drawer_can_update = item.instructions.can_update_quantity | default: true -%}
              {%- assign drawer_can_remove = item.instructions.can_remove | default: true -%}
              <div class="kt-cart-drawer__item-footer">
                {%- if drawer_can_update -%}
                  <div class="kt-cart-drawer__qty">
                    <button
                      type="button"
                      class="kt-cart-drawer__qty-btn"
                      aria-label="{{ 'kt.product.quantity.decrease' | t: title: item.product.title | default: 'Decrease quantity' }}"
                      data-qty-change
                      data-line-key="{{ item.key }}"
                      data-qty="{{ drawer_qty_next_down }}"
                    >
                      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                    <span class="kt-cart-drawer__qty-value" aria-live="polite">{{ item.quantity }}</span>
                    <button
                      type="button"
                      class="kt-cart-drawer__qty-btn"
                      aria-label="{{ 'kt.product.quantity.increase' | t: title: item.product.title | default: 'Increase quantity' }}"
                      data-qty-change
                      data-line-key="{{ item.key }}"
                      data-qty="{{ drawer_qty_next_up }}"
                      {% if drawer_qty_at_max %}disabled aria-disabled="true"{% endif %}
                    >
                      {% render 'icon-plus', width: 14, height: 14 %}
                    </button>
                  </div>
                {%- else -%}
                  {%- comment -%} Read-only quantity for bundle children. {%- endcomment -%}
                  <span class="kt-cart-drawer__qty-readonly" aria-label="{{ 'kt.product.quantity.label' | t | default: 'Quantity' }}">
                    × {{ item.quantity }}
                  </span>
                {%- endif -%}

                {%- if drawer_can_remove -%}
                  {%- comment -%} Remove button — sets qty to 0 {%- endcomment -%}
                  <button
                    type="button"
                    class="kt-cart-drawer__remove"
                    aria-label="{{ 'kt.cart.remove' | t: title: item.product.title | default: 'Remove' }}"
                    data-qty-change
                    data-line-key="{{ item.key }}"
                    data-qty="0"
                  >
                    <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                      <path d="M10 11v6"></path>
                      <path d="M14 11v6"></path>
                      <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path>
                    </svg>
                  </button>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="kt-cart-drawer__empty-state">
          <svg class="kt-cart-drawer__empty-icon" aria-hidden="true" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 10h26l-3 22a4 4 0 0 1-4 3.5H18a4 4 0 0 1-4-3.5L11 10z"/>
            <path d="M11 10l-2-4H5"/>
            <circle cx="19" cy="41" r="2"/>
            <circle cx="32" cy="41" r="2"/>
          </svg>
          <p class="kt-cart-drawer__empty">{{ 'kt.cart.empty' | t | default: 'Your cart is empty' }}</p>
          {%- comment -%}
            Give empty-cart visitors a way out of the drawer without
            having to close it and hunt. Link the default "Start
            shopping" CTA to the all-products collection — same target
            main-cart.liquid uses for its own empty state.
          {%- endcomment -%}
          <a href="{{ routes.all_products_collection_url }}" class="kt-cart-drawer__empty-cta">
            {{ 'kt.cart.empty_cta' | t | default: 'Start shopping' }}
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} App blocks (e.g. cart upsells, discount widgets) {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="kt-cart-drawer__app-blocks">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%}
      R122 — Cart drawer recommendations / upsell. Reads the
      curated complementary products of the cart's most-recent
      item (cart.items[0] is the most-recently-added per Shopify
      conventions). Synchronous server-render — no async fetch
      needed because the metafield is loaded with the cart payload.

      Uses Shopify Search & Discovery's curated complementary
      products metafield (same source as PDP complementary_products
      block in R121). When the metafield is empty OR the merchant
      hasn't installed the Search & Discovery app, the
      recommendations section emits NOTHING — no broken band, no
      fallback to deceptive "Customers also bought".

      Empty-state: zero recommendations + design_mode would also
      emit nothing (cart drawer's editor preview is rare; the
      merchant tests this on a populated dev store anyway).

      Settings come from `section.settings` (passed through to this
      snippet via section: arg in sections/cart-drawer.liquid:26).
    {%- endcomment -%}
    {%- if cart.item_count > 0 and section.settings.show_recommendations -%}
      {%- assign cart_anchor_product = cart.items[0].product -%}
      {%- assign cart_recs = cart_anchor_product.metafields.shopify--discovery--product_recommendation.related_products.value -%}
      {%- if cart_recs and cart_recs.size > 0 -%}
        <div class="kt-cart-drawer__recommendations" data-cart-recommendations>
          <h3 class="kt-cart-drawer__recommendations-heading">
            {{- section.settings.recommendations_heading | default: 'You may also like' | escape -}}
          </h3>
          <ul class="kt-cart-drawer__recommendations-list" role="list">
            {%- for rec_product in cart_recs limit: section.settings.recommendations_count -%}
              {%- comment -%}
                Skip products already in the cart — recommending an
                item the customer just added is noise and reads as
                broken UX. Iterate cart.items to check.
              {%- endcomment -%}
              {%- assign rec_in_cart = false -%}
              {%- for cart_item in cart.items -%}
                {%- if cart_item.product_id == rec_product.id -%}
                  {%- assign rec_in_cart = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- unless rec_in_cart -%}
                <li class="kt-cart-drawer__recommendation">
                  <a class="kt-cart-drawer__recommendation-link" href="{{ rec_product.url }}">
                    <div class="kt-cart-drawer__recommendation-media">
                      {%- if rec_product.featured_media != blank -%}
                        {{ rec_product.featured_media | image_url: width: 200 | image_tag:
                            loading: 'lazy',
                            widths: '100, 200, 300',
                            sizes: '100px',
                            width: 100,
                            height: 100,
                            class: 'kt-cart-drawer__recommendation-image',
                            alt: rec_product.featured_media.alt | default: rec_product.title }}
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'kt-cart-drawer__recommendation-image kt-cart-drawer__recommendation-image--placeholder' }}
                      {%- endif -%}
                    </div>
                    <div class="kt-cart-drawer__recommendation-text">
                      <p class="kt-cart-drawer__recommendation-title">{{ rec_product.title | escape }}</p>
                      {%- if rec_product.price_varies -%}
                        {%- assign rec_price_money = rec_product.price_min | money -%}
                        <p class="kt-cart-drawer__recommendation-price">{{ 'kt.product.from_price_label' | t }} {{ rec_price_money }}</p>
                      {%- else -%}
                        <p class="kt-cart-drawer__recommendation-price">{{ rec_product.price | money }}</p>
                      {%- endif -%}
                    </div>
                  </a>
                </li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} Footer {%- endcomment -%}
    {%- if cart.item_count > 0 -%}
      <div class="kt-cart-drawer__footer">
        {%- render 'free-shipping-bar' -%}

        {%- comment -%}
          Cart-level discount applications (auto-applied or code-applied
          to the whole cart, not a specific line). /cart page renders
          this between subtotal and total; drawer mirrors. Without it,
          a customer who applies a discount code on /cart and re-
          opens the drawer can't see what they saved.
        {%- endcomment -%}
        {%- if cart.cart_level_discount_applications.size > 0 -%}
          <ul class="kt-cart-drawer__discounts" role="list">
            {%- for discount in cart.cart_level_discount_applications -%}
              <li class="kt-cart-drawer__discount">
                <span class="kt-cart-drawer__discount-label">{{ discount.title | escape }}</span>
                <span class="kt-cart-drawer__discount-amount">– {{ discount.total_allocated_amount | money }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- comment -%}
          Discount code entry — drawer parity with /cart page. Without
          this, a customer pasting a promo from a marketing email has
          to navigate away from the drawer to /cart to redeem it,
          which Theme Store reviewers cite as a known parity gap on
          modern themes. Same `/discount/<code>` server-side endpoint
          used by main-cart.liquid; works without JS via plain GET
          form + `redirect` hidden input. Gated on the same
          `kt_cart_show_discount` setting so merchants who hide
          discount entry on /cart also get it hidden in the drawer.
        {%- endcomment -%}
        {%- if settings.kt_cart_show_discount -%}
          <form
            action="{{ routes.root_url }}discount/{% if cart.discount_codes.size > 0 %}{{ cart.discount_codes | first | url_encode }}{% endif %}"
            method="get"
            class="kt-cart-drawer__discount-form"
            data-cart-drawer-discount-form
          >
            <input type="hidden" name="redirect" value="{{ routes.cart_url }}">
            <label for="cart-drawer-discount-code" class="visually-hidden">
              {{ 'kt.cart.discount.label' | t | default: 'Discount code' }}
            </label>
            <div class="kt-cart-drawer__discount-row">
              <input
                type="text"
                id="cart-drawer-discount-code"
                name="code"
                class="kt-cart-drawer__discount-input"
                placeholder="{{ 'kt.cart.discount.placeholder' | t | default: 'Discount code' }}"
                autocomplete="off"
                autocapitalize="characters"
                spellcheck="false"
              >
              <button type="submit" class="kt-cart-drawer__discount-submit">
                {{ 'kt.cart.discount.apply' | t | default: 'Apply' }}
              </button>
            </div>
            {%- if cart.discount_codes.size > 0 -%}
              <ul class="kt-cart-drawer__discount-applied" role="list">
                {%- for code in cart.discount_codes -%}
                  <li class="kt-cart-drawer__discount-chip">
                    <span>{{ code }}</span>
                    <a
                      href="{{ routes.root_url }}discount?redirect={{ routes.cart_url | url_encode }}"
                      class="kt-cart-drawer__discount-remove"
                      aria-label="{{ 'kt.cart.discount.remove_aria' | t: code: code | default: 'Remove discount code' }}"
                    >&times;</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </form>
        {%- endif -%}

        {%- comment -%}
          Visual error region for cart-update failures. cart-drawer.js
          calls `Kitchero.announce(msg, 'assertive')` on /cart/change.js
          422s — that reaches SR users via the global live region but
          sighted users see the qty silently snap back with no visible
          feedback. role="alert" + JS-toggled hidden gives both.
        {%- endcomment -%}
        <div class="kt-cart-drawer__error" data-cart-drawer-error role="alert" hidden></div>

        <div class="kt-cart-drawer__subtotal">
          <span class="kt-cart-drawer__subtotal-label">{{ 'kt.cart.subtotal' | t | default: 'Subtotal' }}</span>
          {%- comment -%}
            Grand total in the drawer footer uses money_with_currency
            to match the /cart page. On multi-currency stores the ISO
            code right above the Checkout CTA prevents customer
            confusion about which currency will be charged.

            data-cart-subtotal — INS-05: Shopify's
            <shopify-payment-terms> custom element observes this
            attribute to refresh installment quotes after cart
            mutations. Same hook as main-cart.liquid summary row.
          {%- endcomment -%}
          <span class="kt-cart-drawer__subtotal-value" data-cart-subtotal>{{ cart.total_price | money_with_currency }}</span>
        </div>
        <p class="kt-cart-drawer__taxes">
          {%- comment -%}
            Four-way branch: tax-exempt customer (B2B / nonprofit),
            digital-only cart (no shipping), tax-inclusive (EU-style),
            or default "calculated at checkout".

            R150 TAX-EXEMPT-COPY-1: customer.tax_exempt? takes
            precedence — for B2B / nonprofit customers Shopify zeros
            the tax at checkout but the default "Taxes calculated at
            checkout" copy is misleading because no tax is calculable.
            Surface a "Tax-exempt account" note instead. Matches the
            B2B-focused reviewer rubric (R148 audit).

            Matches main-cart.liquid copy logic exactly so page and
            drawer can't contradict each other.
          {%- endcomment -%}
          {%- if customer.tax_exempt? -%}
            {{ 'kt.cart.taxes_note_exempt' | t | default: 'Tax-exempt account. Shipping calculated at checkout.' }}
          {%- elsif cart.requires_shipping == false -%}
            {{ 'kt.cart.taxes_note_digital' | t }}
          {%- elsif cart.taxes_included -%}
            {{ 'kt.cart.taxes_note_included' | t | default: 'Tax included. Shipping calculated at checkout.' }}
          {%- else -%}
            {{ 'kt.cart.taxes_note' | t }}
          {%- endif -%}
        </p>
        {%- comment -%}
          Real checkout submit — Shopify routes POST to /cart with
          name="checkout" directly to /checkouts/..., bypassing the
          /cart page. Wrapping only the submit button (not the whole
          drawer) keeps the existing AJAX quantity update path intact.

          Use `{% form 'cart' %}` here so Shopify injects the CSRF
          authenticity_token + auto-routes to routes.cart_url for
          the current locale. Hand-rolled `<form action="{{ routes.cart_url }}">`
          was missing the authenticity token; main-cart.liquid
          already uses the form block — drawer now matches.
        {%- endcomment -%}
        {%- comment -%}
          Pass `cart` as the second positional argument. Shopify's
          `{% form 'cart' %}` tag requires the cart object — without
          it the runtime throws "cart form must be given a cart",
          which in turn leaves the drawer's checkout button unrendered
          and the surrounding HTML malformed (the error message bleeds
          into the drawer body). main-cart.liquid already does this
          at line 40; drawer now matches.
        {%- endcomment -%}
        {%- form 'cart', cart, class: 'kt-cart-drawer__checkout-form', novalidate: 'novalidate' -%}
          {%- comment -%}
            Installments banner (INS-03): emitted inside the cart
            form so the `form` object resolves for the
            payment_terms filter. Renders nothing if Shop Pay
            Installments isn't configured for the merchant.
            Positioned at the top of the form (just above the
            order-note details + checkout button) so the customer
            sees the financing offer alongside the cart total.
          {%- endcomment -%}
          {{ form | payment_terms }}

          {%- comment -%}
            Optional order note — gated on the same kt_cart_show_note
            setting as /cart. Drawer checkout skips the /cart page and
            POSTs straight to /checkouts/..., so if we didn't surface
            the note here a merchant who enabled notes in settings
            would see them on the page but never from the drawer. Must
            live INSIDE {% form 'cart' %} so the name="note" attr binds
            to the same POST body Shopify sends to /checkouts/... The
            <details> wrapper keeps the drawer compact — collapsed by
            default, expands when the customer wants to leave a note
            (gift message, delivery instructions, etc.).
          {%- endcomment -%}
          {%- if settings.kt_cart_show_note -%}
            <details class="kt-cart-drawer__note-details">
              <summary class="kt-cart-drawer__note-toggle">
                {{ 'kt.cart.note_toggle' | t | default: 'Add order note' }}
              </summary>
              <label class="kt-cart-drawer__note-label" for="CartDrawerNote">
                <span class="visually-hidden">{{ 'kt.cart.note' | t | default: 'Order note' }}</span>
              </label>
              <textarea
                id="CartDrawerNote"
                name="note"
                class="kt-cart-drawer__note"
                rows="3"
                maxlength="2000"
                placeholder="{{ 'kt.cart.note_placeholder' | t }}"
              >{{ cart.note | escape }}</textarea>
            </details>
          {%- endif -%}

          <button type="submit" name="checkout" class="kt-cart-drawer__checkout">
            {{ 'kt.cart.checkout' | t | default: 'Checkout' }}
          </button>

          {%- comment -%}
            Express / dynamic checkout buttons — Shop Pay, Apple Pay,
            Google Pay, PayPal, etc. Shopify injects these via
            content_for_additional_checkout_buttons ONLY when they are
            enabled in Settings → Payments and the current cart is
            eligible (no subscription-only bundles, etc.). The slot
            MUST live inside the cart form so the active cart ships
            with the express-payment POST. Matching main-cart.liquid's
            wrapper so both checkout surfaces render the same chrome.
          {%- endcomment -%}
          {%- if additional_checkout_buttons -%}
            <div class="kt-cart-drawer__additional-checkout" role="group" aria-label="{{ 'kt.cart.additional_checkout' | t | default: 'Additional payment options' }}">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%}
        {%- endform -%}
        <button type="button" class="kt-cart-drawer__continue" data-cart-drawer-close>
          {{ 'kt.cart.continue_shopping' | t | default: 'Continue shopping' }}
        </button>
      </div>
    {%- endif -%}
  </div>
</cart-drawer>
