{%- comment -%}
  Shared video modal — iframe-based lightbox for YouTube / Vimeo.
  Used by video-split-modal and video-poster-modal sections.

  Accepts:
  - modal_id: {String} unique DOM id (e.g. 'VideoModal-<section.id>')

  The iframe src is set by assets/video-modal.js when the user clicks
  an element with `[data-modal-video-open]`. Closing clears the src so
  playback stops. Escape, backdrop click, and close button all close.
{%- endcomment -%}

<div
  class="kt-video-modal"
  id="{{ modal_id }}"
  data-video-modal
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'sections.video_modal.aria_label' | t | default: 'Video player' }}"
>
  <div class="kt-video-modal__backdrop" data-video-modal-close aria-hidden="true"></div>

  <div class="kt-video-modal__inner">
    <button
      type="button"
      class="kt-video-modal__close"
      data-video-modal-close
      aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
    >
      <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="kt-video-modal__frame-wrap">
      <iframe
        class="kt-video-modal__frame"
        data-video-modal-frame
        src=""
        title="{{ 'sections.video_modal.iframe_title' | t | default: 'Video player' }}"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>
