{%- comment -%}
  Outputs JSON-LD structured data for SEO.
  Scope: Organization (always) + BreadcrumbList (non-homepage).

  Product and Article JSON-LD are intentionally NOT handled here —
  they are emitted by snippets/meta-tags.liquid using Shopify's
  native `| structured_data` filter, which produces a richer,
  always-up-to-date payload than hand-rolled JSON. Duplicating them
  would produce two <script type="application/ld+json"> blocks of
  the same type on the page, which Google flags as a schema issue.
{%- endcomment -%}

{%- unless request.page_type == 'product' or request.page_type == 'article' -%}
  {%- comment -%}
    Build sameAs as a collected array then join, so we never emit a
    trailing comma. The previous shape used `{%- unless forloop.last -%}`
    inside a series of independent `if` blocks (no `forloop` exists in
    that context), which meant the comma was always emitted: enabling
    only Facebook produced `"sameAs": [url1,]` — invalid JSON that
    Google's Rich Results Test rejects outright.

    Logo: Google's Organization schema strongly recommends a logo of
    at least 112×112 so the Knowledge Panel can pick up the brand
    mark. Emit the theme logo when set, otherwise Shopify's native
    brand logo (admin → Settings → Brand).
  {%- endcomment -%}
  {%- assign social_urls = '' -%}
  {%- if settings.kt_social_facebook != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_facebook | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_instagram != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_instagram | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_twitter != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_twitter | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_youtube != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_youtube | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_pinterest != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_pinterest | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_tiktok != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_tiktok | append: '||' -%}{%- endif -%}
  {%- assign social_urls = social_urls | split: '||' -%}

  {%- assign brand_logo = settings.kt_logo | default: shop.brand.logo -%}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }}
      {%- if brand_logo != blank -%}
        ,"logo": {{ brand_logo | image_url: width: 512 | prepend: 'https:' | json }}
      {%- endif -%}
      {%- if social_urls.size > 0 -%}
        ,"sameAs": [
          {%- for url in social_urls -%}
            {{ url | json }}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      {%- endif -%}
    }
  </script>
{%- endunless -%}

{%- comment -%}
  WebSite + SearchAction — homepage only. Gives Google the sitelinks
  search-box treatment in SERPs by pointing at /search?q={term}.
{%- endcomment -%}
{%- if request.page_type == 'index' -%}
  {%- capture search_action_url_template -%}{{ request.origin }}{{ routes.search_url }}?q={search_term_string}{%- endcapture -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ search_action_url_template | json }}
        },
        "query-input": "required name=search_term_string"
      }
    }
  </script>
{%- endif -%}

{%- comment -%} BreadcrumbList — output on every non-homepage template. {%- endcomment -%}
{%- unless request.page_type == 'index' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ request.origin | json }}
        }
        {%- if request.page_type == 'product' -%}
          {%- comment -%}
            Pick the first collection this product lives in — that's the
            breadcrumb's "category" rung. When the product is orphan
            (no collection associated), fall back to the locale-aware
            all-products route and a translated label so Google gets a
            valid breadcrumb either way.

            Aside: do NOT chain `| default: ...` after `request.origin
            | append: product.collections.first.url` — `append` on a nil
            value still produces `request.origin`, which is a non-empty
            string, so the default never fires.
          {%- endcomment -%}
          {%- if product.collections.first != blank -%}
            {%- assign breadcrumb_collection_title = product.collections.first.title -%}
            {%- assign breadcrumb_collection_url = product.collections.first.url -%}
          {%- else -%}
            {%- assign breadcrumb_collection_title = 'kt.general.breadcrumbs.products' | t -%}
            {%- assign breadcrumb_collection_url = routes.all_products_collection_url -%}
          {%- endif -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ breadcrumb_collection_title | json }},
            "item": {{ request.origin | append: breadcrumb_collection_url | json }}
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }}
          }
        {%- elsif request.page_type == 'collection' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }}
          }
        {%- elsif request.page_type == 'article' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ request.origin | append: blog.url | json }}
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ article.title | json }}
          }
        {%- elsif request.page_type == 'page' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ page.title | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endunless -%}
