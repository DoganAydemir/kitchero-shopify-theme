{%- comment -%}
  Outputs JSON-LD structured data for SEO.
  Scope: Organization (always) + BreadcrumbList (non-homepage).

  Product and Article JSON-LD are intentionally NOT handled here —
  they are emitted by snippets/meta-tags.liquid using Shopify's
  native `| structured_data` filter, which produces a richer,
  always-up-to-date payload than hand-rolled JSON. Duplicating them
  would produce two <script type="application/ld+json"> blocks of
  the same type on the page, which Google flags as a schema issue.
{%- endcomment -%}

{%- unless request.page_type == 'product' or request.page_type == 'article' -%}
  {%- comment -%}
    Build sameAs as a collected array then join, so we never emit a
    trailing comma. The previous shape used `{%- unless forloop.last -%}`
    inside a series of independent `if` blocks (no `forloop` exists in
    that context), which meant the comma was always emitted: enabling
    only Facebook produced `"sameAs": [url1,]` — invalid JSON that
    Google's Rich Results Test rejects outright.

    Logo: Google's Organization schema strongly recommends a logo of
    at least 112×112 so the Knowledge Panel can pick up the brand
    mark. Emit the theme logo when set, otherwise Shopify's native
    brand logo (admin → Settings → Brand).
  {%- endcomment -%}
  {%- assign social_urls = '' -%}
  {%- if settings.kt_social_facebook != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_facebook | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_instagram != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_instagram | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_twitter != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_twitter | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_youtube != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_youtube | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_pinterest != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_pinterest | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_tiktok != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_tiktok | append: '||' -%}{%- endif -%}
  {%- if settings.kt_social_linkedin != blank -%}{%- assign social_urls = social_urls | append: settings.kt_social_linkedin | append: '||' -%}{%- endif -%}
  {%- assign social_urls = social_urls | split: '||' -%}

  {%- assign brand_logo = settings.kt_logo | default: shop.brand.logo -%}

  {%- comment -%}
    Organization — enriched with contactPoint + PostalAddress when
    the merchant has populated shop.email / shop.phone / shop.address
    in admin → Settings → General. Google's Knowledge Panel + rich
    results reward the additional fields; reviewers running the
    Rich Results Test flagged "add recommended fields" on the minimal
    version. Everything is gated: absent admin fields → no emission,
    no half-populated contactPoint that Google would flag as broken.
  {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }}
      {%- if brand_logo != blank -%}
        ,"logo": {{ brand_logo | image_url: width: 512 | prepend: 'https:' | json }}
      {%- endif -%}
      {%- if social_urls.size > 0 -%}
        ,"sameAs": [
          {%- for url in social_urls -%}
            {{ url | json }}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      {%- endif -%}
      {%- if shop.phone != blank or shop.email != blank -%}
        ,"contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer support"
          {%- if shop.phone != blank -%}
            ,"telephone": {{ shop.phone | json }}
          {%- endif -%}
          {%- if shop.email != blank -%}
            ,"email": {{ shop.email | json }}
          {%- endif -%}
        }
      {%- endif -%}
      {%- if shop.address.street != blank or shop.address.city != blank -%}
        ,"address": {
          "@type": "PostalAddress"
          {%- if shop.address.street != blank -%}
            ,"streetAddress": {{ shop.address.street | json }}
          {%- endif -%}
          {%- if shop.address.city != blank -%}
            ,"addressLocality": {{ shop.address.city | json }}
          {%- endif -%}
          {%- if shop.address.province != blank -%}
            ,"addressRegion": {{ shop.address.province | json }}
          {%- endif -%}
          {%- if shop.address.zip != blank -%}
            ,"postalCode": {{ shop.address.zip | json }}
          {%- endif -%}
          {%- if shop.address.country != blank -%}
            {%- comment -%}
              Google prefers ISO 3166-1 alpha-2 for addressCountry
              (e.g. "US", "TR", "DE"). Shopify's `country_code` is
              that ISO form; `country` is the localized full name.
              Previous code referenced `country_upper` which isn't a
              real Liquid property and silently fell back to the
              localized name. Emit ISO code first, full name as
              fallback for stores without country_code set.
            {%- endcomment -%}
            ,"addressCountry": {{ shop.address.country_code | default: shop.address.country | json }}
          {%- endif -%}
        }
      {%- endif -%}
    }
  </script>
{%- endunless -%}

{%- comment -%}
  WebSite + SearchAction — homepage only. Gives Google the sitelinks
  search-box treatment in SERPs by pointing at /search?q={term}.
{%- endcomment -%}
{%- if request.page_type == 'index' -%}
  {%- capture search_action_url_template -%}{{ request.origin }}{{ routes.search_url }}?q={search_term_string}{%- endcapture -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }},
      {%- comment -%}
        inLanguage — recommended for multi-locale stores so Google
        Search Console can attribute WebSite / SearchAction to the
        right locale index. `request.locale.iso_code` is "en", "tr",
        "de-DE" etc. — either ISO 639 or BCP 47, both accepted by
        schema.org. Single-locale stores still benefit (clears the
        "missing field" recommendation in Rich Results Test).
      {%- endcomment -%}
      "inLanguage": {{ request.locale.iso_code | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ search_action_url_template | json }}
        },
        "query-input": "required name=search_term_string"
      }
    }
  </script>
{%- endif -%}

{%- comment -%} BreadcrumbList — output on every non-homepage template. {%- endcomment -%}
{%- unless request.page_type == 'index' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ request.origin | json }}
        }
        {%- if request.page_type == 'product' -%}
          {%- comment -%}
            Pick the first collection this product lives in — that's the
            breadcrumb's "category" rung. When the product is orphan
            (no collection associated), fall back to the locale-aware
            all-products route and a translated label so Google gets a
            valid breadcrumb either way.

            Aside: do NOT chain `| default: ...` after `request.origin
            | append: product.collections.first.url` — `append` on a nil
            value still produces `request.origin`, which is a non-empty
            string, so the default never fires.
          {%- endcomment -%}
          {%- if product.collections.first != blank -%}
            {%- assign breadcrumb_collection_title = product.collections.first.title -%}
            {%- assign breadcrumb_collection_url = product.collections.first.url -%}
          {%- else -%}
            {%- assign breadcrumb_collection_title = 'kt.general.breadcrumbs.products' | t -%}
            {%- assign breadcrumb_collection_url = routes.all_products_collection_url -%}
          {%- endif -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ breadcrumb_collection_title | json }},
            "item": {{ request.origin | append: breadcrumb_collection_url | json }}
          }
          {%- comment -%}
            Last-crumb `item` URL — Google's Rich Results Test flags
            "Recommended field: item" when the final ListItem omits
            it. Spec permits omission but every Theme Store reviewer
            who runs the validator will see the warning. `canonical_url`
            is always present and correct for the current page.
          {%- endcomment -%}
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": {{ canonical_url | json }}
          }
        {%- elsif request.page_type == 'collection' -%}
          {%- comment -%}
            When the collection is being viewed under a tag filter
            (/collections/<handle>/<tag>) or with `current_tags`
            active, the tag becomes a third breadcrumb rung. The
            canonical URL at position 2 is the un-tagged collection
            (so Google's graph always has the parent), and position 3
            joins the tag names if present. Without this the tag-
            filtered view shared the same breadcrumb as the un-tagged
            collection — Rich Results flagged "Duplicate breadcrumb"
            on index-vs-filter pages.
          {%- endcomment -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ request.origin | append: collection.url | json }}
          }
          {%- if current_tags -%}
            ,{
              "@type": "ListItem",
              "position": 3,
              "name": {{ current_tags | join: ', ' | json }},
              "item": {{ canonical_url | json }}
            }
          {%- endif -%}
        {%- elsif request.page_type == 'article' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ request.origin | append: blog.url | json }}
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ article.title | json }},
            "item": {{ canonical_url | json }}
          }
        {%- elsif request.page_type == 'page' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ page.title | json }},
            "item": {{ canonical_url | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endunless -%}
