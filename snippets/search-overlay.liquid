{{ 'kt-section-predictive-search.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  Search Overlay — full-screen search modal.
  Ported from SearchOverlay.tsx.

  - Form submits to /search (routes.search_url) as a regular GET request
    so the modal works without JavaScript.
  - Popular search term pills come from theme setting
    `settings.kt_search_popular` (comma-separated). When empty, the
    suggestions row is hidden entirely.
  - JS (assets/search-overlay.js) handles open/close, body scroll lock,
    focus trap, Escape-to-close, and pill → input fill.
{%- endcomment -%}

<div class="kt-search-overlay" id="search-overlay" aria-hidden="true" inert data-search-overlay>
  <div class="kt-search-overlay__backdrop" data-search-close aria-hidden="true"></div>
  <div class="kt-search-overlay__content" role="dialog" aria-modal="true" aria-label="{{ 'kt.search.search' | t }}" tabindex="-1">
    <button type="button" class="kt-search-overlay__close" data-search-close aria-label="{{ 'kt.a11y.close' | t | default: 'Close' }}">
      {% render 'icon-close', stroke_width: 1.5 %}
    </button>

    <div class="kt-search-overlay__form-wrapper">
      <form action="{{ routes.search_url }}" method="get" role="search" class="kt-search-overlay__form">
        <label for="search-overlay-input" class="visually-hidden">{{ 'kt.search.search' | t }}</label>
        <div class="kt-search-overlay__input-wrap">
          <svg class="kt-search-overlay__icon" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          {%- comment -%}
            ARIA combobox pattern — predictive-search.js populates
            #predictive-search-results (role="listbox" below) with
            role="option" items as the customer types. These attrs
            let assistive tech announce the combobox state + current
            highlighted option. WCAG 2.1 SC 4.1.2 compliant.
          {%- endcomment -%}
          <input
            type="search"
            id="search-overlay-input"
            name="q"
            class="kt-search-overlay__input"
            placeholder="{{ 'kt.search.placeholder' | t }}"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            enterkeyhint="search"
            inputmode="search"
            role="combobox"
            aria-expanded="false"
            aria-controls="predictive-search-results"
            {%- comment -%}
              aria-owns mirrors aria-controls per the WAI-ARIA 1.2
              combobox + multi-listbox pattern Shopify's predictive-
              search docs document. Without it, AT can't always
              traverse from the input into the results subtree
              when DOM focus stays on the input (aria-activedescendant
              flow). Belt-and-braces with aria-controls.
            {%- endcomment -%}
            aria-owns="predictive-search-results"
            aria-autocomplete="list"
            aria-haspopup="listbox"
            data-search-input
          >
          {%- comment -%}
            R296 — Type scope is driven by the merchant's "Include in
            results" theme settings (Theme settings → Search behavior).
            Previously the value was hardcoded to ALL four types,
            which meant disabling "Pages" or "Journal articles" in
            theme settings had no effect — the Enter-key submit still
            asked Shopify to search across every type. Now we build
            the scope string from the same toggles that drive the
            predictive-search overlay, so a merchant who wants a
            product-only search consistently gets product-only.
          {%- endcomment -%}
          {%- liquid
            assign overlay_search_types = ''
            if settings.kt_search_inc_products
              assign overlay_search_types = overlay_search_types | append: 'product,'
            endif
            if settings.kt_search_inc_collections
              assign overlay_search_types = overlay_search_types | append: 'collection,'
            endif
            if settings.kt_search_inc_articles
              assign overlay_search_types = overlay_search_types | append: 'article,'
            endif
            if settings.kt_search_inc_pages
              assign overlay_search_types = overlay_search_types | append: 'page,'
            endif
            assign overlay_search_types = overlay_search_types | split: ',' | join: ','
            if overlay_search_types == blank
              assign overlay_search_types = 'product'
            endif
          -%}
          <input type="hidden" name="type" value="{{ overlay_search_types }}">
        </div>
      </form>

      {%- comment -%}
        Predictive search results container. Per Shopify's predictive-
        search docs (and WAI-ARIA combobox pattern): when the popup
        contains MULTIPLE labelled groups (Products, Collections,
        Articles, Pages), each group's <ul> carries role="listbox"
        with aria-labelledby pointing to its heading id. The wrapper
        does NOT carry role="listbox" — that would create an invalid
        listbox-inside-listbox nesting (W3C valid only when the
        outer is role="tree" or similar).

        Kept aria-live="polite" so SR announces result-set changes
        on mass-DOM replacement (debounced fetch responses).
      {%- endcomment -%}
      <div
        class="kt-search-overlay__results"
        id="predictive-search-results"
        aria-live="polite"
      ></div>

      {%- comment -%} Popular search term pills (from theme settings) {%- endcomment -%}
      {%- assign popular_terms = settings.kt_search_popular | default: '' -%}
      {%- if popular_terms != blank -%}
        <div class="kt-search-overlay__suggestions">
          <p class="kt-search-overlay__suggestions-label">{{ 'kt.search.suggestions' | t | default: 'Popular searches' }}</p>
          <div class="kt-search-overlay__suggestions-list">
            {%- assign terms_array = popular_terms | split: ',' -%}
            {%- for raw_term in terms_array -%}
              {%- assign term = raw_term | strip -%}
              {%- if term != blank -%}
                <button type="button" class="kt-search-overlay__suggestion-pill" data-search-term="{{ term | escape }}">
                  {{ term }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
