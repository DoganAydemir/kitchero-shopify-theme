{%- comment -%}
  Product Card — renders a single product in collection grids.
  Ported birebir from CollectionsGrid.tsx card structure.

  Accepts:
  - product: {Object} Shopify product
  - show_vendor: {Boolean} Show vendor name on hover (default: true)
  - show_secondary_image: {Boolean} Show hover image swap (default: true)
  - show_quote_button: {Boolean} Show "Get Quote" button (default: true)
  - index: {Number} Zero-based index of card in grid; first 3 get eager loading for LCP (default: 99)
{%- endcomment -%}

{%- liquid
  assign show_vendor = show_vendor | default: true
  assign show_secondary_image = show_secondary_image | default: true
  assign show_quote_button = show_quote_button | default: true
  assign secondary_image = product.images[1] | default: nil
  assign card_index = index | default: 99
  if card_index < 3
    assign primary_loading = 'eager'
  else
    assign primary_loading = 'lazy'
  endif
  if card_index == 0
    assign primary_fetchpriority = 'high'
  else
    assign primary_fetchpriority = 'auto'
  endif
-%}

<div class="kt-card-product">
  {%- comment -%} Image Link {%- endcomment -%}
  {%- assign hover_has_secondary = false -%}
  {%- if show_secondary_image and secondary_image -%}
    {%- assign hover_has_secondary = true -%}
  {%- endif -%}
  <a href="{{ product.url }}" class="kt-card-product__image-link{% unless hover_has_secondary %} kt-card-product__image-link--zoom-only{% endunless %}" aria-label="{{ product.title }}">
    {%- comment -%} Gradient overlay {%- endcomment -%}
    <div class="kt-card-product__gradient" aria-hidden="true"></div>

    {%- comment -%} Determine if hover swap or hover zoom {%- endcomment -%}
    {%- assign has_hover_swap = false -%}
    {%- if show_secondary_image and secondary_image -%}
      {%- assign has_hover_swap = true -%}
    {%- endif -%}

    {%- comment -%}
      Primary image. `sizes` is tuned to the actual grid layouts:
      collection grid is 3 cols at ≥990px (~33vw), 2 cols at 750-989px
      (~50vw), 1 col below 750px (100vw). Previously declared
      `50vw` across the 990px threshold, forcing the browser to pull
      ~800w candidates on a 1440px viewport (needed ~475w) — estimated
      ~500-900KB wasted per first-fold on a 12-card collection page.
      Width ladder also extended upward (1100) so 2-col tablet
      DPR 2 gets a sharp candidate (previously capped at 800 →
      blurry on retina tablets).
    {%- endcomment -%}
    {%- if product.featured_image -%}
      {{
        product.featured_image
        | image_url: width: 1100
        | image_tag:
          class: 'kt-card-product__image-primary',
          loading: primary_loading,
          fetchpriority: primary_fetchpriority,
          widths: '275, 375, 550, 750, 1100',
          sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
          width: product.featured_image.width,
          height: product.featured_image.height,
          alt: product.title
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg kt-card-product__image-primary' }}
    {%- endif -%}

    {%- comment -%} Secondary hover image (only if exists) {%- endcomment -%}
    {%- if has_hover_swap -%}
      {{
        secondary_image
        | image_url: width: 1100
        | image_tag:
          class: 'kt-card-product__image-secondary',
          loading: 'lazy',
          widths: '275, 375, 550, 750, 1100',
          sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
          width: secondary_image.width,
          height: secondary_image.height,
          alt: 'kt.product.card.image_alt_detail' | t: title: product.title
      }}
    {%- endif -%}

    {%- comment -%} Style badge (first tag or product type) {%- endcomment -%}
    {%- if product.type != blank -%}
      <span class="kt-card-product__badge">{{ product.type }}</span>
    {%- endif -%}

    {%- comment -%} Sale badge {%- endcomment -%}
    {%- if product.compare_at_price > product.price -%}
      {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      <span class="kt-card-product__badge kt-card-product__badge--sale" style="top: auto; bottom: 1.5rem; left: 1.5rem;">
        {{ 'kt.product.discount_badge' | t: amount: discount_pct }}
      </span>
    {%- endif -%}

    {%- comment -%} Countdown pill (if deal_ends_at metafield set) {%- endcomment -%}
    {%- render 'countdown', product: product -%}

    {%- comment -%} Hover info (vendor + material) {%- endcomment -%}
    {%- if show_vendor and product.vendor != blank -%}
      <div class="kt-card-product__hover-info">
        <p class="kt-card-product__vendor">{{ product.vendor }}</p>
      </div>
    {%- endif -%}
  </a>

  {%- comment -%} Content below image {%- endcomment -%}
  <div class="kt-card-product__content">
    <div class="kt-card-product__info">
      <h3 class="kt-card-product__title">
        <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">{{ product.title }}</a>
      </h3>

      {%- comment -%} Star rating {%- endcomment -%}
      {%- render 'product-rating', product: product -%}

      {%- comment -%} Color swatches {%- endcomment -%}
      {%- render 'product-swatches', product: product -%}

      {%- comment -%} Price {%- endcomment -%}
      <div class="kt-card-product__price-row">
        {%- if product.price_varies -%}
          <span class="kt-card-product__price-from">{{ 'kt.product.from_price_label' | t }}</span>
          <span class="kt-card-product__price">{{ product.price_min | money }}</span>
        {%- else -%}
          <span class="kt-card-product__price">
            {%- if product.compare_at_price > product.price -%}
              <span class="visually-hidden">{{ 'kt.product.sale_price' | t }}&nbsp;</span>
            {%- endif -%}
            {{ product.price | money }}
          </span>
        {%- endif -%}
        {%- if product.compare_at_price > product.price -%}
          {%- comment -%}
            <s> makes the strikethrough semantic so screen readers
            announce the "no-longer-valid" meaning of the price.
            Visually-hidden prefix supplies the textual label so AT
            reads "Regular price $80" instead of just "$80".
          {%- endcomment -%}
          <s class="kt-card-product__compare-price">
            <span class="visually-hidden">{{ 'kt.product.regular_price' | t }}&nbsp;</span>
            {{ product.compare_at_price | money }}
          </s>
        {%- endif -%}
      </div>

      <a href="{{ product.url }}" class="kt-card-product__view-link">
        {{ 'kt.product.view_details' | t | default: 'View Details' }}
      </a>
    </div>

    {%- if show_quote_button -%}
      <div>
        <a href="{{ product.url }}" class="kt-card-product__quote-btn">
          {{ 'kt.product.get_quote' | t | default: 'Get Quote' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>
