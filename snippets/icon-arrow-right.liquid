{%- comment -%}
  Arrow-right icon. Used in CTAs, slider/carousel arrows, "Read more"
  links, "View all" links, "Continue" buttons.

  Accepts:
    width  : Number  (default 16)
    height : Number  (default 16)
    stroke_width : Number  (default 2)
    class : String  (optional)
{%- endcomment -%}
{%- liquid
  assign icon_w = width | default: 16
  assign icon_h = height | default: 16
  assign icon_sw = stroke_width | default: 2
-%}
<svg{% if class %} class="{{ class }}"{% endif %} aria-hidden="true" focusable="false" width="{{ icon_w }}" height="{{ icon_h }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ icon_sw }}" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
