{%- comment -%}
  Chevron-left icon. Used in carousel/slider prev arrows, before/
  after handle, gallery navigation.

  Accepts:
    width  : Number  (default 24)
    height : Number  (default 24)
    stroke_width : Number  (default 1.8)
    class : String  (optional)
{%- endcomment -%}
{%- liquid
  assign icon_w = width | default: 24
  assign icon_h = height | default: 24
  assign icon_sw = stroke_width | default: 1.8
-%}
<svg{% if class %} class="{{ class }}"{% endif %} aria-hidden="true" focusable="false" width="{{ icon_w }}" height="{{ icon_h }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ icon_sw }}" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
