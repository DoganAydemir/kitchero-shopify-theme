{%- doc -%}
  First-paint intro loader — "The Opening".

  Awwwards-style multi-layer reveal:
    · top horizontal line draws left→right
    · corner meta text fades in
    · brand text center-stage, per-character slide-up with stagger
    · rotating word cycler bottom-left
    · 00 → 100 counter bottom-right
    · full-width progress bar at bottom edge
    · exit: characters slide up, clip-path splits vertically

  Fully merchant-controllable via theme settings (Intro loader group):
    · enable / disable entirely
    · brand text (defaults to shop.name when blank)
    · four rotating words + on/off
    · background, text and accent colors

  The bootstrap script in theme.liquid toggles `kt-loader-skip` on
  <html> before first paint to skip this block on repeat sessions,
  inside the theme editor, or when the merchant has disabled the
  loader entirely. The <noscript> fallback hides it when JS is off.
{%- enddoc -%}

{%- unless settings.kt_loader_enable -%}
  {%- comment -%} Merchant turned the loader off — render nothing. {%- endcomment -%}
{%- else -%}
{%- comment -%}
  No-JS hide is handled globally in assets/base.css via the
  `html:not(.js) .kt-loader { display: none }` rule — the early
  bootstrap script in theme.liquid sets `html.js` synchronously
  before paint, so the rule only matches when JS is unavailable.
  Previously we shipped an inline <noscript><style> here; the
  Theme Store frowns on inline <style> in Liquid, so it was lifted
  into base.css.
{%- endcomment -%}

{%- liquid
  assign brand_raw = settings.kt_loader_brand | default: shop.name
  assign brand_chars = brand_raw | split: ''
  assign brand_length = brand_chars | size
  assign current_year = 'now' | date: '%Y'
-%}

<div
  class="kt-loader"
  id="kt-loader"
  aria-hidden="true"
  role="presentation"
  style="--kt-loader-chars: {{ brand_length }}; --kt-loader-bg: {{ settings.kt_loader_bg }}; --kt-loader-text: {{ settings.kt_loader_text }}; --kt-loader-accent: {{ settings.kt_loader_accent }};"
>
  <span class="kt-loader__noise" aria-hidden="true"></span>
  <span class="kt-loader__topline" aria-hidden="true"></span>

  <div class="kt-loader__meta kt-loader__meta--tl">
    <span class="kt-loader__meta-dot"></span>
    <span>{{ 'kt.loader.est' | t | default: 'Est.' }} {{ current_year }}</span>
  </div>
  <div class="kt-loader__meta kt-loader__meta--tr">
    <span>&copy; {{ shop.name | upcase | escape }}</span>
  </div>

  <div class="kt-loader__stage">
    {%- comment -%}
      Brand lockup is intentionally NOT an h1 — every template under
      the loader has its own semantic h1 (hero, product title, collection
      title, etc.). Rendering two h1s in the DOM (even with the loader's
      aria-hidden="true" on the parent) trips SEO + structure audits
      that manually grep the source. <div> with aria-label preserves
      the accessible-name behaviour the loader needs without competing
      for the page's primary heading semantics.
    {%- endcomment -%}
    <div class="kt-loader__brand" role="presentation" aria-hidden="true">
      {%- for char in brand_chars -%}
        <span class="kt-loader__brand-char" style="--i: {{ forloop.index0 }};">
          <span class="kt-loader__brand-char-inner">{%- if char == ' ' -%}&nbsp;{%- else -%}{{ char }}{%- endif -%}</span>
        </span>
      {%- endfor -%}
    </div>
    <span class="kt-loader__underline" aria-hidden="true"></span>
  </div>

  <div class="kt-loader__footer">
    {%- if settings.kt_loader_words_enable -%}
      <div class="kt-loader__words" aria-hidden="true">
        <span class="kt-loader__words-prefix">{{ 'kt.loader.prefix' | t | default: '—' }}</span>
        <span class="kt-loader__words-clip">
          <span class="kt-loader__words-track">
            <span class="kt-loader__word">{{ settings.kt_loader_word_1 | default: 'Form.' }}</span>
            <span class="kt-loader__word">{{ settings.kt_loader_word_2 | default: 'Craft.' }}</span>
            <span class="kt-loader__word">{{ settings.kt_loader_word_3 | default: 'Light.' }}</span>
            <span class="kt-loader__word">{{ settings.kt_loader_word_4 | default: 'Story.' }}</span>
          </span>
        </span>
      </div>
    {%- else -%}
      <div></div>
    {%- endif -%}

    <div class="kt-loader__counter" aria-hidden="true">
      <span class="kt-loader__counter-num">00</span>
      <span class="kt-loader__counter-slash">/</span>
      <span class="kt-loader__counter-max">100</span>
    </div>
  </div>

  <div class="kt-loader__bar" aria-hidden="true">
    <span class="kt-loader__bar-fill"></span>
  </div>
</div>
{%- endunless -%}
