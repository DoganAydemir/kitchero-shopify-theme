{%- comment -%}
  Product Rating — renders star icons from metafield.
  Reads product.metafields.reviews.rating (Shopify standard)
  or product.metafields.custom.rating (manual number_decimal).
  Renders nothing if no rating exists.

  Accepts:
  - product: {Object} Shopify product
{%- endcomment -%}

{%- liquid
  assign rating_value = product.metafields.reviews.rating.value.rating
  assign rating_scale_max = product.metafields.reviews.rating.value.scale_max | default: 5
  assign rating_count = product.metafields.reviews.rating_count.value

  unless rating_value
    assign rating_value = product.metafields.custom.rating.value
    assign rating_scale_max = 5
    assign rating_count = nil
  endunless
-%}

{%- if rating_value -%}
  {%- assign rating_decimal = rating_value | times: 1.0 -%}
  {%- assign full_stars = rating_decimal | floor -%}
  {%- assign remainder = rating_decimal | minus: full_stars -%}
  {%- assign has_half = false -%}
  {%- if remainder >= 0.25 and remainder < 0.75 -%}
    {%- assign has_half = true -%}
  {%- elsif remainder >= 0.75 -%}
    {%- assign full_stars = full_stars | plus: 1 -%}
  {%- endif -%}
  {%- assign empty_stars = rating_scale_max | minus: full_stars -%}
  {%- if has_half -%}
    {%- assign empty_stars = empty_stars | minus: 1 -%}
  {%- endif -%}

  {%- comment -%}
    `escape` the metafield-sourced values before they land in an
    aria-label attribute. The `reviews.rating` + `custom.rating`
    metafields should only ever contain numbers, but a merchant
    with metafield write access could put arbitrary strings there.
    Unescaped values would let them inject `" onclick="..."` and
    break out of the attribute. Cost of escaping numbers is 0.
  {%- endcomment -%}
  <div class="kt-rating" role="img" aria-label="{{ rating_decimal | escape }} {{ 'kt.product.rating.out_of' | t | default: 'out of' }} {{ rating_scale_max | escape }}">
    {%- for i in (1..full_stars) -%}
      <svg aria-hidden="true" focusable="false" class="kt-rating__star kt-rating__star--full" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    {%- endfor -%}
    {%- if has_half -%}
      {%- comment -%}
        Half-star: SVG gradient stop-color can't consume CSS var()
        directly, so we expose the empty-half colour through a
        `stop-color="var(...)"` using the computed style — this is
        supported via the `color` inheritance pattern on the <stop>
        element.
      {%- endcomment -%}
      {%- comment -%}
        SVG defs use `id` to let `fill="url(#…)"` reference the
        gradient. On a collection grid with N rating components
        a literal `id="half-star"` collides N times — the HTML
        spec forbids duplicate ids in the same document, Chrome
        DevTools Issues panel flags every occurrence, and some
        browsers resolve the url() reference to the first match
        (typically fine, but validators reject). Scope the id to
        the product so it's always unique. Fallback `'solo'` for
        snippets rendered outside a product loop.
      {%- endcomment -%}
      {%- assign rating_gradient_id = 'half-star-' | append: product.id | default: 'half-star-solo' -%}
      <svg aria-hidden="true" focusable="false" class="kt-rating__star kt-rating__star--half" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="none">
        <defs>
          <linearGradient id="{{ rating_gradient_id }}">
            <stop offset="50%" stop-color="currentColor"/>
            <stop offset="50%" class="kt-rating__half-stop"/>
          </linearGradient>
        </defs>
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="url(#{{ rating_gradient_id }})"/>
      </svg>
    {%- endif -%}
    {%- for i in (1..empty_stars) -%}
      <svg aria-hidden="true" focusable="false" class="kt-rating__star kt-rating__star--empty" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    {%- endfor -%}
    <span class="kt-rating__value">{{ rating_decimal | escape }}</span>
    {%- if rating_count -%}
      <span class="kt-rating__count">({{ rating_count | escape }})</span>
    {%- endif -%}
  </div>
{%- endif -%}
