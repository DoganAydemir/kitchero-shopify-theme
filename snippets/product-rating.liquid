{%- comment -%}
  Product Rating — renders star icons from metafield.
  Reads product.metafields.reviews.rating (Shopify standard)
  or product.metafields.custom.rating (manual number_decimal).
  Renders nothing if no rating exists.

  Accepts:
  - product: {Object} Shopify product
{%- endcomment -%}

{%- liquid
  assign rating_value = product.metafields.reviews.rating.value.rating
  assign rating_scale_max = product.metafields.reviews.rating.value.scale_max | default: 5
  assign rating_count = product.metafields.reviews.rating_count.value

  unless rating_value
    assign rating_value = product.metafields.custom.rating.value
    assign rating_scale_max = 5
    assign rating_count = nil
  endunless
-%}

{%- if rating_value -%}
  {%- assign rating_decimal = rating_value | times: 1.0 -%}
  {%- assign full_stars = rating_decimal | floor -%}
  {%- assign remainder = rating_decimal | minus: full_stars -%}
  {%- assign has_half = false -%}
  {%- if remainder >= 0.25 and remainder < 0.75 -%}
    {%- assign has_half = true -%}
  {%- elsif remainder >= 0.75 -%}
    {%- assign full_stars = full_stars | plus: 1 -%}
  {%- endif -%}
  {%- assign empty_stars = rating_scale_max | minus: full_stars -%}
  {%- if has_half -%}
    {%- assign empty_stars = empty_stars | minus: 1 -%}
  {%- endif -%}

  <div class="kt-rating" role="img" aria-label="{{ rating_decimal }} {{ 'products.product.rating.out_of' | t | default: 'out of' }} {{ rating_scale_max }}">
    {%- for i in (1..full_stars) -%}
      <svg class="kt-rating__star kt-rating__star--full" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    {%- endfor -%}
    {%- if has_half -%}
      <svg class="kt-rating__star kt-rating__star--half" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="none">
        <defs>
          <linearGradient id="half-star">
            <stop offset="50%" stop-color="currentColor"/>
            <stop offset="50%" stop-color="#d6d3d1"/>
          </linearGradient>
        </defs>
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="url(#half-star)"/>
      </svg>
    {%- endif -%}
    {%- for i in (1..empty_stars) -%}
      <svg class="kt-rating__star kt-rating__star--empty" width="14" height="14" viewBox="0 0 24 24" fill="#d6d3d1" stroke="none">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    {%- endfor -%}
    <span class="kt-rating__value">{{ rating_decimal }}</span>
    {%- if rating_count -%}
      <span class="kt-rating__count">({{ rating_count }})</span>
    {%- endif -%}
  </div>
{%- endif -%}
